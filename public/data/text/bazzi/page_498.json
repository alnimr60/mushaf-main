{
  "pageNumber": 498,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "إِنَّ يَوۡمَ ٱلۡفَصۡلِ مِيقَٰتُهُمُۥ أَجۡمَعِينَ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "يَوۡمَ لَا يُغۡنِي مَوۡلًى عَن مَّوۡلٗى شَيۡـٔٗا وَلَا هُمُۥ يُنصَرُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِلَّا مَن رَّحِمَ ٱللَّهُۚ إِنَّهُۥ هُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "إِنَّ شَجَرَتَ ٱلزَّقُّومِ طَعَامُ ٱلۡأَثِيمِ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "كَٱلۡمُهۡلِ يَغۡلِي فِي ٱلۡبُطُونِ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "كَغَلۡيِ ٱلۡحَمِيمِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "خُذُوهُۥ فَٱعۡتُلُوهُۥ إِلَىٰ سَوَآءِ ٱلۡجَحِيمِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "ثُمَّ صُبُّواْ فَوۡقَ رَأۡسِهِۦ مِنۡ عَذَابِ ٱلۡحَمِيمِ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِيزُ ٱلۡكَرِيمُ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "إِنَّ هَٰذَا مَا كُنتُمُۥ بِهِۦ تَمۡتَرُونَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي مَقَامٍ أَمِينٖ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "فِي جَنَّٰتٖ وَعِيُونٖ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "يَلۡبَسُونَ مِن سُندُسٖ وَإِسۡتَبۡرَقٖ مُّتَقَٰبِلِينَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "كَذَٰلِكَ وَزَوَّجۡنَٰهُمُۥ بِحُورٍ عِينٖ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "يَدۡعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "لَا يَذُوقُونَ فِيهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمُۥ عَذَابَ ٱلۡجَحِيمِ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَضۡلٗا مِّن رَّبِّكَۚ ذَٰلِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَإِنَّمَا يَسَّرۡنَٰهُۥ بِلِسَانِكَ لَعَلَّهُمُۥ يَتَذَكَّرُونَ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فَٱرۡتَقِبۡ إِنَّهُمُۥ مُرۡتَقِبُونَ ٥٦",
      "numberInSurah": 56
    }
  ]
}
