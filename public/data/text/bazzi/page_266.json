{
  "pageNumber": 266,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "قَالَ هَٰؤُلَآءِ بَنَاتِي إِن كُنتُمُۥ فَٰعِلِينَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "لَعَمۡرُكَ إِنَّهُمُۥ لَفِي سَكۡرَتِهِمُۥ يَعۡمَهُونَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "فَأَخَذَتۡهُمُ ٱلصَّيۡحَةُ مُشۡرِقِينَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "فَجَعَلۡنَا عَٰلِيَهَا سَافِلَهَا وَأَمۡطَرۡنَا عَلَيۡهِمُۥ حِجَارَةٗ مِّن سِجِّيلٍ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَٰتٖ لِّلۡمُتَوَسِّمِينَ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "وَإِنَّهَا لَبِسَبِيلٖ مُّقِيمٍ ٧٦",
      "numberInSurah": 76
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗ لِّلۡمُؤۡمِنِينَ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "وَإِن كَانَ أَصۡحَٰبُ ٱلۡأَيۡكَةِ لَظَٰلِمِينَ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "فَٱنتَقَمۡنَا مِنۡهُمُۥ وَإِنَّهُمَا لَبِإِمَامٖ مُّبِينٖ ٧٩",
      "numberInSurah": 79
    },
    {
      "text": "وَلَقَدۡ كَذَّبَ أَصۡحَٰبُ ٱلۡحِجۡرِ ٱلۡمُرۡسَلِينَ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "وَءَاتَيۡنَٰهُمُۥ ءَايَٰتِنَا فَكَانُواْ عَنۡهَا مُعۡرِضِينَ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "وَكَانُواْ يَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بِيُوتًا ءَامِنِينَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "فَأَخَذَتۡهُمُ ٱلصَّيۡحَةُ مُصۡبِحِينَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "فَمَا أَغۡنَىٰ عَنۡهُمُۥ مَا كَانُواْ يَكۡسِبُونَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَمَا خَلَقۡنَا ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضَ وَمَا بَيۡنَهُمَا إِلَّا بِٱلۡحَقِّۗ وَإِنَّ ٱلسَّاعَةَ لَأٓتِيَةٞۖ فَٱصۡفَحِ ٱلصَّفۡحَ ٱلۡجَمِيلَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "إِنَّ رَبَّكَ هُوَ ٱلۡخَلَّٰقُ ٱلۡعَلِيمُ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "وَلَقَدۡ ءَاتَيۡنَٰكَ سَبۡعٗا مِّنَ ٱلۡمَثَانِي وَٱلۡقُرَانَ ٱلۡعَظِيمَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "لَا تَمُدَّنَّ عَيۡنَيۡكَ إِلَىٰ مَا مَتَّعۡنَا بِهِۦ أَزۡوَٰجٗا مِّنۡهُمُۥ وَلَا تَحۡزَنۡ عَلَيۡهِمُۥ وَٱخۡفِضۡ جَنَاحَكَ لِلۡمُؤۡمِنِينَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "وَقُلۡ إِنِّيَ أَنَا ٱلنَّذِيرُ ٱلۡمُبِينُ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "كَمَا أَنزَلۡنَا عَلَى ٱلۡمُقۡتَسِمِينَ ٩٠",
      "numberInSurah": 90
    }
  ]
}
