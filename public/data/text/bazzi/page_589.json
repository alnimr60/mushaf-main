{
  "pageNumber": 589,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "فَٱلۡيَوۡمَ ٱلَّذِينَ ءَامَنُواْ مِنَ ٱلۡكُفَّارِ يَضۡحَكُونَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "عَلَى ٱلۡأَرَآئِكِ يَنظُرُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "هَلۡ ثُوِّبَ ٱلۡكُفَّارُ مَا كَانُواْ يَفۡعَلُونَ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "سُورَةُ الانشِقَاقِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِذَا ٱلسَّمَآءُ ٱنشَقَّتۡ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا ٱلۡأَرۡضُ مُدَّتۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَأَلۡقَتۡ مَا فِيهَا وَتَخَلَّتۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَٰأَيُّهَا ٱلۡإِنسَٰنُ إِنَّكَ كَادِحٌ إِلَىٰ رَبِّكَ كَدۡحٗا فَمُلَٰقِيهِۦ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَسَوۡفَ يُحَاسَبُ حِسَابٗا يَسِيرٗا ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَيَنقَلِبُ إِلَىٰ أَهۡلِهِۦ مَسۡرُورٗا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ وَرَآءَ ظَهۡرِهِۦ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَسَوۡفَ يَدۡعُواْ ثُبُورٗا ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَيُصَلَّي سَعِيرًا ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّهُۥ كَانَ فِي أَهۡلِهِۦ مَسۡرُورًا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "بَلَىٰۚ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرٗا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَلَا أُقۡسِمُ بِٱلشَّفَقِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَٱلَّيۡلِ وَمَا وَسَقَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَٱلۡقَمَرِ إِذَا ٱتَّسَقَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "لَتَرۡكَبَنَّ طَبَقًا عَن طَبَقٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَمَا لَهُمُۥ لَا يُؤۡمِنُونَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَإِذَا قُرِئَ عَلَيۡهِمُ ٱلۡقُرَانُ لَا يَسۡجُدُونَۤ۩ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "بَلِ ٱلَّذِينَ كَفَرُواْ يُكَذِّبُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَٱللَّهُ أَعۡلَمُ بِمَا يُوعُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَبَشِّرۡهُمُۥ بِعَذَابٍ أَلِيمٍ ٢٤",
      "numberInSurah": 24
    }
  ]
}
