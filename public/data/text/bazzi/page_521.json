{
  "pageNumber": 521,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلۡحُبُكِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّكُمُۥ لَفِي قَوۡلٖ مُّخۡتَلِفٖ ٨",
      "numberInSurah": 8
    },
    {
      "text": "يُؤۡفَكُ عَنۡهُۥ مَنۡ أُفِكَ ٩",
      "numberInSurah": 9
    },
    {
      "text": "قُتِلَ ٱلۡخَرَّٰصُونَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "ٱلَّذِينَ هُمُۥ فِي غَمۡرَةٖ سَاهُونَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "يَسۡـَٔلُونَ أَيَّانَ يَوۡمُ ٱلدِّينِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يَوۡمَ هُمُۥ عَلَى ٱلنَّارِ يُفۡتَنُونَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "ذُوقُواْ فِتۡنَتَكُمُۥ هَٰذَا ٱلَّذِي كُنتُمُۥ بِهِۦ تَسۡتَعۡجِلُونَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي جَنَّٰتٖ وَعِيُونٍ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ءَاخِذِينَ مَا ءَاتَىٰهُمُۥ رَبُّهُمُۥۚ إِنَّهُمُۥ كَانُواْ قَبۡلَ ذَٰلِكَ مُحۡسِنِينَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "كَانُواْ قَلِيلٗا مِّنَ ٱلَّيۡلِ مَا يَهۡجَعُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَبِٱلۡأَسۡحَارِ هُمُۥ يَسۡتَغۡفِرُونَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَفِي أَمۡوَٰلِهِمُۥ حَقّٞ لِّلسَّآئِلِ وَٱلۡمَحۡرُومِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَفِي ٱلۡأَرۡضِ ءَايَٰتٞ لِّلۡمُوقِنِينَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَفِي أَنفُسِكُمُۥۚ أَفَلَا تُبۡصِرُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَفِي ٱلسَّمَآءِ رِزۡقُكُمُۥ وَمَا تُوعَدُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَوَرَبِّ ٱلسَّمَآءِ وَٱلۡأَرۡضِ إِنَّهُۥ لَحَقّٞ مِّثۡلَ مَا أَنَّكُمُۥ تَنطِقُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ ضَيۡفِ إِبۡرَٰهِيمَ ٱلۡمُكۡرَمِينَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِذۡ دَخَلُواْ عَلَيۡهِۦ فَقَالُواْ سَلَٰمٗاۖ قَالَ سَلَٰمٞ قَوۡمٞ مُّنكَرُونَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَرَاغَ إِلَىٰ أَهۡلِهِۦ فَجَآءَ بِعِجۡلٖ سَمِينٖ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "فَقَرَّبَهُۥ إِلَيۡهِمُۥ قَالَ أَلَا تَأۡكُلُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَأَوۡجَسَ مِنۡهُمُۥ خِيفَةٗۖ قَالُواْ لَا تَخَفۡۖ وَبَشَّرُوهُۥ بِغُلَٰمٍ عَلِيمٖ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "فَأَقۡبَلَتِ ٱمۡرَأَتُهُۥ فِي صَرَّةٖ فَصَكَّتۡ وَجۡهَهَا وَقَالَتۡ عَجُوزٌ عَقِيمٞ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "قَالُواْ كَذَٰلِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ ٱلۡحَكِيمُ ٱلۡعَلِيمُ ٣٠",
      "numberInSurah": 30
    }
  ]
}
