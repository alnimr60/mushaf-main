{
  "pageNumber": 588,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "لِيَوۡمٍ عَظِيمٖ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَوۡمَ يَقُومُ ٱلنَّاسُ لِرَبِّ ٱلۡعَٰلَمِينَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "كَلَّا إِنَّ كِتَٰبَ ٱلۡفُجَّارِ لَفِي سِجِّينٖ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَمَا أَدۡرَىٰكَ مَا سِجِّينٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "كِتَٰبٞ مَّرۡقُومٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "ٱلَّذِينَ يُكَذِّبُونَ بِيَوۡمِ ٱلدِّينِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَمَا يُكَذِّبُ بِهِۦ إِلَّا كُلُّ مُعۡتَدٍ أَثِيمٍ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِذَا تُتۡلَىٰ عَلَيۡهِۦ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ ٱلۡأَوَّلِينَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "كَلَّاۖ بَل رَّانَ عَلَىٰ قُلُوبِهِمُۥ مَا كَانُواْ يَكۡسِبُونَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "كَلَّا إِنَّهُمُۥ عَن رَّبِّهِمُۥ يَوۡمَئِذٖ لَّمَحۡجُوبُونَ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ثُمَّ إِنَّهُمُۥ لَصَالُواْ ٱلۡجَحِيمِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "ثُمَّ يُقَالُ هَٰذَا ٱلَّذِي كُنتُمُۥ بِهِۦ تُكَذِّبُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "كَلَّا إِنَّ كِتَٰبَ ٱلۡأَبۡرَارِ لَفِي عِلِّيِّينَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَمَا أَدۡرَىٰكَ مَا عِلِّيُّونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "كِتَٰبٞ مَّرۡقُومٞ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "يَشۡهَدُهُ ٱلۡمُقَرَّبُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِنَّ ٱلۡأَبۡرَارَ لَفِي نَعِيمٍ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "عَلَى ٱلۡأَرَآئِكِ يَنظُرُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "تَعۡرِفُ فِي وُجُوهِهِمُۥ نَضۡرَةَ ٱلنَّعِيمِ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "يُسۡقَوۡنَ مِن رَّحِيقٖ مَّخۡتُومٍ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "خِتَٰمُهُۥ مِسۡكٞۚ وَفِي ذَٰلِكَ فَلۡيَتَنَافَسِ ٱلۡمُتَنَٰفِسُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَمِزَاجُهُۥ مِن تَسۡنِيمٍ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "عَيۡنٗا يَشۡرَبُ بِهَا ٱلۡمُقَرَّبُونَ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "إِنَّ ٱلَّذِينَ أَجۡرَمُواْ كَانُواْ مِنَ ٱلَّذِينَ ءَامَنُواْ يَضۡحَكُونَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَإِذَا مَرُّواْ بِهِمُۥ يَتَغَامَزُونَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَإِذَا ٱنقَلَبُواْ إِلَىٰ أَهۡلِهِمُ ٱنقَلَبُواْ فَٰكِهِينَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَإِذَا رَأَوۡهُمُۥ قَالُواْ إِنَّ هَٰؤُلَآءِ لَضَآلُّونَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَمَا أُرۡسِلُواْ عَلَيۡهِمُۥ حَٰفِظِينَ ٣٣",
      "numberInSurah": 33
    }
  ]
}
