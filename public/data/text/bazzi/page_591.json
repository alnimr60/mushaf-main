{
  "pageNumber": 591,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَٱلسَّمَآءِ وَٱلطَّارِقِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَمَا أَدۡرَىٰكَ مَا ٱلطَّارِقُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "ٱلنَّجۡمُ ٱلثَّاقِبُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِن كُلُّ نَفۡسٖ لَّمَا عَلَيۡهَا حَافِظٞ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "خُلِقَ مِن مَّآءٖ دَافِقٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "يَوۡمَ تُبۡلَى ٱلسَّرَآئِرُ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجۡعِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَمَا هُوَ بِٱلۡهَزۡلِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "إِنَّهُمُۥ يَكِيدُونَ كَيۡدٗا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَأَكِيدُ كَيۡدٗا ١٦",
      "numberInSurah": 16
    },
    {
      "text": "فَمَهِّلِ ٱلۡكَٰفِرِينَ أَمۡهِلۡهُمُۥ رُوَيۡدَۢا ١٧",
      "numberInSurah": 17
    },
    {
      "text": "سُورَةُ الأَعۡلَىٰ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ سَبِّحِ ٱسۡمَ رَبِّكَ ٱلۡأَعۡلَى ١",
      "numberInSurah": 1
    },
    {
      "text": "ٱلَّذِي خَلَقَ فَسَوَّىٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلَّذِي قَدَّرَ فَهَدَىٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلَّذِي أَخۡرَجَ ٱلۡمَرۡعَىٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَجَعَلَهُۥ غُثَآءً أَحۡوَىٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سَنُقۡرِئُكَ فَلَا تَنسَىٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِلَّا مَا شَآءَ ٱللَّهُۚ إِنَّهُۥ يَعۡلَمُ ٱلۡجَهۡرَ وَمَا يَخۡفَىٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَنُيَسِّرُكَ لِلۡيُسۡرَىٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَذَكِّرۡ إِن نَّفَعَتِ ٱلذِّكۡرَىٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "سَيَذَّكَّرُ مَن يَخۡشَىٰ ١٠",
      "numberInSurah": 10
    }
  ]
}
