{
  "pageNumber": 537,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "إِنَّهُۥ لَقُرَانٞ كَرِيمٞ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "فِي كِتَٰبٖ مَّكۡنُونٖ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "لَّا يَمَسُّهُۥ إِلَّا ٱلۡمُطَهَّرُونَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ ٱلۡعَٰلَمِينَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "أَفَبِهَٰذَا ٱلۡحَدِيثِ أَنتُمُۥ مُدۡهِنُونَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَتَجۡعَلُونَ رِزۡقَكُمُۥ أَنَّكُمُۥ تُكَذِّبُونَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "فَلَوۡلَا إِذَا بَلَغَتِ ٱلۡحُلۡقُومَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "وَأَنتُمُۥ حِينَئِذٖ تَنظُرُونَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "وَنَحۡنُ أَقۡرَبُ إِلَيۡهِۦ مِنكُمُۥ وَلَٰكِن لَّا تُبۡصِرُونَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "فَلَوۡلَا إِن كُنتُمُۥ غَيۡرَ مَدِينِينَ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "تَرۡجِعُونَهَا إِن كُنتُمُۥ صَٰدِقِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "فَأَمَّا إِن كَانَ مِنَ ٱلۡمُقَرَّبِينَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "فَرَوۡحٞ وَرَيۡحَانٞ وَجَنَّتُ نَعِيمٖ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "وَأَمَّا إِن كَانَ مِنۡ أَصۡحَٰبِ ٱلۡيَمِينِ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَسَلَٰمٞ لَّكَ مِنۡ أَصۡحَٰبِ ٱلۡيَمِينِ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "وَأَمَّا إِن كَانَ مِنَ ٱلۡمُكَذِّبِينَ ٱلضَّآلِّينَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "فَنُزُلٞ مِّنۡ حَمِيمٖ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "وَتَصۡلِيَةُ جَحِيمٍ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ حَقُّ ٱلۡيَقِينِ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "سُورَةُ الحَدِيدِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ سَبَّحَ لِلَّهِ مَا فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۖ وَهُوَ ٱلۡعَزِيزُ ٱلۡحَكِيمُ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَهُۥ مُلۡكُ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۖ يُحۡيِۦ وَيُمِيتُۖ وَهُوَ عَلَىٰ كُلِّ شَيۡءٖ قَدِيرٌ ٢",
      "numberInSurah": 2
    },
    {
      "text": "هُوَ ٱلۡأَوَّلُ وَٱلۡأٓخِرُ وَٱلظَّٰهِرُ وَٱلۡبَاطِنُۖ وَهُوَ بِكُلِّ شَيۡءٍ عَلِيمٌ ٣",
      "numberInSurah": 3
    }
  ]
}
