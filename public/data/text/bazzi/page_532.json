  "ayahs": [
    {
      "text": "مَرَجَ ٱلۡبَحۡرَيۡنِ يَلۡتَقِيَانِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "بَيۡنَهُمَا بَرۡزَخٞ لَّا يَبۡغِيَانِ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "يَخۡرُجُ مِنۡهُمَا ٱللُّؤۡلُؤُ وَٱلۡمَرۡجَانُ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَلَهُ ٱلۡجَوَارِ ٱلۡمُنشَـَٔاتُ فِي ٱلۡبَحۡرِ كَٱلۡأَعۡلَٰمِ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "كُلُّ مَنۡ عَلَيۡهَا فَانٖ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَيَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَسۡـَٔلُهُۥ مَن فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ كُلَّ يَوۡمٍ هُوَ فِي شَأۡنٖ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "سَنَفۡرُغُ لَكُمُۥ أَيُّهَ ٱلثَّقَلَانِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "يَٰمَعۡشَرَ ٱلۡجِنِّ وَٱلۡإِنسِ إِنِ ٱسۡتَطَعۡتُمُۥ أَن تَنفُذُواْ مِنۡ أَقۡطَارِ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ فَٱنفُذُواْۚ لَا تَنفُذُونَ إِلَّا بِسُلۡطَٰنٖ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "يُرۡسَلُ عَلَيۡكُمَا شِوَاظٞ مِّن نَّارٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَنُحَاسٖ فَلَا تَنتَصِرَانِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتۡ وَرۡدَةٗ كَٱلدِّهَانِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَيَوۡمَئِذٖ لَّا يُسۡـَٔلُ عَن ذَنۢبِهِۦ إِنسٞ وَلَا جَآنّٞ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "يُعۡرَفُ ٱلۡمُجۡرِمُونَ بِسِيمَٰهُمُۥ فَيُؤۡخَذُ بِٱلنَّوَٰصِي وَٱلۡأَقۡدَامِ ٤٠",
      "numberInSurah": 40
    }
  ]
