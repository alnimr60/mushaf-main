{
  "pageNumber": 452,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "مَا لَكُمُۥ كَيۡفَ تَحۡكُمُونَ ١٥٤",
      "numberInSurah": 154
    },
    {
      "text": "أَفَلَا تَذَّكَّرُونَ ١٥٥",
      "numberInSurah": 155
    },
    {
      "text": "أَمۡ لَكُمُۥ سُلۡطَٰنٞ مُّبِينٞ ١٥٦",
      "numberInSurah": 156
    },
    {
      "text": "فَأۡتُواْ بِكِتَٰبِكُمُۥ إِن كُنتُمُۥ صَٰدِقِينَ ١٥٧",
      "numberInSurah": 157
    },
    {
      "text": "وَجَعَلُواْ بَيۡنَهُۥ وَبَيۡنَ ٱلۡجِنَّةِ نَسَبٗاۚ وَلَقَدۡ عَلِمَتِ ٱلۡجِنَّةُ إِنَّهُمُۥ لَمُحۡضَرُونَ ١٥٨",
      "numberInSurah": 158
    },
    {
      "text": "سُبۡحَٰنَ ٱللَّهِ عَمَّا يَصِفُونَ ١٥٩",
      "numberInSurah": 159
    },
    {
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ ١٦٠",
      "numberInSurah": 160
    },
    {
      "text": "فَإِنَّكُمُۥ وَمَا تَعۡبُدُونَ ١٦١",
      "numberInSurah": 161
    },
    {
      "text": "مَا أَنتُمُۥ عَلَيۡهِۦ بِفَٰتِنِينَ ١٦٢",
      "numberInSurah": 162
    },
    {
      "text": "إِلَّا مَنۡ هُوَ صَالِ ٱلۡجَحِيمِ ١٦٣",
      "numberInSurah": 163
    },
    {
      "text": "وَمَا مِنَّا إِلَّا لَهُۥ مَقَامٞ مَّعۡلُومٞ ١٦٤",
      "numberInSurah": 164
    },
    {
      "text": "وَإِنَّا لَنَحۡنُ ٱلصَّآفُّونَ ١٦٥",
      "numberInSurah": 165
    },
    {
      "text": "وَإِنَّا لَنَحۡنُ ٱلۡمُسَبِّحُونَ ١٦٦",
      "numberInSurah": 166
    },
    {
      "text": "وَإِن كَانُواْ لَيَقُولُونَ ١٦٧",
      "numberInSurah": 167
    },
    {
      "text": "لَوۡ أَنَّ عِندَنَا ذِكۡرٗا مِّنَ ٱلۡأَوَّلِينَ ١٦٨",
      "numberInSurah": 168
    },
    {
      "text": "لَكُنَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ ١٦٩",
      "numberInSurah": 169
    },
    {
      "text": "فَكَفَرُواْ بِهِۦۖ فَسَوۡفَ يَعۡلَمُونَ ١٧٠",
      "numberInSurah": 170
    },
    {
      "text": "وَلَقَدۡ سَبَقَتۡ كَلِمَتُنَا لِعِبَادِنَا ٱلۡمُرۡسَلِينَ ١٧١",
      "numberInSurah": 171
    },
    {
      "text": "إِنَّهُمُۥ لَهُمُ ٱلۡمَنصُورُونَ ١٧٢",
      "numberInSurah": 172
    },
    {
      "text": "وَإِنَّ جُندَنَا لَهُمُ ٱلۡغَٰلِبُونَ ١٧٣",
      "numberInSurah": 173
    },
    {
      "text": "فَتَوَلَّ عَنۡهُمُۥ حَتَّىٰ حِينٖ ١٧٤",
      "numberInSurah": 174
    },
    {
      "text": "وَأَبۡصِرۡهُمُۥ فَسَوۡفَ يُبۡصِرُونَ ١٧٥",
      "numberInSurah": 175
    },
    {
      "text": "أَفَبِعَذَابِنَا يَسۡتَعۡجِلُونَ ١٧٦",
      "numberInSurah": 176
    },
    {
      "text": "فَإِذَا نَزَلَ بِسَاحَتِهِمُۥ فَسَآءَ صَبَاحُ ٱلۡمُنذَرِينَ ١٧٧",
      "numberInSurah": 177
    },
    {
      "text": "وَتَوَلَّ عَنۡهُمُۥ حَتَّىٰ حِينٖ ١٧٨",
      "numberInSurah": 178
    },
    {
      "text": "وَأَبۡصِرۡ فَسَوۡفَ يُبۡصِرُونَ ١٧٩",
      "numberInSurah": 179
    },
    {
      "text": "سُبۡحَٰنَ رَبِّكَ رَبِّ ٱلۡعِزَّةِ عَمَّا يَصِفُونَ ١٨٠",
      "numberInSurah": 180
    },
    {
      "text": "وَسَلَٰمٌ عَلَى ٱلۡمُرۡسَلِينَ ١٨١",
      "numberInSurah": 181
    },
    {
      "text": "وَٱلۡحَمۡدُ لِلَّهِ رَبِّ ٱلۡعَٰلَمِينَ ١٨٢",
      "numberInSurah": 182
    }
  ]
}
