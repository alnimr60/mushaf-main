{
  "pageNumber": 536,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "ثُمَّ إِنَّكُمُۥ أَيُّهَا ٱلضَّآلُّونَ ٱلۡمُكَذِّبُونَ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "فَشَٰرِبُونَ عَلَيۡهِۦ مِنَ ٱلۡحَمِيمِ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "فَشَٰرِبُونَ شَرۡبَ ٱلۡهِيمِ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "هَٰذَا نُزُلُهُمُۥ يَوۡمَ ٱلدِّينِ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "نَحۡنُ خَلَقۡنَٰكُمُۥ فَلَوۡلَا تُصَدِّقُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "أَفَرَءَيۡتُمُۥ مَا تُمۡنُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "ءَا۬نتُمُۥ تَخۡلُقُونَهُۥ أَمۡ نَحۡنُ ٱلۡخَٰلِقُونَ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "نَحۡنُ قَدَرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِينَ ٦٣",
      "numberInSurah": 63
    },
    {
      "text": "عَلَىٰ أَن نُّبَدِّلَ أَمۡثَٰلَكُمُۥ وَنُنشِئَكُمُۥ فِي مَا لَا تَعۡلَمُونَ ٦٤",
      "numberInSurah": 64
    },
    {
      "text": "وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشَآءَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَّكَّرُونَ ٦٥",
      "numberInSurah": 65
    },
    {
      "text": "أَفَرَءَيۡتُمُۥ مَا تَحۡرُثُونَ ٦٦",
      "numberInSurah": 66
    },
    {
      "text": "ءَا۬نتُمُۥ تَزۡرَعُونَهُۥ أَمۡ نَحۡنُ ٱلزَّٰرِعُونَ ٦٧",
      "numberInSurah": 67
    },
    {
      "text": "لَوۡ نَشَآءُ لَجَعَلۡنَٰهُۥ حُطَٰمٗا فَظَلۡتُمُۥ تَفَكَّهُونَ ٦٨",
      "numberInSurah": 68
    },
    {
      "text": "إِنَّا لَمُغۡرَمُونَ ٦٩",
      "numberInSurah": 69
    },
    {
      "text": "بَلۡ نَحۡنُ مَحۡرُومُونَ ٧٠",
      "numberInSurah": 70
    },
    {
      "text": "أَفَرَءَيۡتُمُ ٱلۡمَآءَ ٱلَّذِي تَشۡرَبُونَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "ءَا۬نتُمُۥ أَنزَلۡتُمُوهُۥ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "لَوۡ نَشَآءُ جَعَلۡنَٰهُۥ أُجَاجٗا فَلَوۡلَا تَشۡكُرُونَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "أَفَرَءَيۡتُمُ ٱلنَّارَ ٱلَّتِي تُورُونَ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "ءَا۬نتُمُۥ أَنشَأۡتُمُۥ شَجَرَتَهَا أَمۡ نَحۡنُ ٱلۡمُنشِـُٔونَ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "نَحۡنُ جَعَلۡنَٰهَا تَذۡكِرَةٗ وَمَتَٰعٗا لِّلۡمُقۡوِينَ ٧٦",
      "numberInSurah": 76
    },
    {
      "text": "فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "۞فَلَا أُقۡسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "وَإِنَّهُۥ لَقَسَمٞ لَّوۡ تَعۡلَمُونَ عَظِيمٌ ٧٩",
      "numberInSurah": 79
    }
  ]
}
