{
  "pageNumber": 577,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "فَمَا تَنفَعُهُمُۥ شَفَٰعَةُ ٱلشَّٰفِعِينَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "فَمَا لَهُمُۥ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "كَأَنَّهُمُۥ حُمُرٞ مُّسۡتَنفِرَةٞ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "فَرَّتۡ مِن قَسۡوَرَةِۭ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "بَلۡ يُرِيدُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمُۥ أَن يُؤۡتَىٰ صُحُفٗا مُّنَشَّرَةٗ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "كَلَّاۖ بَل لَّا يَخَافُونَ ٱلۡأٓخِرَةَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "كَلَّا إِنَّهُۥ تَذۡكِرَةٞ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "وَمَا يَذۡكُرُونَ إِلَّا أَن يَشَآءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "سُورَةُ القِيَامَةِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ لَأُاْقۡسِمُ بِيَوۡمِ ٱلۡقِيَٰمَةِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَلَا أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "أَيَحۡسِبُ ٱلۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ٣",
      "numberInSurah": 3
    },
    {
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰ أَن نُّسَوِّيَ بَنَانَهُۥ ٤",
      "numberInSurah": 4
    },
    {
      "text": "بَلۡ يُرِيدُ ٱلۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَسۡـَٔلُ أَيَّانَ يَوۡمُ ٱلۡقِيَٰمَةِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَإِذَا بَرِقَ ٱلۡبَصَرُ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَخَسَفَ ٱلۡقَمَرُ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ ٩",
      "numberInSurah": 9
    },
    {
      "text": "يَقُولُ ٱلۡإِنسَٰنُ يَوۡمَئِذٍ أَيۡنَ ٱلۡمَفَرُّ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَلَّا لَا وَزَرَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمُسۡتَقَرُّ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يُنَبَّؤُاْ ٱلۡإِنسَٰنُ يَوۡمَئِذِۭ بِمَا قَدَّمَ وَأَخَّرَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "بَلِ ٱلۡإِنسَٰنُ عَلَىٰ نَفۡسِهِۦ بَصِيرَةٞ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦ إِنَّ عَلَيۡنَا جَمۡعَهُۥ وَقُرَانَهُۥ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "فَإِذَا قَرَأۡنَٰهُۥ فَٱتَّبِعۡ قُرَانَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيۡنَا بَيَانَهُۥ ١٨",
      "numberInSurah": 18
    }
  ]
}
