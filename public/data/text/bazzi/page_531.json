  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "وَمَا أَمۡرُنَا إِلَّا وَٰحِدَةٞ كَلَمۡحِۭ بِٱلۡبَصَرِ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَلَقَدۡ أَهۡلَكۡنَا أَشۡيَاعَكُمُۥ فَهَلۡ مِن مُّدَّكِرٖ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "وَكُلُّ شَيۡءٖ فَعَلُوهُۥ فِي ٱلزُّبُرِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "وَكُلُّ صَغِيرٖ وَكَبِيرٖ مُّسۡتَطَرٌ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي جَنَّٰتٖ وَنَهَرٖ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فِي مَقۡعَدِ صِدۡقٍ عِندَ مَلِيكٖ مُّقۡتَدِرِۭ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "سُورَةُ الرَّحۡمَٰن بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ٱلرَّحۡمَٰنُ عَلَّمَ ٱلۡقُرَانَ ١",
      "numberInSurah": 1
    },
    {
      "text": "خَلَقَ ٱلۡإِنسَٰنَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "عَلَّمَهُ ٱلۡبَيَانَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "ٱلشَّمۡسُ وَٱلۡقَمَرُ بِحُسۡبَانٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَٱلنَّجۡمُ وَٱلشَّجَرُ يَسۡجُدَانِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَٱلسَّمَآءَ رَفَعَهَا وَوَضَعَ ٱلۡمِيزَانَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "أَلَّا تَطۡغَوۡاْ فِي ٱلۡمِيزَانِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَأَقِيمُواْ ٱلۡوَزۡنَ بِٱلۡقِسۡطِ وَلَا تُخۡسِرُواْ ٱلۡمِيزَانَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَٱلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ فِيهَا فَٰكِهَةٞ وَٱلنَّخۡلُ ذَاتُ ٱلۡأَكۡمَامِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَٱلۡحَبُّ ذُو ٱلۡعَصۡفِ وَٱلرَّيۡحَانُ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "خَلَقَ ٱلۡإِنسَٰنَ مِن صَلۡصَٰلٖ كَٱلۡفَخَّارِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَخَلَقَ ٱلۡجَآنَّ مِن مَّارِجٖ مِّن نَّارٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "رَبُّ ٱلۡمَشۡرِقَيۡنِ وَرَبُّ ٱلۡمَغۡرِبَيۡنِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٦",
