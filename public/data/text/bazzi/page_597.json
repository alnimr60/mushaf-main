{
  "pageNumber": 597,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "ٱلَّذِي أَنقَضَ ظَهۡرَكَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَرَفَعۡنَا لَكَ ذِكۡرَكَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَإِذَا فَرَغۡتَ فَٱنصَبۡ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِلَىٰ رَبِّكَ فَٱرۡغَب ٨",
      "numberInSurah": 8
    },
    {
      "text": "سُورَةُ التِّينِ بِّسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلتِّينِ وَٱلزَّيۡتُونِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَطُورِ سِينِينَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَهَٰذَا ٱلۡبَلَدِ ٱلۡأَمِينِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "لَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ فِي أَحۡسَنِ تَقۡوِيمٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ثُمَّ رَدَدۡنَٰهُۥ أَسۡفَلَ سَٰفِلِينَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ فَلَهُمُۥ أَجۡرٌ غَيۡرُ مَمۡنُونٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَمَا يُكَذِّبُكَ بَعۡدُ بِٱلدِّينِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "أَلَيۡسَ ٱللَّهُ بِأَحۡكَمِ ٱلۡحَٰكِمِينَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "سُورَةُ العَلَقِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ ١",
      "numberInSurah": 1
    },
    {
      "text": "خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ ٢",
      "numberInSurah": 2
    },
    {
      "text": "ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "كَلَّا إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "أَن رَّءَاهُ ٱسۡتَغۡنَىٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "عَبۡدًا إِذَا صَلَّىٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰ ١١",
      "numberInSurah": 11
    },
    {
      "text": "أَوۡ أَمَرَ بِٱلتَّقۡوَىٰ ١٢",
      "numberInSurah": 12
    }
  ]
}
