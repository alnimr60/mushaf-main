{
  "pageNumber": 446,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَٱلصَّٰٓفَّٰتِ صَفّٗا ١",
      "numberInSurah": 1
    },
    {
      "text": "فَٱلزَّٰجِرَٰتِ زَجۡرٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "فَٱلتَّٰلِيَٰتِ ذِكۡرًا ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنَّ إِلَٰهَكُمُۥ لَوَٰحِدٞ ٤",
      "numberInSurah": 4
    },
    {
      "text": "رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا وَرَبُّ ٱلۡمَشَٰرِقِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِنَّا زَيَّنَّا ٱلسَّمَآءَ ٱلدُّنۡيَا بِزِينَةِ ٱلۡكَوَاكِبِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَحِفۡظٗا مِّن كُلِّ شَيۡطَٰنٖ مَّارِدٖ ٧",
      "numberInSurah": 7
    },
    {
      "text": "لَّا يَسۡمَعُونَ إِلَى ٱلۡمَلَإِ ٱلۡأَعۡلَىٰ وَيُقۡذَفُونَ مِن كُلِّ جَانِبٖ ٨",
      "numberInSurah": 8
    },
    {
      "text": "دُحُورٗاۖ وَلَهُمُۥ عَذَابٞ وَاصِبٌ ٩",
      "numberInSurah": 9
    },
    {
      "text": "إِلَّا مَنۡ خَطِفَ ٱلۡخَطۡفَةَ فَأَتۡبَعَهُۥ شِهَابٞ ثَاقِبٞ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَٱسۡتَفۡتِهِمُۥ أَهُمُۥ أَشَدُّ خَلۡقًا أَم مَّنۡ خَلَقۡنَاۚ إِنَّا خَلَقۡنَٰهُمُۥ مِن طِينٖ لَّازِبِۭ ١١",
      "numberInSurah": 11
    },
    {
      "text": "بَلۡ عَجِبۡتَ وَيَسۡخَرُونَ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَإِذَا ذُكِّرُواْ لَا يَذۡكُرُونَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَإِذَا رَأَوۡاْ ءَايَةٗ يَسۡتَسۡخِرُونَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَقَالُواْ إِنۡ هَٰذَا إِلَّا سِحۡرٞ مُّبِينٌ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "أَ۟ذَا مُتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَ۟نَّا لَمَبۡعُوثُونَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "أَوَ ءَابَآؤُنَا ٱلۡأَوَّلُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "قُلۡ نَعَمۡ وَأَنتُمُۥ دَٰخِرُونَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ فَإِذَا هُمُۥ يَنظُرُونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَقَالُواْ يَٰوَيۡلَنَا هَٰذَا يَوۡمُ ٱلدِّينِ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "هَٰذَا يَوۡمُ ٱلۡفَصۡلِ ٱلَّذِي كُنتُمُۥ بِهِۦ تُكَذِّبُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "۞ٱحۡشُرُواْ ٱلَّذِينَ ظَلَمُواْ وَأَزۡوَٰجَهُمُۥ وَمَا كَانُواْ يَعۡبُدُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "مِن دُونِ ٱللَّهِ فَٱهۡدُوهُمُۥ إِلَىٰ صِرَٰطِ ٱلۡجَحِيمِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَقِفُوهُمُۥۖ إِنَّهُمُۥ مَسۡـُٔولُونَ ٢٤",
      "numberInSurah": 24
    }
  ]
}
