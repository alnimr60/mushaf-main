{
  "pageNumber": 602,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "لِإِيلَٰفِ قُرَيۡشٍ ١",
      "numberInSurah": 1
    },
    {
      "text": "إِۦلَٰفِهِمُۥ رِحۡلَةَ ٱلشِّتَآءِ وَٱلصَّيۡفِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "فَلۡيَعۡبُدُواْ رَبَّ هَٰذَا ٱلۡبَيۡتِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "ٱلَّذِي أَطۡعَمَهُمُۥ مِن جُوعٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَءَامَنَهُمُۥ مِنۡ خَوۡفِۭ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سُورَةُ المَاعُونِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ ١",
      "numberInSurah": 1
    },
    {
      "text": "فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "فَوَيۡلٞ لِّلۡمُصَلِّينَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ٱلَّذِينَ هُمُۥ عَن صَلَاتِهِمُۥ سَاهُونَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "ٱلَّذِينَ هُمُۥ يُرَآءُونَ وَيَمۡنَعُونَ ٱلۡمَاعُونَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "سُورَةُ الكَوثَرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِنَّا أَعۡطَيۡنَٰكَ ٱلۡكَوۡثَرَ ١",
      "numberInSurah": 1
    },
    {
      "text": "فَصَلِّ لِرَبِّكَ وَٱنۡحَرۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِنَّ شَانِئَكَ هُوَ ٱلۡأَبۡتَرُ ٣",
      "numberInSurah": 3
    }
  ]
}
