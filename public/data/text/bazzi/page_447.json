{
  "pageNumber": 447,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "مَا لَكُمُۥ لَآ تَّنَاصَرُونَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "بَلۡ هُمُ ٱلۡيَوۡمَ مُسۡتَسۡلِمُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَأَقۡبَلَ بَعۡضُهُمُۥ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "قَالُواْ إِنَّكُمُۥ كُنتُمُۥ تَأۡتُونَنَا عَنِ ٱلۡيَمِينِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "قَالُواْ بَل لَّمۡ تَكُونُواْ مُؤۡمِنِينَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَمَا كَانَ لَنَا عَلَيۡكُمُۥ مِن سُلۡطَٰنِۭۖ بَلۡ كُنتُمُۥ قَوۡمٗا طَٰغِينَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "فَحَقَّ عَلَيۡنَا قَوۡلُ رَبِّنَاۖ إِنَّا لَذَآئِقُونَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَأَغۡوَيۡنَٰكُمُۥ إِنَّا كُنَّا غَٰوِينَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "فَإِنَّهُمُۥ يَوۡمَئِذٖ فِي ٱلۡعَذَابِ مُشۡتَرِكُونَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "إِنَّهُمُۥ كَانُواْ إِذَا قِيلَ لَهُمُۥ لَا إِلَٰهَ إِلَّا ٱللَّهُ يَسۡتَكۡبِرُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَيَقُولُونَ أَى۪نَّا لَتَارِكُواْ ءَالِهَتِنَا لِشَاعِرٖ مَّجۡنُونِۭ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "بَلۡ جَآءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِينَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "إِنَّكُمُۥ لَذَآئِقُواْ ٱلۡعَذَابِ ٱلۡأَلِيمِ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمُۥ تَعۡمَلُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "أُوْلَٰٓئِكَ لَهُمُۥ رِزۡقٞ مَّعۡلُومٞ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "فَوَٰكِهُ وَهُمُۥ مُكۡرَمُونَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "فِي جَنَّٰتِ ٱلنَّعِيمِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "عَلَىٰ سُرُرٖ مُّتَقَٰبِلِينَ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "يُطَافُ عَلَيۡهِمُۥ بِكَأۡسٖ مِّن مَّعِينِۭ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "بَيۡضَآءَ لَذَّةٖ لِّلشَّٰرِبِينَ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "لَا فِيهَا غَوۡلٞ وَلَا هُمُۥ عَنۡهَا يُنزَفُونَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَعِندَهُمُۥ قَٰصِرَٰتُ ٱلطَّرۡفِ عِينٞ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "كَأَنَّهُنَّ بَيۡضٞ مَّكۡنُونٞ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "فَأَقۡبَلَ بَعۡضُهُمُۥ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "قَالَ قَآئِلٞ مِّنۡهُمُۥ إِنِّي كَانَ لِي قَرِينٞ ٥١",
      "numberInSurah": 51
    }
  ]
}
