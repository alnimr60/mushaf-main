{
  "pageNumber": 567,
  "riwayaId": "bazzi",
  "ayahs": [
    {
      "text": "وَجَآءَ فِرۡعَوۡنُ وَمَن قَبۡلَهُۥ وَٱلۡمُؤۡتَفِكَٰتُ بِٱلۡخَاطِئَةِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَعَصَوۡاْ رَسُولَ رَبِّهِمُۥ فَأَخَذَهُمُۥ أَخۡذَةٗ رَّابِيَةً ٩",
      "numberInSurah": 9
    },
    {
      "text": "إِنَّا لَمَّا طَغَا ٱلۡمَآءُ حَمَلۡنَٰكُمُۥ فِي ٱلۡجَارِيَةِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "لِنَجۡعَلَهَا لَكُمُۥ تَذۡكِرَةٗ وَتَعِيَهَا أُذُنٞ وَٰعِيَةٞ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فَإِذَا نُفِخَ فِي ٱلصُّورِ نَفۡخَةٞ وَٰحِدَةٞ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَحُمِلَتِ ٱلۡأَرۡضُ وَٱلۡجِبَالُ فَدُكَّتَا دَكَّةٗ وَٰحِدَةٗ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَيَوۡمَئِذٖ وَقَعَتِ ٱلۡوَاقِعَةُ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَٱنشَقَّتِ ٱلسَّمَآءُ فَهِيَ يَوۡمَئِذٖ وَاهِيَةٞ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَٱلۡمَلَكُ عَلَىٰ أَرۡجَآئِهَاۚ وَيَحۡمِلُ عَرۡشَ رَبِّكَ فَوۡقَهُمُۥ يَوۡمَئِذٖ ثَمَٰنِيَةٞ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "يَوۡمَئِذٖ تُعۡرَضُونَ لَا تَخۡفَىٰ مِنكُمُۥ خَافِيَةٞ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ ٱقۡرَءُواْ كِتَٰبِيَهۡ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "إِنِّي ظَنَنتُ أَنِّي مُلَٰقٍ حِسَابِيَهۡ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَهُوَ فِي عِيشَةٖ رَّاضِيَةٖ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فِي جَنَّةٍ عَالِيَةٖ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "قُطُوفُهَا دَانِيَةٞ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَا أَسۡلَفۡتُمُۥ فِي ٱلۡأَيَّامِ ٱلۡخَالِيَةِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِشِمَالِهِۦ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَيَقُولُ يَٰلَيۡتَنِي لَمۡ أُوتَ كِتَٰبِيَهۡ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَلَمۡ أَدۡرِ مَا حِسَابِيَهۡ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَٰلَيۡتَهَا كَانَتِ ٱلۡقَاضِيَةَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "مَا أَغۡنَىٰ عَنِّي مَالِيَهۡۜ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "هَلَكَ عَنِّي سُلۡطَٰنِيَهۡ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "خُذُوهُۥ فَغُلُّوهُۥ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "ثُمَّ ٱلۡجَحِيمَ صَلُّوهُۥ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "ثُمَّ فِي سِلۡسِلَةٖ ذَرۡعُهَا سَبۡعُونَ ذِرَاعٗا فَٱسۡلُكُوهُۥ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "إِنَّهُۥ كَانَ لَا يُؤۡمِنُ بِٱللَّهِ ٱلۡعَظِيمِ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "فَلَيۡسَ لَهُ ٱلۡيَوۡمَ هَٰهُنَا حَمِيمٞ ٣٥",
      "numberInSurah": 35
    }
  ]
}
