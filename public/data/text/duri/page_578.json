{
  "pageNumber": 578,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "فَسَنُيَسِّرُهُۥ لِلۡعُسۡر۪يٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَمَا يُغۡنِي عَنۡهُ مَالُهُۥٓ إِذَا تَرَدّۭيٰٓ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِنَّ عَلَيۡنَا لَلۡهُدۭيٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَإِنَّ لَنَا لَلۡأٓخِرَةَ وَاَلۡأُولۭيٰ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَأَنذَرۡتُكُمۡ نَارٗا تَلَظّۭيٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "لَا يَصۡلَىٰهَآ إِلَّا اَ۬لۡأَشۡقَى ١٥",
      "numberInSurah": 15
    },
    {
      "text": "اَ۬لَّذِي كَذَّبَ وَتَوَلّۭيٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَسَيُجَنَّبُهَا اَ۬لۡأَتۡقَى ١٧",
      "numberInSurah": 17
    },
    {
      "text": "اَ۬لَّذِي يُؤۡتِي مَالَهُۥ يَتَزَكّۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةٖ تُجۡزۭيٰٓ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "إِلَّا اَ۪بۡتِغَآءَ وَجۡهِ رَبِّهِ اِ۬لۡأَعۡلۭيٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَلَسَوۡفَ يَرۡضۭيٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "سُورَةُ الضُّحَىٰ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلضُّحۭيٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَاَلَّيۡلِ إِذَا سَجۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلۭيٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَلۡأٓخِرَةُ خَيۡرٞ لَّكَ مِنَ اَ۬لۡأُولۭيٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ فَتَرۡضۭيٰٓ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَمۡ يَجِدۡكَ يَتِيمٗا فَـَٔاوۭيٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَوَجَدَكَ ضَآلّٗا فَهَدۭيٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَوَجَدَكَ عَآئِلٗا فَأَغۡنۭيٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَأَمَّا اَ۬لۡيَتِيمَ فَلَا تَقۡهَرۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَأَمَّا اَ۬لسَّآئِلَ فَلَا تَنۡهَرۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَأَمَّا بِنِعۡمَةِ رَبِّكَ فَحَدِّثۡ ١١",
      "numberInSurah": 11
    },
    {
      "text": "سُورَةُ الشَّرۡحِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَوَضَعۡنَا عَنكَ وِزۡرَكَ ٢",
      "numberInSurah": 2
    }
  ]
}
