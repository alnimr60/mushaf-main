{
  "pageNumber": 560,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "فَمَا تَنفَعُهُمۡ شَفَٰعَةُ اُ۬لشَّٰفِعِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "فَمَا لَهُمۡ عَنِ اِ۬لتَّذۡكِرَةِ مُعۡرِضِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "كَأَنَّهُمۡ حُمُرٞ مُّسۡتَنفِرَةٞ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "فَرَّتۡ مِن قَسۡوَرَةِۢ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "بَلۡ يُرِيدُ كُلُّ اُ۪مۡرِيٕٖ مِّنۡهُمۡ أَن يُؤۡتَىٰ صُحُفٗا مُّنَشَّرَةٗ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "كَلَّاۖ بَل لَّا يَخَافُونَ اَ۬لۡأٓخِرَةَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "كَلَّآ إِنَّهُۥ تَذۡكِرَةٞ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "وَمَا يَذۡكُرُونَ إِلَّآ أَن يَشَآءَ اَ۬للَّهُۚ هُوَ أَهۡلُ اُ۬لتَّقۡوۭيٰ وَأَهۡلُ اُ۬لۡمَغۡفِرَةِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "سُورَةُ القِيَامَةِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ لَآ أُقۡسِمُ بِيَوۡمِ اِ۬لۡقِيَٰمَةِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَلَآ أُقۡسِمُ بِالنَّفۡسِ اِ۬للَّوَّامَةِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "أَيَحۡسِبُ اُ۬لۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ٣",
      "numberInSurah": 3
    },
    {
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّيَ بَنَانَهُۥ ٤",
      "numberInSurah": 4
    },
    {
      "text": "بَلۡ يُرِيدُ اُ۬لۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَسۡـَٔلُ أَيَّانَ يَوۡمُ اُ۬لۡقِيَٰمَةِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَإِذَا بَرِقَ اَ۬لۡبَصَرُ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَخَسَفَ اَ۬لۡقَمَرُ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَجُمِعَ اَ۬لشَّمۡسُ وَاَلۡقَمَرُ ٩",
      "numberInSurah": 9
    },
    {
      "text": "يَقُولُ اُ۬لۡإِنسَٰنُ يَوۡمَئِذٍ أَيۡنَ اَ۬لۡمَفَرُّ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَلَّا لَا وَزَرَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ اِ۬لۡمُسۡتَقَرُّ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يُنَبَّؤُاْ اُ۬لۡإِنسَٰنُ يَوۡمَئِذِۢ بِمَا قَدَّمَ وَأَخَّرَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "بَلِ اِ۬لۡإِنسَٰنُ عَلَىٰ نَفۡسِهِۦ بَصِيرَةٞ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ إِنَّ عَلَيۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "فَإِذَا قَرَأۡنَٰهُ فَاَتَّبِعۡ قُرۡءَانَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيۡنَا بَيَانَهُۥ ١٨",
      "numberInSurah": 18
    }
  ]
}
