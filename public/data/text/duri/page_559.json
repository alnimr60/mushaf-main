      "numberInSurah": 19
    },
    {
      "text": "ثُمَّ قُتِلَ كَيۡفَ قَدَّرَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "ثُمَّ نَظَرَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ عَبَسَ وَبَسَرَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "ثُمَّ أَدۡبَرَ وَاَسۡتَكۡبَرَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَقَالَ إِنۡ هَٰذَآ إِلَّا سِحۡرٞ يُؤۡثَرُ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنۡ هَٰذَآ إِلَّا قَوۡلُ اُ۬لۡبَشَرِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "سَأُصۡلِيهِ سَقَرَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا سَقَرُ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "لَا تُبۡقِي وَلَا تَذَرُ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "لَوَّاحَةٞ لِّلۡبَشَرِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "عَلَيۡهَا تِسۡعَةَ عَشَرَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "۞وَمَا جَعَلۡنَآ أَصۡحَٰبَ اَ۬لنّ۪ارِ إِلَّا مَلَٰٓئِكَةٗۖ وَمَا جَعَلۡنَا عِدَّتَهُمۡ إِلَّا فِتۡنَةٗ لِّلَّذِينَ كَفَرُواْ لِيَسۡتَيۡقِنَ اَ۬لَّذِينَ أُوتُواْ اُ۬لۡكِتَٰبَ وَيَزۡدَادَ اَ۬لَّذِينَ ءَامَنُوٓاْ إِيمَٰنٗا وَلَا يَرۡتَابَ اَ۬لَّذِينَ أُوتُواْ اُ۬لۡكِتَٰبَ وَاَلۡمُؤۡمِنُونَ وَلِيَقُولَ اَ۬لَّذِينَ فِي قُلُوبِهِم مَّرَضٞ وَاَلۡكَٰفِرُونَ مَاذَآ أَرَادَ اَ۬للَّهُ بِهَٰذَا مَثَلٗاۚ كَذَٰلِكَ يُضِلُّ اُ۬للَّهُ مَن يَشَآءُ وَيَهۡدِي مَن يَشَآءُۚ وَمَا يَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ وَمَا هِيَ إِلَّا ذِكۡر۪يٰ لِلۡبَشَرِ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "كَلَّا وَاَلۡقَمَرِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَاَلَّيۡلِ إِذَا دَبَرَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَاَلصُّبۡحِ إِذَآ أَسۡفَرَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "إِنَّهَا لَإِحۡدَى اَ۬لۡكُبَرِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "نَذِيرٗا لِّلۡبَشَرِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لِمَن شَآءَ مِنكُمۡ أَن يَتَقَدَّمَ أَوۡ يَتَأَخَّرَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "كُلُّ نَفۡسِۢ بِمَا كَسَبَتۡ رَهِينَةٌ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "إِلَّآ أَصۡحَٰبَ اَ۬لۡيَمِينِ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فِي جَنَّٰتٖ يَتَسَآءَلُونَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "عَنِ اِ۬لۡمُجۡرِمِينَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "مَا سَلَكَكُمۡ فِي سَقَرَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "قَالُواْ لَمۡ نَكُ مِنَ اَ۬لۡمُصَلِّينَ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "وَلَمۡ نَكُ نُطۡعِمُ اُ۬لۡمِسۡكِينَ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "وَكُنَّا نَخُوضُ مَعَ اَ۬لۡخَآئِضِينَ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "وَكُنَّا نُكَذِّبُ بِيَوۡمِ اِ۬لدِّينِ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "حَتَّىٰٓ أَتَىٰنَا اَ۬لۡيَقِينُ ٤٧",
      "numberInSurah": 47
    }
  ]
