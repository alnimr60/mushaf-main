{
  "pageNumber": 569,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا اَ۬لسَّمَآءُ اُ۪نفَطَرَتۡ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِذَا اَ۬لۡكَوَاكِبُ اُ۪نتَثَرَتۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا اَ۬لۡبِحَارُ فُجِّرَتۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَإِذَا اَ۬لۡقُبُورُ بُعۡثِرَتۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "عَلِمَتۡ نَفۡسٞ مَّا قَدَّمَتۡ وَأَخَّرَتۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَٰٓأَيُّهَا اَ۬لۡإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ اَ۬لۡكَرِيمِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "اِ۬لَّذِي خَلَقَكَ فَسَوَّىٰكَ فَعَدَّلَكَ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فِيٓ أَيِّ صُورَةٖ مَّا شَآءَ رَكَّبَكَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "كَلَّا بَلۡ تُكَذِّبُونَ بِالدِّينِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَإِنَّ عَلَيۡكُمۡ لَحَٰفِظِينَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كِرَامٗا كَٰتِبِينَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "يَعۡلَمُونَ مَا تَفۡعَلُونَ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّ اَ۬لۡأَبۡرَارَ لَفِي نَعِيمٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَإِنَّ اَ۬لۡفُجَّارَ لَفِي جَحِيمٖ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "يَصۡلَوۡنَهَا يَوۡمَ اَ۬لدِّينِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَمَا هُمۡ عَنۡهَا بِغَآئِبِينَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا يَوۡمُ اُ۬لدِّينِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "ثُمَّ مَآ أَدۡر۪ىٰكَ مَا يَوۡمُ اُ۬لدِّينِ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "يَوۡمُ لَا تَمۡلِكُ نَفۡسٞ لِّنَفۡسٖ شَيۡـٔٗاۖ وَاَلۡأَمۡرُ يَوۡمَئِذٖ لِّلَّهِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "سُورَةُ المُطَفِّفِينَ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَيۡلٞ لِّلۡمُطَفِّفِينَ ١",
      "numberInSurah": 1
    },
    {
      "text": "اَ۬لَّذِينَ إِذَا اَ۪كۡتَالُواْ عَلَى اَ۬لنّ۪اسِ يَسۡتَوۡفُونَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا كَالُوهُمۡ أَو وَّزَنُوهُمۡ يُخۡسِرُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "أَلَا يَظُنُّ أُوْلَٰٓئِكَ أَنَّهُم مَّبۡعُوثُونَ ٤",
      "numberInSurah": 4
    }
  ]
}
