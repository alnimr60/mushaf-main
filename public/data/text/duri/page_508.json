{
  "pageNumber": 508,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "وَاَلسَّمَآءِ ذَاتِ اِ۬لۡحُبُكِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّكُمۡ لَفِي قَوۡلٖ مُّخۡتَلِفٖ ٨",
      "numberInSurah": 8
    },
    {
      "text": "يُؤۡفَكُ عَنۡهُ مَنۡ أُفِكَ ٩",
      "numberInSurah": 9
    },
    {
      "text": "قُتِلَ اَ۬لۡخَرَّٰصُونَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "اَ۬لَّذِينَ هُمۡ فِي غَمۡرَةٖ سَاهُونَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "يَسۡـَٔلُونَ أَيَّانَ يَوۡمُ اُ۬لدِّينِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يَوۡمَ هُمۡ عَلَى اَ۬لنّ۪ارِ يُفۡتَنُونَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "ذُوقُواْ فِتۡنَتَكُمۡ هَٰذَا اَ۬لَّذِي كُنتُم بِهِۦ تَسۡتَعۡجِلُونَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "إِنَّ اَ۬لۡمُتَّقِينَ فِي جَنَّٰتٖ وَعُيُونٍ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ءَاخِذِينَ مَآ ءَاتَىٰهُمۡ رَبُّهُمۡۚ إِنَّهُمۡ كَانُواْ قَبۡلَ ذَٰلِكَ مُحۡسِنِينَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "كَانُواْ قَلِيلٗا مِّنَ اَ۬لَّيۡلِ مَا يَهۡجَعُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَبِالۡأَسۡح۪ارِ هُمۡ يَسۡتَغۡفِرُونَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَفِيٓ أَمۡوَٰلِهِمۡ حَقّٞ لِّلسَّآئِلِ وَاَلۡمَحۡرُومِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَفِي اِ۬لۡأَرۡضِ ءَايَٰتٞ لِّلۡمُوقِنِينَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَفِيٓ أَنفُسِكُمۡۚ أَفَلَا تُبۡصِرُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَفِي اِ۬لسَّمَآءِ رِزۡقُكُمۡ وَمَا تُوعَدُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَوَرَبِّ اِ۬لسَّمَآءِ وَاَلۡأَرۡضِ إِنَّهُۥ لَحَقّٞ مِّثۡلَ مَآ أَنَّكُمۡ تَنطِقُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ ضَيۡفِ إِبۡرَٰهِيمَ اَ۬لۡمُكۡرَمِينَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِذ دَّخَلُواْ عَلَيۡهِ فَقَالُواْ سَلَٰمٗاۖ قَالَ سَلَٰمٞ قَوۡمٞ مُّنكَرُونَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَرَاغَ إِلَىٰٓ أَهۡلِهِۦ فَجَآءَ بِعِجۡلٖ سَمِينٖ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "فَقَرَّبَهُۥٓ إِلَيۡهِمۡ قَالَ أَلَا تَأۡكُلُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَأَوۡجَسَ مِنۡهُمۡ خِيفَةٗۖ قَالُواْ لَا تَخَفۡۖ وَبَشَّرُوهُ بِغُلَٰمٍ عَلِيمٖ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "فَأَقۡبَلَتِ اِ۪مۡرَأَتُهُۥ فِي صَرَّةٖ فَصَكَّتۡ وَجۡهَهَا وَقَالَتۡ عَجُوزٌ عَقِيمٞ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "قَالُواْ كَذَٰلِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ اَ۬لۡحَكِيمُ اُ۬لۡعَلِيمُ ٣٠",
      "numberInSurah": 30
    }
  ]
}
