{
  "pageNumber": 579,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "اَ۬لَّذِيٓ أَنقَضَ ظَهۡرَكَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَرَفَعۡنَا لَكَ ذِكۡرَكَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَإِنَّ مَعَ اَ۬لۡعُسۡرِ يُسۡرًا ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِنَّ مَعَ اَ۬لۡعُسۡرِ يُسۡرٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَإِذَا فَرَغۡتَ فَاَنصَبۡ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِلَىٰ رَبِّكَ فَاَرۡغَب ٨",
      "numberInSurah": 8
    },
    {
      "text": "سُورَةُ التِّينِ بِّسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلتِّينِ وَاَلزَّيۡتُونِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَطُورِ سِينِينَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَهَٰذَا اَ۬لۡبَلَدِ اِ۬لۡأَمِينِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "لَقَدۡ خَلَقۡنَا اَ۬لۡإِنسَٰنَ فِيٓ أَحۡسَنِ تَقۡوِيمٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ثُمَّ رَدَدۡنَٰهُ أَسۡفَلَ سَٰفِلِينَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِلَّا اَ۬لَّذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ فَلَهُمۡ أَجۡرٌ غَيۡرُ مَمۡنُونٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَمَا يُكَذِّبُكَ بَعۡدُ بِالدِّينِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "أَلَيۡسَ اَ۬للَّهُ بِأَحۡكَمِ اِ۬لۡحَٰكِمِينَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "سُورَةُ العَلَقِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ اِ۪قۡرَأۡ بِاسۡمِ رَبِّكَ اَ۬لَّذِي خَلَقَ ١",
      "numberInSurah": 1
    },
    {
      "text": "خَلَقَ اَ۬لۡإِنسَٰنَ مِنۡ عَلَقٍ ٢",
      "numberInSurah": 2
    },
    {
      "text": "اِ۪قۡرَأۡ وَرَبُّكَ اَ۬لۡأَكۡرَمُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "اُ۬لَّذِي عَلَّمَ بِالۡقَلَمِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "عَلَّمَ اَ۬لۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "كَلَّآ إِنَّ اَ۬لۡإِنسَٰنَ لَيَطۡغۭيٰٓ ٦",
      "numberInSurah": 6
    },
    {
      "text": "أَن رَّء۪اهُ اُ۪سۡتَغۡنۭيٰٓ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّ إِلَىٰ رَبِّكَ اَ۬لرُّجۡعۭيٰٓ ٨",
      "numberInSurah": 8
    },
    {
      "text": "أَرَءَيۡتَ اَ۬لَّذِي يَنۡهۭيٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "عَبۡدًا إِذَا صَلّۭيٰٓ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "أَرَءَيۡتَ إِن كَانَ عَلَى اَ۬لۡهُدۭيٰٓ ١١",
      "numberInSurah": 11
    },
    {
      "text": "أَوۡ أَمَرَ بِالتَّقۡوۭيٰٓ ١٢",
      "numberInSurah": 12
    }
  ]
}
