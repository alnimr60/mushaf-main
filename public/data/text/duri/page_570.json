{
  "pageNumber": 570,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "لِيَوۡمٍ عَظِيمٖ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَوۡمَ يَقُومُ اُ۬لنَّاسُ لِرَبِّ اِ۬لۡعَٰلَمِينَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "كَلَّآ إِنَّ كِتَٰبَ اَ۬لۡفُجّ۪ارِ لَفِي سِجِّينٖ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا سِجِّينٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "كِتَٰبٞ مَّرۡقُومٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "اَ۬لَّذِينَ يُكَذِّبُونَ بِيَوۡمِ اِ۬لدِّينِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعۡتَدٍ أَثِيمٍ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِذَا تُتۡلَىٰ عَلَيۡهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ اُ۬لۡأَوَّلِينَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "كَلَّاۖ بَل رَّانَ عَلَىٰ قُلُوبِهِم مَّا كَانُواْ يَكۡسِبُونَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "كَلَّآ إِنَّهُمۡ عَن رَّبِّهِمۡ يَوۡمَئِذٖ لَّمَحۡجُوبُونَ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ثُمَّ إِنَّهُمۡ لَصَالُواْ اُ۬لۡجَحِيمِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "ثُمَّ يُقَالُ هَٰذَا اَ۬لَّذِي كُنتُم بِهِۦ تُكَذِّبُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "۞كَلَّآ إِنَّ كِتَٰبَ اَ۬لۡأَبۡر۪ارِ لَفِي عِلِّيِّينَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا عِلِّيُّونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "كِتَٰبٞ مَّرۡقُومٞ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "يَشۡهَدُهُ اُ۬لۡمُقَرَّبُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِنَّ اَ۬لۡأَبۡرَارَ لَفِي نَعِيمٍ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "عَلَى اَ۬لۡأَرَآئِكِ يَنظُرُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "تَعۡرِفُ فِي وُجُوهِهِمۡ نَضۡرَةَ اَ۬لنَّعِيمِ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "يُسۡقَوۡنَ مِن رَّحِيقٖ مَّخۡتُومٍ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "خِتَٰمُهُۥ مِسۡكٞۚ وَفِي ذَٰلِكَ فَلۡيَتَنَافَسِ اِ۬لۡمُتَنَٰفِسُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَمِزَاجُهُۥ مِن تَسۡنِيمٍ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "عَيۡنٗا يَشۡرَبُ بِهَا اَ۬لۡمُقَرَّبُونَ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "إِنَّ اَ۬لَّذِينَ أَجۡرَمُواْ كَانُواْ مِنَ اَ۬لَّذِينَ ءَامَنُواْ يَضۡحَكُونَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَإِذَا مَرُّواْ بِهِمۡ يَتَغَامَزُونَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَإِذَا اَ۪نقَلَبُوٓاْ إِلَىٰٓ أَهۡلِهِمِ اِ۪نقَلَبُواْ فَٰكِهِينَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَإِذَا رَأَوۡهُمۡ قَالُوٓاْ إِنَّ هَٰٓؤُلَآءِ لَضَآلُّونَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَمَآ أُرۡسِلُواْ عَلَيۡهِمۡ حَٰفِظِينَ ٣٣",
      "numberInSurah": 33
    }
  ]
}
