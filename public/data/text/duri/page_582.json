{
  "pageNumber": 582,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "إِنَّ اَ۬لۡإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٞ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِنَّهُۥ لِحُبِّ اِ۬لۡخَيۡرِ لَشَدِيدٌ ٨",
      "numberInSurah": 8
    },
    {
      "text": "۞أَفَلَا يَعۡلَمُ إِذَا بُعۡثِرَ مَا فِي اِ۬لۡقُبُورِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَحُصِّلَ مَا فِي اِ۬لصُّدُورِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "إِنَّ رَبَّهُم بِهِمۡ يَوۡمَئِذٖ لَّخَبِيرُۢ ١١",
      "numberInSurah": 11
    },
    {
      "text": "سُورَةُ القَارِعَةِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ اِ۬لۡقَارِعَةُ مَا اَ۬لۡقَارِعَةُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا اَ۬لۡقَارِعَةُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "يَوۡمَ يَكُونُ اُ۬لنَّاسُ كَاَلۡفَرَاشِ اِ۬لۡمَبۡثُوثِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَتَكُونُ اُ۬لۡجِبَالُ كَاَلۡعِهۡنِ اِ۬لۡمَنفُوشِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَأَمَّا مَن ثَقُلَتۡ مَوَٰزِينُهُۥ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَهۡوَ فِي عِيشَةٖ رَّاضِيَةٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَأَمَّا مَنۡ خَفَّتۡ مَوَٰزِينُهُۥ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَأُمُّهُۥ هَاوِيَةٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَمَآ أَدۡر۪ىٰكَ مَا هِيَهۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "نَارٌ حَامِيَةُۢ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "سُورَةُ التَّكَاثُرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ أَلۡهَىٰكُمُ اُ۬لتَّكَاثُرُ ١",
      "numberInSurah": 1
    },
    {
      "text": "حَتَّىٰ زُرۡتُمُ اُ۬لۡمَقَابِرَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "كَلَّا سَوۡفَ تَعۡلَمُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "ثُمَّ كَلَّا سَوۡفَ تَعۡلَمُونَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "كَلَّا لَوۡ تَعۡلَمُونَ عِلۡمَ اَ۬لۡيَقِينِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "لَتَرَوُنَّ اَ۬لۡجَحِيمَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "ثُمَّ لَتَرَوُنَّهَا عَيۡنَ اَ۬لۡيَقِينِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "ثُمَّ لَتُسۡـَٔلُنَّ يَوۡمَئِذٍ عَنِ اِ۬لنَّعِيمِ ٨",
      "numberInSurah": 8
    }
  ]
}
