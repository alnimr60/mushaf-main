{
  "pageNumber": 551,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِينٖ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لَّا يَأۡكُلُهُۥٓ إِلَّا اَ۬لۡخَٰطِـُٔونَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَلَآ أُقۡسِمُ بِمَا تُبۡصِرُونَ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَمَا لَا تُبۡصِرُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "وَمَا هُوَ بِقَوۡلِ شَاعِرٖۚ قَلِيلٗا مَّا تُؤۡمِنُونَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "وَلَا بِقَوۡلِ كَاهِنٖۚ قَلِيلٗا مَّا تَذَّكَّرُونَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ اِ۬لۡعَٰلَمِينَ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "وَلَوۡ تَقَوَّلَ عَلَيۡنَا بَعۡضَ اَ۬لۡأَقَاوِيلِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "لَأَخَذۡنَا مِنۡهُ بِالۡيَمِينِ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "ثُمَّ لَقَطَعۡنَا مِنۡهُ اُ۬لۡوَتِينَ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "فَمَا مِنكُم مِّنۡ أَحَدٍ عَنۡهُ حَٰجِزِينَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَإِنَّهُۥ لَتَذۡكِرَةٞ لِّلۡمُتَّقِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَإِنَّهُۥ لَحَسۡرَةٌ عَلَى اَ۬لۡكٰ۪فِرِينَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَإِنَّهُۥ لَحَقُّ اُ۬لۡيَقِينِ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "فَسَبِّحۡ بِاسۡمِ رَبِّكَ اَ۬لۡعَظِيمِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "سُورَةُ المَعَارِجِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ سَأَلَ سَآئِلُۢ بِعَذَابٖ وَاقِعٖ ١",
      "numberInSurah": 1
    },
    {
      "text": "لِّلۡكٰ۪فِرِينَ لَيۡسَ لَهُۥ دَافِعٞ ٢",
      "numberInSurah": 2
    },
    {
      "text": "مِّنَ اَ۬للَّهِ ذِي اِ۬لۡمَعَارِجِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "تَعۡرُجُ اُ۬لۡمَلَٰٓئِكَةُ وَاَلرُّوحُ إِلَيۡهِ فِي يَوۡمٖ كَانَ مِقۡدَارُهُۥ خَمۡسِينَ أَلۡفَ سَنَةٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَاَصۡبِرۡ صَبۡرٗا جَمِيلًا ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِنَّهُمۡ يَرَوۡنَهُۥ بَعِيدٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَنَر۪ىٰهُ قَرِيبٗا ٧",
      "numberInSurah": 7
    },
    {
      "text": "يَوۡمَ تَكُونُ اُ۬لسَّمَآءُ كَاَلۡمُهۡلِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَتَكُونُ اُ۬لۡجِبَالُ كَاَلۡعِهۡنِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمٗا ١٠",
      "numberInSurah": 10
    }
  ]
}
