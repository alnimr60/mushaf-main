{
  "pageNumber": 561,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "كَلَّا بَلۡ يُحِبُّونَ اَ۬لۡعَاجِلَةَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَيَذَرُونَ اَ۬لۡأٓخِرَةَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وُجُوهٞ يَوۡمَئِذٖ نَّاضِرَةٌ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٞ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَوُجُوهٞ يَوۡمَئِذِۢ بَاسِرَةٞ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "تَظُنُّ أَن يُفۡعَلَ بِهَا فَاقِرَةٞ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "كَلَّآ إِذَا بَلَغَتِ اِ۬لتَّرَاقِيَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَقِيلَ مَن رَّاقٖ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَظَنَّ أَنَّهُ اُ۬لۡفِرَاقُ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَاَلۡتَفَّتِ اِ۬لسَّاقُ بِالسَّاقِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ اِ۬لۡمَسَاقُ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فَلَا صَدَّقَ وَلَا صَلّۭيٰ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلّۭيٰ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهۡلِهِۦ يَتَمَطّۭيٰٓ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "أَوۡلَىٰ لَكَ فَأَوۡلۭيٰ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "ثُمَّ أَوۡلَىٰ لَكَ فَأَوۡلۭيٰٓ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "أَيَحۡسِبُ اُ۬لۡإِنسَٰنُ أَن يُتۡرَكَ سُدًى ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "أَلَمۡ يَكُ نُطۡفَةٗ مِّن مَّنِيّٖ تُمۡنۭيٰ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوّۭيٰ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَجَعَلَ مِنۡهُ اُ۬لزَّوۡجَيۡنِ اِ۬لذَّكَرَ وَاَلۡأُنثۭيٰٓ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "أَلَيۡسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحۡـِۧيَ اَ۬لۡمَوۡتۭيٰ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "سُورَةُ الإِنسَانِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ هَلۡ أَتَىٰ عَلَى اَ۬لۡإِنسَٰنِ حِينٞ مِّنَ اَ۬لدَّهۡرِ لَمۡ يَكُن شَيۡـٔٗا مَّذۡكُورًا ١",
      "numberInSurah": 1
    },
    {
      "text": "إِنَّا خَلَقۡنَا اَ۬لۡإِنسَٰنَ مِن نُّطۡفَةٍ أَمۡشَاجٖ نَّبۡتَلِيهِ فَجَعَلۡنَٰهُ سَمِيعَۢا بَصِيرًا ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِنَّا هَدَيۡنَٰهُ اُ۬لسَّبِيلَ إِمَّا شَاكِرٗا وَإِمَّا كَفُورًا ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنَّآ أَعۡتَدۡنَا لِلۡكٰ۪فِرِينَ سَلَٰسِلَا۠ وَأَغۡلَٰلٗا وَسَعِيرًا ٤",
      "numberInSurah": 4
    },
    {
      "text": "إِنَّ اَ۬لۡأَبۡرَارَ يَشۡرَبُونَ مِن كَأۡسٖ كَانَ مِزَاجُهَا كَافُورًا ٥",
      "numberInSurah": 5
    }
  ]
}
