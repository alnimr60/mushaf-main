{
  "pageNumber": 521,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "يَطُوفُ عَلَيۡهِمۡ وِلۡدَٰنٞ مُّخَلَّدُونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "بِأَكۡوَابٖ وَأَبَارِيقَ وَكَأۡسٖ مِّن مَّعِينٖ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "لَّا يُصَدَّعُونَ عَنۡهَا وَلَا يُنزَفُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَفَٰكِهَةٖ مِّمَّا يَتَخَيَّرُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَلَحۡمِ طَيۡرٖ مِّمَّا يَشۡتَهُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَحُورٌ عِينٞ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "كَأَمۡثَٰلِ اِ۬للُّؤۡلُوِٕ اِ۬لۡمَكۡنُونِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "جَزَآءَۢ بِمَا كَانُواْ يَعۡمَلُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "لَا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا تَأۡثِيمًا إِلَّا قِيلٗا سَلَٰمٗا سَلَٰمٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَأَصۡحَٰبُ اُ۬لۡيَمِينِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "مَآ أَصۡحَٰبُ اُ۬لۡيَمِينِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فِي سِدۡرٖ مَّخۡضُودٖ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَطَلۡحٖ مَّنضُودٖ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَظِلّٖ مَّمۡدُودٖ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَمَآءٖ مَّسۡكُوبٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَفَٰكِهَةٖ كَثِيرَةٖ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "لَّا مَقۡطُوعَةٖ وَلَا مَمۡنُوعَةٖ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَفُرُشٖ مَّرۡفُوعَةٍ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "إِنَّآ أَنشَأۡنَٰهُنَّ إِنشَآءٗ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَجَعَلۡنَٰهُنَّ أَبۡكَارًا ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "عُرُبًا أَتۡرَابٗا ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "لِّأَصۡحَٰبِ اِ۬لۡيَمِينِ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "۞ثُلَّةٞ مِّنَ اَ۬لۡأَوَّلِينَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "وَثُلَّةٞ مِّنَ اَ۬لۡأٓخِرِينَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "وَأَصۡحَٰبُ اُ۬لشِّمَالِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "مَآ أَصۡحَٰبُ اُ۬لشِّمَالِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "فِي سَمُومٖ وَحَمِيمٖ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "وَظِلّٖ مِّن يَحۡمُومٖ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "لَّا بَارِدٖ وَلَا كَرِيمٍ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "إِنَّهُمۡ كَانُواْ قَبۡلَ ذَٰلِكَ مُتۡرَفِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَكَانُواْ يُصِرُّونَ عَلَى اَ۬لۡحِنثِ اِ۬لۡعَظِيمِ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَكَانُواْ يَقُولُونَ أَٰى۪ذَا مُتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَٰ۟نَّا لَمَبۡعُوثُونَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "أَوَءَابَآؤُنَا اَ۬لۡأَوَّلُونَ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "قُلۡ إِنَّ اَ۬لۡأَوَّلِينَ وَاَلۡأٓخِرِينَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "لَمَجۡمُوعُونَ إِلَىٰ مِيقَٰتِ يَوۡمٖ مَّعۡلُومٖ ٥٣",
      "numberInSurah": 53
    }
  ]
}
