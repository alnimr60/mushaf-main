{
  "pageNumber": 568,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "تَرۡهَقُهَا قَتَرَةٌ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "أُوْلَٰٓئِكَ هُمُ اُ۬لۡكَفَرَةُ اُ۬لۡفَجَرَةُ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "سُورَةُ التَّكۡوِيرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ إِذَا اَ۬لشَّمۡسُ كُوِّرَتۡ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِذَا اَ۬لنُّجُومُ اُ۪نكَدَرَتۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا اَ۬لۡجِبَالُ سُيِّرَتۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَإِذَا اَ۬لۡعِشَارُ عُطِّلَتۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَإِذَا اَ۬لۡوُحُوشُ حُشِرَتۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَإِذَا اَ۬لۡبِحَارُ سُجِرَتۡ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَإِذَا اَ۬لنُّفُوسُ زُوِّجَتۡ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِذَا اَ۬لۡمَوۡءُۥدَةُ سُئِلَتۡ ٨",
      "numberInSurah": 8
    },
    {
      "text": "بِأَيِّ ذَنۢبٖ قُتِلَتۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَإِذَا اَ۬لصُّحُفُ نُشِّرَتۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَإِذَا اَ۬لسَّمَآءُ كُشِطَتۡ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَإِذَا اَ۬لۡجَحِيمُ سُعِرَتۡ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَإِذَا اَ۬لۡجَنَّةُ أُزۡلِفَتۡ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "عَلِمَتۡ نَفۡسٞ مَّآ أَحۡضَرَتۡ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَلَآ أُقۡسِمُ بِالۡخُنَّسِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "اِ۬لۡجَوَارِ اِ۬لۡكُنَّسِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَاَلَّيۡلِ إِذَا عَسۡعَسَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَاَلصُّبۡحِ إِذَا تَنَفَّسَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "ذِي قُوَّةٍ عِندَ ذِي اِ۬لۡعَرۡشِ مَكِينٖ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "مُّطَاعٖ ثَمَّ أَمِينٖ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَمَا صَاحِبُكُم بِمَجۡنُونٖ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَلَقَدۡ رَء۪اهُ بِالۡأُفُقِ اِ۬لۡمُبِينِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَمَا هُوَ عَلَى اَ۬لۡغَيۡبِ بِضظَنِينٖ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَمَا هُوَ بِقَوۡلِ شَيۡطَٰنٖ رَّجِيمٖ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَأَيۡنَ تَذۡهَبُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "إِنۡ هُوَ إِلَّا ذِكۡرٞ لِّلۡعَٰلَمِينَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "لِمَن شَآءَ مِنكُمۡ أَن يَسۡتَقِيمَ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ اَ۬للَّهُ رَبُّ اُ۬لۡعَٰلَمِينَ ٢٩",
      "numberInSurah": 29
    }
  ]
}
