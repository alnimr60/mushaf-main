{
  "pageNumber": 441,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "فَكَذَّبُوهُ فَإِنَّهُمۡ لَمُحۡضَرُونَ ١٢٧",
      "numberInSurah": 127
    },
    {
      "text": "إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لۡمُخۡلِصِينَ ١٢٨",
      "numberInSurah": 128
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِ فِي اِ۬لۡأٓخِرِينَ ١٢٩",
      "numberInSurah": 129
    },
    {
      "text": "سَلَٰمٌ عَلَىٰٓ إِلۡ يَاسِينَ ١٣٠",
      "numberInSurah": 130
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ ١٣١",
      "numberInSurah": 131
    },
    {
      "text": "إِنَّهُۥ مِنۡ عِبَادِنَا اَ۬لۡمُؤۡمِنِينَ ١٣٢",
      "numberInSurah": 132
    },
    {
      "text": "وَإِنَّ لُوطٗا لَّمِنَ اَ۬لۡمُرۡسَلِينَ ١٣٣",
      "numberInSurah": 133
    },
    {
      "text": "إِذۡ نَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ ١٣٤",
      "numberInSurah": 134
    },
    {
      "text": "إِلَّا عَجُوزٗا فِي اِ۬لۡغَٰبِرِينَ ١٣٥",
      "numberInSurah": 135
    },
    {
      "text": "ثُمَّ دَمَّرۡنَا اَ۬لۡأٓخَرِينَ ١٣٦",
      "numberInSurah": 136
    },
    {
      "text": "وَإِنَّكُمۡ لَتَمُرُّونَ عَلَيۡهِم مُّصۡبِحِينَ ١٣٧",
      "numberInSurah": 137
    },
    {
      "text": "وَبِالَّيۡلِۗ أَفَلَا تَعۡقِلُونَ ١٣٨",
      "numberInSurah": 138
    },
    {
      "text": "وَإِنَّ يُونُسَ لَمِنَ اَ۬لۡمُرۡسَلِينَ ١٣٩",
      "numberInSurah": 139
    },
    {
      "text": "إِذۡ أَبَقَ إِلَى اَ۬لۡفُلۡكِ اِ۬لۡمَشۡحُونِ ١٤٠",
      "numberInSurah": 140
    },
    {
      "text": "فَسَاهَمَ فَكَانَ مِنَ اَ۬لۡمُدۡحَضِينَ ١٤١",
      "numberInSurah": 141
    },
    {
      "text": "فَاَلۡتَقَمَهُ اُ۬لۡحُوتُ وَهۡوَ مُلِيمٞ ١٤٢",
      "numberInSurah": 142
    },
    {
      "text": "فَلَوۡلَآ أَنَّهُۥ كَانَ مِنَ اَ۬لۡمُسَبِّحِينَ ١٤٣",
      "numberInSurah": 143
    },
    {
      "text": "لَلَبِثَ فِي بَطۡنِهِۦٓ إِلَىٰ يَوۡمِ يُبۡعَثُونَ ١٤٤",
      "numberInSurah": 144
    },
    {
      "text": "فَنَبَذۡنَٰهُ بِالۡعَرَآءِ وَهۡوَ سَقِيمٞ ١٤٥",
      "numberInSurah": 145
    },
    {
      "text": "۞وَأَنۢبَتۡنَا عَلَيۡهِ شَجَرَةٗ مِّن يَقۡطِينٖ ١٤٦",
      "numberInSurah": 146
    },
    {
      "text": "وَأَرۡسَلۡنَٰهُ إِلَىٰ مِاْئَةِ أَلۡفٍ أَوۡ يَزِيدُونَ ١٤٧",
      "numberInSurah": 147
    },
    {
      "text": "فَـَٔامَنُواْ فَمَتَّعۡنَٰهُمۡ إِلَىٰ حِينٖ ١٤٨",
      "numberInSurah": 148
    },
    {
      "text": "فَاَسۡتَفۡتِهِمۡ أَلِرَبِّكَ اَ۬لۡبَنَاتُ وَلَهُمُ اُ۬لۡبَنُونَ ١٤٩",
      "numberInSurah": 149
    },
    {
      "text": "أَمۡ خَلَقۡنَا اَ۬لۡمَلَٰٓئِكَةَ إِنَٰثٗا وَهُمۡ شَٰهِدُونَ ١٥٠",
      "numberInSurah": 150
    },
    {
      "text": "أَلَآ إِنَّهُم مِّنۡ إِفۡكِهِمۡ لَيَقُولُونَ ١٥١",
      "numberInSurah": 151
    },
    {
      "text": "وَلَدَ اَ۬للَّهُ وَإِنَّهُمۡ لَكَٰذِبُونَ ١٥٢",
      "numberInSurah": 152
    },
    {
      "text": "أَصۡطَفَى اَ۬لۡبَنَاتِ عَلَى اَ۬لۡبَنِينَ ١٥٣",
      "numberInSurah": 153
    }
  ]
}
