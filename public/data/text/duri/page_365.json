{
  "pageNumber": 365,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "وَاَجۡعَل لِّي لِسَانَ صِدۡقٖ فِي اِ۬لۡأٓخِرِينَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَاَجۡعَلۡنِي مِن وَرَثَةِ جَنَّةِ اِ۬لنَّعِيمِ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "وَاَغۡفِر لِّأَبِيَ إِنَّهُۥ كَانَ مِنَ اَ۬لضَّآلِّينَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "وَلَا تُخۡزِنِي يَوۡمَ يُبۡعَثُونَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "يَوۡمَ لَا يَنفَعُ مَالٞ وَلَا بَنُونَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "إِلَّا مَنۡ أَتَى اَ۬للَّهَ بِقَلۡبٖ سَلِيمٖ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "وَأُزۡلِفَتِ اِ۬لۡجَنَّةُ لِلۡمُتَّقِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "وَبُرِّزَتِ اِ۬لۡجَحِيمُ لِلۡغَاوِينَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "وَقِيلَ لَهُمۡ أَيۡنَ مَا كُنتُمۡ تَعۡبُدُونَ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "مِن دُونِ اِ۬للَّهِ هَلۡ يَنصُرُونَكُمۡ أَوۡ يَنتَصِرُونَ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَكُبۡكِبُواْ فِيهَا هُمۡ وَاَلۡغَاوُۥنَ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "وَجُنُودُ إِبۡلِيسَ أَجۡمَعُونَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "قَالُواْ وَهُمۡ فِيهَا يَخۡتَصِمُونَ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "تَاَللَّهِ إِن كُنَّا لَفِي ضَلَٰلٖ مُّبِينٍ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "إِذۡ نُسَوِّيكُم بِرَبِّ اِ۬لۡعَٰلَمِينَ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "وَمَآ أَضَلَّنَآ إِلَّا اَ۬لۡمُجۡرِمُونَ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "فَمَا لَنَا مِن شَٰفِعِينَ ١٠٠",
      "numberInSurah": 100
    },
    {
      "text": "وَلَا صَدِيقٍ حَمِيمٖ ١٠١",
      "numberInSurah": 101
    },
    {
      "text": "فَلَوۡ أَنَّ لَنَا كَرَّةٗ فَنَكُونَ مِنَ اَ۬لۡمُؤۡمِنِينَ ١٠٢",
      "numberInSurah": 102
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ ١٠٣",
      "numberInSurah": 103
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهۡوَ اَ۬لۡعَزِيزُ اُ۬لرَّحِيمُ ١٠٤",
      "numberInSurah": 104
    },
    {
      "text": "كَذَّبَتۡ قَوۡمُ نُوحٍ اِ۬لۡمُرۡسَلِينَ ١٠٥",
      "numberInSurah": 105
    },
    {
      "text": "إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ نُوحٌ أَلَا تَتَّقُونَ ١٠٦",
      "numberInSurah": 106
    },
    {
      "text": "إِنِّي لَكُمۡ رَسُولٌ أَمِينٞ ١٠٧",
      "numberInSurah": 107
    },
    {
      "text": "فَاَتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِ ١٠٨",
      "numberInSurah": 108
    },
    {
      "text": "وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ اِ۬لۡعَٰلَمِينَ ١٠٩",
      "numberInSurah": 109
    },
    {
      "text": "فَاَتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِ ١١٠",
      "numberInSurah": 110
    },
    {
      "text": "۞قَالُوٓاْ أَنُؤۡمِنُ لَكَ وَاَتَّبَعَكَ اَ۬لۡأَرۡذَلُونَ ١١١",
      "numberInSurah": 111
    }
  ]
}
