{
  "pageNumber": 585,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قُلۡ يَٰٓأَيُّهَا اَ۬لۡكَٰفِرُونَ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَآ أَعۡبُدُ مَا تَعۡبُدُونَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "لَكُمۡ دِينُكُمۡ وَلِي دِينِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "سُورَةُ النَّصۡرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ إِذَا جَآءَ نَصۡرُ اُ۬للَّهِ وَاَلۡفَتۡحُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَرَأَيۡتَ اَ۬لنَّاسَ يَدۡخُلُونَ فِي دِينِ اِ۬للَّهِ أَفۡوَاجٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "فَسَبِّحۡ بِحَمۡدِ رَبِّكَ وَاَسۡتَغۡفِرۡهُۚ إِنَّهُۥ كَانَ تَوَّابَۢا ٣",
      "numberInSurah": 3
    },
    {
      "text": "سُورَةُ المَسَدِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ تَبَّتۡ يَدَآ أَبِي لَهَبٖ وَتَبَّ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ وَمَا كَسَبَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "سَيَصۡلَىٰ نَارٗا ذَاتَ لَهَبٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَاَمۡرَأَتُهُۥ حَمَّالَةُ اُ۬لۡحَطَبِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فِي جِيدِهَا حَبۡلٞ مِّن مَّسَدِۢ ٥",
      "numberInSurah": 5
    }
  ]
}
