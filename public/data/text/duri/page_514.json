{
  "pageNumber": 514,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "وَأَنَّهُۥ خَلَقَ اَ۬لزَّوۡجَيۡنِ اِ۬لذَّكَرَ وَاَلۡأُنثۭيٰ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "مِن نُّطۡفَةٍ إِذَا تُمۡنۭيٰ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "وَأَنَّ عَلَيۡهِ اِ۬لنَّشَآءَةَ اَ۬لۡأُخۡر۪يٰ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنۭيٰ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَأَنَّهُۥ هُوَ رَبُّ اُ۬لشِّعۡر۪يٰ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَأَنَّهُۥٓ أَهۡلَكَ عَادٗا اَ۬لُّاولۭيٰ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَثَمُودٗا فَمَآ أَبۡقۭيٰ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَقَوۡمَ نُوحٖ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُواْ هُمۡ أَظۡلَمَ وَأَطۡغۭيٰ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "وَاَلۡمُؤۡتَفِكَةَ أَهۡوۭيٰ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "فَغَشَّىٰهَا مَا غَشّۭيٰ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَار۪يٰ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "هَٰذَا نَذِيرٞ مِّنَ اَ۬لنُّذُرِ اِ۬لۡأُولۭيٰٓ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "أَزِفَتِ اِ۬لۡأٓزِفَةُ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "لَيۡسَ لَهَا مِن دُونِ اِ۬للَّهِ كَاشِفَةٌ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "أَفَمِنۡ هَٰذَا اَ۬لۡحَدِيثِ تَعۡجَبُونَ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "وَأَنتُمۡ سَٰمِدُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "فَاَسۡجُدُواْۤ لِلَّهِۤ وَاَعۡبُدُواْ۩ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "سُورَةُ القَمَرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ اِ۪قۡتَرَبَتِ اِ۬لسَّاعَةُ وَاَنشَقَّ اَ۬لۡقَمَرُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِن يَرَوۡاْ ءَايَةٗ يُعۡرِضُواْ وَيَقُولُواْ سِحۡرٞ مُّسۡتَمِرّٞ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَكَذَّبُواْ وَاَتَّبَعُوٓاْ أَهۡوَآءَهُمۡۚ وَكُلُّ أَمۡرٖ مُّسۡتَقِرّٞ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَقَد جَّآءَهُم مِّنَ اَ۬لۡأَنۢبَآءِ مَا فِيهِ مُزۡدَجَرٌ ٤",
      "numberInSurah": 4
    },
    {
      "text": "حِكۡمَةُۢ بَٰلِغَةٞۖ فَمَا تُغۡنِ اِ۬لنُّذُرُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَتَوَلَّ عَنۡهُمۡۘ يَوۡمَ يَدۡعُ اُ۬لدَّاعِۦٓ إِلَىٰ شَيۡءٖ نُّكُرٍ ٦",
      "numberInSurah": 6
    }
  ]
}
