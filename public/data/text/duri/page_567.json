{
  "pageNumber": 567,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "اَ۪ذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغۭيٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَقُلۡ هَل لَّكَ إِلَىٰٓ أَن تَزَكّۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَأَهۡدِيَكَ إِلَىٰ رَبِّكَ فَتَخۡشۭيٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَأَر۪ىٰهُ اُ۬لۡأٓيَةَ اَ۬لۡكُبۡر۪يٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَكَذَّبَ وَعَصۭيٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ أَدۡبَرَ يَسۡعۭيٰ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَحَشَرَ فَنَادۭيٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ اُ۬لۡأَعۡلۭيٰ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَأَخَذَهُ اُ۬للَّهُ نَكَالَ اَ۬لۡأٓخِرَةِ وَاَلۡأُولۭيٰٓ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَعِبۡرَةٗ لِّمَن يَخۡشۭيٰٓ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "ءَٰا۬نتُمۡ أَشَدُّ خَلۡقًا أَمِ اِ۬لسَّمَآءُۚ بَنۭىٰهَا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "رَفَعَ سَمۡكَهَا فَسَوّۭىٰهَا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَأَغۡطَشَ لَيۡلَهَا وَأَخۡرَجَ ضُحۭىٰهَا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَاَلۡأَرۡضَ بَعۡدَ ذَٰلِكَ دَحۭىٰهَآ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "أَخۡرَجَ مِنۡهَا مَآءَهَا وَمَرۡعۭىٰهَا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَاَلۡجِبَالَ أَرۡسۭىٰهَا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "مَتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لطَّآمَّةُ اُ۬لۡكُبۡر۪يٰ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "يَوۡمَ يَتَذَكَّرُ اُ۬لۡإِنسَٰنُ مَا سَعۭيٰ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَبُرِّزَتِ اِ۬لۡجَحِيمُ لِمَن يَر۪يٰ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَأَمَّا مَن طَغَىٰ وَءَاثَرَ اَ۬لۡحَيَوٰةَ اَ۬لدُّنۡيۭا ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَإِنَّ اَ۬لۡجَحِيمَ هِيَ اَ۬لۡمَأۡوۭيٰ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَأَمَّا مَنۡ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى اَ۬لنَّفۡسَ عَنِ اِ۬لۡهَوۭيٰ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فَإِنَّ اَ۬لۡجَنَّةَ هِيَ اَ۬لۡمَأۡوۭيٰ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "۞يَسۡـَٔلُونَكَ عَنِ اِ۬لسَّاعَةِ أَيَّانَ مُرۡسۭىٰهَا ٤١",
      "numberInSurah": 41
    },
    {
      "text": "فِيمَ أَنتَ مِن ذِكۡر۪ىٰهَآ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "إِلَىٰ رَبِّكَ مُنتَهۭىٰهَآ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخۡشۭىٰهَا ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "كَأَنَّهُمۡ يَوۡمَ يَرَوۡنَهَا لَمۡ يَلۡبَثُوٓاْ إِلَّا عَشِيَّةً أَوۡ ضُحۭىٰهَا ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "سُورَةُ عَبَسَ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ عَبَسَ وَتَوَلّۭيٰٓ ١",
      "numberInSurah": 1
    },
    {
      "text": "أَن جَآءَهُ اُ۬لۡأَعۡمۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا يُدۡرِيكَ لَعَلَّهُۥ يَزَّكّۭيٰٓ ٣",
      "numberInSurah": 3
    },
    {
      "text": "أَوۡ يَذَّكَّرُ فَتَنفَعُهُ اُ۬لذِّكۡر۪يٰٓ ٤",
      "numberInSurah": 4
    },
    {
      "text": "أَمَّا مَنِ اِ۪سۡتَغۡنۭيٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَأَنتَ لَهُۥ تَصَدّۭيٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَمَا عَلَيۡكَ أَلَّا يَزَّكّۭيٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَأَمَّا مَن جَآءَكَ يَسۡعۭيٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَهۡوَ يَخۡشۭيٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَأَنتَ عَنۡهُ تَلَهّۭيٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَلَّآ إِنَّهَا تَذۡكِرَةٞ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فِي صُحُفٖ مُّكَرَّمَةٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "مَّرۡفُوعَةٖ مُّطَهَّرَةِۢ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "بِأَيۡدِي سَفَرَةٖ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "كِرَامِۢ بَرَرَةٖ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "قُتِلَ اَ۬لۡإِنسَٰنُ مَآ أَكۡفَرَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "مِنۡ أَيِّ شَيۡءٍ خَلَقَهُۥ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "ثُمَّ اَ۬لسَّبِيلَ يَسَّرَهُۥ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ إِذَا شَآ أَنشَرَهُۥ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "كَلَّا لَمَّا يَقۡضِ مَآ أَمَرَهُۥ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَلۡيَنظُرِ اِ۬لۡإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنَّا صَبَبۡنَا اَ۬لۡمَآءَ صَبّٗا ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "ثُمَّ شَقَقۡنَا اَ۬لۡأَرۡضَ شَقّٗا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "فَأَنۢبَتۡنَا فِيهَا حَبّٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَعِنَبٗا وَقَضۡبٗا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَزَيۡتُونٗا وَنَخۡلٗا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَحَدَآئِقَ غُلۡبٗا ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَفَٰكِهَةٗ وَأَبّٗا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "مَّتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لصَّآخَّةُ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "يَوۡمَ يَفِرُّ اُ۬لۡمَرۡءُ مِنۡ أَخِيهِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "وَأُمِّهِۦ وَأَبِيهِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لِكُلِّ اِ۪مۡرِيٕٖ مِّنۡهُمۡ يَوۡمَئِذٖ شَأۡنٞ يُغۡنِيهِ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "۞وُجُوهٞ يَوۡمَئِذٖ مُّسۡفِرَةٞ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "ضَاحِكَةٞ مُّسۡتَبۡشِرَةٞ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "وَوُجُوهٞ يَوۡمَئِذٍ عَلَيۡهَا غَبَرَةٞ ٤٠",
      "numberInSurah": 40
    }
  ]
}
