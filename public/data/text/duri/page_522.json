{
  "pageNumber": 522,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "ثُمَّ إِنَّكُمۡ أَيُّهَا اَ۬لضَّآلُّونَ اَ۬لۡمُكَذِّبُونَ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فَمَالِـُٔونَ مِنۡهَا اَ۬لۡبُطُونَ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "فَشَٰرِبُونَ عَلَيۡهِ مِنَ اَ۬لۡحَمِيمِ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "فَشَٰرِبُونَ شَرۡبَ اَ۬لۡهِيمِ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "هَٰذَا نُزُلُهُمۡ يَوۡمَ اَ۬لدِّينِ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "نَحۡنُ خَلَقۡنَٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "أَفَرَءَيۡتُم مَّا تُمۡنُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "ءَٰا۬نتُمۡ تَخۡلُقُونَهُۥٓ أَمۡ نَحۡنُ اُ۬لۡخَٰلِقُونَ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "نَحۡنُ قَدَّرۡنَا بَيۡنَكُمُ اُ۬لۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِينَ ٦٣",
      "numberInSurah": 63
    },
    {
      "text": "عَلَىٰٓ أَن نُّبَدِّلَ أَمۡثَٰلَكُمۡ وَنُنشِئَكُمۡ فِي مَا لَا تَعۡلَمُونَ ٦٤",
      "numberInSurah": 64
    },
    {
      "text": "وَلَقَدۡ عَلِمۡتُمُ اُ۬لنَّشَآءَةَ اَ۬لۡأُولۭيٰ فَلَوۡلَا تَذَّكَّرُونَ ٦٥",
      "numberInSurah": 65
    },
    {
      "text": "أَفَرَءَيۡتُم مَّا تَحۡرُثُونَ ٦٦",
      "numberInSurah": 66
    },
    {
      "text": "ءَٰا۬نتُمۡ تَزۡرَعُونَهُۥٓ أَمۡ نَحۡنُ اُ۬لزَّٰرِعُونَ ٦٧",
      "numberInSurah": 67
    },
    {
      "text": "لَوۡ نَشَآءُ لَجَعَلۡنَٰهُ حُطَٰمٗا فَظَلۡتُمۡ تَفَكَّهُونَ ٦٨",
      "numberInSurah": 68
    },
    {
      "text": "إِنَّا لَمُغۡرَمُونَ ٦٩",
      "numberInSurah": 69
    },
    {
      "text": "بَلۡ نَحۡنُ مَحۡرُومُونَ ٧٠",
      "numberInSurah": 70
    },
    {
      "text": "أَفَرَءَيۡتُمُ اُ۬لۡمَآءَ اَ۬لَّذِي تَشۡرَبُونَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "ءَٰا۬نتُمۡ أَنزَلۡتُمُوهُ مِنَ اَ۬لۡمُزۡنِ أَمۡ نَحۡنُ اُ۬لۡمُنزِلُونَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "لَوۡ نَشَآءُ جَعَلۡنَٰهُ أُجَاجٗا فَلَوۡلَا تَشۡكُرُونَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "أَفَرَءَيۡتُمُ اُ۬لنَّارَ اَ۬لَّتِي تُورُونَ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "ءَٰا۬نتُمۡ أَنشَأۡتُمۡ شَجَرَتَهَآ أَمۡ نَحۡنُ اُ۬لۡمُنشِـُٔونَ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "نَحۡنُ جَعَلۡنَٰهَا تَذۡكِرَةٗ وَمَتَٰعٗا لِّلۡمُقۡوِينَ ٧٦",
      "numberInSurah": 76
    },
    {
      "text": "فَسَبِّحۡ بِاسۡمِ رَبِّكَ اَ۬لۡعَظِيمِ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "۞فَلَآ أُقۡسِمُ بِمَوَٰقِعِ اِ۬لنُّجُومِ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "وَإِنَّهُۥ لَقَسَمٞ لَّوۡ تَعۡلَمُونَ عَظِيمٌ ٧٩",
      "numberInSurah": 79
    }
  ]
}
