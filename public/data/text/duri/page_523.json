{
  "pageNumber": 523,
  "riwayaId": "duri",
  "ayahs": [
    {
      "text": "إِنَّهُۥ لَقُرۡءَانٞ كَرِيمٞ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "فِي كِتَٰبٖ مَّكۡنُونٖ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "لَّا يَمَسُّهُۥٓ إِلَّا اَ۬لۡمُطَهَّرُونَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ اِ۬لۡعَٰلَمِينَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "أَفَبِهَٰذَا اَ۬لۡحَدِيثِ أَنتُم مُّدۡهِنُونَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَتَجۡعَلُونَ رِزۡقَكُمۡ أَنَّكُمۡ تُكَذِّبُونَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "فَلَوۡلَآ إِذَا بَلَغَتِ اِ۬لۡحُلۡقُومَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "وَأَنتُمۡ حِينَئِذٖ تَنظُرُونَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "وَنَحۡنُ أَقۡرَبُ إِلَيۡهِ مِنكُمۡ وَلَٰكِن لَّا تُبۡصِرُونَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "فَلَوۡلَآ إِن كُنتُمۡ غَيۡرَ مَدِينِينَ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "تَرۡجِعُونَهَآ إِن كُنتُمۡ صَٰدِقِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "فَأَمَّآ إِن كَانَ مِنَ اَ۬لۡمُقَرَّبِينَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "فَرَوۡحٞ وَرَيۡحَانٞ وَجَنَّتُ نَعِيمٖ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنۡ أَصۡحَٰبِ اِ۬لۡيَمِينِ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَسَلَٰمٞ لَّكَ مِنۡ أَصۡحَٰبِ اِ۬لۡيَمِينِ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنَ اَ۬لۡمُكَذِّبِينَ اَ۬لضَّآلِّينَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "فَنُزُلٞ مِّنۡ حَمِيمٖ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "وَتَصۡلِيَةُ جَحِيمٍ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "إِنَّ هَٰذَا لَهۡوَ حَقُّ اُ۬لۡيَقِينِ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "فَسَبِّحۡ بِاسۡمِ رَبِّكَ اَ۬لۡعَظِيمِ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "سُورَةُ الحَدِيدِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ سَبَّحَ لِلَّهِ مَا فِي اِ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِۖ وَهۡوَ اَ۬لۡعَزِيزُ اُ۬لۡحَكِيمُ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَهُۥ مُلۡكُ اُ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِۖ يُحۡيِۦ وَيُمِيتُۖ وَهۡوَ عَلَىٰ كُلِّ شَيۡءٖ قَدِيرٌ ٢",
      "numberInSurah": 2
    },
    {
      "text": "هُوَ اَ۬لۡأَوَّلُ وَاَلۡأٓخِرُ وَاَلظَّٰهِرُ وَاَلۡبَاطِنُۖ وَهۡوَ بِكُلِّ شَيۡءٍ عَلِيمٌ ٣",
      "numberInSurah": 3
    }
  ]
}
