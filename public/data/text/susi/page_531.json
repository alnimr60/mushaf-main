{
  "pageNumber": 531,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "وَمَا أَمۡرُنَا إِلَّا وَٰحِدَةٞ كَلَمۡحِۢ بِالۡبَصَرِ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَلَقَدۡ أَهۡلَكۡنَا أَشۡيَاعَكُمۡ فَهَلۡ مِن مُّدَّكِرٖ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "وَكُلُّ شَيۡءٖ فَعَلُوهُ فِي اِ۬لزُّبُرِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "وَكُلُّ صَغِيرٖ وَكَبِيرٖ مُّسۡتَطَرٌ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "إِنَّ اَ۬لۡمُتَّقِينَ فِي جَنَّٰتٖ وَنَهَرٖ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فِي مَقۡعَد صِّدۡقٍ عِندَ مَلِيكٖ مُّقۡتَدِرِۢ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "سُورَةُ الرَّحۡمَٰن بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ اِ۬لرَّحۡمَٰنُ عَلَّمَ اَ۬لۡقُرۡءَانَ ١",
      "numberInSurah": 1
    },
    {
      "text": "خَلَقَ اَ۬لۡإِنسَٰنَ عَلَّمَهُ اُ۬لۡبَيَانَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "اَ۬لشَّمۡسُ وَاَلۡقَمَرُ بِحُسۡبَانٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَاَلنَّجۡمُ وَاَلشَّجَرُ يَسۡجُدَانِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَاَلسَّمَآءَ رَفَعَهَا وَوَضَعَ اَ۬لۡمِيزَانَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَّا تَطۡغَوۡاْ فِي اِ۬لۡمِيزَانِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَأَقِيمُواْ اُ۬لۡوَزۡنَ بِالۡقِسۡطِ وَلَا تُخۡسِرُواْ اُ۬لۡمِيزَانَ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَاَلۡأَرۡضَ وَضَعَهَا لِلۡأَنَامِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فِيهَا فَٰكِهَةٞ وَاَلنَّخۡلُ ذَاتُ اُ۬لۡأَكۡمَامِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَاَلۡحَبُّ ذُو اُ۬لۡعَصۡفِ وَاَلرَّيۡحَانُ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "خَلَقَ اَ۬لۡإِنسَٰنَ مِن صَلۡصَٰلٖ كَاَلۡفَخّ۪ارِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَخَلَقَ اَ۬لۡجَآنَّ مِن مَّارِجٖ مِّن نّ۪ارٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "رَبُّ اُ۬لۡمَشۡرِقَيۡنِ وَرَبُّ اُ۬لۡمَغۡرِبَيۡنِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٦",
      "numberInSurah": 16
    }
  ]
}
