{
  "pageNumber": 591,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَاَلسَّمَآءِ وَاَلطَّارِقِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَمَا أَدۡر۪ىٰكَ مَا اَ۬لطَّارِقُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "اُ۬لنَّجۡمُ اُ۬لثَّاقِبُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِن كُلُّ نَفۡسٖ لَّمَا عَلَيۡهَا حَافِظٞ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَلۡيَنظُرِ اِ۬لۡإِنسَٰنُ مِمَّ خُلِقَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "خُلِقَ مِن مَّآءٖ دَافِقٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "يَخۡرُجُ مِنۢ بَيۡنِ اِ۬لصُّلۡبِ وَاَلتَّرَآئِبِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "يَوۡمَ تُبۡلَى اَ۬لسَّرَآئِرُ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَاَلسَّمَآءِ ذَاتِ اِ۬لرَّجۡعِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَاَلۡأَرۡضِ ذَاتِ اِ۬لصَّدۡعِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَمَا هُوَ بِالۡهَزۡلِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "إِنَّهُمۡ يَكِيدُونَ كَيۡدٗا وَأَكِيدُ كَيۡدٗا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَمَهِّلِ اِ۬لۡكٰ۪فِرِينَ أَمۡهِلۡهُمۡ رُوَيۡدَۢا ١٦",
      "numberInSurah": 16
    },
    {
      "text": "سُورَةُ الأَعۡلَىٰ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ سَبِّحِ اِ۪سۡمَ رَبِّكَ اَ۬لۡأَعۡلَى ١",
      "numberInSurah": 1
    },
    {
      "text": "اَ۬لَّذِي خَلَقَ فَسَوّۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَاَلَّذِي قَدَّرَ فَهَدۭيٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَاَلَّذِي أَخۡرَجَ اَ۬لۡمَرۡعۭيٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَجَعَلَهُۥ غُثَآءً أَحۡوۭيٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سَنُقۡرِئُكَ فَلَا تَنسۭيٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِلَّا مَا شَآءَ اَ۬للَّهُۚ إِنَّهُۥ يَعۡلَمُ اُ۬لۡجَهۡرَ وَمَا يَخۡفۭيٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَنُيَسِّرُكَ لِلۡيُسۡر۪يٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَذَكِّرۡ إِن نَّفَعَتِ اِ۬لذِّكۡر۪يٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "سَيَذَّكَّرُ مَن يَخۡشۭيٰ ١٠",
      "numberInSurah": 10
    }
  ]
}
