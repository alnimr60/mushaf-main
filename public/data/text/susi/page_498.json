{
  "pageNumber": 498,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "إِنَّ يَوۡمَ اَ۬لۡفَصۡلِ مِيقَٰتُهُمۡ أَجۡمَعِينَ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "يَوۡمَ لَا يُغۡنِي مَوۡلًى عَن مَّوۡلٗى شَيۡـٔٗا وَلَا هُمۡ يُنصَرُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِلَّا مَن رَّحِمَ اَ۬للَّهُۚ إِنَّه هُّوَ اَ۬لۡعَزِيزُ اُ۬لرَّحِيمُ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "إِنَّ شَجَرَتَ اَ۬لزَّقُّومِ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "طَعَامُ اُ۬لۡأَثِيمِ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "كَاَلۡمُهۡلِ تَغۡلِي فِي اِ۬لۡبُطُونِ كَغَلۡيِ اِ۬لۡحَمِيمِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "خُذُوهُ فَاَعۡتِلُوهُ إِلَىٰ سَوَآءِ اِ۬لۡجَحِيمِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "ثُمَّ صُبُّواْ فَوۡقَ رَاسِهِۦ مِنۡ عَذَابِ اِ۬لۡحَمِيمِ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "ذُقۡ إِنَّكَ أَنتَ اَ۬لۡعَزِيزُ اُ۬لۡكَرِيمُ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "إِنَّ اَ۬لۡمُتَّقِينَ فِي مَقَامٍ أَمِينٖ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "فِي جَنَّٰتٖ وَعُيُونٖ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "يَلۡبَسُونَ مِن سُندُسٖ وَإِسۡتَبۡرَقٖ مُّتَقَٰبِلِينَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "كَذَٰلِكَ وَزَوَّجۡنَٰهُم بِحُورٍ عِينٖ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "يَدۡعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "لَا يَذُوقُونَ فِيهَا اَ۬لۡمَوۡتَ إِلَّا اَ۬لۡمَوۡتَةَ اَ۬لۡأُولۭيٰۖ وَوَقَىٰهُمۡ عَذَابَ اَ۬لۡجَحِيمِ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَضۡلٗا مِّن رَّبِّكَۚ ذَٰلِكَ هُوَ اَ۬لۡفَوۡزُ اُ۬لۡعَظِيمُ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَإِنَّمَا يَسَّرۡنَٰهُ بِلِسَانِكَ لَعَلَّهُمۡ يَتَذَكَّرُونَ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فَاَرۡتَقِبۡ إِنَّهُم مُّرۡتَقِبُونَ ٥٦",
      "numberInSurah": 56
    }
  ]
}
