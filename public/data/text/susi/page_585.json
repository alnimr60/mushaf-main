{
  "pageNumber": 585,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "عَبَسَ وَتَوَلّۭيٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "أَن جَآءَهُ اُ۬لۡأَعۡمۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا يُدۡرِيكَ لَعَلَّهُۥ يَزَّكّۭيٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "أَوۡ يَذَّكَّرُ فَتَنفَعُهُ اُ۬لذِّكۡر۪يٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "أَمَّا مَنِ اِ۪سۡتَغۡنۭيٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَأَنتَ لَهُۥ تَصَدّۭيٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَمَا عَلَيۡكَ أَلَّا يَزَّكّۭيٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَأَمَّا مَن جَآءَكَ يَسۡعۭيٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَهۡوَ يَخۡشۭيٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَأَنتَ عَنۡهُ تَلَهّۭيٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَلَّا إِنَّهَا تَذۡكِرَةٞ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فِي صُحُفٖ مُّكَرَّمَةٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "مَّرۡفُوعَةٖ مُّطَهَّرَةِۢ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "بِأَيۡدِي سَفَرَةٖ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "كِرَامِۢ بَرَرَةٖ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "قُتِلَ اَ۬لۡإِنسَٰنُ مَا أَكۡفَرَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "مِنۡ أَيِّ شَيۡءٍ خَلَقَهُۥ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "ثُمَّ اَ۬لسَّبِيلَ يَسَّرَهُۥ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ إِذَا شَا أَنشَرَهُۥ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "كَلَّا لَمَّا يَقۡضِ مَا أَمَرَهُۥ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَلۡيَنظُرِ اِ۬لۡإِنسَٰنُ إِلَىٰ طَعَامِهِۦ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنَّا صَبَبۡنَا اَ۬لۡمَآءَ صَبّٗا ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "ثُمَّ شَقَقۡنَا اَ۬لۡأَرۡضَ شَقّٗا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "فَأَنۢبَتۡنَا فِيهَا حَبّٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَعِنَبٗا وَقَضۡبٗا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَزَيۡتُونٗا وَنَخۡلٗا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَحَدَآئِقَ غُلۡبٗا ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَفَٰكِهَةٗ وَأَبّٗا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "مَّتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لصَّآخَّةُ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "يَوۡمَ يَفِرُّ اُ۬لۡمَرۡءُ مِنۡ أَخِيهِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "وَأُمِّهِۦ وَأَبِيهِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لِكُلِّ اِ۪مۡرِيٕٖ مِّنۡهُمۡ يَوۡمَئِذٖ شَانٞ يُغۡنِيهِ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "۞وُجُوهٞ يَوۡمَئِذٖ مُّسۡفِرَةٞ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "ضَاحِكَةٞ مُّسۡتَبۡشِرَةٞ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "وَوُجُوهٞ يَوۡمَئِذٍ عَلَيۡهَا غَبَرَةٞ ٤٠",
      "numberInSurah": 40
    }
  ]
}
