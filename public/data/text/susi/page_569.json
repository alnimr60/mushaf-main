{
  "pageNumber": 569,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "يُبَصَّرُونَهُمۡۚ يَوَدُّ اُ۬لۡمُجۡرِمُ لَوۡ يَفۡتَدِي مِنۡ عَذَابِ يَوۡمِئِذِۢ بِبَنِيهِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَأَخِيهِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَفَصِيلَتِهِ اِ۬لَّتِي تُـٔۡوِيهِ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَمَن فِي اِ۬لۡأَرۡضِ جَمِيعٗا ثُمَّ يُنجِيهِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "كَلَّاۖ إِنَّهَا لَظۭيٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "نَزَّاعَةٞ لِّلشَّوۭيٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "تَدۡعُواْ مَنۡ أَدۡبَرَ وَتَوَلّۭيٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَجَمَعَ فَأَوۡعۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "إِنَّ اَ۬لۡإِنسَٰنَ خُلِقَ هَلُوعًا ١٩",
      "numberInSurah": 19
    },
    {
      "text": "إِذَا مَسَّهُ اُ۬لشَّرُّ جَزُوعٗا ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَإِذَا مَسَّهُ اُ۬لۡخَيۡرُ مَنُوعًا ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِلَّا اَ۬لۡمُصَلِّينَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "اَ۬لَّذِينَ هُمۡ عَلَىٰ صَلَاتِهِمۡ دَآئِمُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَاَلَّذِينَ فِي أَمۡوَٰلِهِمۡ حَقّٞ مَّعۡلُومٞ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "لِّلسَّآئِلِ وَاَلۡمَحۡرُومِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَاَلَّذِينَ يُصَدِّقُونَ بِيَوۡمِ اِ۬لدِّينِ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَاَلَّذِينَ هُم مِّنۡ عَذَابِ رَبِّهِم مُّشۡفِقُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "إِنَّ عَذَابَ رَبِّهِمۡ غَيۡرُ مَامُونٖ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَاَلَّذِينَ هُمۡ لِفُرُوجِهِمۡ حَٰفِظُونَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "إِلَّا عَلَىٰ أَزۡوَٰجِهِمۡ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ فَإِنَّهُمۡ غَيۡرُ مَلُومِينَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "فَمَنِ اِ۪بۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ اُ۬لۡعَادُونَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَاَلَّذِينَ هُمۡ لِأَمَٰنَٰتِهِمۡ وَعَهۡدِهِمۡ رَٰعُونَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَاَلَّذِينَ هُم بِشَهَٰدَتِهِمۡ قَآئِمُونَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَاَلَّذِينَ هُمۡ عَلَىٰ صَلَاتِهِمۡ يُحَافِظُونَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "أُوْلَٰٓئِكَ فِي جَنَّٰتٖ مُّكۡرَمُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَمَالِ اِ۬لَّذِينَ كَفَرُواْ قِبَلَكَ مُهۡطِعِينَ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "عَنِ اِ۬لۡيَمِينِ وَعَنِ اِ۬لشِّمَالِ عِزِينَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "أَيَطۡمَعُ كُلُّ اُ۪مۡرِيٕٖ مِّنۡهُمۡ أَن يُدۡخَلَ جَنَّةَ نَعِيمٖ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "كَلَّاۖ إِنَّا خَلَقۡنَٰهُم مِّمَّا يَعۡلَمُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "۞فَلَا أُقۡسِم بِرَبِّ اِ۬لۡمَشَٰرِقِ وَاَلۡمَغَٰرِبِ إِنَّا لَقَٰدِرُونَ ٤٠",
      "numberInSurah": 40
    }
  ]
}
