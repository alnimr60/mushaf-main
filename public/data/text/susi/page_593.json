{
  "pageNumber": 593,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَيُعَذِّبُهُ اُ۬للَّهُ اُ۬لۡعَذَابَ اَ۬لۡأَكۡبَرَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنَّ إِلَيۡنَا إِيَابَهُمۡ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيۡنَا حِسَابَهُم ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "سُورَةُ الفَجۡرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلۡفَجۡرِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَلَيَالٍ عَشۡرٖ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَاَلشَّفۡعِ وَاَلۡوَتۡرِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَاَلَّيۡلِ إِذَا يَسۡرِۦ ٤",
      "numberInSurah": 4
    },
    {
      "text": "هَلۡ فِي ذَٰلِك قَّسَمٞ لِّذِي حِجۡرٍ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَمۡ تَرَ كَيۡف فَّعَل رَّبُّكَ بِعَادٍ ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِرَمَ ذَاتِ اِ۬لۡعِمَادِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "اِ۬لَّتِي لَمۡ يُخۡلَقۡ مِثۡلُهَا فِي اِ۬لۡبِلَٰدِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَثَمُودَ اَ۬لَّذِينَ جَابُواْ اُ۬لصَّخۡرَ بِالۡوَادِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَفِرۡعَوۡنَ ذِي اِ۬لۡأَوۡتَادِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "اِ۬لَّذِينَ طَغَوۡاْ فِي اِ۬لۡبِلَٰدِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فَأَكۡثَرُواْ فِيهَا اَ۬لۡفَسَادَ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَصَبَّ عَلَيۡهِمۡ رَبُّكَ سَوۡطَ عَذَابٍ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّ رَبَّكَ لَبِالۡمِرۡصَادِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَأَمَّا اَ۬لۡإِنسَٰنُ إِذَا مَا اَ۪بۡتَلَىٰهُ رَبُّهُۥ فَأَكۡرَمَهُۥ وَنَعَّمَهُۥ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَيَقُول رَّبِّيَ أَكۡرَمَنِۦ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَأَمَّا إِذَا مَا اَ۪بۡتَلَىٰهُ فَقَدَرَ عَلَيۡهِ رِزۡقَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَيَقُول رَّبِّيَ أَهَٰنَنِۦ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "كَلَّاۖ بَل لَّا يُكۡرِمُونَ اَ۬لۡيَتِيمَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَلَا يَحُضُّونَ عَلَىٰ طَعَامِ اِ۬لۡمِسۡكِينِ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَيَاكُلُونَ اَ۬لتُّرَاثَ أَكۡلٗا لَّمّٗا ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَيُحِبُّونَ اَ۬لۡمَالَ حُبّٗا جَمّٗا ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "كَلَّاۖ إِذَا دُكَّتِ اِ۬لۡأَرۡضُ دَكّٗا دَكّٗا ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَجَآءَ رَبُّكَ وَاَلۡمَلَكُ صَفّٗا صَفّٗا ٢٤",
      "numberInSurah": 24
    }
  ]
}
