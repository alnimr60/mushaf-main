{
  "pageNumber": 526,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَاَلنَّجۡمِ إِذَا هَوۭيٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَا ضَلَّ صَاحِبُكُمۡ وَمَا غَوۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا يَنطِقُ عَنِ اِ۬لۡهَوۭيٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنۡ هُوَ إِلَّا وَحۡيٞ يُوحۭيٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "عَلَّمَهُۥ شَدِيدُ اُ۬لۡقُوۭيٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "ذُو مِرَّةٖ فَاَسۡتَوۭيٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَهۡوَ بِالۡأُفُقِ اِ۬لۡأَعۡلۭيٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "ثُمَّ دَنَا فَتَدَلّۭيٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَكَانَ قَابَ قَوۡسَيۡنِ أَوۡ أَدۡنۭيٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَأَوۡحَىٰ إِلَىٰ عَبۡدِهِۦ مَا أَوۡحۭيٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "مَا كَذَبَ اَ۬لۡفُؤَادُ مَا رَأ۪يٰ ١١",
      "numberInSurah": 11
    },
    {
      "text": "أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَر۪يٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَلَقَدۡ رَء۪اهُ نَزۡلَةً أُخۡر۪يٰ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "عِندَ سِدۡرَةِ اِ۬لۡمُنتَهۭيٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "عِندَهَا جَنَّةُ اُ۬لۡمَاوۭيٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "إِذۡ يَغۡشَى اَ۬لسِّدۡرَةَ مَا يَغۡشۭيٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "مَا زَاغَ اَ۬لۡبَصَرُ وَمَا طَغۭيٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "لَقَدۡ رَأ۪يٰ مِنۡ ءَايَٰتِ رَبِّهِ اِ۬لۡكُبۡر۪يٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "أَفَرَءَيۡتُمُ اُ۬للَّٰتَ وَاَلۡعُزّۭيٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَمَنَوٰةَ اَ۬لثَّالِثَةَ اَ۬لۡأُخۡر۪يٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "أَلَكُمُ اُ۬لذَّكَرُ وَلَهُ اُ۬لۡأُنثۭيٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "تِلۡكَ إِذٗا قِسۡمَةٞ ضِيزۭيٰ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "إِنۡ هِيَ إِلَّا أَسۡمَآءٞ سَمَّيۡتُمُوهَا أَنتُمۡ وَءَابَآؤُكُم مَّا أَنزَلَ اَ۬للَّهُ بِهَا مِن سُلۡطَٰنٍۚ إِن يَتَّبِعُونَ إِلَّا اَ۬لظَّنَّ وَمَا تَهۡوَى اَ۬لۡأَنفُسُۖ وَلَقَد جَّآءَهُم مِّن رَّبِّهِمِ اِ۬لۡهُدۭيٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "أَمۡ لِلۡإِنسَٰنِ مَا تَمَنّۭيٰ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَلِلَّهِ اِ۬لۡأٓخِرَةُ وَاَلۡأُولۭيٰ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "۞وَكَم مِّن مَّلَكٖ فِي اِ۬لسَّمَٰوَٰتِ لَا تُغۡنِي شَفَٰعَتُهُمۡ شَيۡـًٔا إِلَّا مِنۢ بَعۡدِ أَن يَاذَنَ اَ۬للَّهُ لِمَن يَشَآءُ وَيَرۡضۭيٰ ٢٦",
      "numberInSurah": 26
    }
  ]
}
