  "ayahs": [
    {
      "text": "مَرَجَ اَ۬لۡبَحۡرَيۡنِ يَلۡتَقِيَانِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "بَيۡنَهُمَا بَرۡزَخٞ لَّا يَبۡغِيَانِ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "يُخۡرَجُ مِنۡهُمَا اَ۬للُّولُؤُ وَاَلۡمَرۡجَانُ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَلَهُ اُ۬لۡجَوَارِ اِ۬لۡمُنشَـَٔاتُ فِي اِ۬لۡبَحۡرِ كَاَلۡأَعۡلَٰمِ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "كُلُّ مَنۡ عَلَيۡهَا فَانٖ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَيَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو اُ۬لۡجَلَٰلِ وَاَلۡإِكۡرَامِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَسۡـَٔلُهُۥ مَن فِي اِ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِۚ كُلَّ يَوۡمٍ هُوَ فِي شَانٖ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "سَنَفۡرُغُ لَكُمۡ أَيُّهَ اَ۬لثَّقَلَانِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "يَٰمَعۡشَرَ اَ۬لۡجِنِّ وَاَلۡإِنسِ إِنِ اِ۪سۡتَطَعۡتُمۡ أَن تَنفُذُواْ مِنۡ أَقۡط۪ارِ اِ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِ فَاَنفُذُواْۚ لَا تَنفُذُونَ إِلَّا بِسُلۡطَٰنٖ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "يُرۡسَلُ عَلَيۡكُمَا شُوَاظٞ مِّن نّ۪ارٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَنُحَاسٖ فَلَا تَنتَصِرَانِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَإِذَا اَ۪نشَقَّتِ اِ۬لسَّمَآءُ فَكَانَتۡ وَرۡدَةٗ كَاَلدِّهَانِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَيَوۡمَئِذٖ لَّا يُسۡـَٔلُ عَن ذَنۢبِهِۦ إِنسٞ وَلَا جَآنّٞ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "۞يُعۡرَفُ اُ۬لۡمُجۡرِمُونَ بِسِيمٰۭهُمۡ فَيُوخَذُ بِالنَّوَٰصِي وَاَلۡأَقۡدَامِ ٤٠",
      "numberInSurah": 40
    }
  ]
