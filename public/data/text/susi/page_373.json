{
  "pageNumber": 373,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "إِنۡ هَٰذَا إِلَّا خَلۡقُ اُ۬لۡأَوَّلِينَ ١٣٧",
      "numberInSurah": 137
    },
    {
      "text": "وَمَا نَحۡنُ بِمُعَذَّبِينَ ١٣٨",
      "numberInSurah": 138
    },
    {
      "text": "فَكَذَّبُوهُ فَأَهۡلَكۡنَٰهُمۡۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّومِنِينَ ١٣٩",
      "numberInSurah": 139
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهۡوَ اَ۬لۡعَزِيزُ اُ۬لرَّحِيمُ ١٤٠",
      "numberInSurah": 140
    },
    {
      "text": "كَذَّبَت ثَّمُودُ اُ۬لۡمُرۡسَلِينَ ١٤١",
      "numberInSurah": 141
    },
    {
      "text": "إِذۡ قَال لَّهُمۡ أَخُوهُمۡ صَٰلِحٌ أَلَا تَتَّقُونَ ١٤٢",
      "numberInSurah": 142
    },
    {
      "text": "إِنِّي لَكُمۡ رَسُولٌ أَمِينٞ ١٤٣",
      "numberInSurah": 143
    },
    {
      "text": "فَاَتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِ ١٤٤",
      "numberInSurah": 144
    },
    {
      "text": "وَمَا أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيَ إِلَّا عَلَىٰ رَبِّ اِ۬لۡعَٰلَمِينَ ١٤٥",
      "numberInSurah": 145
    },
    {
      "text": "۞أَتُتۡرَكُونَ فِي مَا هَٰهُنَا ءَامِنِينَ ١٤٦",
      "numberInSurah": 146
    },
    {
      "text": "فِي جَنَّٰتٖ وَعُيُونٖ ١٤٧",
      "numberInSurah": 147
    },
    {
      "text": "وَزُرُوعٖ وَنَخۡلٖ طَلۡعُهَا هَضِيمٞ ١٤٨",
      "numberInSurah": 148
    },
    {
      "text": "وَتَنۡحِتُونَ مِنَ اَ۬لۡجِبَالِ بُيُوتٗا فَرِهِينَ ١٤٩",
      "numberInSurah": 149
    },
    {
      "text": "فَاَتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِ ١٥٠",
      "numberInSurah": 150
    },
    {
      "text": "وَلَا تُطِيعُواْ أَمۡرَ اَ۬لۡمُسۡرِفِينَ ١٥١",
      "numberInSurah": 151
    },
    {
      "text": "اَ۬لَّذِينَ يُفۡسِدُونَ فِي اِ۬لۡأَرۡضِ وَلَا يُصۡلِحُونَ ١٥٢",
      "numberInSurah": 152
    },
    {
      "text": "قَالُواْ إِنَّمَا أَنتَ مِنَ اَ۬لۡمُسَحَّرِينَ ١٥٣",
      "numberInSurah": 153
    },
    {
      "text": "مَا أَنتَ إِلَّا بَشَرٞ مِّثۡلُنَا فَاتِ بِـَٔايَةٍ إِن كُنتَ مِنَ اَ۬لصَّٰدِقِينَ ١٥٤",
      "numberInSurah": 154
    },
    {
      "text": "قَالَ هَٰذِهِۦ نَاقَةٞ لَّهَا شِرۡبٞ وَلَكُمۡ شِرۡبُ يَوۡمٖ مَّعۡلُومٖ ١٥٥",
      "numberInSurah": 155
    },
    {
      "text": "وَلَا تَمَسُّوهَا بِسُوٓءٖ فَيَاخُذَكُمۡ عَذَابُ يَوۡمٍ عَظِيمٖ ١٥٦",
      "numberInSurah": 156
    },
    {
      "text": "فَعَقَرُوهَا فَأَصۡبَحُواْ نَٰدِمِينَ ١٥٧",
      "numberInSurah": 157
    },
    {
      "text": "فَأَخَذَهُمُ اُ۬لۡعَذَابُۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّومِنِينَ ١٥٨",
      "numberInSurah": 158
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهۡوَ اَ۬لۡعَزِيزُ اُ۬لرَّحِيمُ ١٥٩",
      "numberInSurah": 159
    }
  ]
}
