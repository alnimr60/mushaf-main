{
  "pageNumber": 601,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَاَلۡعَصۡرِ ١",
      "numberInSurah": 1
    },
    {
      "text": "إِنَّ اَ۬لۡإِنسَٰنَ لَفِي خُسۡرٍ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِلَّا اَ۬لَّذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ وَتَوَاصَوۡاْ بِالۡحَقِّ وَتَوَاصَوۡاْ بِالصَّبۡرِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "سُورَةُ الهُمَزَةِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ ١",
      "numberInSurah": 1
    },
    {
      "text": "اِ۬لَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ ٢",
      "numberInSurah": 2
    },
    {
      "text": "يَحۡسِبُ أَنَّ مَالَهُۥ أَخۡلَدَهُۥ ٣",
      "numberInSurah": 3
    },
    {
      "text": "كَلَّاۖ لَيُنۢبَذَنَّ فِي اِ۬لۡحُطَمَةِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَمَا أَدۡر۪ىٰكَ مَا اَ۬لۡحُطَمَةُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "نَارُ اُ۬للَّهِ اِ۬لۡمُوقَدَةُ ٦",
      "numberInSurah": 6
    },
    {
      "text": "اُ۬لَّتِي تَطَّلِع عَّلَى اَ۬لۡأَفۡـِٔدَةِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّهَا عَلَيۡهِم مُّؤۡصَدَةٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فِي عَمَدٖ مُّمَدَّدَةِۢ ٩",
      "numberInSurah": 9
    },
    {
      "text": "سُورَةُ الفِيلِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ أَلَمۡ تَرَ كَيۡف فَّعَل رَّبُّكَ بِأَصۡحَٰبِ اِ۬لۡفِيلِ ١",
      "numberInSurah": 1
    },
    {
      "text": "أَلَمۡ يَجۡعَلۡ كَيۡدَهُمۡ فِي تَضۡلِيلٖ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَأَرۡسَلَ عَلَيۡهِمۡ طَيۡرًا أَبَابِيلَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "تَرۡمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَجَعَلَهُمۡ كَعَصۡفٖ مَّاكُولِۢ ٥",
      "numberInSurah": 5
    }
  ]
}
