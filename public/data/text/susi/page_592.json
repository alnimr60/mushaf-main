{
  "pageNumber": 592,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "وَيَتَجَنَّبُهَا اَ۬لۡأَشۡقَى ١١",
      "numberInSurah": 11
    },
    {
      "text": "اَ۬لَّذِي يَصۡلَى اَ۬لنَّارَ اَ۬لۡكُبۡر۪يٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحۡيۭيٰ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "قَدۡ أَفۡلَحَ مَن تَزَكّۭيٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَذَكَرَ اَ۪سۡمَ رَبِّهِۦ فَصَلّۭيٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "بَلۡ يُوثِرُونَ اَ۬لۡحَيَوٰةَ اَ۬لدُّنۡيۭا ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَاَلۡأٓخِرَةُ خَيۡرٞ وَأَبۡقۭيٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "إِنَّ هَٰذَا لَفِي اِ۬لصُّحُفِ اِ۬لۡأُولۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "صُحُفِ إِبۡرَٰهِيمَ وَمُوسۭيٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "سُورَةُ الغَاشِيَةِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ هَلۡ أَتَىٰكَ حَدِيثُ اُ۬لۡغَٰشِيَةِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وُجُوهٞ يَوۡمَئِذٍ خَٰشِعَةٌ ٢",
      "numberInSurah": 2
    },
    {
      "text": "عَامِلَةٞ نَّاصِبَةٞ ٣",
      "numberInSurah": 3
    },
    {
      "text": "تُصۡلَىٰ نَارًا حَامِيَةٗ ٤",
      "numberInSurah": 4
    },
    {
      "text": "تُسۡقَىٰ مِنۡ عَيۡنٍ ءَانِيَةٖ ٥",
      "numberInSurah": 5
    },
    {
      "text": "لَّيۡسَ لَهُمۡ طَعَامٌ إِلَّا مِن ضَرِيعٖ ٦",
      "numberInSurah": 6
    },
    {
      "text": "لَّا يُسۡمِنُ وَلَا يُغۡنِي مِن جُوعٖ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وُجُوهٞ يَوۡمَئِذٖ نَّاعِمَةٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "لِّسَعۡيِهَا رَاضِيَةٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فِي جَنَّةٍ عَالِيَةٖ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "لَّا يُسۡمَعُ فِيهَا لَٰغِيَةٞ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فِيهَا عَيۡنٞ جَارِيَةٞ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فِيهَا سُرُرٞ مَّرۡفُوعَةٞ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَأَكۡوَابٞ مَّوۡضُوعَةٞ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَنَمَارِقُ مَصۡفُوفَةٞ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَزَرَابِيُّ مَبۡثُوثَةٌ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "أَفَلَا يَنظُرُونَ إِلَى اَ۬لۡإِبِلِ كَيۡفَ خُلِقَتۡ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَإِلَى اَ۬لسَّمَآءِ كَيۡفَ رُفِعَتۡ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَإِلَى اَ۬لۡجِبَالِ كَيۡفَ نُصِبَتۡ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَإِلَى اَ۬لۡأَرۡضِ كَيۡفَ سُطِحَتۡ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَذَكِّرۡ إِنَّمَا أَنتَ مُذَكِّرٞ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "لَّسۡتَ عَلَيۡهِم بِمُصَيۡطِرٍ ٢٢",
      "numberInSurah": 22
    }
  ]
}
