{
  "pageNumber": 313,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "وَأَنَا اَ۪خۡتَرۡتُكَ فَاَسۡتَمِعۡ لِمَا يُوحۭيٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّنِيَ أَنَا اَ۬للَّهُ لَا إِلَٰهَ إِلَّا أَنَا۠ فَاَعۡبُدۡنِي وَأَقِمِ اِ۬لصَّلَوٰةَ لِذِكۡرِيَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّ اَ۬لسَّاعَةَ ءَاتِيَةٌ أَكَادُ أُخۡفِيهَا لِتُجۡزَىٰ كُلُّ نَفۡسِۢ بِمَا تَسۡعۭيٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَلَا يَصُدَّنَّكَ عَنۡهَا مَن لَّا يُومِنُ بِهَا وَاَتَّبَعَ هَوَىٰهُ فَتَرۡدۭيٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَمَا تِلۡكَ بِيَمِينِكَ يَٰمُوسۭيٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "قَالَ هِيَ عَصَايَ أَتَوَكَّؤُاْ عَلَيۡهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِي وَلِي فِيهَا مَـَٔارِبُ أُخۡر۪يٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "قَالَ أَلۡقِهَا يَٰمُوسۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "فَأَلۡقَىٰهَا فَإِذَا هِيَ حَيَّةٞ تَسۡعۭيٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "قَالَ خُذۡهَا وَلَا تَخَفۡۖ سَنُعِيدُهَا سِيرَتَهَا اَ۬لۡأُولۭيٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَاَضۡمُمۡ يَدَكَ إِلَىٰ جَنَاحِكَ تَخۡرُجۡ بَيۡضَآءَ مِنۡ غَيۡرِ سُوٓءٍ ءَايَةً أُخۡر۪يٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "لِنُرِيَكَ مِنۡ ءَايَٰتِنَا اَ۬لۡكُبۡرَى ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "اَ۪ذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغۭيٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "قَال رَّبِّ اِ۪شۡرَحۡ لِي صَدۡرِي ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَيَسِّر لِّيَ أَمۡرِي ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَاَحۡلُلۡ عُقۡدَةٗ مِّن لِّسَانِي ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَفۡقَهُواْ قَوۡلِي ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَاَجۡعَل لِّي وَزِيرٗا مِّنۡ أَهۡلِي ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "هَٰرُونَ أَخِيَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "اَ۟شۡدُدۡ بِهِۦ أَزۡرِي ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَأَشۡرِكۡهُ فِي أَمۡرِي ٣١",
      "numberInSurah": 31
    },
    {
      "text": "كَيۡ نُسَبِّحَك كَّثِيرٗا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَنَذۡكُرَك كَّثِيرًا ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "إِنَّك كُّنتَ بِنَا بَصِيرٗا ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "۞قَالَ قَدۡ أُوتِيتَ سُولَكَ يَٰمُوسۭيٰ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَلَقَدۡ مَنَنَّا عَلَيۡكَ مَرَّةً أُخۡر۪يٰ ٣٦",
      "numberInSurah": 36
    }
  ]
}
