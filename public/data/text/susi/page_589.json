{
  "pageNumber": 589,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "فَاَلۡيَوۡمَ اَ۬لَّذِينَ ءَامَنُواْ مِنَ اَ۬لۡكُفّ۪ارِ يَضۡحَكُونَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "عَلَى اَ۬لۡأَرَآئِكِ يَنظُرُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "هَلۡ ثُوِّبَ اَ۬لۡكُفَّارُ مَا كَانُواْ يَفۡعَلُونَ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "سُورَةُ الانشِقَاقِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ إِذَا اَ۬لسَّمَآءُ اُ۪نشَقَّتۡ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا اَ۬لۡأَرۡضُ مُدَّتۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَأَلۡقَتۡ مَا فِيهَا وَتَخَلَّتۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَأَذِنَتۡ لِرَبِّهَا وَحُقَّتۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَٰأَيُّهَا اَ۬لۡإِنسَٰنُ إِنَّك كَّادِحٌ إِلَىٰ رَبِّك كَّدۡحٗا فَمُلَٰقِيهِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَسَوۡفَ يُحَاسَبُ حِسَابٗا يَسِيرٗا ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَيَنقَلِبُ إِلَىٰ أَهۡلِهِۦ مَسۡرُورٗا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَأَمَّا مَنۡ أُوتِيَ كِتَٰبَهُۥ وَرَآءَ ظَهۡرِهِۦ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَسَوۡفَ يَدۡعُواْ ثُبُورٗا ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَيَصۡلَىٰ سَعِيرًا ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّهُۥ كَانَ فِي أَهۡلِهِۦ مَسۡرُورًا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّهُۥ ظَنَّ أَن لَّن يَحُورَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "بَلَىٰۚ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيرٗا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "۞فَلَا أُقۡسِم بِالشَّفَقِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَاَلَّيۡلِ وَمَا وَسَقَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَاَلۡقَمَرِ إِذَا اَ۪تَّسَقَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "لَتَرۡكَبُنَّ طَبَقًا عَن طَبَقٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَمَا لَهُمۡ لَا يُومِنُونَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَإِذَا قُرِئَ عَلَيۡهِمِ اِ۬لۡقُرۡءَانُ لَا يَسۡجُدُونَۤ۩ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "بَلِ اِ۬لَّذِينَ كَفَرُواْ يُكَذِّبُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَاَللَّهُ أَعۡلَم بِمَا يُوعُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَبَشِّرۡهُم بِعَذَابٍ أَلِيمٍ ٢٤",
      "numberInSurah": 24
    }
  ]
}
