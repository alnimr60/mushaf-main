  "ayahs": [
    {
      "text": "وَاَلَّذِينَ كَفَرُواْ بِـَٔايَٰتِنَا هُمۡ أَصۡحَٰبُ اُ۬لۡمَشۡـَٔمَةِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "عَلَيۡهِمۡ نَارٞ مُّؤۡصَدَةُۢ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "سُورَةُ الشَّمۡسِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلشَّمۡسِ وَضُحۭىٰهَا ١",
      "numberInSurah": 1
    },
    {
      "text": "وَاَلۡقَمَرِ إِذَا تَلۭىٰهَا ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَاَلنَّه۪ارِ إِذَا جَلّۭىٰهَا ٣",
