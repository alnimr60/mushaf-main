    },
    {
      "text": "وَاَلَّيۡلِ إِذَا يَغۡشۭىٰهَا ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَاَلسَّمَآءِ وَمَا بَنۭىٰهَا ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَاَلۡأَرۡضِ وَمَا طَحۭىٰهَا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَنَفۡسٖ وَمَا سَوّۭىٰهَا ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَأَلۡهَمَهَا فُجُورَهَا وَتَقۡوۭىٰهَا ٨",
      "numberInSurah": 8
    },
    {
      "text": "قَدۡ أَفۡلَحَ مَن زَكّۭىٰهَا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَقَدۡ خَابَ مَن دَسّۭىٰهَا ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَذَّبَت ثَّمُودُ بِطَغۡوۭىٰهَا ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِذِ اِ۪نۢبَعَثَ أَشۡقۭىٰهَا ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَقَال لَّهُمۡ رَسُولُ اُ۬للَّهِ نَاقَةَ اَ۬للَّهِ وَسُقۡيٰۭهَا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَكَذَّبُوهُ فَعَقَرُوهَا ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَدَمۡدَمَ عَلَيۡهِمۡ رَبُّهُم بِذَنۢبِهِمۡ فَسَوّۭىٰهَا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَلَا يَخَافُ عُقۡبٰۭهَا ١٦",
      "numberInSurah": 16
    },
    {
      "text": "سُورَةُ اللَّيۡلِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلَّيۡلِ إِذَا يَغۡشۭيٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَاَلنَّه۪ارِ إِذَا تَجَلّۭيٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا خَلَقَ اَ۬لذَّكَرَ وَاَلۡأُنثۭيٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنَّ سَعۡيَكُمۡ لَشَتّۭيٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَأَمَّا مَنۡ أَعۡطَىٰ وَاَتَّقۭيٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَصَدَّقَ بِالۡحُسۡنۭيٰ ٦",
      "numberInSurah": 6
