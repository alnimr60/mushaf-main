{
  "pageNumber": 449,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "وَجَعَلۡنَا ذُرِّيَّتَه هُّمُ اُ۬لۡبَاقِينَ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِ فِي اِ۬لۡأٓخِرِينَ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "سَلَٰمٌ عَلَىٰ نُوحٖ فِي اِ۬لۡعَٰلَمِينَ ٧٩",
      "numberInSurah": 79
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي اِ۬لۡمُحۡسِنِينَ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "إِنَّهُۥ مِنۡ عِبَادِنَا اَ۬لۡمُومِنِينَ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "ثُمَّ أَغۡرَقۡنَا اَ۬لۡأٓخَرِينَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبۡرَٰهِيمَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "إِذ جَّآءَ رَبَّهُۥ بِقَلۡبٖ سَلِيمٍ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "إِذۡ قَال لِّأَبِيهِ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "أَٰى۪فۡكًا ءَالِهَةٗ دُونَ اَ۬للَّهِ تُرِيدُونَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "فَمَا ظَنُّكُم بِرَبِّ اِ۬لۡعَٰلَمِينَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "فَنَظَرَ نَظۡرَةٗ فِي اِ۬لنُّجُومِ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "فَقَالَ إِنِّي سَقِيمٞ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "فَتَوَلَّوۡاْ عَنۡهُ مُدۡبِرِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "فَرَاغَ إِلَىٰ ءَالِهَتِهِمۡ فَقَالَ أَلَا تَاكُلُونَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "مَا لَكُمۡ لَا تَنطِقُونَ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "فَرَاغَ عَلَيۡهِمۡ ضَرۡبَۢا بِالۡيَمِينِ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَأَقۡبَلُواْ إِلَيۡهِ يَزِفُّونَ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "وَاَللَّهُ خَلَقكُّمۡ وَمَا تَعۡمَلُونَ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "قَالُواْ اُ۪بۡنُواْ لَهُۥ بُنۡيَٰنٗا فَأَلۡقُوهُ فِي اِ۬لۡجَحِيمِ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "فَأَرَادُواْ بِهِۦ كَيۡدٗا فَجَعَلۡنَٰهُمُ اُ۬لۡأَسۡفَلِينَ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "وَقَالَ إِنِّي ذَاهِبٌ إِلَىٰ رَبِّي سَيَهۡدِينِ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "رَبِّ هَبۡ لِي مِنَ اَ۬لصَّٰلِحِينَ ١٠٠",
      "numberInSurah": 100
    },
    {
      "text": "فَبَشَّرۡنَٰهُ بِغُلَٰمٍ حَلِيمٖ ١٠١",
      "numberInSurah": 101
    },
    {
      "text": "فَلَمَّا بَلَغَ مَعَهُ اُ۬لسَّعۡيَ قَالَ يَٰبُنَيِّ إِنِّيَ أَر۪يٰ فِي اِ۬لۡمَنَامِ أَنِّيَ أَذۡبَحُكَ فَاَنظُرۡ مَاذَا تَر۪يٰۚ قَالَ يَٰأَبَتِ اِ۪فۡعَلۡ مَا تُومَرُۖ سَتَجِدُنِي إِن شَآءَ اَ۬للَّهُ مِنَ اَ۬لصَّٰبِرِينَ ١٠٢",
      "numberInSurah": 102
    }
  ]
}
