  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "إِنَّ لِلۡمُتَّقِينَ مَفَازًا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "حَدَآئِقَ وَأَعۡنَٰبٗا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَكَوَاعِبَ أَتۡرَابٗا ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَكَاسٗا دِهَاقٗا ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "لَّا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا كِذَّٰبٗا ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "جَزَآءٗ مِّن رَّبِّكَ عَطَآءً حِسَابٗا ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "رَّبُّ اُ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِ وَمَا بَيۡنَهُمَا اَ۬لرَّحۡمَٰنُۖ لَا يَمۡلِكُونَ مِنۡهُ خِطَابٗا ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "يَوۡمَ يَقُومُ اُ۬لرُّوحُ وَاَلۡمَلَٰٓئِكَة صَّفّٗاۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنۡ أَذِن لَّهُ اُ۬لرَّحۡمَٰنُ وَقَالَ صَوَابٗا ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "ذَٰلِكَ اَ۬لۡيَوۡمُ اُ۬لۡحَقُّۖ فَمَن شَآءَ اَ۪تَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِنَّا أَنذَرۡنَٰكُمۡ عَذَابٗا قَرِيبٗا يَوۡمَ يَنظُرُ اُ۬لۡمَرۡءُ مَا قَدَّمَتۡ يَدَاهُ وَيَقُولُ اُ۬لۡكَافِرُ يَٰلَيۡتَنِي كُنتُ تُرَٰبَۢا ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "سُورَةُ النَّازِعَاتِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلنَّٰزِعَٰتِ غَرۡقٗا ١",
      "numberInSurah": 1
    },
    {
      "text": "وَاَلنَّٰشِطَٰتِ نَشۡطٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَاَلسَّٰبِحَٰت سَّبۡحٗا ٣",
      "numberInSurah": 3
    },
    {
      "text": "فَاَلسَّٰبِقَٰت سَّبۡقٗا ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَاَلۡمُدَبِّرَٰتِ أَمۡرٗا ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَوۡمَ تَرۡجُفُ اُ۬لرَّاجِفَة ٦",
      "numberInSurah": 6
    },
    {
      "text": "تَّتۡبَعُهَا اَ۬لرَّادِفَةُ ٧",
      "numberInSurah": 7
    },
    {
      "text": "قُلُوبٞ يَوۡمَئِذٖ وَاجِفَةٌ ٨",
      "numberInSurah": 8
    },
    {
      "text": "أَبۡصَٰرُهَا خَٰشِعَةٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "يَقُولُونَ أَٰ۟نَّا لَمَرۡدُودُونَ فِي اِ۬لۡحَافِرَةِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "أَٰ۟ذَا كُنَّا عِظَٰمٗا نَّخِرَةٗ ١١",
      "numberInSurah": 11
    },
    {
      "text": "قَالُواْ تِلۡكَ إِذٗا كَرَّةٌ خَاسِرَةٞ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَإِذَا هُم بِالسَّاهِرَةِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ مُوسۭيٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "إِذۡ نَادَىٰهُ رَبُّهُۥ بِالۡوَادِ اِ۬لۡمُقَدَّسِ طُوَى ١٦",
      "numberInSurah": 16
    }
  ]
}
