  "pageNumber": 604,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قُلۡ هُوَ اَ۬للَّهُ أَحَدٌ ١",
      "numberInSurah": 1
    },
    {
      "text": "اِ۬للَّهُ اُ۬لصَّمَدُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَمۡ يَكُن لَّهُۥ كُفُؤًا أَحَدُۢ ٤",
      "numberInSurah": 4
    },
    {
      "text": "سُورَةُ الفَلَقِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ اِ۬لۡفَلَقِ ١",
      "numberInSurah": 1
    },
    {
      "text": "مِن شَرِّ مَا خَلَقَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَمِن شَرِّ اِ۬لنَّفَّٰثَٰتِ فِي اِ۬لۡعُقَدِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سُورَةُ النَّاسِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ اِ۬لنَّاسِ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَلِكِ اِ۬لنَّاسِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِلَٰهِ اِ۬لنَّاسِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "مِن شَرِّ اِ۬لۡوَسۡوَاسِ اِ۬لۡخَنَّاسِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "اِ۬لَّذِي يُوَسۡوِسُ فِي صُدُورِ اِ۬لنَّاسِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "مِنَ اَ۬لۡجِنَّةِ وَاَلنَّاسِ ٦",
      "numberInSurah": 6
    }
  ]
}
