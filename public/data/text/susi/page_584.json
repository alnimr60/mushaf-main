{
  "pageNumber": 584,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "اَ۪ذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغۭيٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَقُلۡ هَل لَّكَ إِلَىٰ أَن تَزَكّۭيٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَأَهۡدِيَكَ إِلَىٰ رَبِّكَ فَتَخۡشۭيٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَأَر۪ىٰهُ اُ۬لۡأٓيَةَ اَ۬لۡكُبۡر۪يٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَكَذَّبَ وَعَصۭيٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ أَدۡبَرَ يَسۡعۭيٰ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَحَشَرَ فَنَادۭيٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ اُ۬لۡأَعۡلۭيٰ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَأَخَذَهُ اُ۬للَّهُ نَكَالَ اَ۬لۡأٓخِرَةِ وَاَلۡأُولۭيٰ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَعِبۡرَةٗ لِّمَن يَخۡشۭيٰ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "ءَٰا۬نتُمۡ أَشَدُّ خَلۡقًا أَمِ اِ۬لسَّمَآءُۚ بَنۭىٰهَا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "رَفَعَ سَمۡكَهَا فَسَوّۭىٰهَا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَأَغۡطَشَ لَيۡلَهَا وَأَخۡرَجَ ضُحۭىٰهَا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَاَلۡأَرۡضَ بَعۡدَ ذَٰلِكَ دَحۭىٰهَا ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "أَخۡرَجَ مِنۡهَا مَآءَهَا وَمَرۡعۭىٰهَا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَاَلۡجِبَالَ أَرۡسۭىٰهَا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "مَتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لطَّآمَّةُ اُ۬لۡكُبۡر۪يٰ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "يَوۡمَ يَتَذَكَّرُ اُ۬لۡإِنسَٰنُ مَا سَعۭيٰ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَبُرِّزَتِ اِ۬لۡجَحِيمُ لِمَن يَر۪يٰ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَأَمَّا مَن طَغَىٰ وَءَاثَرَ اَ۬لۡحَيَوٰةَ اَ۬لدُّنۡيۭا ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَإِنَّ اَ۬لۡجَحِيمَ هِيَ اَ۬لۡمَاوۭيٰ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَأَمَّا مَنۡ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى اَ۬لنَّفۡسَ عَنِ اِ۬لۡهَوۭيٰ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فَإِنَّ اَ۬لۡجَنَّةَ هِيَ اَ۬لۡمَاوۭيٰ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "۞يَسۡـَٔلُونَكَ عَنِ اِ۬لسَّاعَةِ أَيَّانَ مُرۡسۭىٰهَا ٤١",
      "numberInSurah": 41
    },
    {
      "text": "فِيمَ أَنتَ مِن ذِكۡر۪ىٰهَا ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "إِلَىٰ رَبِّكَ مُنتَهۭىٰهَا ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "إِنَّمَا أَنتَ مُنذِرُ مَن يَخۡشۭىٰهَا ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "كَأَنَّهُمۡ يَوۡمَ يَرَوۡنَهَا لَمۡ يَلۡبَثُواْ إِلَّا عَشِيَّةً أَوۡ ضُحۭىٰهَا ٤٥",
      "numberInSurah": 45
    }
  ]
}
