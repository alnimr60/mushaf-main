  "ayahs": [
    {
      "text": "إِلَّا اَ۬لَّذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمۡ أَجۡرٌ غَيۡرُ مَمۡنُونِۢ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "سُورَةُ البُرُوجِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ وَاَلسَّمَآءِ ذَاتِ اِ۬لۡبُرُوجِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَاَلۡيَوۡمِ اِ۬لۡمَوۡعُودِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَشَاهِدٖ وَمَشۡهُودٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "قُتِلَ أَصۡحَٰبُ اُ۬لۡأُخۡدُودِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "اِ۬لنّ۪ارِ ذَاتِ اِ۬لۡوَقُودِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِذۡ هُمۡ عَلَيۡهَا قُعُودٞ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَهُمۡ عَلَىٰ مَا يَفۡعَلُونَ بِالۡمُومِنِينَ شُهُودٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَمَا نَقَمُواْ مِنۡهُمۡ إِلَّا أَن يُومِنُواْ بِاللَّهِ اِ۬لۡعَزِيزِ اِ۬لۡحَمِيدِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "اِ۬لَّذِي لَهُۥ مُلۡكُ اُ۬لسَّمَٰوَٰتِ وَاَلۡأَرۡضِۚ وَاَللَّهُ عَلَىٰ كُلِّ شَيۡءٖ شَهِيدٌ ٩",
      "numberInSurah": 9
    },
    {
      "text": "إِنَّ اَ۬لَّذِينَ فَتَنُواْ اُ۬لۡمُومِنِينَ وَاَلۡمُومِنَٰت ثُّمَّ لَمۡ يَتُوبُواْ فَلَهُمۡ عَذَابُ جَهَنَّمَ وَلَهُمۡ عَذَابُ اُ۬لۡحَرِيقِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "إِنَّ اَ۬لَّذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمۡ جَنَّٰتٞ تَجۡرِي مِن تَحۡتِهَا اَ۬لۡأَنۡهَٰرُۚ ذَٰلِكَ اَ۬لۡفَوۡزُ اُ۬لۡكَبِيرُ ١١",
      "numberInSurah": 11
    },
    {
      "text": "۞إِنَّ بَطۡشَ رَبِّكَ لَشَدِيدٌ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّه هُّوَ يُبۡدِئُ وَيُعِيدُ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَهۡوَ اَ۬لۡغَفُورُ اُ۬لۡوَدُود ١٤",
      "numberInSurah": 14
    },
    {
      "text": "ذُّو اُ۬لۡعَرۡشِ اِ۬لۡمَجِيدُ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَعَّالٞ لِّمَا يُرِيدُ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ اُ۬لۡجُنُودِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فِرۡعَوۡنَ وَثَمُودَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "بَلِ اِ۬لَّذِينَ كَفَرُواْ فِي تَكۡذِيبٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَاَللَّهُ مِن وَرَآئِهِم مُّحِيطُۢ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "بَلۡ هُوَ قُرۡءَانٞ مَّجِيدٞ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "فِي لَوۡحٖ مَّحۡفُوظِۢ ٢٢",
