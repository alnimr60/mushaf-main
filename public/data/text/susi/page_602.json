  "pageNumber": 602,
  "riwayaId": "susi",
  "ayahs": [
    {
      "text": "بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "لِإِيلَٰفِ قُرَيۡشٍ ١",
      "numberInSurah": 1
    },
    {
      "text": "إِۦلَٰفِهِمۡ رِحۡلَةَ اَ۬لشِّتَآءِ وَاَلصَّيۡف ٢",
      "numberInSurah": 2
    },
    {
      "text": "فَّلۡيَعۡبُدُواْ رَبَّ هَٰذَا اَ۬لۡبَيۡتِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "اِ۬لَّذِي أَطۡعَمَهُم مِّن جُوعٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَءَامَنَهُم مِّنۡ خَوۡفِۢ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سُورَةُ المَاعُونِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ أَرَءَيۡتَ اَ۬لَّذِي يُكَذِّب بِّالدِّينِ ١",
      "numberInSurah": 1
    },
    {
      "text": "فَذَٰلِكَ اَ۬لَّذِي يَدُعُّ اُ۬لۡيَتِيمَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَلَا يَحُضُّ عَلَىٰ طَعَامِ اِ۬لۡمِسۡكِينِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "فَوَيۡلٞ لِّلۡمُصَلِّينَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "اَ۬لَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "اَ۬لَّذِينَ هُمۡ يُرَآءُونَ وَيَمۡنَعُونَ اَ۬لۡمَاعُونَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "سُورَةُ الكَوثَرِ بِسۡمِ اِ۬للَّهِ اِ۬لرَّحۡمَٰنِ اِ۬لرَّحِيمِ إِنَّا أَعۡطَيۡنَٰكَ اَ۬لۡكَوۡثَرَ ١",
      "numberInSurah": 1
    },
    {
      "text": "فَصَلِّ لِرَبِّكَ وَاَنۡحَرۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِنَّ شَانِئَكَ هُوَ اَ۬لۡأَبۡتَرُ ٣",
      "numberInSurah": 3
    }
  ]
}
