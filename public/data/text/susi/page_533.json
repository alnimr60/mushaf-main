    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "هَلۡ جَزَآءُ اُ۬لۡإِحۡسَٰنِ إِلَّا اَ۬لۡإِحۡسَٰنُ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٦٠",
