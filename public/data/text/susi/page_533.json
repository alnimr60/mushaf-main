    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "فِيهِمَا مِن كُلِّ فَٰكِهَةٖ زَوۡجَانِ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "مُتَّكِـِٔينَ عَلَىٰ فُرُشِۢ بَطَآئِنُهَا مِنۡ إِسۡتَبۡرَقٖۚ وَجَنَى اَ۬لۡجَنَّتَيۡنِ دَانٖ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فِيهِنَّ قَٰصِرَٰتُ اُ۬لطَّرۡفِ لَمۡ يَطۡمِثۡهُنَّ إِنسٞ قَبۡلَهُمۡ وَلَا جَآنّٞ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "كَأَنَّهُنَّ اَ۬لۡيَاقُوتُ وَاَلۡمَرۡجَانُ ٥٧",
