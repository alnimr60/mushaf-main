{
  "pageNumber": 582,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "عَمَّ يَتَسَآءَلُونَ ١",
      "numberInSurah": 1
    },
    {
      "text": "عَنِ ٱلنَّبَإِ ٱلۡعَظِيمِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "ٱلَّذِي هُمۡ فِيهِ مُخۡتَلِفُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "كَلَّا سَيَعۡلَمُونَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ثُمَّ كَلَّا سَيَعۡلَمُونَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ مِهَٰدٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَٱلۡجِبَالَ أَوۡتَادٗا ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَخَلَقۡنَٰكُمۡ أَزۡوَٰجٗا ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَجَعَلۡنَا نَوۡمَكُمۡ سُبَاتٗا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَجَعَلۡنَا ٱلَّيۡلَ لِبَاسٗا ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَجَعَلۡنَا ٱلنَّهَارَ مَعَاشٗا ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَبَنَيۡنَا فَوۡقَكُمۡ سَبۡعٗا شِدَادٗا ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَجَعَلۡنَا سِرَاجٗا وَهَّاجٗا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَأَنزَلۡنَا مِنَ ٱلۡمُعۡصِرَٰتِ مَآءٗ ثَجَّاجٗا ١٤",
      "numberInSurah": 14
    },
    {
      "text": "لِّنُخۡرِجَ بِهِۦ حَبّٗا وَنَبَاتٗا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَجَنَّٰتٍ أَلۡفَافًا ١٦",
      "numberInSurah": 16
    },
    {
      "text": "إِنَّ يَوۡمَ ٱلۡفَصۡلِ كَانَ مِيقَٰتٗا ١٧",
      "numberInSurah": 17
    },
    {
      "text": "يَوۡمَ يُنفَخُ فِي ٱلصُّورِ فَتَأۡتُونَ أَفۡوَاجٗا ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَفُتِحَتِ ٱلسَّمَآءُ فَكَانَتۡ أَبۡوَٰبٗا ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَسُيِّرَتِ ٱلۡجِبَالُ فَكَانَتۡ سَرَابًا ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "إِنَّ جَهَنَّمَ كَانَتۡ مِرۡصَادٗا ٢١",
      "numberInSurah": 21
    },
    {
      "text": "لِّلطَّٰغِينَ مَـَٔابٗا ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "لَّٰبِثِينَ فِيهَآ أَحۡقَابٗا ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "لَّا يَذُوقُونَ فِيهَا بَرۡدٗا وَلَا شَرَابًا ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِلَّا حَمِيمٗا وَغَسَاقٗا ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "جَزَآءٗ وِفَاقًا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "إِنَّهُمۡ كَانُواْ لَا يَرۡجُونَ حِسَابٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَكَذَّبُواْ بِـَٔايَٰتِنَا كِذَّابٗا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَكُلَّ شَيۡءٍ أَحۡصَيۡنَٰهُ كِتَٰبٗا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فَذُوقُواْ فَلَن نَّزِيدَكُمۡ إِلَّا عَذَابًا ٣٠",
      "numberInSurah": 30
    }
  ]
}
