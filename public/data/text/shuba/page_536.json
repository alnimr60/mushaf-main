{
  "pageNumber": 536,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "ثُمَّ إِنَّكُمۡ أَيُّهَا ٱلضَّآلُّونَ ٱلۡمُكَذِّبُونَ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَشَٰرِبُونَ عَلَيۡهِ مِنَ ٱلۡحَمِيمِ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَشَٰرِبُونَ شُرۡبَ ٱلۡهِيمِ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "هَٰذَا نُزُلُهُمۡ يَوۡمَ ٱلدِّينِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "نَحۡنُ خَلَقۡنَٰكُمۡ فَلَوۡلَا تُصَدِّقُونَ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "أَفَرَءَيۡتُم مَّا تُمۡنُونَ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "ءَأَنتُمۡ تَخۡلُقُونَهُۥٓ أَمۡ نَحۡنُ ٱلۡخَٰلِقُونَ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "نَحۡنُ قَدَّرۡنَا بَيۡنَكُمُ ٱلۡمَوۡتَ وَمَا نَحۡنُ بِمَسۡبُوقِينَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "عَلَىٰٓ أَن نُّبَدِّلَ أَمۡثَٰلَكُمۡ وَنُنشِئَكُمۡ فِي مَا لَا تَعۡلَمُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "وَلَقَدۡ عَلِمۡتُمُ ٱلنَّشۡأَةَ ٱلۡأُولَىٰ فَلَوۡلَا تَذَّكَّرُونَ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "أَفَرَءَيۡتُم مَّا تَحۡرُثُونَ ٦٣",
      "numberInSurah": 63
    },
    {
      "text": "ءَأَنتُمۡ تَزۡرَعُونَهُۥٓ أَمۡ نَحۡنُ ٱلزَّٰرِعُونَ ٦٤",
      "numberInSurah": 64
    },
    {
      "text": "لَوۡ نَشَآءُ لَجَعَلۡنَٰهُ حُطَٰمٗا فَظَلۡتُمۡ تَفَكَّهُونَ ٦٥",
      "numberInSurah": 65
    },
    {
      "text": "أَءِنَّا لَمُغۡرَمُونَ ٦٦",
      "numberInSurah": 66
    },
    {
      "text": "بَلۡ نَحۡنُ مَحۡرُومُونَ ٦٧",
      "numberInSurah": 67
    },
    {
      "text": "أَفَرَءَيۡتُمُ ٱلۡمَآءَ ٱلَّذِي تَشۡرَبُونَ ٦٨",
      "numberInSurah": 68
    },
    {
      "text": "ءَأَنتُمۡ أَنزَلۡتُمُوهُ مِنَ ٱلۡمُزۡنِ أَمۡ نَحۡنُ ٱلۡمُنزِلُونَ ٦٩",
      "numberInSurah": 69
    },
    {
      "text": "لَوۡ نَشَآءُ جَعَلۡنَٰهُ أُجَاجٗا فَلَوۡلَا تَشۡكُرُونَ ٧٠",
      "numberInSurah": 70
    },
    {
      "text": "أَفَرَءَيۡتُمُ ٱلنَّارَ ٱلَّتِي تُورُونَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "ءَأَنتُمۡ أَنشَأۡتُمۡ شَجَرَتَهَآ أَمۡ نَحۡنُ ٱلۡمُنشِـُٔونَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "نَحۡنُ جَعَلۡنَٰهَا تَذۡكِرَةٗ وَمَتَٰعٗا لِّلۡمُقۡوِينَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "۞فَلَآ أُقۡسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "وَإِنَّهُۥ لَقَسَمٞ لَّوۡ تَعۡلَمُونَ عَظِيمٌ ٧٦",
      "numberInSurah": 76
    }
  ]
}
