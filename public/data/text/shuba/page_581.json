{
  "pageNumber": 581,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "أَلَمۡ نَخۡلُقكُّم مِّن مَّآءٖ مَّهِينٖ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَجَعَلۡنَٰهُ فِي قَرَارٖ مَّكِينٍ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِلَىٰ قَدَرٖ مَّعۡلُومٖ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَقَدَرۡنَا فَنِعۡمَ ٱلۡقَٰدِرُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "أَلَمۡ نَجۡعَلِ ٱلۡأَرۡضَ كِفَاتًا ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "أَحۡيَآءٗ وَأَمۡوَٰتٗا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَجَعَلۡنَا فِيهَا رَوَٰسِيَ شَٰمِخَٰتٖ وَأَسۡقَيۡنَٰكُم مَّآءٗ فُرَاتٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "ٱنطَلِقُوٓاْ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "ٱنطَلِقُوٓاْ إِلَىٰ ظِلّٖ ذِي ثَلَٰثِ شُعَبٖ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "لَّا ظَلِيلٖ وَلَا يُغۡنِي مِنَ ٱللَّهَبِ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "إِنَّهَا تَرۡمِي بِشَرَرٖ كَٱلۡقَصۡرِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "كَأَنَّهُۥ جِمَٰلَٰتٞ صُفۡرٞ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "هَٰذَا يَوۡمُ لَا يَنطِقُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَلَا يُؤۡذَنُ لَهُمۡ فَيَعۡتَذِرُونَ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "هَٰذَا يَوۡمُ ٱلۡفَصۡلِۖ جَمَعۡنَٰكُمۡ وَٱلۡأَوَّلِينَ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَإِن كَانَ لَكُمۡ كَيۡدٞ فَكِيدُونِ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي ظِلَٰلٖ وَعِيُونٖ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "وَفَوَٰكِهَ مِمَّا يَشۡتَهُونَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "كُلُواْ وَٱشۡرَبُواْ هَنِيٓـَٔۢا بِمَا كُنتُمۡ تَعۡمَلُونَ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "كُلُواْ وَتَمَتَّعُواْ قَلِيلًا إِنَّكُم مُّجۡرِمُونَ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَإِذَا قِيلَ لَهُمُ ٱرۡكَعُواْ لَا يَرۡكَعُونَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "فَبِأَيِّ حَدِيثِۭ بَعۡدَهُۥ يُؤۡمِنُونَ ٥٠",
      "numberInSurah": 50
    }
  ]
}
