{
  "pageNumber": 578,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "كَلَّا بَلۡ تُحِبُّونَ ٱلۡعَاجِلَةَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَتَذَرُونَ ٱلۡأٓخِرَةَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وُجُوهٞ يَوۡمَئِذٖ نَّاضِرَةٌ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٞ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَوُجُوهٞ يَوۡمَئِذِۭ بَاسِرَةٞ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "تَظُنُّ أَن يُفۡعَلَ بِهَا فَاقِرَةٞ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِيَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَقِيلَ مَن رَّاقٖ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَظَنَّ أَنَّهُ ٱلۡفِرَاقُ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمَسَاقُ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهۡلِهِۦ يَتَمَطَّىٰٓ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "أَوۡلَىٰ لَكَ فَأَوۡلَىٰ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "ثُمَّ أَوۡلَىٰ لَكَ فَأَوۡلَىٰٓ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَن يُتۡرَكَ سُدًى ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "أَلَمۡ يَكُ نُطۡفَةٗ مِّن مَّنِيّٖ تُمۡنَىٰ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوَّىٰ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَجَعَلَ مِنۡهُ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "أَلَيۡسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحۡـِۧيَ ٱلۡمَوۡتَىٰ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "سُورَةُ الإِنسَانِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ هَلۡ أَتَىٰ عَلَى ٱلۡإِنسَٰنِ حِينٞ مِّنَ ٱلدَّهۡرِ لَمۡ يَكُن شَيۡـٔٗا مَّذۡكُورًا ١",
      "numberInSurah": 1
    },
    {
      "text": "إِنَّا خَلَقۡنَا ٱلۡإِنسَٰنَ مِن نُّطۡفَةٍ أَمۡشَاجٖ نَّبۡتَلِيهِ فَجَعَلۡنَٰهُ سَمِيعَۢا بَصِيرًا ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِنَّا هَدَيۡنَٰهُ ٱلسَّبِيلَ إِمَّا شَاكِرٗا وَإِمَّا كَفُورًا ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنَّآ أَعۡتَدۡنَا لِلۡكَٰفِرِينَ سَلَٰسِلٗا وَأَغۡلَٰلٗا وَسَعِيرًا ٤",
      "numberInSurah": 4
    },
    {
      "text": "إِنَّ ٱلۡأَبۡرَارَ يَشۡرَبُونَ مِن كَأۡسٖ كَانَ مِزَاجُهَا كَافُورًا ٥",
      "numberInSurah": 5
    }
  ]
}
