{
  "pageNumber": 498,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "إِنَّ يَوۡمَ ٱلۡفَصۡلِ مِيقَٰتُهُمۡ أَجۡمَعِينَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "يَوۡمَ لَا يُغۡنِي مَوۡلًى عَن مَّوۡلٗى شَيۡـٔٗا وَلَا هُمۡ يُنصَرُونَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "إِلَّا مَن رَّحِمَ ٱللَّهُۚ إِنَّهُۥ هُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "إِنَّ شَجَرَتَ ٱلزَّقُّومِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "طَعَامُ ٱلۡأَثِيمِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "كَٱلۡمُهۡلِ تَغۡلِي فِي ٱلۡبُطُونِ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "كَغَلۡيِ ٱلۡحَمِيمِ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "خُذُوهُ فَٱعۡتِلُوهُ إِلَىٰ سَوَآءِ ٱلۡجَحِيمِ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "ثُمَّ صُبُّواْ فَوۡقَ رَأۡسِهِۦ مِنۡ عَذَابِ ٱلۡحَمِيمِ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "ذُقۡ إِنَّكَ أَنتَ ٱلۡعَزِيزُ ٱلۡكَرِيمُ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمۡتَرُونَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "إِنَّ ٱلۡمُتَّقِينَ فِي مَقَامٍ أَمِينٖ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "فِي جَنَّٰتٖ وَعِيُونٖ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "يَلۡبَسُونَ مِن سُندُسٖ وَإِسۡتَبۡرَقٖ مُّتَقَٰبِلِينَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "كَذَٰلِكَ وَزَوَّجۡنَٰهُم بِحُورٍ عِينٖ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "يَدۡعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ ءَامِنِينَ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "لَا يَذُوقُونَ فِيهَا ٱلۡمَوۡتَ إِلَّا ٱلۡمَوۡتَةَ ٱلۡأُولَىٰۖ وَوَقَىٰهُمۡ عَذَابَ ٱلۡجَحِيمِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "فَضۡلٗا مِّن رَّبِّكَۚ ذَٰلِكَ هُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "فَإِنَّمَا يَسَّرۡنَٰهُ بِلِسَانِكَ لَعَلَّهُمۡ يَتَذَكَّرُونَ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "فَٱرۡتَقِبۡ إِنَّهُم مُّرۡتَقِبُونَ ٥٩",
      "numberInSurah": 59
    }
  ]
}
