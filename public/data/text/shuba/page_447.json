{
  "pageNumber": 447,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "مَا لَكُمۡ لَا تَنَاصَرُونَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "بَلۡ هُمُ ٱلۡيَوۡمَ مُسۡتَسۡلِمُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "قَالُوٓاْ إِنَّكُمۡ كُنتُمۡ تَأۡتُونَنَا عَنِ ٱلۡيَمِينِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "قَالُواْ بَل لَّمۡ تَكُونُواْ مُؤۡمِنِينَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَمَا كَانَ لَنَا عَلَيۡكُم مِّن سُلۡطَٰنِۭۖ بَلۡ كُنتُمۡ قَوۡمٗا طَٰغِينَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "فَحَقَّ عَلَيۡنَا قَوۡلُ رَبِّنَآۖ إِنَّا لَذَآئِقُونَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَأَغۡوَيۡنَٰكُمۡ إِنَّا كُنَّا غَٰوِينَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "فَإِنَّهُمۡ يَوۡمَئِذٖ فِي ٱلۡعَذَابِ مُشۡتَرِكُونَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "إِنَّهُمۡ كَانُوٓاْ إِذَا قِيلَ لَهُمۡ لَآ إِلَٰهَ إِلَّا ٱللَّهُ يَسۡتَكۡبِرُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓاْ ءَالِهَتِنَا لِشَاعِرٖ مَّجۡنُونِۭ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "بَلۡ جَآءَ بِٱلۡحَقِّ وَصَدَّقَ ٱلۡمُرۡسَلِينَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "إِنَّكُمۡ لَذَآئِقُواْ ٱلۡعَذَابِ ٱلۡأَلِيمِ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَمَا تُجۡزَوۡنَ إِلَّا مَا كُنتُمۡ تَعۡمَلُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "أُوْلَٰٓئِكَ لَهُمۡ رِزۡقٞ مَّعۡلُومٞ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "فَوَٰكِهُ وَهُم مُّكۡرَمُونَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "فِي جَنَّٰتِ ٱلنَّعِيمِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "عَلَىٰ سُرُرٖ مُّتَقَٰبِلِينَ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "يُطَافُ عَلَيۡهِم بِكَأۡسٖ مِّن مَّعِينِۭ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "بَيۡضَآءَ لَذَّةٖ لِّلشَّٰرِبِينَ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "لَا فِيهَا غَوۡلٞ وَلَا هُمۡ عَنۡهَا يُنزَفُونَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَعِندَهُمۡ قَٰصِرَٰتُ ٱلطَّرۡفِ عِينٞ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "كَأَنَّهُنَّ بَيۡضٞ مَّكۡنُونٞ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "فَأَقۡبَلَ بَعۡضُهُمۡ عَلَىٰ بَعۡضٖ يَتَسَآءَلُونَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "قَالَ قَآئِلٞ مِّنۡهُمۡ إِنِّي كَانَ لِي قَرِينٞ ٥١",
      "numberInSurah": 51
    }
  ]
}
