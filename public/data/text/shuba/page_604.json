{
  "pageNumber": 604,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قُلۡ هُوَ ٱللَّهُ أَحَدٌ ١",
      "numberInSurah": 1
    },
    {
      "text": "ٱللَّهُ ٱلصَّمَدُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَمۡ يَكُن لَّهُۥ كُفُؤًا أَحَدُۢ ٤",
      "numberInSurah": 4
    },
    {
      "text": "سُورَةُ الفَلَقِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ ٱلۡفَلَقِ ١",
      "numberInSurah": 1
    },
    {
      "text": "مِن شَرِّ مَا خَلَقَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمِن شَرِّ غَاسِقٍ إِذَا وَقَبَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَمِن شَرِّ ٱلنَّفَّٰثَٰتِ فِي ٱلۡعُقَدِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَمِن شَرِّ حَاسِدٍ إِذَا حَسَدَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "سُورَةُ النَّاسِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَلِكِ ٱلنَّاسِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِلَٰهِ ٱلنَّاسِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ ٦",
      "numberInSurah": 6
    }
  ]
}
