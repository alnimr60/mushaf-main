{
  "pageNumber": 535,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "يَطُوفُ عَلَيۡهِمۡ وِلۡدَٰنٞ مُّخَلَّدُونَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "بِأَكۡوَابٖ وَأَبَارِيقَ وَكَأۡسٖ مِّن مَّعِينٖ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "لَّا يُصَدَّعُونَ عَنۡهَا وَلَا يُنزِفُونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَفَٰكِهَةٖ مِّمَّا يَتَخَيَّرُونَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَلَحۡمِ طَيۡرٖ مِّمَّا يَشۡتَهُونَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَحُورٌ عِينٞ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "كَأَمۡثَٰلِ ٱللُّولُوِٕ ٱلۡمَكۡنُونِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "جَزَآءَۢ بِمَا كَانُواْ يَعۡمَلُونَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "لَا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا تَأۡثِيمًا ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "إِلَّا قِيلٗا سَلَٰمٗا سَلَٰمٗا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَأَصۡحَٰبُ ٱلۡيَمِينِ مَآ أَصۡحَٰبُ ٱلۡيَمِينِ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فِي سِدۡرٖ مَّخۡضُودٖ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَطَلۡحٖ مَّنضُودٖ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَظِلّٖ مَّمۡدُودٖ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَمَآءٖ مَّسۡكُوبٖ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَفَٰكِهَةٖ كَثِيرَةٖ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "لَّا مَقۡطُوعَةٖ وَلَا مَمۡنُوعَةٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَفُرُشٖ مَّرۡفُوعَةٍ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "إِنَّآ أَنشَأۡنَٰهُنَّ إِنشَآءٗ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَجَعَلۡنَٰهُنَّ أَبۡكَارًا ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "عُرۡبًا أَتۡرَابٗا ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "لِّأَصۡحَٰبِ ٱلۡيَمِينِ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "ثُلَّةٞ مِّنَ ٱلۡأَوَّلِينَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "وَثُلَّةٞ مِّنَ ٱلۡأٓخِرِينَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "وَأَصۡحَٰبُ ٱلشِّمَالِ مَآ أَصۡحَٰبُ ٱلشِّمَالِ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "فِي سَمُومٖ وَحَمِيمٖ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "وَظِلّٖ مِّن يَحۡمُومٖ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "لَّا بَارِدٖ وَلَا كَرِيمٍ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "إِنَّهُمۡ كَانُواْ قَبۡلَ ذَٰلِكَ مُتۡرَفِينَ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "وَكَانُواْ يُصِرُّونَ عَلَى ٱلۡحِنثِ ٱلۡعَظِيمِ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "وَكَانُواْ يَقُولُونَ أَئِذَا مُتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَءِنَّا لَمَبۡعُوثُونَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "أَوَءَابَآؤُنَا ٱلۡأَوَّلُونَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "قُلۡ إِنَّ ٱلۡأَوَّلِينَ وَٱلۡأٓخِرِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "لَمَجۡمُوعُونَ إِلَىٰ مِيقَٰتِ يَوۡمٖ مَّعۡلُومٖ ٥٠",
      "numberInSurah": 50
    }
  ]
}
