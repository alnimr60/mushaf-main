{
  "pageNumber": 451,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "فَكَذَّبُوهُ فَإِنَّهُمۡ لَمُحۡضَرُونَ ١٢٧",
      "numberInSurah": 127
    },
    {
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلَصِينَ ١٢٨",
      "numberInSurah": 128
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ ١٢٩",
      "numberInSurah": 129
    },
    {
      "text": "سَلَٰمٌ عَلَىٰٓ إِلۡ يَاسِينَ ١٣٠",
      "numberInSurah": 130
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ١٣١",
      "numberInSurah": 131
    },
    {
      "text": "إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ ١٣٢",
      "numberInSurah": 132
    },
    {
      "text": "وَإِنَّ لُوطٗا لَّمِنَ ٱلۡمُرۡسَلِينَ ١٣٣",
      "numberInSurah": 133
    },
    {
      "text": "إِذۡ نَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ ١٣٤",
      "numberInSurah": 134
    },
    {
      "text": "إِلَّا عَجُوزٗا فِي ٱلۡغَٰبِرِينَ ١٣٥",
      "numberInSurah": 135
    },
    {
      "text": "ثُمَّ دَمَّرۡنَا ٱلۡأٓخَرِينَ ١٣٦",
      "numberInSurah": 136
    },
    {
      "text": "وَإِنَّكُمۡ لَتَمُرُّونَ عَلَيۡهِم مُّصۡبِحِينَ ١٣٧",
      "numberInSurah": 137
    },
    {
      "text": "وَبِٱلَّيۡلِۚ أَفَلَا تَعۡقِلُونَ ١٣٨",
      "numberInSurah": 138
    },
    {
      "text": "وَإِنَّ يُونُسَ لَمِنَ ٱلۡمُرۡسَلِينَ ١٣٩",
      "numberInSurah": 139
    },
    {
      "text": "إِذۡ أَبَقَ إِلَى ٱلۡفُلۡكِ ٱلۡمَشۡحُونِ ١٤٠",
      "numberInSurah": 140
    },
    {
      "text": "فَسَاهَمَ فَكَانَ مِنَ ٱلۡمُدۡحَضِينَ ١٤١",
      "numberInSurah": 141
    },
    {
      "text": "فَٱلۡتَقَمَهُ ٱلۡحُوتُ وَهُوَ مُلِيمٞ ١٤٢",
      "numberInSurah": 142
    },
    {
      "text": "فَلَوۡلَآ أَنَّهُۥ كَانَ مِنَ ٱلۡمُسَبِّحِينَ ١٤٣",
      "numberInSurah": 143
    },
    {
      "text": "لَلَبِثَ فِي بَطۡنِهِۦٓ إِلَىٰ يَوۡمِ يُبۡعَثُونَ ١٤٤",
      "numberInSurah": 144
    },
    {
      "text": "۞فَنَبَذۡنَٰهُ بِٱلۡعَرَآءِ وَهُوَ سَقِيمٞ ١٤٥",
      "numberInSurah": 145
    },
    {
      "text": "وَأَنۢبَتۡنَا عَلَيۡهِ شَجَرَةٗ مِّن يَقۡطِينٖ ١٤٦",
      "numberInSurah": 146
    },
    {
      "text": "وَأَرۡسَلۡنَٰهُ إِلَىٰ مِاْئَةِ أَلۡفٍ أَوۡ يَزِيدُونَ ١٤٧",
      "numberInSurah": 147
    },
    {
      "text": "فَـَٔامَنُواْ فَمَتَّعۡنَٰهُمۡ إِلَىٰ حِينٖ ١٤٨",
      "numberInSurah": 148
    },
    {
      "text": "فَٱسۡتَفۡتِهِمۡ أَلِرَبِّكَ ٱلۡبَنَاتُ وَلَهُمُ ٱلۡبَنُونَ ١٤٩",
      "numberInSurah": 149
    },
    {
      "text": "أَمۡ خَلَقۡنَا ٱلۡمَلَٰٓئِكَةَ إِنَٰثٗا وَهُمۡ شَٰهِدُونَ ١٥٠",
      "numberInSurah": 150
    },
    {
      "text": "أَلَآ إِنَّهُم مِّنۡ إِفۡكِهِمۡ لَيَقُولُونَ ١٥١",
      "numberInSurah": 151
    },
    {
      "text": "وَلَدَ ٱللَّهُ وَإِنَّهُمۡ لَكَٰذِبُونَ ١٥٢",
      "numberInSurah": 152
    },
    {
      "text": "أَصۡطَفَى ٱلۡبَنَاتِ عَلَى ٱلۡبَنِينَ ١٥٣",
      "numberInSurah": 153
    }
  ]
}
