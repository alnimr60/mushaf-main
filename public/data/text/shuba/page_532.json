  "ayahs": [
    {
      "text": "مَرَجَ ٱلۡبَحۡرَيۡنِ يَلۡتَقِيَانِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "بَيۡنَهُمَا بَرۡزَخٞ لَّا يَبۡغِيَانِ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "يَخۡرُجُ مِنۡهُمَا ٱللُّولُؤُ وَٱلۡمَرۡجَانُ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَلَهُ ٱلۡجَوَارِ ٱلۡمُنشِـَٔاتُ فِي ٱلۡبَحۡرِ كَٱلۡأَعۡلَٰمِ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "كُلُّ مَنۡ عَلَيۡهَا فَانٖ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَيَبۡقَىٰ وَجۡهُ رَبِّكَ ذُو ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "يَسۡـَٔلُهُۥ مَن فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ كُلَّ يَوۡمٍ هُوَ فِي شَأۡنٖ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "سَنَفۡرُغُ لَكُمۡ أَيُّهَ ٱلثَّقَلَانِ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "يَٰمَعۡشَرَ ٱلۡجِنِّ وَٱلۡإِنسِ إِنِ ٱسۡتَطَعۡتُمۡ أَن تَنفُذُواْ مِنۡ أَقۡطَارِ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ فَٱنفُذُواْۚ لَا تَنفُذُونَ إِلَّا بِسُلۡطَٰنٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "يُرۡسَلُ عَلَيۡكُمَا شُوَاظٞ مِّن نَّارٖ وَنُحَاسٞ فَلَا تَنتَصِرَانِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَإِذَا ٱنشَقَّتِ ٱلسَّمَآءُ فَكَانَتۡ وَرۡدَةٗ كَٱلدِّهَانِ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَيَوۡمَئِذٖ لَّا يُسۡـَٔلُ عَن ذَنۢبِهِۦٓ إِنسٞ وَلَا جَآنّٞ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "يُعۡرَفُ ٱلۡمُجۡرِمُونَ بِسِيمَٰهُمۡ فَيُؤۡخَذُ بِٱلنَّوَٰصِي وَٱلۡأَقۡدَامِ ٤١",
      "numberInSurah": 41
    }
  ]
