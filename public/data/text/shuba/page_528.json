{
  "pageNumber": 528,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "وَأَنَّ عَلَيۡهِ ٱلنَّشۡأَةَ ٱلۡأُخۡرَىٰ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَأَنَّهُۥٓ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَثَمُودَاْ فَمَآ أَبۡقَىٰ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "وَقَوۡمَ نُوحٖ مِّن قَبۡلُۖ إِنَّهُمۡ كَانُواْ هُمۡ أَظۡلَمَ وَأَطۡغَىٰ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَغَشَّىٰهَا مَا غَشَّىٰ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "هَٰذَا نَذِيرٞ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰٓ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "أَزِفَتِ ٱلۡأٓزِفَةُ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "أَفَمِنۡ هَٰذَا ٱلۡحَدِيثِ تَعۡجَبُونَ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "وَأَنتُمۡ سَٰمِدُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "فَٱسۡجُدُواْۤ لِلَّهِۤ وَٱعۡبُدُواْ۩ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "سُورَةُ القَمَرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِن يَرَوۡاْ ءَايَةٗ يُعۡرِضُواْ وَيَقُولُواْ سِحۡرٞ مُّسۡتَمِرّٞ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَكَذَّبُواْ وَٱتَّبَعُوٓاْ أَهۡوَآءَهُمۡۚ وَكُلُّ أَمۡرٖ مُّسۡتَقِرّٞ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَقَدۡ جَآءَهُم مِّنَ ٱلۡأَنۢبَآءِ مَا فِيهِ مُزۡدَجَرٌ ٤",
      "numberInSurah": 4
    },
    {
      "text": "حِكۡمَةُۢ بَٰلِغَةٞۖ فَمَا تُغۡنِ ٱلنُّذُرُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَتَوَلَّ عَنۡهُمۡۘ يَوۡمَ يَدۡعُ ٱلدَّاعِ إِلَىٰ شَيۡءٖ نُّكُرٍ ٦",
      "numberInSurah": 6
    }
  ]
}
