{
  "pageNumber": 374,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "كَذَّبَتۡ قَوۡمُ لُوطٍ ٱلۡمُرۡسَلِينَ ١٦٠",
      "numberInSurah": 160
    },
    {
      "text": "إِذۡ قَالَ لَهُمۡ أَخُوهُمۡ لُوطٌ أَلَا تَتَّقُونَ ١٦١",
      "numberInSurah": 161
    },
    {
      "text": "إِنِّي لَكُمۡ رَسُولٌ أَمِينٞ ١٦٢",
      "numberInSurah": 162
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١٦٣",
      "numberInSurah": 163
    },
    {
      "text": "وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيٓ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ ١٦٤",
      "numberInSurah": 164
    },
    {
      "text": "أَتَأۡتُونَ ٱلذُّكۡرَانَ مِنَ ٱلۡعَٰلَمِينَ ١٦٥",
      "numberInSurah": 165
    },
    {
      "text": "وَتَذَرُونَ مَا خَلَقَ لَكُمۡ رَبُّكُم مِّنۡ أَزۡوَٰجِكُمۚ بَلۡ أَنتُمۡ قَوۡمٌ عَادُونَ ١٦٦",
      "numberInSurah": 166
    },
    {
      "text": "قَالُواْ لَئِن لَّمۡ تَنتَهِ يَٰلُوطُ لَتَكُونَنَّ مِنَ ٱلۡمُخۡرَجِينَ ١٦٧",
      "numberInSurah": 167
    },
    {
      "text": "قَالَ إِنِّي لِعَمَلِكُم مِّنَ ٱلۡقَالِينَ ١٦٨",
      "numberInSurah": 168
    },
    {
      "text": "رَبِّ نَجِّنِي وَأَهۡلِي مِمَّا يَعۡمَلُونَ ١٦٩",
      "numberInSurah": 169
    },
    {
      "text": "فَنَجَّيۡنَٰهُ وَأَهۡلَهُۥٓ أَجۡمَعِينَ ١٧٠",
      "numberInSurah": 170
    },
    {
      "text": "إِلَّا عَجُوزٗا فِي ٱلۡغَٰبِرِينَ ١٧١",
      "numberInSurah": 171
    },
    {
      "text": "ثُمَّ دَمَّرۡنَا ٱلۡأٓخَرِينَ ١٧٢",
      "numberInSurah": 172
    },
    {
      "text": "وَأَمۡطَرۡنَا عَلَيۡهِم مَّطَرٗاۖ فَسَآءَ مَطَرُ ٱلۡمُنذَرِينَ ١٧٣",
      "numberInSurah": 173
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُم مُّؤۡمِنِينَ ١٧٤",
      "numberInSurah": 174
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ١٧٥",
      "numberInSurah": 175
    },
    {
      "text": "كَذَّبَ أَصۡحَٰبُ لۡـَٔيۡكَةِ ٱلۡمُرۡسَلِينَ ١٧٦",
      "numberInSurah": 176
    },
    {
      "text": "إِذۡ قَالَ لَهُمۡ شُعَيۡبٌ أَلَا تَتَّقُونَ ١٧٧",
      "numberInSurah": 177
    },
    {
      "text": "إِنِّي لَكُمۡ رَسُولٌ أَمِينٞ ١٧٨",
      "numberInSurah": 178
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١٧٩",
      "numberInSurah": 179
    },
    {
      "text": "وَمَآ أَسۡـَٔلُكُمۡ عَلَيۡهِ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِيٓ إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ ١٨٠",
      "numberInSurah": 180
    },
    {
      "text": "۞أَوۡفُواْ ٱلۡكَيۡلَ وَلَا تَكُونُواْ مِنَ ٱلۡمُخۡسِرِينَ ١٨١",
      "numberInSurah": 181
    },
    {
      "text": "وَزِنُواْ بِٱلۡقُسۡطَاسِ ٱلۡمُسۡتَقِيمِ ١٨٢",
      "numberInSurah": 182
    },
    {
      "text": "وَلَا تَبۡخَسُواْ ٱلنَّاسَ أَشۡيَآءَهُمۡ وَلَا تَعۡثَوۡاْ فِي ٱلۡأَرۡضِ مُفۡسِدِينَ ١٨٣",
      "numberInSurah": 183
    }
  ]
}
