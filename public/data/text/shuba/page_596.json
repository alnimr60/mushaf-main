{
  "pageNumber": 596,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "فَسَنُيَسِّرُهُۥ لِلۡعُسۡرَىٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَمَا يُغۡنِي عَنۡهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِنَّ عَلَيۡنَا لَلۡهُدَىٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَإِنَّ لَنَا لَلۡأٓخِرَةَ وَٱلۡأُولَىٰ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَأَنذَرۡتُكُمۡ نَارٗا تَلَظَّىٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "لَا يَصۡلَىٰهَآ إِلَّا ٱلۡأَشۡقَى ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ٱلَّذِي كَذَّبَ وَتَوَلَّىٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَسَيُجَنَّبُهَا ٱلۡأَتۡقَى ١٧",
      "numberInSurah": 17
    },
    {
      "text": "ٱلَّذِي يُؤۡتِي مَالَهُۥ يَتَزَكَّىٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةٖ تُجۡزَىٰٓ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "إِلَّا ٱبۡتِغَآءَ وَجۡهِ رَبِّهِ ٱلۡأَعۡلَىٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَلَسَوۡفَ يَرۡضَىٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "سُورَةُ الضُّحَىٰ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلضُّحَىٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَٱلَّيۡلِ إِذَا سَجَىٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَلۡأٓخِرَةُ خَيۡرٞ لَّكَ مِنَ ٱلۡأُولَىٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ فَتَرۡضَىٰٓ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَمۡ يَجِدۡكَ يَتِيمٗا فَـَٔاوَىٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَوَجَدَكَ ضَآلّٗا فَهَدَىٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَوَجَدَكَ عَآئِلٗا فَأَغۡنَىٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَأَمَّا ٱلۡيَتِيمَ فَلَا تَقۡهَرۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنۡهَرۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَأَمَّا بِنِعۡمَةِ رَبِّكَ فَحَدِّثۡ ١١",
      "numberInSurah": 11
    },
    {
      "text": "سُورَةُ الشَّرۡحِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَوَضَعۡنَا عَنكَ وِزۡرَكَ ٢",
      "numberInSurah": 2
    }
  ]
}
