  "ayahs": [
    {
      "text": "وَمِنَ ٱلَّيۡلِ فَٱسۡجُدۡ لَهُۥ وَسَبِّحۡهُ لَيۡلٗا طَوِيلًا ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "إِنَّ هَٰٓؤُلَآءِ يُحِبُّونَ ٱلۡعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمۡ يَوۡمٗا ثَقِيلٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "نَّحۡنُ خَلَقۡنَٰهُمۡ وَشَدَدۡنَآ أَسۡرَهُمۡۖ وَإِذَا شِئۡنَا بَدَّلۡنَآ أَمۡثَٰلَهُمۡ تَبۡدِيلًا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "إِنَّ هَٰذِهِۦ تَذۡكِرَةٞۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ سَبِيلٗا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُۚ إِنَّ ٱللَّهَ كَانَ عَلِيمًا حَكِيمٗا ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "يُدۡخِلُ مَن يَشَآءُ فِي رَحۡمَتِهِۦۚ وَٱلظَّٰلِمِينَ أَعَدَّ لَهُمۡ عَذَابًا أَلِيمَۢا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "سُورَةُ المُرۡسَلَاتِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلۡمُرۡسَلَٰتِ عُرۡفٗا ١",
      "numberInSurah": 1
    },
    {
      "text": "فَٱلۡعَٰصِفَٰتِ عَصۡفٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلنَّٰشِرَٰتِ نَشۡرٗا ٣",
      "numberInSurah": 3
    },
    {
      "text": "فَٱلۡفَٰرِقَٰتِ فَرۡقٗا ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَٱلۡمُلۡقِيَٰتِ ذِكۡرًا ٥",
      "numberInSurah": 5
    },
    {
      "text": "عُذۡرًا أَوۡ نُذُرًا ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَإِذَا ٱلنُّجُومُ طُمِسَتۡ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَإِذَا ٱلسَّمَآءُ فُرِجَتۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَإِذَا ٱلۡجِبَالُ نُسِفَتۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَإِذَا ٱلرُّسُلُ أُقِّتَتۡ ١١",
      "numberInSurah": 11
    },
    {
      "text": "لِأَيِّ يَوۡمٍ أُجِّلَتۡ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "لِيَوۡمِ ٱلۡفَصۡلِ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَمَآ أَدۡرٜىٰكَ مَا يَوۡمُ ٱلۡفَصۡلِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "أَلَمۡ نُهۡلِكِ ٱلۡأَوَّلِينَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "ثُمَّ نُتۡبِعُهُمُ ٱلۡأٓخِرِينَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "كَذَٰلِكَ نَفۡعَلُ بِٱلۡمُجۡرِمِينَ ١٨",
