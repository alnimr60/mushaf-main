{
  "pageNumber": 523,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "كَذَٰلِكَ مَآ أَتَى ٱلَّذِينَ مِن قَبۡلِهِم مِّن رَّسُولٍ إِلَّا قَالُواْ سَاحِرٌ أَوۡ مَجۡنُونٌ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "أَتَوَاصَوۡاْ بِهِۦۚ بَلۡ هُمۡ قَوۡمٞ طَاغُونَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَتَوَلَّ عَنۡهُمۡ فَمَآ أَنتَ بِمَلُومٖ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "وَذَكِّرۡ فَإِنَّ ٱلذِّكۡرَىٰ تَنفَعُ ٱلۡمُؤۡمِنِينَ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "وَمَا خَلَقۡتُ ٱلۡجِنَّ وَٱلۡإِنسَ إِلَّا لِيَعۡبُدُونِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "مَآ أُرِيدُ مِنۡهُم مِّن رِّزۡقٖ وَمَآ أُرِيدُ أَن يُطۡعِمُونِ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "إِنَّ ٱللَّهَ هُوَ ٱلرَّزَّاقُ ذُو ٱلۡقُوَّةِ ٱلۡمَتِينُ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "فَإِنَّ لِلَّذِينَ ظَلَمُواْ ذَنُوبٗا مِّثۡلَ ذَنُوبِ أَصۡحَٰبِهِمۡ فَلَا يَسۡتَعۡجِلُونِ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "فَوَيۡلٞ لِّلَّذِينَ كَفَرُواْ مِن يَوۡمِهِمُ ٱلَّذِي يُوعَدُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "سُورَةُ الطُّورِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلطُّورِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَكِتَٰبٖ مَّسۡطُورٖ ٢",
      "numberInSurah": 2
    },
    {
      "text": "فِي رَقّٖ مَّنشُورٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلۡبَيۡتِ ٱلۡمَعۡمُورِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَٱلسَّقۡفِ ٱلۡمَرۡفُوعِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَٱلۡبَحۡرِ ٱلۡمَسۡجُورِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "مَّا لَهُۥ مِن دَافِعٖ ٨",
      "numberInSurah": 8
    },
    {
      "text": "يَوۡمَ تَمُورُ ٱلسَّمَآءُ مَوۡرٗا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَتَسِيرُ ٱلۡجِبَالُ سَيۡرٗا ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَوَيۡلٞ يَوۡمَئِذٖ لِّلۡمُكَذِّبِينَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "ٱلَّذِينَ هُمۡ فِي خَوۡضٖ يَلۡعَبُونَ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يَوۡمَ يُدَعُّونَ إِلَىٰ نَارِ جَهَنَّمَ دَعًّا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "هَٰذِهِ ٱلنَّارُ ٱلَّتِي كُنتُم بِهَا تُكَذِّبُونَ ١٤",
      "numberInSurah": 14
    }
  ]
}
