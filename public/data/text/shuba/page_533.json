      "numberInSurah": 47
    },
    {
      "text": "ذَوَاتَآ أَفۡنَانٖ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "فِيهِمَا عَيۡنَانِ تَجۡرِيَانِ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "فِيهِمَا مِن كُلِّ فَٰكِهَةٖ زَوۡجَانِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "مُتَّكِـِٔينَ عَلَىٰ فُرُشِۭ بَطَآئِنُهَا مِنۡ إِسۡتَبۡرَقٖۚ وَجَنَى ٱلۡجَنَّتَيۡنِ دَانٖ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "فِيهِنَّ قَٰصِرَٰتُ ٱلطَّرۡفِ لَمۡ يَطۡمِثۡهُنَّ إِنسٞ قَبۡلَهُمۡ وَلَا جَآنّٞ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "كَأَنَّهُنَّ ٱلۡيَاقُوتُ وَٱلۡمَرۡجَانُ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "هَلۡ جَزَآءُ ٱلۡإِحۡسَٰنِ إِلَّا ٱلۡإِحۡسَٰنُ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٦١",
