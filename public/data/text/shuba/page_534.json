      "numberInSurah": 73
    },
    {
      "text": "لَمۡ يَطۡمِثۡهُنَّ إِنسٞ قَبۡلَهُمۡ وَلَا جَآنّٞ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "مُتَّكِـِٔينَ عَلَىٰ رَفۡرَفٍ خُضۡرٖ وَعَبۡقَرِيٍّ حِسَانٖ ٧٦",
      "numberInSurah": 76
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "تَبَٰرَكَ ٱسۡمُ رَبِّكَ ذِي ٱلۡجَلَٰلِ وَٱلۡإِكۡرَامِ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "سُورَةُ الوَاقِعَةِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِذَا وَقَعَتِ ٱلۡوَاقِعَةُ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَيۡسَ لِوَقۡعَتِهَا كَاذِبَةٌ ٢",
      "numberInSurah": 2
    },
    {
      "text": "خَافِضَةٞ رَّافِعَةٌ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِذَا رُجَّتِ ٱلۡأَرۡضُ رَجّٗا ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَبُسَّتِ ٱلۡجِبَالُ بَسّٗا ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَكَانَتۡ هَبَآءٗ مُّنۢبَثّٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَكُنتُمۡ أَزۡوَٰجٗا ثَلَٰثَةٗ ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَأَصۡحَٰبُ ٱلۡمَيۡمَنَةِ مَآ أَصۡحَٰبُ ٱلۡمَيۡمَنَةِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَأَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ مَآ أَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَٱلسَّٰبِقُونَ ٱلسَّٰبِقُونَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "أُوْلَٰٓئِكَ ٱلۡمُقَرَّبُونَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فِي جَنَّٰتِ ٱلنَّعِيمِ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "ثُلَّةٞ مِّنَ ٱلۡأَوَّلِينَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَقَلِيلٞ مِّنَ ٱلۡأٓخِرِينَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "عَلَىٰ سُرُرٖ مَّوۡضُونَةٖ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "مُّتَّكِـِٔينَ عَلَيۡهَا مُتَقَٰبِلِينَ ١٦",
