  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قُلۡ يَٰٓأَيُّهَا ٱلۡكَٰفِرُونَ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَآ أَعۡبُدُ مَا تَعۡبُدُونَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "لَكُمۡ دِينُكُمۡ وَلِي دِينِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "سُورَةُ النَّصۡرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِذَا جَآءَ نَصۡرُ ٱللَّهِ وَٱلۡفَتۡحُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَرَأَيۡتَ ٱلنَّاسَ يَدۡخُلُونَ فِي دِينِ ٱللَّهِ أَفۡوَاجٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "فَسَبِّحۡ بِحَمۡدِ رَبِّكَ وَٱسۡتَغۡفِرۡهُۚ إِنَّهُۥ كَانَ تَوَّابَۢا ٣",
      "numberInSurah": 3
    },
    {
      "text": "سُورَةُ المَسَدِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ تَبَّتۡ يَدَآ أَبِي لَهَبٖ وَتَبَّ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَآ أَغۡنَىٰ عَنۡهُ مَالُهُۥ وَمَا كَسَبَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "سَيَصۡلَىٰ نَارٗا ذَاتَ لَهَبٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱمۡرَأَتُهُۥ حَمَّالَةَ ٱلۡحَطَبِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فِي جِيدِهَا حَبۡلٞ مِّن مَّسَدِۭ ٥",
      "numberInSurah": 5
    }
  ]
}
