{
  "pageNumber": 577,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "فَمَا تَنفَعُهُمۡ شَفَٰعَةُ ٱلشَّٰفِعِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "فَمَا لَهُمۡ عَنِ ٱلتَّذۡكِرَةِ مُعۡرِضِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "كَأَنَّهُمۡ حُمُرٞ مُّسۡتَنفِرَةٞ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "فَرَّتۡ مِن قَسۡوَرَةِۭ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "بَلۡ يُرِيدُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمۡ أَن يُؤۡتَىٰ صُحُفٗا مُّنَشَّرَةٗ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "كَلَّاۖ بَل لَّا يَخَافُونَ ٱلۡأٓخِرَةَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "كَلَّآ إِنَّهُۥ تَذۡكِرَةٞ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "وَمَا يَذۡكُرُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُۚ هُوَ أَهۡلُ ٱلتَّقۡوَىٰ وَأَهۡلُ ٱلۡمَغۡفِرَةِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "سُورَةُ القِيَامَةِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ لَآ أُقۡسِمُ بِيَوۡمِ ٱلۡقِيَٰمَةِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَلَآ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ ٣",
      "numberInSurah": 3
    },
    {
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّيَ بَنَانَهُۥ ٤",
      "numberInSurah": 4
    },
    {
      "text": "بَلۡ يُرِيدُ ٱلۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَسۡـَٔلُ أَيَّانَ يَوۡمُ ٱلۡقِيَٰمَةِ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَإِذَا بَرِقَ ٱلۡبَصَرُ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَخَسَفَ ٱلۡقَمَرُ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ ٩",
      "numberInSurah": 9
    },
    {
      "text": "يَقُولُ ٱلۡإِنسَٰنُ يَوۡمَئِذٍ أَيۡنَ ٱلۡمَفَرُّ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَلَّا لَا وَزَرَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمُسۡتَقَرُّ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "يُنَبَّؤُاْ ٱلۡإِنسَٰنُ يَوۡمَئِذِۭ بِمَا قَدَّمَ وَأَخَّرَ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "بَلِ ٱلۡإِنسَٰنُ عَلَىٰ نَفۡسِهِۦ بَصِيرَةٞ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "إِنَّ عَلَيۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَإِذَا قَرَأۡنَٰهُ فَٱتَّبِعۡ قُرۡءَانَهُۥ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيۡنَا بَيَانَهُۥ ١٩",
      "numberInSurah": 19
    }
  ]
}
