{
  "pageNumber": 593,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَيُعَذِّبُهُ ٱللَّهُ ٱلۡعَذَابَ ٱلۡأَكۡبَرَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنَّ إِلَيۡنَآ إِيَابَهُمۡ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيۡنَا حِسَابَهُم ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "سُورَةُ الفَجۡرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلۡفَجۡرِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَلَيَالٍ عَشۡرٖ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلشَّفۡعِ وَٱلۡوَتۡرِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلَّيۡلِ إِذَا يَسۡرِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "هَلۡ فِي ذَٰلِكَ قَسَمٞ لِّذِي حِجۡرٍ ٥",
      "numberInSurah": 5
    },
    {
      "text": "أَلَمۡ تَرَ كَيۡفَ فَعَلَ رَبُّكَ بِعَادٍ ٦",
      "numberInSurah": 6
    },
    {
      "text": "إِرَمَ ذَاتِ ٱلۡعِمَادِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "ٱلَّتِي لَمۡ يُخۡلَقۡ مِثۡلُهَا فِي ٱلۡبِلَٰدِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَثَمُودَ ٱلَّذِينَ جَابُواْ ٱلصَّخۡرَ بِٱلۡوَادِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَفِرۡعَوۡنَ ذِي ٱلۡأَوۡتَادِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "ٱلَّذِينَ طَغَوۡاْ فِي ٱلۡبِلَٰدِ ١١",
      "numberInSurah": 11
    },
    {
      "text": "فَأَكۡثَرُواْ فِيهَا ٱلۡفَسَادَ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَصَبَّ عَلَيۡهِمۡ رَبُّكَ سَوۡطَ عَذَابٍ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّ رَبَّكَ لَبِٱلۡمِرۡصَادِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَأَمَّا ٱلۡإِنسَٰنُ إِذَا مَا ٱبۡتَلَىٰهُ رَبُّهُۥ فَأَكۡرَمَهُۥ وَنَعَّمَهُۥ فَيَقُولُ رَبِّيٓ أَكۡرَمَنِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَأَمَّآ إِذَا مَا ٱبۡتَلَىٰهُ فَقَدَرَ عَلَيۡهِ رِزۡقَهُۥ فَيَقُولُ رَبِّيٓ أَهَٰنَنِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "كَلَّاۖ بَل لَّا تُكۡرِمُونَ ٱلۡيَتِيمَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَلَا تَحَٰٓضُّونَ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَتَأۡكُلُونَ ٱلتُّرَاثَ أَكۡلٗا لَّمّٗا ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَتُحِبُّونَ ٱلۡمَالَ حُبّٗا جَمّٗا ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "كَلَّآۖ إِذَا دُكَّتِ ٱلۡأَرۡضُ دَكّٗا دَكّٗا ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَجَآءَ رَبُّكَ وَٱلۡمَلَكُ صَفّٗا صَفّٗا ٢٢",
      "numberInSurah": 22
    }
  ]
}
