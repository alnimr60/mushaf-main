{
  "pageNumber": 450,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "فَلَمَّآ أَسۡلَمَا وَتَلَّهُۥ لِلۡجَبِينِ ١٠٣",
      "numberInSurah": 103
    },
    {
      "text": "وَنَٰدَيۡنَٰهُ أَن يَٰٓإِبۡرَٰهِيمُ ١٠٤",
      "numberInSurah": 104
    },
    {
      "text": "قَدۡ صَدَّقۡتَ ٱلرُّءۡيَآۚ إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ١٠٥",
      "numberInSurah": 105
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلۡبَلَٰٓؤُاْ ٱلۡمُبِينُ ١٠٦",
      "numberInSurah": 106
    },
    {
      "text": "وَفَدَيۡنَٰهُ بِذِبۡحٍ عَظِيمٖ ١٠٧",
      "numberInSurah": 107
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِ فِي ٱلۡأٓخِرِينَ ١٠٨",
      "numberInSurah": 108
    },
    {
      "text": "سَلَٰمٌ عَلَىٰٓ إِبۡرَٰهِيمَ ١٠٩",
      "numberInSurah": 109
    },
    {
      "text": "كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ١١٠",
      "numberInSurah": 110
    },
    {
      "text": "إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ ١١١",
      "numberInSurah": 111
    },
    {
      "text": "وَبَشَّرۡنَٰهُ بِإِسۡحَٰقَ نَبِيّٗا مِّنَ ٱلصَّٰلِحِينَ ١١٢",
      "numberInSurah": 112
    },
    {
      "text": "وَبَٰرَكۡنَا عَلَيۡهِ وَعَلَىٰٓ إِسۡحَٰقَۚ وَمِن ذُرِّيَّتِهِمَا مُحۡسِنٞ وَظَالِمٞ لِّنَفۡسِهِۦ مُبِينٞ ١١٣",
      "numberInSurah": 113
    },
    {
      "text": "وَلَقَدۡ مَنَنَّا عَلَىٰ مُوسَىٰ وَهَٰرُونَ ١١٤",
      "numberInSurah": 114
    },
    {
      "text": "وَنَجَّيۡنَٰهُمَا وَقَوۡمَهُمَا مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ ١١٥",
      "numberInSurah": 115
    },
    {
      "text": "وَنَصَرۡنَٰهُمۡ فَكَانُواْ هُمُ ٱلۡغَٰلِبِينَ ١١٦",
      "numberInSurah": 116
    },
    {
      "text": "وَءَاتَيۡنَٰهُمَا ٱلۡكِتَٰبَ ٱلۡمُسۡتَبِينَ ١١٧",
      "numberInSurah": 117
    },
    {
      "text": "وَهَدَيۡنَٰهُمَا ٱلصِّرَٰطَ ٱلۡمُسۡتَقِيمَ ١١٨",
      "numberInSurah": 118
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِمَا فِي ٱلۡأٓخِرِينَ ١١٩",
      "numberInSurah": 119
    },
    {
      "text": "سَلَٰمٌ عَلَىٰ مُوسَىٰ وَهَٰرُونَ ١٢٠",
      "numberInSurah": 120
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ١٢١",
      "numberInSurah": 121
    },
    {
      "text": "إِنَّهُمَا مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ ١٢٢",
      "numberInSurah": 122
    },
    {
      "text": "وَإِنَّ إِلۡيَاسَ لَمِنَ ٱلۡمُرۡسَلِينَ ١٢٣",
      "numberInSurah": 123
    },
    {
      "text": "إِذۡ قَالَ لِقَوۡمِهِۦٓ أَلَا تَتَّقُونَ ١٢٤",
      "numberInSurah": 124
    },
    {
      "text": "أَتَدۡعُونَ بَعۡلٗا وَتَذَرُونَ أَحۡسَنَ ٱلۡخَٰلِقِينَ ١٢٥",
      "numberInSurah": 125
    },
    {
      "text": "ٱللَّهُ رَبُّكُمۡ وَرَبُّ ءَابَآئِكُمُ ٱلۡأَوَّلِينَ ١٢٦",
      "numberInSurah": 126
    }
  ]
}
