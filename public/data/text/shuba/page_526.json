{
  "pageNumber": 526,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَٱلنَّجۡمِ إِذَا هَوَىٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَا ضَلَّ صَاحِبُكُمۡ وَمَا غَوَىٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا يَنطِقُ عَنِ ٱلۡهَوَىٰٓ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنۡ هُوَ إِلَّا وَحۡيٞ يُوحَىٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "عَلَّمَهُۥ شَدِيدُ ٱلۡقُوَىٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "ذُو مِرَّةٖ فَٱسۡتَوَىٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَهُوَ بِٱلۡأُفُقِ ٱلۡأَعۡلَىٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "ثُمَّ دَنَا فَتَدَلَّىٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَكَانَ قَابَ قَوۡسَيۡنِ أَوۡ أَدۡنَىٰ ٩",
      "numberInSurah": 9
    },
    {
      "text": "فَأَوۡحَىٰٓ إِلَىٰ عَبۡدِهِۦ مَآ أَوۡحَىٰ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "مَا كَذَبَ ٱلۡفُؤَادُ مَا رٜأٜىٰٓ ١١",
      "numberInSurah": 11
    },
    {
      "text": "أَفَتُمَٰرُونَهُۥ عَلَىٰ مَا يَرَىٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَلَقَدۡ رٜءٜاهُ نَزۡلَةً أُخۡرَىٰ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "عِندَ سِدۡرَةِ ٱلۡمُنتَهَىٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "عِندَهَا جَنَّةُ ٱلۡمَأۡوَىٰٓ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "إِذۡ يَغۡشَى ٱلسِّدۡرَةَ مَا يَغۡشَىٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "مَا زَاغَ ٱلۡبَصَرُ وَمَا طَغَىٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "لَقَدۡ رٜأٜىٰ مِنۡ ءَايَٰتِ رَبِّهِ ٱلۡكُبۡرَىٰٓ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "أَفَرَءَيۡتُمُ ٱللَّٰتَ وَٱلۡعُزَّىٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَمَنَوٰةَ ٱلثَّالِثَةَ ٱلۡأُخۡرَىٰٓ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "أَلَكُمُ ٱلذَّكَرُ وَلَهُ ٱلۡأُنثَىٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "تِلۡكَ إِذٗا قِسۡمَةٞ ضِيزَىٰٓ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "إِنۡ هِيَ إِلَّآ أَسۡمَآءٞ سَمَّيۡتُمُوهَآ أَنتُمۡ وَءَابَآؤُكُم مَّآ أَنزَلَ ٱللَّهُ بِهَا مِن سُلۡطَٰنٍۚ إِن يَتَّبِعُونَ إِلَّا ٱلظَّنَّ وَمَا تَهۡوَى ٱلۡأَنفُسُۖ وَلَقَدۡ جَآءَهُم مِّن رَّبِّهِمُ ٱلۡهُدَىٰٓ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "أَمۡ لِلۡإِنسَٰنِ مَا تَمَنَّىٰ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَلِلَّهِ ٱلۡأٓخِرَةُ وَٱلۡأُولَىٰ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "۞وَكَم مِّن مَّلَكٖ فِي ٱلسَّمَٰوَٰتِ لَا تُغۡنِي شَفَٰعَتُهُمۡ شَيۡـًٔا إِلَّا مِنۢ بَعۡدِ أَن يَأۡذَنَ ٱللَّهُ لِمَن يَشَآءُ وَيَرۡضَىٰٓ ٢٦",
      "numberInSurah": 26
    }
  ]
}
