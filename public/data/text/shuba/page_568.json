{
  "pageNumber": 568,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "وَلَا طَعَامٌ إِلَّا مِنۡ غِسۡلِينٖ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لَّا يَأۡكُلُهُۥٓ إِلَّا ٱلۡخَٰطِـُٔونَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَلَآ أُقۡسِمُ بِمَا تُبۡصِرُونَ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "وَمَا لَا تُبۡصِرُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "وَمَا هُوَ بِقَوۡلِ شَاعِرٖۚ قَلِيلٗا مَّا تُؤۡمِنُونَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "وَلَا بِقَوۡلِ كَاهِنٖۚ قَلِيلٗا مَّا تَذَّكَّرُونَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ ٱلۡعَٰلَمِينَ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "وَلَوۡ تَقَوَّلَ عَلَيۡنَا بَعۡضَ ٱلۡأَقَاوِيلِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "لَأَخَذۡنَا مِنۡهُ بِٱلۡيَمِينِ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "ثُمَّ لَقَطَعۡنَا مِنۡهُ ٱلۡوَتِينَ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "فَمَا مِنكُم مِّنۡ أَحَدٍ عَنۡهُ حَٰجِزِينَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَإِنَّهُۥ لَتَذۡكِرَةٞ لِّلۡمُتَّقِينَ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَإِنَّا لَنَعۡلَمُ أَنَّ مِنكُم مُّكَذِّبِينَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَإِنَّهُۥ لَحَسۡرَةٌ عَلَى ٱلۡكَٰفِرِينَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَإِنَّهُۥ لَحَقُّ ٱلۡيَقِينِ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "سُورَةُ المَعَارِجِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ سَأَلَ سَآئِلُۢ بِعَذَابٖ وَاقِعٖ ١",
      "numberInSurah": 1
    },
    {
      "text": "لِّلۡكَٰفِرِينَ لَيۡسَ لَهُۥ دَافِعٞ ٢",
      "numberInSurah": 2
    },
    {
      "text": "مِّنَ ٱللَّهِ ذِي ٱلۡمَعَارِجِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "تَعۡرُجُ ٱلۡمَلَٰٓئِكَةُ وَٱلرُّوحُ إِلَيۡهِ فِي يَوۡمٖ كَانَ مِقۡدَارُهُۥ خَمۡسِينَ أَلۡفَ سَنَةٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَٱصۡبِرۡ صَبۡرٗا جَمِيلًا ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِنَّهُمۡ يَرَوۡنَهُۥ بَعِيدٗا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَنَرَىٰهُ قَرِيبٗا ٧",
      "numberInSurah": 7
    },
    {
      "text": "يَوۡمَ تَكُونُ ٱلسَّمَآءُ كَٱلۡمُهۡلِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَلَا يَسۡـَٔلُ حَمِيمٌ حَمِيمٗا ١٠",
      "numberInSurah": 10
    }
  ]
}
