{
  "pageNumber": 601,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَٱلۡعَصۡرِ ١",
      "numberInSurah": 1
    },
    {
      "text": "إِنَّ ٱلۡإِنسَٰنَ لَفِي خُسۡرٍ ٢",
      "numberInSurah": 2
    },
    {
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ وَتَوَاصَوۡاْ بِٱلۡحَقِّ وَتَوَاصَوۡاْ بِٱلصَّبۡرِ ٣",
      "numberInSurah": 3
    },
    {
      "text": "سُورَةُ الهُمَزَةِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ ١",
      "numberInSurah": 1
    },
    {
      "text": "ٱلَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ ٢",
      "numberInSurah": 2
    },
    {
      "text": "يَحۡسَبُ أَنَّ مَالَهُۥٓ أَخۡلَدَهُۥ ٣",
      "numberInSurah": 3
    },
    {
      "text": "كَلَّاۖ لَيُنۢبَذَنَّ فِي ٱلۡحُطَمَةِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَمَآ أَدۡرٜىٰكَ مَا ٱلۡحُطَمَةُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ ٦",
      "numberInSurah": 6
    },
    {
      "text": "ٱلَّتِي تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "إِنَّهَا عَلَيۡهِم مُّوصَدَةٞ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فِي عُمُدٖ مُّمَدَّدَةِۭ ٩",
      "numberInSurah": 9
    },
    {
      "text": "سُورَةُ الفِيلِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ أَلَمۡ تَرَ كَيۡفَ فَعَلَ رَبُّكَ بِأَصۡحَٰبِ ٱلۡفِيلِ ١",
      "numberInSurah": 1
    },
    {
      "text": "أَلَمۡ يَجۡعَلۡ كَيۡدَهُمۡ فِي تَضۡلِيلٖ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَأَرۡسَلَ عَلَيۡهِمۡ طَيۡرًا أَبَابِيلَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "تَرۡمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَجَعَلَهُمۡ كَعَصۡفٖ مَّأۡكُولِۭ ٥",
      "numberInSurah": 5
    }
  ]
}
