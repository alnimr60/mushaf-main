{
  "pageNumber": 600,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "إِنَّ ٱلۡإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٞ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِنَّهُۥ لِحُبِّ ٱلۡخَيۡرِ لَشَدِيدٌ ٨",
      "numberInSurah": 8
    },
    {
      "text": "۞أَفَلَا يَعۡلَمُ إِذَا بُعۡثِرَ مَا فِي ٱلۡقُبُورِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَحُصِّلَ مَا فِي ٱلصُّدُورِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "إِنَّ رَبَّهُم بِهِمۡ يَوۡمَئِذٖ لَّخَبِيرُۢ ١١",
      "numberInSurah": 11
    },
    {
      "text": "سُورَةُ القَارِعَةِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ٱلۡقَارِعَةُ ١",
      "numberInSurah": 1
    },
    {
      "text": "مَا ٱلۡقَارِعَةُ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَآ أَدۡرٜىٰكَ مَا ٱلۡقَارِعَةُ ٣",
      "numberInSurah": 3
    },
    {
      "text": "يَوۡمَ يَكُونُ ٱلنَّاسُ كَٱلۡفَرَاشِ ٱلۡمَبۡثُوثِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَتَكُونُ ٱلۡجِبَالُ كَٱلۡعِهۡنِ ٱلۡمَنفُوشِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَأَمَّا مَن ثَقُلَتۡ مَوَٰزِينُهُۥ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَهُوَ فِي عِيشَةٖ رَّاضِيَةٖ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَأَمَّا مَنۡ خَفَّتۡ مَوَٰزِينُهُۥ ٨",
      "numberInSurah": 8
    },
    {
      "text": "فَأُمُّهُۥ هَاوِيَةٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَمَآ أَدۡرٜىٰكَ مَا هِيَهۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "نَارٌ حَامِيَةُۢ ١١",
      "numberInSurah": 11
    },
    {
      "text": "سُورَةُ التَّكَاثُرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ أَلۡهَىٰكُمُ ٱلتَّكَاثُرُ ١",
      "numberInSurah": 1
    },
    {
      "text": "حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "كَلَّا سَوۡفَ تَعۡلَمُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "ثُمَّ كَلَّا سَوۡفَ تَعۡلَمُونَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "كَلَّا لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "لَتَرَوُنَّ ٱلۡجَحِيمَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ ٧",
      "numberInSurah": 7
    },
    {
      "text": "ثُمَّ لَتُسۡـَٔلُنَّ يَوۡمَئِذٍ عَنِ ٱلنَّعِيمِ ٨",
      "numberInSurah": 8
    }
  ]
}
