{
  "pageNumber": 342,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ ١",
      "numberInSurah": 1
    },
    {
      "text": "ٱلَّذِينَ هُمۡ فِي صَلَاتِهِمۡ خَٰشِعُونَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلَّذِينَ هُمۡ عَنِ ٱللَّغۡوِ مُعۡرِضُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلَّذِينَ هُمۡ لِلزَّكَوٰةِ فَٰعِلُونَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَٱلَّذِينَ هُمۡ لِفُرُوجِهِمۡ حَٰفِظُونَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِلَّا عَلَىٰٓ أَزۡوَٰجِهِمۡ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمۡ فَإِنَّهُمۡ غَيۡرُ مَلُومِينَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ ٱلۡعَادُونَ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَٱلَّذِينَ هُمۡ لِأَمَٰنَٰتِهِمۡ وَعَهۡدِهِمۡ رَٰعُونَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَٱلَّذِينَ هُمۡ عَلَىٰ صَلَوَٰتِهِمۡ يُحَافِظُونَ ٩",
      "numberInSurah": 9
    },
    {
      "text": "أُوْلَٰٓئِكَ هُمُ ٱلۡوَٰرِثُونَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "ٱلَّذِينَ يَرِثُونَ ٱلۡفِرۡدَوۡسَ هُمۡ فِيهَا خَٰلِدُونَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ مِن سُلَٰلَةٖ مِّن طِينٖ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "ثُمَّ جَعَلۡنَٰهُ نُطۡفَةٗ فِي قَرَارٖ مَّكِينٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "ثُمَّ خَلَقۡنَا ٱلنُّطۡفَةَ عَلَقَةٗ فَخَلَقۡنَا ٱلۡعَلَقَةَ مُضۡغَةٗ فَخَلَقۡنَا ٱلۡمُضۡغَةَ عَظۡمٗا فَكَسَوۡنَا ٱلۡعَظۡمَ لَحۡمٗا ثُمَّ أَنشَأۡنَٰهُ خَلۡقًا ءَاخَرَۚ فَتَبَارَكَ ٱللَّهُ أَحۡسَنُ ٱلۡخَٰلِقِينَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "ثُمَّ إِنَّكُم بَعۡدَ ذَٰلِكَ لَمَيِّتُونَ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ثُمَّ إِنَّكُمۡ يَوۡمَ ٱلۡقِيَٰمَةِ تُبۡعَثُونَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَلَقَدۡ خَلَقۡنَا فَوۡقَكُمۡ سَبۡعَ طَرَآئِقَ وَمَا كُنَّا عَنِ ٱلۡخَلۡقِ غَٰفِلِينَ ١٧",
      "numberInSurah": 17
    }
  ]
}
