{
  "pageNumber": 376,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "مَآ أَغۡنَىٰ عَنۡهُم مَّا كَانُواْ يُمَتَّعُونَ ٢٠٧",
      "numberInSurah": 207
    },
    {
      "text": "وَمَآ أَهۡلَكۡنَا مِن قَرۡيَةٍ إِلَّا لَهَا مُنذِرُونَ ٢٠٨",
      "numberInSurah": 208
    },
    {
      "text": "ذِكۡرَىٰ وَمَا كُنَّا ظَٰلِمِينَ ٢٠٩",
      "numberInSurah": 209
    },
    {
      "text": "وَمَا تَنَزَّلَتۡ بِهِ ٱلشَّيَٰطِينُ ٢١٠",
      "numberInSurah": 210
    },
    {
      "text": "وَمَا يَنۢبَغِي لَهُمۡ وَمَا يَسۡتَطِيعُونَ ٢١١",
      "numberInSurah": 211
    },
    {
      "text": "إِنَّهُمۡ عَنِ ٱلسَّمۡعِ لَمَعۡزُولُونَ ٢١٢",
      "numberInSurah": 212
    },
    {
      "text": "فَلَا تَدۡعُ مَعَ ٱللَّهِ إِلَٰهًا ءَاخَرَ فَتَكُونَ مِنَ ٱلۡمُعَذَّبِينَ ٢١٣",
      "numberInSurah": 213
    },
    {
      "text": "وَأَنذِرۡ عَشِيرَتَكَ ٱلۡأَقۡرَبِينَ ٢١٤",
      "numberInSurah": 214
    },
    {
      "text": "وَٱخۡفِضۡ جَنَاحَكَ لِمَنِ ٱتَّبَعَكَ مِنَ ٱلۡمُؤۡمِنِينَ ٢١٥",
      "numberInSurah": 215
    },
    {
      "text": "فَإِنۡ عَصَوۡكَ فَقُلۡ إِنِّي بَرِيٓءٞ مِّمَّا تَعۡمَلُونَ ٢١٦",
      "numberInSurah": 216
    },
    {
      "text": "وَتَوَكَّلۡ عَلَى ٱلۡعَزِيزِ ٱلرَّحِيمِ ٢١٧",
      "numberInSurah": 217
    },
    {
      "text": "ٱلَّذِي يَرَىٰكَ حِينَ تَقُومُ ٢١٨",
      "numberInSurah": 218
    },
    {
      "text": "وَتَقَلُّبَكَ فِي ٱلسَّٰجِدِينَ ٢١٩",
      "numberInSurah": 219
    },
    {
      "text": "إِنَّهُۥ هُوَ ٱلسَّمِيعُ ٱلۡعَلِيمُ ٢٢٠",
      "numberInSurah": 220
    },
    {
      "text": "هَلۡ أُنَبِّئُكُمۡ عَلَىٰ مَن تَنَزَّلُ ٱلشَّيَٰطِينُ ٢٢١",
      "numberInSurah": 221
    },
    {
      "text": "تَنَزَّلُ عَلَىٰ كُلِّ أَفَّاكٍ أَثِيمٖ ٢٢٢",
      "numberInSurah": 222
    },
    {
      "text": "يُلۡقُونَ ٱلسَّمۡعَ وَأَكۡثَرُهُمۡ كَٰذِبُونَ ٢٢٣",
      "numberInSurah": 223
    },
    {
      "text": "وَٱلشُّعَرَآءُ يَتَّبِعُهُمُ ٱلۡغَاوُۥنَ ٢٢٤",
      "numberInSurah": 224
    },
    {
      "text": "أَلَمۡ تَرَ أَنَّهُمۡ فِي كُلِّ وَادٖ يَهِيمُونَ ٢٢٥",
      "numberInSurah": 225
    },
    {
      "text": "وَأَنَّهُمۡ يَقُولُونَ مَا لَا يَفۡعَلُونَ ٢٢٦",
      "numberInSurah": 226
    },
    {
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ وَذَكَرُواْ ٱللَّهَ كَثِيرٗا وَٱنتَصَرُواْ مِنۢ بَعۡدِ مَا ظُلِمُواْۗ وَسَيَعۡلَمُ ٱلَّذِينَ ظَلَمُوٓاْ أَيَّ مُنقَلَبٖ يَنقَلِبُونَ ٢٢٧",
      "numberInSurah": 227
    }
  ]
}
