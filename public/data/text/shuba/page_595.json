  "ayahs": [
    {
      "text": "وَٱلَّذِينَ كَفَرُواْ بِـَٔايَٰتِنَا هُمۡ أَصۡحَٰبُ ٱلۡمَشۡـَٔمَةِ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "عَلَيۡهِمۡ نَارٞ مُّوصَدَةُۢ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "سُورَةُ الشَّمۡسِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلشَّمۡسِ وَضُحَىٰهَا ١",
      "numberInSurah": 1
    },
    {
      "text": "وَٱلۡقَمَرِ إِذَا تَلَىٰهَا ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلنَّهَارِ إِذَا جَلَّىٰهَا ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلَّيۡلِ إِذَا يَغۡشَىٰهَا ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَٱلسَّمَآءِ وَمَا بَنَىٰهَا ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَٱلۡأَرۡضِ وَمَا طَحَىٰهَا ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَنَفۡسٖ وَمَا سَوَّىٰهَا ٧",
      "numberInSurah": 7
    },
    {
      "text": "فَأَلۡهَمَهَا فُجُورَهَا وَتَقۡوَىٰهَا ٨",
      "numberInSurah": 8
    },
    {
      "text": "قَدۡ أَفۡلَحَ مَن زَكَّىٰهَا ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَقَدۡ خَابَ مَن دَسَّىٰهَا ١٠",
      "numberInSurah": 10
    },
    {
      "text": "كَذَّبَتۡ ثَمُودُ بِطَغۡوَىٰهَآ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِذِ ٱنۢبَعَثَ أَشۡقَىٰهَا ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَقَالَ لَهُمۡ رَسُولُ ٱللَّهِ نَاقَةَ ٱللَّهِ وَسُقۡيَٰهَا ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمۡدَمَ عَلَيۡهِمۡ رَبُّهُم بِذَنۢبِهِمۡ فَسَوَّىٰهَا ١٤",
      "numberInSurah": 14
    },
    {
      "text": "وَلَا يَخَافُ عُقۡبَٰهَا ١٥",
      "numberInSurah": 15
    },
    {
      "text": "سُورَةُ اللَّيۡلِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلَّيۡلِ إِذَا يَغۡشَىٰ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ ٣",
      "numberInSurah": 3
    },
    {
      "text": "إِنَّ سَعۡيَكُمۡ لَشَتَّىٰ ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَأَمَّا مَنۡ أَعۡطَىٰ وَٱتَّقَىٰ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَصَدَّقَ بِٱلۡحُسۡنَىٰ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَسَنُيَسِّرُهُۥ لِلۡيُسۡرَىٰ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسۡتَغۡنَىٰ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَكَذَّبَ بِٱلۡحُسۡنَىٰ ٩",
      "numberInSurah": 9
    }
  ]
