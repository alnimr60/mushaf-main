{
  "pageNumber": 584,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فَقُلۡ هَل لَّكَ إِلَىٰٓ أَن تَزَكَّىٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "وَأَهۡدِيَكَ إِلَىٰ رَبِّكَ فَتَخۡشَىٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "فَأَرَىٰهُ ٱلۡأٓيَةَ ٱلۡكُبۡرَىٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "فَكَذَّبَ وَعَصَىٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ أَدۡبَرَ يَسۡعَىٰ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "فَحَشَرَ فَنَادَىٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَقَالَ أَنَا۠ رَبُّكُمُ ٱلۡأَعۡلَىٰ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "فَأَخَذَهُ ٱللَّهُ نَكَالَ ٱلۡأٓخِرَةِ وَٱلۡأُولَىٰٓ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَعِبۡرَةٗ لِّمَن يَخۡشَىٰٓ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "ءَأَنتُمۡ أَشَدُّ خَلۡقًا أَمِ ٱلسَّمَآءُۚ بَنَىٰهَا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "رَفَعَ سَمۡكَهَا فَسَوَّىٰهَا ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَأَغۡطَشَ لَيۡلَهَا وَأَخۡرَجَ ضُحَىٰهَا ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "وَٱلۡأَرۡضَ بَعۡدَ ذَٰلِكَ دَحَىٰهَآ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "أَخۡرَجَ مِنۡهَا مَآءَهَا وَمَرۡعَىٰهَا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَٱلۡجِبَالَ أَرۡسَىٰهَا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "مَتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "فَإِذَا جَآءَتِ ٱلطَّآمَّةُ ٱلۡكُبۡرَىٰ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "يَوۡمَ يَتَذَكَّرُ ٱلۡإِنسَٰنُ مَا سَعَىٰ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَبُرِّزَتِ ٱلۡجَحِيمُ لِمَن يَرَىٰ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "فَأَمَّا مَن طَغَىٰ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "وَءَاثَرَ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "فَإِنَّ ٱلۡجَحِيمَ هِيَ ٱلۡمَأۡوَىٰ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "وَأَمَّا مَنۡ خَافَ مَقَامَ رَبِّهِۦ وَنَهَى ٱلنَّفۡسَ عَنِ ٱلۡهَوَىٰ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "فَإِنَّ ٱلۡجَنَّةَ هِيَ ٱلۡمَأۡوَىٰ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "يَسۡـَٔلُونَكَ عَنِ ٱلسَّاعَةِ أَيَّانَ مُرۡسَىٰهَا ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "فِيمَ أَنتَ مِن ذِكۡرَىٰهَآ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "إِلَىٰ رَبِّكَ مُنتَهَىٰهَآ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَن يَخۡشَىٰهَا ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "كَأَنَّهُمۡ يَوۡمَ يَرَوۡنَهَا لَمۡ يَلۡبَثُوٓاْ إِلَّا عَشِيَّةً أَوۡ ضُحَىٰهَا ٤٦",
      "numberInSurah": 46
    }
  ]
}
