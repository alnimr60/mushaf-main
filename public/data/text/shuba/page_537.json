{
  "pageNumber": 537,
  "riwayaId": "shuba",
  "ayahs": [
    {
      "text": "إِنَّهُۥ لَقُرۡءَانٞ كَرِيمٞ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "فِي كِتَٰبٖ مَّكۡنُونٖ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "لَّا يَمَسُّهُۥٓ إِلَّا ٱلۡمُطَهَّرُونَ ٧٩",
      "numberInSurah": 79
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ ٱلۡعَٰلَمِينَ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "أَفَبِهَٰذَا ٱلۡحَدِيثِ أَنتُم مُّدۡهِنُونَ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "وَتَجۡعَلُونَ رِزۡقَكُمۡ أَنَّكُمۡ تُكَذِّبُونَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "فَلَوۡلَآ إِذَا بَلَغَتِ ٱلۡحُلۡقُومَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "وَأَنتُمۡ حِينَئِذٖ تَنظُرُونَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَنَحۡنُ أَقۡرَبُ إِلَيۡهِ مِنكُمۡ وَلَٰكِن لَّا تُبۡصِرُونَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "فَلَوۡلَآ إِن كُنتُمۡ غَيۡرَ مَدِينِينَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "تَرۡجِعُونَهَآ إِن كُنتُمۡ صَٰدِقِينَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "فَأَمَّآ إِن كَانَ مِنَ ٱلۡمُقَرَّبِينَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "فَرَوۡحٞ وَرَيۡحَانٞ وَجَنَّتُ نَعِيمٖ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنۡ أَصۡحَٰبِ ٱلۡيَمِينِ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "فَسَلَٰمٞ لَّكَ مِنۡ أَصۡحَٰبِ ٱلۡيَمِينِ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنَ ٱلۡمُكَذِّبِينَ ٱلضَّآلِّينَ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "فَنُزُلٞ مِّنۡ حَمِيمٖ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "وَتَصۡلِيَةُ جَحِيمٍ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ حَقُّ ٱلۡيَقِينِ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "فَسَبِّحۡ بِٱسۡمِ رَبِّكَ ٱلۡعَظِيمِ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "سُورَةُ الحَدِيدِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ سَبَّحَ لِلَّهِ مَا فِي ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۖ وَهُوَ ٱلۡعَزِيزُ ٱلۡحَكِيمُ ١",
      "numberInSurah": 1
    },
    {
      "text": "لَهُۥ مُلۡكُ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۖ يُحۡيِۦ وَيُمِيتُۖ وَهُوَ عَلَىٰ كُلِّ شَيۡءٖ قَدِيرٌ ٢",
      "numberInSurah": 2
    },
    {
      "text": "هُوَ ٱلۡأَوَّلُ وَٱلۡأٓخِرُ وَٱلظَّٰهِرُ وَٱلۡبَاطِنُۖ وَهُوَ بِكُلِّ شَيۡءٍ عَلِيمٌ ٣",
      "numberInSurah": 3
    }
  ]
}
