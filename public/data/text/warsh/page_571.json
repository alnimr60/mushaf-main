{
  "pageNumber": 571,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "يُرْسِلِ اِ۬لسَّمَآءَ عَلَيْكُم مِّدْرَاراٗ ١١",
      "numberInSurah": 11,
      "verse_key": "71:11"
    },
    {
      "text": "وَيُمْدِدْكُم بِأَمْوَٰلٖ وَبَنِينَ وَيَجْعَل لَّكُمْ جَنَّٰتٖ وَيَجْعَل لَّكُمُۥٓ أَنْهَٰراٗۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "71:12"
    },
    {
      "text": "مَّا لَكُمْ لَا تَرْجُونَ لِلهِ وَقَاراٗ ١٣",
      "numberInSurah": 13,
      "verse_key": "71:13"
    },
    {
      "text": "وَقَدْ خَلَقَكُمُۥٓ أَطْوَاراًۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "71:14"
    },
    {
      "text": "۞اَلَمْ تَرَوْاْ كَيْفَ خَلَقَ اَ۬للَّهُ سَبْعَ سَمَٰوَٰتٖ طِبَاقاٗ ١٥",
      "numberInSurah": 15,
      "verse_key": "71:15"
    },
    {
      "text": "وَجَعَلَ اَ۬لْقَمَرَ فِيهِنَّ نُوراٗ وَجَعَلَ اَ۬لشَّمْسَ سِرَاجاٗۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "71:16"
    },
    {
      "text": "وَاللَّهُ أَنۢبَتَكُم مِّنَ اَ۬لَارْضِ نَبَاتاٗ ١٧",
      "numberInSurah": 17,
      "verse_key": "71:17"
    },
    {
      "text": "ثُمَّ يُعِيدُكُمْ فِيهَا وَيُخْرِجُكُمُۥٓ إِخْرَاجاٗۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "71:18"
    },
    {
      "text": "وَاللَّهُ جَعَلَ لَكُمُ اُ۬لَارْضَ بِسَاطاٗ ١٩",
      "numberInSurah": 19,
      "verse_key": "71:19"
    },
    {
      "text": "لِّتَسْلُكُواْ مِنْهَا سُبُلاٗ فِجَاجاٗۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "71:20"
    },
    {
      "text": "قَالَ نُوحٞ رَّبِّ إِنَّهُمْ عَصَوْنِے وَاتَّبَعُواْ مَن لَّمْ يَزِدْهُ مَالُهُۥ وَوَلَدُهُۥٓ إِلَّا خَسَاراٗ ٢١",
      "numberInSurah": 21,
      "verse_key": "71:21"
    },
    {
      "text": "وَمَكَرُواْ مَكْراٗ كُبَّاراٗۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "71:22"
    },
    {
      "text": "وَقَالُواْ لَا تَذَرُنَّ ءَالِهَتَكُمْ وَلَا تَذَرُنَّ وُدّاٗ وَلَا سُوَاعاٗ ٢٣",
      "numberInSurah": 23,
      "verse_key": "71:23"
    },
    {
      "text": "وَلَا يَغُوثَ وَيَعُوقَ وَنَسْراٗۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "71:24"
    },
    {
      "text": "وَقَدَ اَضَلُّواْ كَثِيراٗۖ وَلَا تَزِدِ اِ۬لظَّٰلِمِينَ إِلَّا ضَلَٰلاٗۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "71:25"
    },
    {
      "text": "مِّمَّا خَطِيٓـَٰٔتِهِمُۥٓ أُغْرِقُواْ فَأُدْخِلُواْ نَاراٗ ٢٦",
      "numberInSurah": 26,
      "verse_key": "71:26"
    },
    {
      "text": "فَلَمْ يَجِدُواْ لَهُم مِّن دُونِ اِ۬للَّهِ أَنصَاراٗۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "71:27"
    },
    {
      "text": "وَقَالَ نُوحٞ رَّبِّ لَا تَذَرْ عَلَي اَ۬لَارْضِ مِنَ اَ۬لْكٰ۪فِرِينَ دَيَّاراًۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "71:28"
    }
  ],
