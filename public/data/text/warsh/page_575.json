  "ayahs": [
    {
      "text": "",
      "numberInSurah": 20,
      "verse_key": "73:20"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "يَٰٓأَيُّهَا اَ۬لْمُدَّثِّرُ ١",
      "numberInSurah": 1,
      "verse_key": "74:1"
    },
    {
      "text": "قُمْ فَأَنذِرْۖ ٢",
      "numberInSurah": 2,
      "verse_key": "74:2"
    },
    {
      "text": "وَرَبَّكَ فَكَبِّرْ ٣",
      "numberInSurah": 3,
      "verse_key": "74:3"
    },
    {
      "text": "وَثِيَابَكَ فَطَهِّرْۖ ٤",
      "numberInSurah": 4,
      "verse_key": "74:4"
    },
    {
      "text": "وَالرِّجْزَ فَاهْجُرْۖ ٥",
      "numberInSurah": 5,
      "verse_key": "74:5"
    },
    {
      "text": "وَلَا تَمْنُن تَسْتَكْثِرُۖ ٦",
      "numberInSurah": 6,
      "verse_key": "74:6"
    },
    {
      "text": "وَلِرَبِّكَ فَاصْبِرْۖ ٧",
      "numberInSurah": 7,
      "verse_key": "74:7"
    },
    {
      "text": "فَإِذَا نُقِرَ فِے اِ۬لنَّاقُورِ ٨",
      "numberInSurah": 8,
      "verse_key": "74:8"
    },
    {
      "text": "فَذَٰلِكَ يَوْمَئِذٖ يَوْمٌ عَسِيرٌ ٩",
      "numberInSurah": 9,
      "verse_key": "74:9"
    },
    {
      "text": "عَلَي اَ۬لْكٰ۪فِرِينَ غَيْرُ يَسِيرٖۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "74:10"
    },
    {
      "text": "ذَرْنِے وَمَنْ خَلَقْتُ وَحِيداٗ ١١",
      "numberInSurah": 11,
      "verse_key": "74:11"
    },
    {
      "text": "وَجَعَلْتُ لَهُۥ مَالاٗ مَّمْدُوداٗ ١٢",
      "numberInSurah": 12,
      "verse_key": "74:12"
    },
    {
      "text": "وَبَنِينَ شُهُوداٗ ١٣",
      "numberInSurah": 13,
      "verse_key": "74:13"
    },
    {
      "text": "وَمَهَّدتُّ لَهُۥ تَمْهِيداٗ ١٤",
      "numberInSurah": 14,
      "verse_key": "74:14"
    },
    {
      "text": "ثُمَّ يَطْمَعُ أَنَ اَزِيدَ ١٥",
      "numberInSurah": 15,
      "verse_key": "74:15"
    },
    {
      "text": "كَلَّآۖ إِنَّهُۥ كَانَ لِأٓيَٰتِنَا عَنِيداٗۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "74:16"
    },
    {
      "text": "سَأُرْهِقُهُۥ صَعُوداًۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "74:17"
    }
  ],
