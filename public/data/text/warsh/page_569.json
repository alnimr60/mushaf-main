{
  "pageNumber": 569,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "يُبَصَّرُونَهُمْۖ يَوَدُّ اُ۬لْمُجْرِمُ لَوْ يَفْتَدِے مِنْ عَذَابِ يَوْمَئِذِۢ بِبَنِيهِ ١١",
      "numberInSurah": 11,
      "verse_key": "70:11"
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَأَخِيهِ ١٢",
      "numberInSurah": 12,
      "verse_key": "70:12"
    },
    {
      "text": "وَفَصِيلَتِهِ اِ۬لتِے تُـْٔوِيهِ ١٣",
      "numberInSurah": 13,
      "verse_key": "70:13"
    },
    {
      "text": "وَمَن فِے اِ۬لَارْضِ جَمِيعاٗ ثُمَّ يُنجِيهِ ١٤",
      "numberInSurah": 14,
      "verse_key": "70:14"
    },
    {
      "text": "كَلَّآۖ إِنَّهَا لَظ۪يٰ ١٥",
      "numberInSurah": 15,
      "verse_key": "70:15"
    },
    {
      "text": "نَزَّاعَةٞ لِّلشَّو۪يٰ ١٦",
      "numberInSurah": 16,
      "verse_key": "70:16"
    },
    {
      "text": "تَدْعُواْ مَنَ اَدْبَرَ وَتَوَلّ۪يٰ ١٧",
      "numberInSurah": 17,
      "verse_key": "70:17"
    },
    {
      "text": "وَجَمَعَ فَأَوْع۪يٰٓۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "70:18"
    },
    {
      "text": "إِنَّ اَ۬لِانسَٰنَ خُلِقَ هَلُوعاً ١٩",
      "numberInSurah": 19,
      "verse_key": "70:19"
    },
    {
      "text": "اِذَا مَسَّهُ اُ۬لشَّرُّ جَزُوعاٗ ٢٠",
      "numberInSurah": 20,
      "verse_key": "70:20"
    },
    {
      "text": "وَإِذَا مَسَّهُ اُ۬لْخَيْرُ مَنُوعاً ٢١",
      "numberInSurah": 21,
      "verse_key": "70:21"
    },
    {
      "text": "اِلَّا اَ۬لْمُصَلِّينَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "70:22"
    },
    {
      "text": "اَ۬لذِينَ هُمْ عَلَيٰ صَلَاتِهِمْ دَآئِمُونَۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "70:23"
    },
    {
      "text": "وَالذِينَ فِےٓ أَمْوَٰلِهِمْ حَقّٞ مَّعْلُومٞ ٢٤",
      "numberInSurah": 24,
      "verse_key": "70:24"
    },
    {
      "text": "لِّلسَّآئِلِ وَالْمَحْرُومِۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "70:25"
    },
    {
      "text": "وَالذِينَ يُصَدِّقُونَ بِيَوْمِ اِ۬لدِّينِۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "70:26"
    },
    {
      "text": "وَالذِينَ هُم مِّنْ عَذَابِ رَبِّهِم مُّشْفِقُونَ ٢٧",
      "numberInSurah": 27,
      "verse_key": "70:27"
    },
    {
      "text": "إِنَّ عَذَابَ رَبِّهِمْ غَيْرُ مَامُونٖۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "70:28"
    },
    {
      "text": "وَالذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ ٢٩",
      "numberInSurah": 29,
      "verse_key": "70:29"
    },
    {
      "text": "إِلَّا عَلَيٰٓ أَزْوَٰجِهِمُۥٓ أَوْ مَا مَلَكَتَ اَيْمَٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "70:30"
    },
    {
      "text": "فَمَنِ اِ۪بْتَغ۪يٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ اُ۬لْعَادُونَۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "70:31"
    },
    {
      "text": "وَالذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "70:32"
    },
    {
      "text": "وَالذِينَ هُم بِشَهَٰدَتِهِمْ قَآئِمُونَۖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "70:33"
    },
    {
      "text": "وَالذِينَ هُمْ عَلَيٰ صَلَاتِهِمْ يُحَافِظُونَ ٣٤",
      "numberInSurah": 34,
      "verse_key": "70:34"
    },
    {
      "text": "أُوْلَٰٓئِكَ فِے جَنَّٰتٖ مُّكْرَمُونَۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "70:35"
    },
    {
      "text": "فَمَالِ اِ۬لذِينَ كَفَرُواْ قِبَلَكَ مُهْطِعِينَ ٣٦",
      "numberInSurah": 36,
      "verse_key": "70:36"
    },
    {
      "text": "عَنِ اِ۬لْيَمِينِ وَعَنِ اِ۬لشِّمَالِ عِزِينَۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "70:37"
    },
    {
      "text": "أَيَطْمَعُ كُلُّ اُ۪مْرِےٕٖ مِّنْهُمُۥٓ أَنْ يُّدْخَلَ جَنَّةَ نَعِيمٖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "70:38"
    },
    {
      "text": "كَلَّآۖ إِنَّا خَلَقْنَٰهُم مِّمَّا يَعْلَمُونَۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "70:39"
    }
  ],
