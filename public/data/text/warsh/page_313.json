{
  "pageNumber": 313,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "إِنَّنِيَ أَنَا اَ۬للَّهُ لَآ إِلَٰهَ إِلَّآ أَنَا فَاعْبُدْنِے وَأَقِمِ اِ۬لصَّلَوٰةَ لِذِكْرِيَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "20:13"
    },
    {
      "text": "إِنَّ اَ۬لسَّاعَةَ ءَاتِيَةٌ اَكَادُ أُخْفِيهَا لِتُجْز۪يٰ كُلُّ نَفْسِۢ بِمَا تَسْع۪يٰۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "20:14"
    },
    {
      "text": "فَلَا يَصُدَّنَّكَ عَنْهَا مَن لَّا يُومِنُ بِهَا وَاتَّبَعَ هَو۪يٰهُ فَتَرْد۪يٰۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "20:15"
    },
    {
      "text": "وَمَا تِلْكَ بِيَمِينِكَ يَٰمُوس۪يٰۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "20:16"
    },
    {
      "text": "قَالَ هِيَ عَصَايَ أَتَوَكَّؤُاْ عَلَيْهَا وَأَهُشُّ بِهَا عَلَيٰ غَنَمِے وَلِيَ فِيهَا مَـَٔارِبُ أُخْر۪يٰۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "20:17"
    },
    {
      "text": "قَالَ أَلْقِهَا يَٰمُوس۪يٰۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "20:18"
    },
    {
      "text": "فَأَلْق۪يٰهَا فَإِذَا هِيَ حَيَّةٞ تَسْع۪يٰۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "20:19"
    },
    {
      "text": "قَالَ خُذْهَا وَلَا تَخَفْ سَنُعِيدُهَا سِيرَتَهَا اَ۬لُاول۪يٰۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "20:20"
    },
    {
      "text": "وَاضْمُمْ يَدَكَ إِلَيٰ جَنَاحِكَ تَخْرُجْ بَيْضَآءَ مِنْ غَيْرِ سُوٓءٍ اٰيَةً ا۟خْر۪يٰ ٢١",
      "numberInSurah": 21,
      "verse_key": "20:21"
    },
    {
      "text": "لِنُرِيَكَ مِنَ اٰيَٰتِنَا اَ۬لْكُبْرَيۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "20:22"
    },
    {
      "text": "اَ۪ذْهَبِ اِلَيٰ فِرْعَوْنَ إِنَّهُۥ طَغ۪يٰۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "20:23"
    },
    {
      "text": "قَالَ رَبِّ اِ۪شْرَحْ لِے صَدْرِے ٢٤",
      "numberInSurah": 24,
      "verse_key": "20:24"
    },
    {
      "text": "وَيَسِّرْ لِيَ أَمْرِے ٢٥",
      "numberInSurah": 25,
      "verse_key": "20:25"
    },
    {
      "text": "وَاحْلُلْ عُقْدَةٗ مِّن لِّسَانِے ٢٦",
      "numberInSurah": 26,
      "verse_key": "20:26"
    },
    {
      "text": "يَفْقَهُواْ قَوْلِے ٢٧",
      "numberInSurah": 27,
      "verse_key": "20:27"
    },
    {
      "text": "وَاجْعَل لِّے وَزِيراٗ مِّنَ اَهْلِے ٢٨",
      "numberInSurah": 28,
      "verse_key": "20:28"
    },
    {
      "text": "هَٰرُونَ أَخِےۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "20:29"
    },
    {
      "text": "اِ۟شْدُدْ بِهِۦٓ أَزْرِے ٣٠",
      "numberInSurah": 30,
      "verse_key": "20:30"
    },
    {
      "text": "وَأَشْرِكْهُ فِےٓ أَمْرِے ٣١",
      "numberInSurah": 31,
      "verse_key": "20:31"
    },
    {
      "text": "كَےْ نُسَبِّحَكَ كَثِيراٗ ٣٢",
      "numberInSurah": 32,
      "verse_key": "20:32"
    },
    {
      "text": "وَنَذْكُرَكَ كَثِيراً ٣٣",
      "numberInSurah": 33,
      "verse_key": "20:33"
    },
    {
      "text": "اِنَّكَ كُنتَ بِنَا بَصِيراٗۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "20:34"
    },
    {
      "text": "۞قَالَ قَدُ ا۟وتِيتَ سُؤْلَكَ يَٰمُوس۪يٰۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "20:35"
    },
    {
      "text": "وَلَقَدْ مَنَنَّا عَلَيْكَ مَرَّةً ا۟خْر۪يٰٓ ٣٦",
      "numberInSurah": 36,
      "verse_key": "20:36"
    },
    {
      "text": "إِذَ اَوْحَيْنَآ إِلَيٰٓ أُمِّكَ مَا يُوح۪يٰٓ ٣٧",
      "numberInSurah": 37,
      "verse_key": "20:37"
    }
  ],
