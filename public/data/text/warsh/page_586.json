{
  "pageNumber": 586,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا اَ۬لشَّمْسُ كُوِّرَتْ ١",
      "numberInSurah": 1,
      "verse_key": "81:1"
    },
    {
      "text": "وَإِذَا اَ۬لنُّجُومُ اُ۪نكَدَرَتْ ٢",
      "numberInSurah": 2,
      "verse_key": "81:2"
    },
    {
      "text": "وَإِذَا اَ۬لْجِبَالُ سُيِّرَتْ ٣",
      "numberInSurah": 3,
      "verse_key": "81:3"
    },
    {
      "text": "وَإِذَا اَ۬لْعِشَارُ عُطِّلَتْ ٤",
      "numberInSurah": 4,
      "verse_key": "81:4"
    },
    {
      "text": "وَإِذَا اَ۬لْوُحُوشُ حُشِرَتْ ٥",
      "numberInSurah": 5,
      "verse_key": "81:5"
    },
    {
      "text": "وَإِذَا اَ۬لْبِحَارُ سُجِّرَتْ ٦",
      "numberInSurah": 6,
      "verse_key": "81:6"
    },
    {
      "text": "وَإِذَا اَ۬لنُّفُوسُ زُوِّجَتْ ٧",
      "numberInSurah": 7,
      "verse_key": "81:7"
    },
    {
      "text": "وَإِذَا اَ۬لْمَوْءُۥدَةُ سُئِلَتْ ٨",
      "numberInSurah": 8,
      "verse_key": "81:8"
    },
    {
      "text": "بِأَيِّ ذَنۢبٖ قُتِلَتْ ٩",
      "numberInSurah": 9,
      "verse_key": "81:9"
    },
    {
      "text": "وَإِذَا اَ۬لصُّحُفُ نُشِرَتْ ١٠",
      "numberInSurah": 10,
      "verse_key": "81:10"
    },
    {
      "text": "وَإِذَا اَ۬لسَّمَآءُ كُشِطَتْ ١١",
      "numberInSurah": 11,
      "verse_key": "81:11"
    },
    {
      "text": "وَإِذَا اَ۬لْجَحِيمُ سُعِّرَتْ ١٢",
      "numberInSurah": 12,
      "verse_key": "81:12"
    },
    {
      "text": "وَإِذَا اَ۬لْجَنَّةُ أُزْلِفَتْ ١٣",
      "numberInSurah": 13,
      "verse_key": "81:13"
    },
    {
      "text": "عَلِمَتْ نَفْسٞ مَّآ أَحْضَرَتْۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "81:14"
    },
    {
      "text": "فَلَآ أُقْسِمُ بِالْخُنَّسِ ١٥",
      "numberInSurah": 15,
      "verse_key": "81:15"
    },
    {
      "text": "اِ۬لْجَوَارِ اِ۬لْكُنَّسِ ١٦",
      "numberInSurah": 16,
      "verse_key": "81:16"
    },
    {
      "text": "وَاليْلِ إِذَا عَسْعَسَ ١٧",
      "numberInSurah": 17,
      "verse_key": "81:17"
    },
    {
      "text": "وَالصُّبْحِ إِذَا تَنَفَّسَ ١٨",
      "numberInSurah": 18,
      "verse_key": "81:18"
    },
    {
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٖ كَرِيمٖ ١٩",
      "numberInSurah": 19,
      "verse_key": "81:19"
    },
    {
      "text": "ذِے قُوَّةٍ عِندَ ذِے اِ۬لْعَرْشِ مَكِينٖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "81:20"
    },
    {
      "text": "مُّطَاعٖ ثَمَّ أَمِينٖۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "81:21"
    },
    {
      "text": "وَمَا صَٰحِبُكُم بِمَجْنُونٖۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "81:22"
    },
    {
      "text": "وَلَقَدْ ر۪ء۪اهُ بِالُافُقِ اِ۬لْمُبِينِۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "81:23"
    },
    {
      "text": "وَمَا هُوَ عَلَي اَ۬لْغَيْبِ بِضَنِينٖۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "81:24"
    },
    {
      "text": "وَمَا هُوَ بِقَوْلِ شَيْطَٰنٖ رَّجِيمٖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "81:25"
    },
    {
      "text": "فَأَيْنَ تَذْهَبُونَۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "81:26"
    },
    {
      "text": "إِنْ هُوَ إِلَّا ذِكْرٞ لِّلْعَٰلَمِينَ ٢٧",
      "numberInSurah": 27,
      "verse_key": "81:27"
    },
    {
      "text": "لِمَن شَآءَ مِنكُمُۥٓ أَنْ يَّسْتَقِيمَۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "81:28"
    },
    {
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَنْ يَّشَآءَ اَ۬للَّهُ رَبُّ اُ۬لْعَٰلَمِينَۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "81:29"
    }
  ],
