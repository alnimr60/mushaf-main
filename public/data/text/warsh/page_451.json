{
  "pageNumber": 451,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَكَذَّبُوهُ فَإِنَّهُمْ لَمُحْضَرُونَ ١٢٧",
      "numberInSurah": 127,
      "verse_key": "37:127"
    },
    {
      "text": "إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لْمُخْلَصِينَۖ ١٢٨",
      "numberInSurah": 128,
      "verse_key": "37:128"
    },
    {
      "text": "وَتَرَكْنَا عَلَيْهِ فِے اِ۬لَاخِرِينَۖ ١٢٩",
      "numberInSurah": 129,
      "verse_key": "37:129"
    },
    {
      "text": "سَلَٰمٌ عَلَيٰٓ ءَالِ يَاسِينَۖ ١٣٠",
      "numberInSurah": 130,
      "verse_key": "37:130"
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ١٣١",
      "numberInSurah": 131,
      "verse_key": "37:131"
    },
    {
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا اَ۬لْمُومِنِينَۖ ١٣٢",
      "numberInSurah": 132,
      "verse_key": "37:132"
    },
    {
      "text": "وَإِنَّ لُوطاٗ لَّمِنَ اَ۬لْمُرْسَلِينَ ١٣٣",
      "numberInSurah": 133,
      "verse_key": "37:133"
    },
    {
      "text": "إِذْ نَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ ١٣٤",
      "numberInSurah": 134,
      "verse_key": "37:134"
    },
    {
      "text": "إِلَّا عَجُوزاٗ فِے اِ۬لْغَٰبِرِينَ ١٣٥",
      "numberInSurah": 135,
      "verse_key": "37:135"
    },
    {
      "text": "ثُمَّ دَمَّرْنَا اَ۬لَاخَرِينَۖ ١٣٦",
      "numberInSurah": 136,
      "verse_key": "37:136"
    },
    {
      "text": "وَإِنَّكُمْ لَتَمُرُّونَ عَلَيْهِم مُّصْبِحِينَ ١٣٧",
      "numberInSurah": 137,
      "verse_key": "37:137"
    },
    {
      "text": "وَبِاليْلِۖ أَفَلَا تَعْقِلُونَۖ ١٣٨",
      "numberInSurah": 138,
      "verse_key": "37:138"
    },
    {
      "text": "وَإِنَّ يُونُسَ لَمِنَ اَ۬لْمُرْسَلِينَ ١٣٩",
      "numberInSurah": 139,
      "verse_key": "37:139"
    },
    {
      "text": "إِذَ اَبَقَ إِلَي اَ۬لْفُلْكِ اِ۬لْمَشْحُونِ ١٤٠",
      "numberInSurah": 140,
      "verse_key": "37:140"
    },
    {
      "text": "فَسَاهَمَ فَكَانَ مِنَ اَ۬لْمُدْحَضِينَ ١٤١",
      "numberInSurah": 141,
      "verse_key": "37:141"
    },
    {
      "text": "فَالْتَقَمَهُ اُ۬لْحُوتُ وَهُوَ مُلِيمٞۖ ١٤٢",
      "numberInSurah": 142,
      "verse_key": "37:142"
    },
    {
      "text": "فَلَوْلَآ أَنَّهُۥ كَانَ مِنَ اَ۬لْمُسَبِّحِينَ ١٤٣",
      "numberInSurah": 143,
      "verse_key": "37:143"
    },
    {
      "text": "لَلَبِثَ فِے بَطْنِهِۦٓ إِلَيٰ يَوْمِ يُبْعَثُونَۖ ١٤٤",
      "numberInSurah": 144,
      "verse_key": "37:144"
    },
    {
      "text": "۞فَنَبَذْنَٰهُ بِالْعَرَآءِ وَهُوَ سَقِيمٞۖ ١٤٥",
      "numberInSurah": 145,
      "verse_key": "37:145"
    },
    {
      "text": "وَأَنۢبَتْنَا عَلَيْهِ شَجَرَةٗ مِّنْ يَّقْطِينٖۖ ١٤٦",
      "numberInSurah": 146,
      "verse_key": "37:146"
    },
    {
      "text": "وَأَرْسَلْنَٰهُ إِلَيٰ مِاْئَةِ أَلْفٍ اَوْ يَزِيدُونَۖ ١٤٧",
      "numberInSurah": 147,
      "verse_key": "37:147"
    },
    {
      "text": "فَـَٔامَنُواْ فَمَتَّعْنَٰهُمُۥٓ إِلَيٰ حِينٖۖ ١٤٨",
      "numberInSurah": 148,
      "verse_key": "37:148"
    },
    {
      "text": "فَاسْتَفْتِهِمُۥٓ أَلِرَبِّكَ اَ۬لْبَنَاتُ وَلَهُمُ اُ۬لْبَنُونَۖ ١٤٩",
      "numberInSurah": 149,
      "verse_key": "37:149"
    },
    {
      "text": "أَمْ خَلَقْنَا اَ۬لْمَلَٰٓئِكَةَ إِنَٰثاٗ وَهُمْ شَٰهِدُونَۖ ١٥٠",
      "numberInSurah": 150,
      "verse_key": "37:150"
    },
    {
      "text": "أَلَآ إِنَّهُم مِّنِ اِفْكِهِمْ لَيَقُولُونَ ١٥١",
      "numberInSurah": 151,
      "verse_key": "37:151"
    },
    {
      "text": "وَلَدَ اَ۬للَّهُ وَإِنَّهُمْ لَكَٰذِبُونَۖ ١٥٢",
      "numberInSurah": 152,
      "verse_key": "37:152"
    },
    {
      "text": "أَصْطَفَي اَ۬لْبَنَاتِ عَلَي اَ۬لْبَنِينَۖ ١٥٣",
      "numberInSurah": 153,
      "verse_key": "37:153"
    }
  ],
