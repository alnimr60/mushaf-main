{
  "pageNumber": 536,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "أَوَءَابَآؤُنَا اَ۬لَاوَّلُونَۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "56:51"
    },
    {
      "text": "۞قُلِ اِنَّ اَ۬لَاوَّلِينَ وَالَاخِرِينَ لَمَجْمُوعُونَ ٥٢",
      "numberInSurah": 52,
      "verse_key": "56:52"
    },
    {
      "text": "إِلَيٰ مِيقَٰتِ يَوْمٖ مَّعْلُومٖۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "56:53"
    },
    {
      "text": "ثُمَّ إِنَّكُمُۥٓ أَيُّهَا اَ۬لضَّآلُّونَ اَ۬لْمُكَذِّبُونَ ٥٤",
      "numberInSurah": 54,
      "verse_key": "56:54"
    },
    {
      "text": "لَأٓكِلُونَ مِن شَجَرٖ مِّن زَقُّومٖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "56:55"
    },
    {
      "text": "فَمَالِـُٔونَ مِنْهَا اَ۬لْبُطُونَ ٥٦",
      "numberInSurah": 56,
      "verse_key": "56:56"
    },
    {
      "text": "فَشَٰرِبُونَ عَلَيْهِ مِنَ اَ۬لْحَمِيمِ ٥٧",
      "numberInSurah": 57,
      "verse_key": "56:57"
    },
    {
      "text": "فَشَٰرِبُونَ شُرْبَ اَ۬لْهِيمِۖ ٥٨",
      "numberInSurah": 58,
      "verse_key": "56:58"
    },
    {
      "text": "هَٰذَا نُزُلُهُمْ يَوْمَ اَ۬لدِّينِۖ ٥٩",
      "numberInSurah": 59,
      "verse_key": "56:59"
    },
    {
      "text": "نَحْنُ خَلَقْنَٰكُمْ فَلَوْلَا تُصَدِّقُونَۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "56:60"
    },
    {
      "text": "أَفَرَٰٓيْتُم مَّا تُمْنُونَ ٦١",
      "numberInSurah": 61,
      "verse_key": "56:61"
    },
    {
      "text": "ءَآنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ اُ۬لْخَٰلِقُونَۖ ٦٢",
      "numberInSurah": 62,
      "verse_key": "56:62"
    },
    {
      "text": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ اُ۬لْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ ٦٣",
      "numberInSurah": 63,
      "verse_key": "56:63"
    },
    {
      "text": "عَلَيٰٓ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِے مَا لَا تَعْلَمُونَۖ ٦٤",
      "numberInSurah": 64,
      "verse_key": "56:64"
    },
    {
      "text": "وَلَقَدْ عَلِمْتُمُ اُ۬لنَّشْأَةَ اَ۬لُاول۪يٰ فَلَوْلَا تَذَّكَّرُونَۖ ٦٥",
      "numberInSurah": 65,
      "verse_key": "56:65"
    },
    {
      "text": "أَفَرَٰٓيْتُم مَّا تَحْرُثُونَ ٦٦",
      "numberInSurah": 66,
      "verse_key": "56:66"
    },
    {
      "text": "ءَآنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ اُ۬لزَّٰرِعُونَۖ ٦٧",
      "numberInSurah": 67,
      "verse_key": "56:67"
    },
    {
      "text": "لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰماٗ فَظَلْتُمْ تَفَكَّهُونَ ٦٨",
      "numberInSurah": 68,
      "verse_key": "56:68"
    },
    {
      "text": "إِنَّا لَمُغْرَمُونَ ٦٩",
      "numberInSurah": 69,
      "verse_key": "56:69"
    },
    {
      "text": "بَلْ نَحْنُ مَحْرُومُونَۖ ٧٠",
      "numberInSurah": 70,
      "verse_key": "56:70"
    },
    {
      "text": "أَفَرَٰٓيْتُمُ اُ۬لْمَآءَ اَ۬لذِے تَشْرَبُونَ ٧١",
      "numberInSurah": 71,
      "verse_key": "56:71"
    },
    {
      "text": "ءَآنتُمُۥٓ أَنزَلْتُمُوهُ مِنَ اَ۬لْمُزْنِ أَمْ نَحْنُ اُ۬لْمُنزِلُونَۖ ٧٢",
      "numberInSurah": 72,
      "verse_key": "56:72"
    },
    {
      "text": "لَوْ نَشَآءُ جَعَلْنَٰهُ أُجَاجاٗ فَلَوْلَا تَشْكُرُونَۖ ٧٣",
      "numberInSurah": 73,
      "verse_key": "56:73"
    },
    {
      "text": "أَفَرَٰٓيْتُمُ اُ۬لنَّارَ اَ۬لتِے تُورُونَ ٧٤",
      "numberInSurah": 74,
      "verse_key": "56:74"
    },
    {
      "text": "ءَآنتُمُۥٓ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ اُ۬لْمُنشِـُٔونَۖ ٧٥",
      "numberInSurah": 75,
      "verse_key": "56:75"
    },
    {
      "text": "نَحْنُ جَعَلْنَٰهَا تَذْكِرَةٗ وَمَتَٰعاٗ لِّلْمُقْوِينَۖ ٧٦",
      "numberInSurah": 76,
      "verse_key": "56:76"
    }
  ],
