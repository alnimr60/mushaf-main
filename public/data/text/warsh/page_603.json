      "numberInSurah": 2,
      "verse_key": "109:2"
    },
    {
      "text": "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُۖ ٣",
      "numberInSurah": 3,
      "verse_key": "109:3"
    },
    {
      "text": "وَلَآ أَنَا عَابِدٞ مَّا عَبَدتُّمْ ٤",
      "numberInSurah": 4,
      "verse_key": "109:4"
    },
    {
      "text": "وَلَآ أَنتُمْ عَٰبِدُونَ مَآ أَعْبُدُۖ ٥",
      "numberInSurah": 5,
      "verse_key": "109:5"
    },
    {
      "text": "لَكُمْ دِينُكُمْ وَلِيَ دِينِۖ ٦",
      "numberInSurah": 6,
      "verse_key": "109:6"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا جَآءَ نَصْرُ اُ۬للَّهِ وَالْفَتْحُ ١",
      "numberInSurah": 1,
      "verse_key": "110:1"
    },
    {
      "text": "وَرَأَيْتَ اَ۬لنَّاسَ يَدْخُلُونَ فِے دِينِ اِ۬للَّهِ أَفْوَاجاٗ ٢",
      "numberInSurah": 2,
      "verse_key": "110:2"
    },
    {
      "text": "فَسَبِّحْ بِحَمْدِ رَبِّكَ وَاسْتَغْفِرْهُۖ إِنَّهُۥ كَانَ تَوَّاباٗۖ ٣",
      "numberInSurah": 3,
      "verse_key": "110:3"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "تَبَّتْ يَدَآ أَبِے لَهَبٖ وَتَبَّۖ ١",
      "numberInSurah": 1,
      "verse_key": "111:1"
    },
    {
      "text": "مَآ أَغْن۪يٰ عَنْهُ مَالُهُۥ وَمَا كَسَبَۖ ٢",
      "numberInSurah": 2,
      "verse_key": "111:2"
    },
    {
      "text": "سَيَصْلَيٰ نَاراٗ ذَاتَ لَهَبٖ ٣",
      "numberInSurah": 3,
      "verse_key": "111:3"
    },
    {
      "text": "وَامْرَأَتُهُۥۖ حَمَّالَةُ اُ۬لْحَطَبِ ٤",
      "numberInSurah": 4,
      "verse_key": "111:4"
    },
    {
      "text": "فِے جِيدِهَا حَبْلٞ مِّن مَّسَدٖۖ ٥",
      "numberInSurah": 5,
