{
  "pageNumber": 372,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "قَالَ وَمَا عِلْمِے بِمَا كَانُواْ يَعْمَلُونَۖ ١١٢",
      "numberInSurah": 112,
      "verse_key": "26:112"
    },
    {
      "text": "إِنْ حِسَابُهُمُۥٓ إِلَّا عَلَيٰ رَبِّے لَوْ تَشْعُرُونَۖ ١١٣",
      "numberInSurah": 113,
      "verse_key": "26:113"
    },
    {
      "text": "وَمَآ أَنَا بِطَارِدِ اِ۬لْمُومِنِينَ ١١٤",
      "numberInSurah": 114,
      "verse_key": "26:114"
    },
    {
      "text": "إِنَ اَنَا إِلَّا نَذِيرٞ مُّبِينٞۖ ١١٥",
      "numberInSurah": 115,
      "verse_key": "26:115"
    },
    {
      "text": "قَالُواْ لَئِن لَّمْ تَنتَهِ يَٰنُوحُ لَتَكُونَنَّ مِنَ اَ۬لْمَرْجُومِينَۖ ١١٦",
      "numberInSurah": 116,
      "verse_key": "26:116"
    },
    {
      "text": "قَالَ رَبِّ إِنَّ قَوْمِے كَذَّبُونِ ١١٧",
      "numberInSurah": 117,
      "verse_key": "26:117"
    },
    {
      "text": "فَافْتَحْ بَيْنِے وَبَيْنَهُمْ فَتْحاٗ وَنَجِّنِے وَمَن مَّعِيَ مِنَ اَ۬لْمُومِنِينَۖ ١١٨",
      "numberInSurah": 118,
      "verse_key": "26:118"
    },
    {
      "text": "فَأَنجَيْنَٰهُ وَمَن مَّعَهُۥ فِے اِ۬لْفُلْكِ اِ۬لْمَشْحُونِۖ ١١٩",
      "numberInSurah": 119,
      "verse_key": "26:119"
    },
    {
      "text": "ثُمَّ أَغْرَقْنَا بَعْدُ اُ۬لْبَاقِينَۖ ١٢٠",
      "numberInSurah": 120,
      "verse_key": "26:120"
    },
    {
      "text": "إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٢١",
      "numberInSurah": 121,
      "verse_key": "26:121"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٢٢",
      "numberInSurah": 122,
      "verse_key": "26:122"
    },
    {
      "text": "كَذَّبَتْ عَادٌ اِ۬لْمُرْسَلِينَ ١٢٣",
      "numberInSurah": 123,
      "verse_key": "26:123"
    },
    {
      "text": "إِذْ قَالَ لَهُمُۥٓ أَخُوهُمْ هُودٌ اَلَا تَتَّقُونَ ١٢٤",
      "numberInSurah": 124,
      "verse_key": "26:124"
    },
    {
      "text": "إِنِّے لَكُمْ رَسُولٌ اَمِينٞۖ ١٢٥",
      "numberInSurah": 125,
      "verse_key": "26:125"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٢٦",
      "numberInSurah": 126,
      "verse_key": "26:126"
    },
    {
      "text": "وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنَ اَجْرٍۖ اِنَ اَجْرِيَ إِلَّا عَلَيٰ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٢٧",
      "numberInSurah": 127,
      "verse_key": "26:127"
    },
    {
      "text": "أَتَبْنُونَ بِكُلِّ رِيعٍ اٰيَةٗ تَعْبَثُونَ ١٢٨",
      "numberInSurah": 128,
      "verse_key": "26:128"
    },
    {
      "text": "وَتَتَّخِذُونَ مَصَانِعَ لَعَلَّكُمْ تَخْلُدُونَ ١٢٩",
      "numberInSurah": 129,
      "verse_key": "26:129"
    },
    {
      "text": "وَإِذَا بَطَشْتُم بَطَشْتُمْ جَبّ۪ارِينَۖ ١٣٠",
      "numberInSurah": 130,
      "verse_key": "26:130"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٣١",
      "numberInSurah": 131,
      "verse_key": "26:131"
    },
    {
      "text": "وَاتَّقُواْ اُ۬لذِےٓ أَمَدَّكُم بِمَا تَعْلَمُونَ ١٣٢",
      "numberInSurah": 132,
      "verse_key": "26:132"
    },
    {
      "text": "أَمَدَّكُم بِأَنْعَٰمٖ وَبَنِينَ ١٣٣",
      "numberInSurah": 133,
      "verse_key": "26:133"
    },
    {
      "text": "وَجَنَّٰتٖ وَعُيُونٍۖ ١٣٤",
      "numberInSurah": 134,
      "verse_key": "26:134"
    },
    {
      "text": "اِنِّيَ أَخَافُ عَلَيْكُمْ عَذَابَ يَوْمٍ عَظِيمٖۖ ١٣٥",
      "numberInSurah": 135,
      "verse_key": "26:135"
    },
    {
      "text": "قَالُواْ سَوَآءٌ عَلَيْنَآ أَوَعَظْتَ أَمْ لَمْ تَكُن مِّنَ اَ۬لْوَٰعِظِينَ ١٣٦",
      "numberInSurah": 136,
      "verse_key": "26:136"
    }
  ],
