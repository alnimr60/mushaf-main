{
  "pageNumber": 537,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَسَبِّحْ بِاسْمِ رَبِّكَ اَ۬لْعَظِيمِۖ ٧٧",
      "numberInSurah": 77,
      "verse_key": "56:77"
    },
    {
      "text": "۞فَلَآ أُقْسِمُ بِمَوَٰقِعِ اِ۬لنُّجُومِ ٧٨",
      "numberInSurah": 78,
      "verse_key": "56:78"
    },
    {
      "text": "وَإِنَّهُۥ لَقَسَمٞ لَّوْ تَعْلَمُونَ عَظِيمٌ ٧٩",
      "numberInSurah": 79,
      "verse_key": "56:79"
    },
    {
      "text": "اِنَّهُۥ لَقُرْءَانٞ كَرِيمٞ ٨٠",
      "numberInSurah": 80,
      "verse_key": "56:80"
    },
    {
      "text": "فِے كِتَٰبٖ مَّكْنُونٖ ٨١",
      "numberInSurah": 81,
      "verse_key": "56:81"
    },
    {
      "text": "لَّا يَمَسُّهُۥٓ إِلَّا اَ۬لْمُطَهَّرُونَۖ ٨٢",
      "numberInSurah": 82,
      "verse_key": "56:82"
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ اِ۬لْعَٰلَمِينَۖ ٨٣",
      "numberInSurah": 83,
      "verse_key": "56:83"
    },
    {
      "text": "أَفَبِهَٰذَا اَ۬لْحَدِيثِ أَنتُم مُّدْهِنُونَ ٨٤",
      "numberInSurah": 84,
      "verse_key": "56:84"
    },
    {
      "text": "وَتَجْعَلُونَ رِزْقَكُمُۥٓ أَنَّكُمْ تُكَذِّبُونَۖ ٨٥",
      "numberInSurah": 85,
      "verse_key": "56:85"
    },
    {
      "text": "فَلَوْلَآ إِذَا بَلَغَتِ اِ۬لْحُلْقُومَ ٨٦",
      "numberInSurah": 86,
      "verse_key": "56:86"
    },
    {
      "text": "وَأَنتُمْ حِينَئِذٖ تَنظُرُونَ ٨٧",
      "numberInSurah": 87,
      "verse_key": "56:87"
    },
    {
      "text": "وَنَحْنُ أَقْرَبُ إِلَيْهِ مِنكُمْ وَلَٰكِن لَّا تُبْصِرُونَ ٨٨",
      "numberInSurah": 88,
      "verse_key": "56:88"
    },
    {
      "text": "فَلَوْلَآ إِن كُنتُمْ غَيْرَ مَدِينِينَ ٨٩",
      "numberInSurah": 89,
      "verse_key": "56:89"
    },
    {
      "text": "تَرْجِعُونَهَآ إِن كُنتُمْ صَٰدِقِينَۖ ٩٠",
      "numberInSurah": 90,
      "verse_key": "56:90"
    },
    {
      "text": "فَأَمَّآ إِن كَانَ مِنَ اَ۬لْمُقَرَّبِينَ ٩١",
      "numberInSurah": 91,
      "verse_key": "56:91"
    },
    {
      "text": "فَرَوْحٞ وَرَيْحَانٞ وَجَنَّتُ نَعِيمٖۖ ٩٢",
      "numberInSurah": 92,
      "verse_key": "56:92"
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنَ اَصْحَٰبِ اِ۬لْيَمِينِ ٩٣",
      "numberInSurah": 93,
      "verse_key": "56:93"
    },
    {
      "text": "فَسَلَٰمٞ لَّكَ مِنَ اَصْحَٰبِ اِ۬لْيَمِينِۖ ٩٤",
      "numberInSurah": 94,
      "verse_key": "56:94"
    },
    {
      "text": "وَأَمَّآ إِن كَانَ مِنَ اَ۬لْمُكَذِّبِينَ اَ۬لضَّآلِّينَ ٩٥",
      "numberInSurah": 95,
      "verse_key": "56:95"
    },
    {
      "text": "فَنُزُلٞ مِّنْ حَمِيمٖ ٩٦",
      "numberInSurah": 96,
      "verse_key": "56:96"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "سَبَّحَ لِلهِ مَا فِے اِ۬لسَّمَٰوَٰتِ وَالَارْضِۖ وَهُوَ اَ۬لْعَزِيزُ اُ۬لْحَكِيمُۖ ١",
      "numberInSurah": 1,
      "verse_key": "57:1"
    },
    {
      "text": "لَهُۥ مُلْكُ اُ۬لسَّمَٰوَٰتِ وَالَارْضِ يُحْيِۦ وَيُمِيتُۖ وَهُوَ عَلَيٰ كُلِّ شَےْءٖ قَدِيرٌۖ ٢",
      "numberInSurah": 2,
      "verse_key": "57:2"
    },
    {
      "text": "هُوَ اَ۬لَاوَّلُ وَالَاخِرُ وَالظَّٰهِرُ وَالْبَاطِنُۖ وَهُوَ بِكُلِّ شَےْءٍ عَلِيمٌۖ ٣",
      "numberInSurah": 3,
      "verse_key": "57:3"
    }
  ],
