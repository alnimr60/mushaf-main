{
  "pageNumber": 566,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "خَٰشِعَةً اَبْصَٰرُهُمْ تَرْهَقُهُمْ ذِلَّةٞۖ وَقَدْ كَانُواْ يُدْعَوْنَ إِلَي اَ۬لسُّجُودِ وَهُمْ سَٰلِمُونَۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "68:43"
    },
    {
      "text": "فَذَرْنِے وَمَنْ يُّكَذِّبُ بِهَٰذَا اَ۬لْحَدِيثِۖ سَنَسْتَدْرِجُهُم مِّنْ حَيْثُ لَا يَعْلَمُونَ ٤٤",
      "numberInSurah": 44,
      "verse_key": "68:44"
    },
    {
      "text": "وَأُمْلِے لَهُمُۥٓۖ إِنَّ كَيْدِے مَتِينٌۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "68:45"
    },
    {
      "text": "اَمْ تَسْـَٔلُهُمُۥٓ أَجْراٗ فَهُم مِّن مَّغْرَمٖ مُّثْقَلُونَۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "68:46"
    },
    {
      "text": "أَمْ عِندَهُمُ اُ۬لْغَيْبُ فَهُمْ يَكْتُبُونَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "68:47"
    },
    {
      "text": "۞فَاصْبِرْ لِحُكْمِ رَبِّكَ وَلَا تَكُن كَصَٰحِبِ اِ۬لْحُوتِ إِذْ نَاد۪يٰ وَهُوَ مَكْظُومٞۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "68:48"
    },
    {
      "text": "لَّوْلَآ أَن تَدَٰرَكَهُۥ نِعْمَةٞ مِّن رَّبِّهِۦ لَنُبِذَ بِالْعَرَآءِ وَهُوَ مَذْمُومٞۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "68:49"
    },
    {
      "text": "فَاجْتَبٰ۪هُ رَبُّهُۥ فَجَعَلَهُۥ مِنَ اَ۬لصَّٰلِحِينَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "68:50"
    },
    {
      "text": "وَإِنْ يَّكَادُ اُ۬لذِينَ كَفَرُواْ لَيَزْلِقُونَكَ بِأَبْصٰ۪رِهِمْ لَمَّا سَمِعُواْ اُ۬لذِّكْرَ وَيَقُولُونَ إِنَّهُۥ لَمَجْنُونٞۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "68:51"
    },
    {
      "text": "وَمَا هُوَ إِلَّا ذِكْرٞ لِّلْعَٰلَمِينَۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "68:52"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اَ۬لْحَآقَّةُ مَا اَ۬لْحَآقَّةُۖ ١",
      "numberInSurah": 1,
      "verse_key": "69:1"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا اَ۬لْحَآقَّةُۖ ٢",
      "numberInSurah": 2,
      "verse_key": "69:2"
    },
    {
      "text": "كَذَّبَتْ ثَمُودُ وَعَادُۢ بِالْقَارِعَةِۖ ٣",
      "numberInSurah": 3,
      "verse_key": "69:3"
    },
    {
      "text": "فَأَمَّا ثَمُودُ فَأُهْلِكُواْ بِالطَّاغِيَةِۖ ٤",
      "numberInSurah": 4,
      "verse_key": "69:4"
    },
    {
      "text": "وَأَمَّا عَادٞ فَأُهْلِكُواْ بِرِيحٖ صَرْصَرٍ عَاتِيَةٖ ٥",
      "numberInSurah": 5,
      "verse_key": "69:5"
    },
    {
      "text": "سَخَّرَهَا عَلَيْهِمْ سَبْعَ لَيَالٖ وَثَمَٰنِيَةَ أَيَّامٍ حُسُوماٗۖ فَتَرَي اَ۬لْقَوْمَ فِيهَا صَرْع۪يٰ كَأَنَّهُمُۥٓ أَعْجَازُ نَخْلٍ خَاوِيَةٖۖ ٦",
      "numberInSurah": 6,
      "verse_key": "69:6"
    },
    {
      "text": "فَهَلْ تَر۪يٰ لَهُم مِّنۢ بَاقِيَةٖۖ ٧",
      "numberInSurah": 7,
      "verse_key": "69:7"
    },
    {
      "text": "وَجَآءَ فِرْعَوْنُ وَمَن قَبْلَهُۥ وَالْمُوتَفِكَٰتُ بِالْخَاطِئَةِ ٨",
      "numberInSurah": 8,
      "verse_key": "69:8"
    }
  ],
