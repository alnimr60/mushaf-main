      "numberInSurah": 51,
      "verse_key": "55:51"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "55:52"
    },
    {
