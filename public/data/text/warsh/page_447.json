{
  "pageNumber": 447,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "مَا لَكُمْ لَا تَنَاصَرُونَۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "37:25"
    },
    {
      "text": "بَلْ هُمُ اُ۬لْيَوْمَ مُسْتَسْلِمُونَۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "37:26"
    },
    {
      "text": "وَأَقْبَلَ بَعْضُهُمْ عَلَيٰ بَعْضٖ يَتَسَآءَلُونَۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "37:27"
    },
    {
      "text": "قَالُوٓاْ إِنَّكُمْ كُنتُمْ تَاتُونَنَا عَنِ اِ۬لْيَمِينِۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "37:28"
    },
    {
      "text": "قَالُواْ بَل لَّمْ تَكُونُواْ مُومِنِينَۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "37:29"
    },
    {
      "text": "وَمَا كَانَ لَنَا عَلَيْكُم مِّن سُلْطَٰنِۢ بَلْ كُنتُمْ قَوْماٗ طَٰغِينَۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "37:30"
    },
    {
      "text": "فَحَقَّ عَلَيْنَا قَوْلُ رَبِّنَآ إِنَّا لَذَآئِقُونَ ٣١",
      "numberInSurah": 31,
      "verse_key": "37:31"
    },
    {
      "text": "فَأَغْوَيْنَٰكُمُۥٓ إِنَّا كُنَّا غَٰوِينَۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "37:32"
    },
    {
      "text": "فَإِنَّهُمْ يَوْمَئِذٖ فِے اِ۬لْعَذَابِ مُشْتَرِكُونَۖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "37:33"
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَفْعَلُ بِالْمُجْرِمِينَۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "37:34"
    },
    {
      "text": "إِنَّهُمْ كَانُوٓاْ إِذَا قِيلَ لَهُمْ لَآ إِلَٰهَ إِلَّا اَ۬للَّهُ يَسْتَكْبِرُونَ ٣٥",
      "numberInSurah": 35,
      "verse_key": "37:35"
    },
    {
      "text": "وَيَقُولُونَ أَئِنَّا لَتَارِكُوٓاْ ءَالِهَتِنَا لِشَاعِرٖ مَّجْنُونِۢۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "37:36"
    },
    {
      "text": "بَلْ جَآءَ بِالْحَقِّ وَصَدَّقَ اَ۬لْمُرْسَلِينَۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "37:37"
    },
    {
      "text": "إِنَّكُمْ لَذَآئِقُواْ اُ۬لْعَذَابِ اِ۬لَالِيمِۖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "37:38"
    },
    {
      "text": "وَمَا تُجْزَوْنَ إِلَّا مَا كُنتُمْ تَعْمَلُونَ ٣٩",
      "numberInSurah": 39,
      "verse_key": "37:39"
    },
    {
      "text": "إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لْمُخْلَصِينَۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "37:40"
    },
    {
      "text": "أُوْلَٰٓئِكَ لَهُمْ رِزْقٞ مَّعْلُومٞ ٤١",
      "numberInSurah": 41,
      "verse_key": "37:41"
    },
    {
      "text": "فَوَٰكِهُۖ وَهُم مُّكْرَمُونَ ٤٢",
      "numberInSurah": 42,
      "verse_key": "37:42"
    },
    {
      "text": "فِے جَنَّٰتِ اِ۬لنَّعِيمِ ٤٣",
      "numberInSurah": 43,
      "verse_key": "37:43"
    },
    {
      "text": "عَلَيٰ سُرُرٖ مُّتَقَٰبِلِينَۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "37:44"
    },
    {
      "text": "يُطَافُ عَلَيْهِم بِكَأْسٖ مِّن مَّعِينِۢ ٤٥",
      "numberInSurah": 45,
      "verse_key": "37:45"
    },
    {
      "text": "بَيْضَآءَ لَذَّةٖ لِّلشَّٰرِبِينَ ٤٦",
      "numberInSurah": 46,
      "verse_key": "37:46"
    },
    {
      "text": "لَا فِيهَا غَوْلٞ وَلَا هُمْ عَنْهَا يُنزَفُونَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "37:47"
    },
    {
      "text": "وَعِندَهُمْ قَٰصِرَٰتُ اُ۬لطَّرْفِ عِينٞ ٤٨",
      "numberInSurah": 48,
      "verse_key": "37:48"
    },
    {
      "text": "كَأَنَّهُنَّ بَيْضٞ مَّكْنُونٞۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "37:49"
    },
    {
      "text": "فَأَقْبَلَ بَعْضُهُمْ عَلَيٰ بَعْضٖ يَتَسَآءَلُونَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "37:50"
    },
    {
      "text": "۞قَالَ قَآئِلٞ مِّنْهُمُۥٓ إِنِّے كَانَ لِے قَرِينٞ ٥١",
      "numberInSurah": 51,
      "verse_key": "37:51"
    }
  ],
