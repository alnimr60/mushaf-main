{
  "pageNumber": 584,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "إِذْ نَاد۪يٰهُ رَبُّهُۥ بِالْوَادِ اِ۬لْمُقَدَّسِ طُوَيۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "79:16"
    },
    {
      "text": "اَ۪ذْهَبِ اِلَيٰ فِرْعَوْنَ إِنَّهُۥ طَغ۪يٰ ١٧",
      "numberInSurah": 17,
      "verse_key": "79:17"
    },
    {
      "text": "فَقُلْ هَل لَّكَ إِلَيٰٓ أَن تَزَّكّ۪يٰ ١٨",
      "numberInSurah": 18,
      "verse_key": "79:18"
    },
    {
      "text": "وَأَهْدِيَكَ إِلَيٰ رَبِّكَ فَتَخْش۪يٰۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "79:19"
    },
    {
      "text": "فَأَر۪يٰهُ اُ۬لَايَةَ اَ۬لْكُبْر۪يٰ ٢٠",
      "numberInSurah": 20,
      "verse_key": "79:20"
    },
    {
      "text": "فَكَذَّبَ وَعَص۪يٰ ٢١",
      "numberInSurah": 21,
      "verse_key": "79:21"
    },
    {
      "text": "ثُمَّ أَدْبَرَ يَسْع۪يٰ ٢٢",
      "numberInSurah": 22,
      "verse_key": "79:22"
    },
    {
      "text": "فَحَشَرَ فَنَاد۪يٰ ٢٣",
      "numberInSurah": 23,
      "verse_key": "79:23"
    },
    {
      "text": "فَقَالَ أَنَا رَبُّكُمُ اُ۬لَاعْل۪يٰ ٢٤",
      "numberInSurah": 24,
      "verse_key": "79:24"
    },
    {
      "text": "فَأَخَذَهُ اُ۬للَّهُ نَكَالَ اَ۬لَاخِرَةِ وَالُاول۪يٰٓۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "79:25"
    },
    {
      "text": "إِنَّ فِے ذَٰلِكَ لَعِبْرَةٗ لِّمَنْ يَّخْش۪يٰٓۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "79:26"
    },
    {
      "text": "ءَآنتُمُۥٓ أَشَدُّ خَلْقاً اَمِ اِ۬لسَّمَآءُۖ بَنَيٰهَا ٢٧",
      "numberInSurah": 27,
      "verse_key": "79:27"
    },
    {
      "text": "رَفَعَ سَمْكَهَا فَسَوَّيٰهَا ٢٨",
      "numberInSurah": 28,
      "verse_key": "79:28"
    },
    {
      "text": "وَأَغْطَشَ لَيْلَهَا وَأَخْرَجَ ضُحَيٰهَاۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "79:29"
    },
    {
      "text": "وَالَارْضَ بَعْدَ ذَٰلِكَ دَحَيٰهَآ ٣٠",
      "numberInSurah": 30,
      "verse_key": "79:30"
    },
    {
      "text": "أَخْرَجَ مِنْهَا مَآءَهَا وَمَرْعَيٰهَا ٣١",
      "numberInSurah": 31,
      "verse_key": "79:31"
    },
    {
      "text": "وَالْجِبَالَ أَرْسَيٰهَا ٣٢",
      "numberInSurah": 32,
      "verse_key": "79:32"
    },
    {
      "text": "مَتَٰعاٗ لَّكُمْ وَلِأَنْعَٰمِكُمْۖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "79:33"
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لطَّآمَّةُ اُ۬لْكُبْر۪يٰ ٣٤",
      "numberInSurah": 34,
      "verse_key": "79:34"
    },
    {
      "text": "يَوْمَ يَتَذَكَّرُ اُ۬لِانسَٰنُ مَا سَع۪يٰ ٣٥",
      "numberInSurah": 35,
      "verse_key": "79:35"
    },
    {
      "text": "وَبُرِّزَتِ اِ۬لْجَحِيمُ لِمَنْ يَّر۪يٰۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "79:36"
    },
    {
      "text": "فَأَمَّا مَن طَغ۪يٰ وَءَاثَرَ اَ۬لْحَيَوٰةَ اَ۬لدُّنْي۪ا ٣٧",
      "numberInSurah": 37,
      "verse_key": "79:37"
    },
    {
      "text": "فَإِنَّ اَ۬لْجَحِيمَ هِيَ اَ۬لْمَأْو۪يٰۖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "79:38"
    },
    {
      "text": "وَأَمَّا مَنْ خَافَ مَقَامَ رَبِّهِۦ وَنَهَي اَ۬لنَّفْسَ عَنِ اِ۬لْهَو۪يٰ ٣٩",
      "numberInSurah": 39,
      "verse_key": "79:39"
    },
    {
      "text": "فَإِنَّ اَ۬لْجَنَّةَ هِيَ اَ۬لْمَأْو۪يٰۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "79:40"
    },
    {
      "text": "۞يَسْـَٔلُونَكَ عَنِ اِ۬لسَّاعَةِ أَيَّانَ مُرْسَيٰهَاۖ ٤١",
      "numberInSurah": 41,
      "verse_key": "79:41"
    },
    {
      "text": "فِيمَ أَنتَ مِن ذِكْر۪يٰهَآۖ ٤٢",
      "numberInSurah": 42,
      "verse_key": "79:42"
    },
    {
      "text": "إِلَيٰ رَبِّكَ مُنتَهَيٰهَآۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "79:43"
    },
    {
      "text": "إِنَّمَآ أَنتَ مُنذِرُ مَنْ يَّخْشَيٰهَاۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "79:44"
    },
    {
      "text": "كَأَنَّهُمْ يَوْمَ يَرَوْنَهَا لَمْ يَلْبَثُوٓاْ إِلَّا عَشِيَّةً اَوْ ضُحَيٰهَاۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "79:45"
    },
    {
      "text": "",
      "numberInSurah": 46,
      "verse_key": "79:46"
    }
  ],
