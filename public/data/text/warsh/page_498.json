{
  "pageNumber": 498,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "إِلَّا مَن رَّحِمَ اَ۬للَّهُۖ إِنَّهُۥ هُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "44:40"
    },
    {
      "text": "إِنَّ شَجَرَتَ اَ۬لزَّقُّومِ طَعَامُ اُ۬لَاثِيمِ ٤١",
      "numberInSurah": 41,
      "verse_key": "44:41"
    },
    {
      "text": "كَالْمُهْلِ تَغْلِے فِے اِ۬لْبُطُونِ ٤٢",
      "numberInSurah": 42,
      "verse_key": "44:42"
    },
    {
      "text": "كَغَلْيِ اِ۬لْحَمِيمِۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "44:43"
    },
    {
      "text": "خُذُوهُ فَاعْتُلُوهُ إِلَيٰ سَوَآءِ اِ۬لْجَحِيمِ ٤٤",
      "numberInSurah": 44,
      "verse_key": "44:44"
    },
    {
      "text": "ثُمَّ صُبُّواْ فَوْقَ رَأْسِهِۦ مِنْ عَذَابِ اِ۬لْحَمِيمِ ٤٥",
      "numberInSurah": 45,
      "verse_key": "44:45"
    },
    {
      "text": "ذُقِۖ اِنَّكَ أَنتَ اَ۬لْعَزِيزُ اُ۬لْكَرِيمُۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "44:46"
    },
    {
      "text": "إِنَّ هَٰذَا مَا كُنتُم بِهِۦ تَمْتَرُونَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "44:47"
    },
    {
      "text": "إِنَّ اَ۬لْمُتَّقِينَ فِے مُقَامٍ اَمِينٖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "44:48"
    },
    {
      "text": "فِے جَنَّٰتٖ وَعُيُونٖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "44:49"
    },
    {
      "text": "يَلْبَسُونَ مِن سُندُسٖ وَإِسْتَبْرَقٖ مُّتَقَٰبِلِينَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "44:50"
    },
    {
      "text": "كَذَٰلِكَۖ وَزَوَّجْنَٰهُم بِحُورٍ عِينٖۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "44:51"
    },
    {
      "text": "يَدْعُونَ فِيهَا بِكُلِّ فَٰكِهَةٍ اٰمِنِينَۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "44:52"
    },
    {
      "text": "لَا يَذُوقُونَ فِيهَا اَ۬لْمَوْتَ إِلَّا اَ۬لْمَوْتَةَ اَ۬لُاول۪يٰۖ وَوَق۪يٰهُمْ عَذَابَ اَ۬لْجَحِيمِ ٥٣",
      "numberInSurah": 53,
      "verse_key": "44:53"
    },
    {
      "text": "فَضْلاٗ مِّن رَّبِّكَۖ ذَٰلِكَ هُوَ اَ۬لْفَوْزُ اُ۬لْعَظِيمُۖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "44:54"
    },
    {
      "text": "فَإِنَّمَا يَسَّرْنَٰهُ بِلِسَانِكَ لَعَلَّهُمْ يَتَذَكَّرُونَۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "44:55"
    },
    {
      "text": "فَارْتَقِبِ اِنَّهُم مُّرْتَقِبُونَۖ ٥٦",
      "numberInSurah": 56,
      "verse_key": "44:56"
    },
