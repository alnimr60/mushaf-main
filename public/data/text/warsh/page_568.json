{
  "pageNumber": 568,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَلَيْسَ لَهُ اُ۬لْيَوْمَ هَٰهُنَا حَمِيمٞ ٣٥",
      "numberInSurah": 35,
      "verse_key": "69:35"
    },
    {
      "text": "وَلَا طَعَامٌ اِلَّا مِنْ غِسْلِينٖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "69:36"
    },
    {
      "text": "لَّا يَاكُلُهُۥٓ إِلَّا اَ۬لْخَٰطِـُٔونَۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "69:37"
    },
    {
      "text": "فَلَآ أُقْسِمُ بِمَا تُبْصِرُونَ ٣٨",
      "numberInSurah": 38,
      "verse_key": "69:38"
    },
    {
      "text": "وَمَا لَا تُبْصِرُونَ ٣٩",
      "numberInSurah": 39,
      "verse_key": "69:39"
    },
    {
      "text": "إِنَّهُۥ لَقَوْلُ رَسُولٖ كَرِيمٖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "69:40"
    },
    {
      "text": "وَمَا هُوَ بِقَوْلِ شَاعِرٖۖ قَلِيلاٗ مَّا تُومِنُونَ ٤١",
      "numberInSurah": 41,
      "verse_key": "69:41"
    },
    {
      "text": "وَلَا بِقَوْلِ كَاهِنٖۖ قَلِيلاٗ مَّا تَذَّكَّرُونَ ٤٢",
      "numberInSurah": 42,
      "verse_key": "69:42"
    },
    {
      "text": "تَنزِيلٞ مِّن رَّبِّ اِ۬لْعَٰلَمِينَۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "69:43"
    },
    {
      "text": "وَلَوْ تَقَوَّلَ عَلَيْنَا بَعْضَ اَ۬لَاقَاوِيلِ ٤٤",
      "numberInSurah": 44,
      "verse_key": "69:44"
    },
    {
      "text": "لَأَخَذْنَا مِنْهُ بِالْيَمِينِ ٤٥",
      "numberInSurah": 45,
      "verse_key": "69:45"
    },
    {
      "text": "ثُمَّ لَقَطَعْنَا مِنْهُ اُ۬لْوَتِينَ ٤٦",
      "numberInSurah": 46,
      "verse_key": "69:46"
    },
    {
      "text": "فَمَا مِنكُم مِّنَ اَحَدٍ عَنْهُ حَٰجِزِينَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "69:47"
    },
    {
      "text": "وَإِنَّهُۥ لَتَذْكِرَةٞ لِّلْمُتَّقِينَۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "69:48"
    },
    {
      "text": "وَإِنَّا لَنَعْلَمُ أَنَّ مِنكُم مُّكَذِّبِينَۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "69:49"
    },
    {
      "text": "وَإِنَّهُۥ لَحَسْرَةٌ عَلَي اَ۬لْكٰ۪فِرِينَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "69:50"
    },
    {
      "text": "وَإِنَّهُۥ لَحَقُّ اُ۬لْيَقِينِۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "69:51"
    },
    {
      "text": "فَسَبِّحْ بِاسْمِ رَبِّكَ اَ۬لْعَظِيمِۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "69:52"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "سَالَ سَآئِلُۢ بِعَذَابٖ وَاقِعٖ ١",
      "numberInSurah": 1,
      "verse_key": "70:1"
    },
    {
      "text": "لِّلْكٰ۪فِرِينَ لَيْسَ لَهُۥ دَافِعٞ ٢",
      "numberInSurah": 2,
      "verse_key": "70:2"
    },
    {
      "text": "مِّنَ اَ۬للَّهِ ذِے اِ۬لْمَعَارِجِۖ ٣",
      "numberInSurah": 3,
      "verse_key": "70:3"
    },
    {
      "text": "تَعْرُجُ اُ۬لْمَلَٰٓئِكَةُ وَالرُّوحُ إِلَيْهِ فِے يَوْمٖ كَانَ مِقْدَارُهُۥ خَمْسِينَ أَلْفَ سَنَةٖۖ ٤",
      "numberInSurah": 4,
      "verse_key": "70:4"
    },
    {
      "text": "فَاصْبِرْ صَبْراٗ جَمِيلاًۖ ٥",
      "numberInSurah": 5,
      "verse_key": "70:5"
    },
    {
      "text": "اِنَّهُمْ يَرَوْنَهُۥ بَعِيداٗ ٦",
      "numberInSurah": 6,
      "verse_key": "70:6"
    },
    {
      "text": "وَنَر۪يٰهُ قَرِيباٗۖ ٧",
      "numberInSurah": 7,
      "verse_key": "70:7"
    },
    {
      "text": "يَوْمَ تَكُونُ اُ۬لسَّمَآءُ كَالْمُهْلِ ٨",
      "numberInSurah": 8,
      "verse_key": "70:8"
    },
    {
      "text": "وَتَكُونُ اُ۬لْجِبَالُ كَالْعِهْنِ ٩",
      "numberInSurah": 9,
      "verse_key": "70:9"
    },
    {
      "text": "وَلَا يَسْـَٔلُ حَمِيمٌ حَمِيماٗ ١٠",
      "numberInSurah": 10,
      "verse_key": "70:10"
    }
  ],
