{
  "pageNumber": 587,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا اَ۬لسَّمَآءُ اُ۪نفَطَرَتْ ١",
      "numberInSurah": 1,
      "verse_key": "82:1"
    },
    {
      "text": "وَإِذَا اَ۬لْكَوَاكِبُ اُ۪نتَثَرَتْ ٢",
      "numberInSurah": 2,
      "verse_key": "82:2"
    },
    {
      "text": "وَإِذَا اَ۬لْبِحَارُ فُجِّرَتْ ٣",
      "numberInSurah": 3,
      "verse_key": "82:3"
    },
    {
      "text": "وَإِذَا اَ۬لْقُبُورُ بُعْثِرَتْ ٤",
      "numberInSurah": 4,
      "verse_key": "82:4"
    },
    {
      "text": "عَلِمَتْ نَفْسٞ مَّا قَدَّمَتْ وَأَخَّرَتْۖ ٥",
      "numberInSurah": 5,
      "verse_key": "82:5"
    },
    {
      "text": "يَٰٓأَيُّهَا اَ۬لِانسَٰنُ مَا غَرَّكَ بِرَبِّكَ اَ۬لْكَرِيمِ ٦",
      "numberInSurah": 6,
      "verse_key": "82:6"
    },
    {
      "text": "اِ۬لذِے خَلَقَكَ فَسَوّ۪يٰكَ فَعَدَّلَكَ ٧",
      "numberInSurah": 7,
      "verse_key": "82:7"
    },
    {
      "text": "فِےٓ أَيِّ صُورَةٖ مَّا شَآءَ رَكَّبَكَۖ ٨",
      "numberInSurah": 8,
      "verse_key": "82:8"
    },
    {
      "text": "كَلَّا بَلْ تُكَذِّبُونَ بِالدِّينِ ٩",
      "numberInSurah": 9,
      "verse_key": "82:9"
    },
    {
      "text": "وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ ١٠",
      "numberInSurah": 10,
      "verse_key": "82:10"
    },
    {
      "text": "كِرَاماٗ كَٰتِبِينَ ١١",
      "numberInSurah": 11,
      "verse_key": "82:11"
    },
    {
      "text": "يَعْلَمُونَ مَا تَفْعَلُونَۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "82:12"
    },
    {
      "text": "إِنَّ اَ۬لَابْرَارَ لَفِے نَعِيمٖۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "82:13"
    },
    {
      "text": "وَإِنَّ اَ۬لْفُجَّارَ لَفِے جَحِيمٖ ١٤",
      "numberInSurah": 14,
      "verse_key": "82:14"
    },
    {
      "text": "يَصْلَوْنَهَا يَوْمَ اَ۬لدِّينِ ١٥",
      "numberInSurah": 15,
      "verse_key": "82:15"
    },
    {
      "text": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "82:16"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا يَوْمُ اُ۬لدِّينِ ١٧",
      "numberInSurah": 17,
      "verse_key": "82:17"
    },
    {
      "text": "ثُمَّ مَآ أَدْر۪يٰكَ مَا يَوْمُ اُ۬لدِّينِۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "82:18"
    },
    {
      "text": "يَوْمَ لَا تَمْلِكُ نَفْسٞ لِّنَفْسٖ شَئْاٗۖ وَالَامْرُ يَوْمَئِذٖ لِّلهِۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "82:19"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَيْلٞ لِّلْمُطَفِّفِينَ ١",
      "numberInSurah": 1,
      "verse_key": "83:1"
    },
    {
      "text": "اَ۬لذِينَ إِذَا اَ۪كْتَالُواْ عَلَي اَ۬لنَّاسِ يَسْتَوْفُونَ ٢",
      "numberInSurah": 2,
      "verse_key": "83:2"
    },
    {
      "text": "وَإِذَا كَالُوهُمُۥٓ أَو وَّزَنُوهُمْ يُخْسِرُونَۖ ٣",
      "numberInSurah": 3,
      "verse_key": "83:3"
    },
    {
      "text": "أَلَا يَظُنُّ أُوْلَٰٓئِكَ أَنَّهُم مَّبْعُوثُونَ ٤",
      "numberInSurah": 4,
      "verse_key": "83:4"
    },
    {
      "text": "لِيَوْمٍ عَظِيمٖ ٥",
      "numberInSurah": 5,
      "verse_key": "83:5"
    },
    {
      "text": "يَوْمَ يَقُومُ اُ۬لنَّاسُ لِرَبِّ اِ۬لْعَٰلَمِينَۖ ٦",
      "numberInSurah": 6,
      "verse_key": "83:6"
    }
  ],
