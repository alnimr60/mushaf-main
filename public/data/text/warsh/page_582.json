{
  "pageNumber": 582,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "عَمَّ يَتَسَآءَلُونَ ١",
      "numberInSurah": 1,
      "verse_key": "78:1"
    },
    {
      "text": "عَنِ اِ۬لنَّبَإِ اِ۬لْعَظِيمِ ٢",
      "numberInSurah": 2,
      "verse_key": "78:2"
    },
    {
      "text": "اِ۬لذِے هُمْ فِيهِ مُخْتَلِفُونَۖ ٣",
      "numberInSurah": 3,
      "verse_key": "78:3"
    },
    {
      "text": "كَلَّا سَيَعْلَمُونَ ٤",
      "numberInSurah": 4,
      "verse_key": "78:4"
    },
    {
      "text": "ثُمَّ كَلَّا سَيَعْلَمُونَۖ ٥",
      "numberInSurah": 5,
      "verse_key": "78:5"
    },
    {
      "text": "أَلَمْ نَجْعَلِ اِ۬لَارْضَ مِهَٰداٗ ٦",
      "numberInSurah": 6,
      "verse_key": "78:6"
    },
    {
      "text": "وَالْجِبَالَ أَوْتَاداٗ ٧",
      "numberInSurah": 7,
      "verse_key": "78:7"
    },
    {
      "text": "وَخَلَقْنَٰكُمُۥٓ أَزْوَٰجاٗ ٨",
      "numberInSurah": 8,
      "verse_key": "78:8"
    },
    {
      "text": "وَجَعَلْنَا نَوْمَكُمْ سُبَاتاٗ ٩",
      "numberInSurah": 9,
      "verse_key": "78:9"
    },
    {
      "text": "وَجَعَلْنَا اَ۬ليْلَ لِبَاساٗ ١٠",
      "numberInSurah": 10,
      "verse_key": "78:10"
    },
    {
      "text": "وَجَعَلْنَا اَ۬لنَّهَارَ مَعَاشاٗ ١١",
      "numberInSurah": 11,
      "verse_key": "78:11"
    },
    {
      "text": "وَبَنَيْنَا فَوْقَكُمْ سَبْعاٗ شِدَاداٗ ١٢",
      "numberInSurah": 12,
      "verse_key": "78:12"
    },
    {
      "text": "وَجَعَلْنَا سِرَاجاٗ وَهَّاجاٗ ١٣",
      "numberInSurah": 13,
      "verse_key": "78:13"
    },
    {
      "text": "وَأَنزَلْنَا مِنَ اَ۬لْمُعْصِرَٰتِ مَآءٗ ثَجَّاجاٗ ١٤",
      "numberInSurah": 14,
      "verse_key": "78:14"
    },
    {
      "text": "لِّنُخْرِجَ بِهِۦ حَبّاٗ وَنَبَاتاٗ ١٥",
      "numberInSurah": 15,
      "verse_key": "78:15"
    },
    {
      "text": "وَجَنَّٰتٍ اَلْفَافاًۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "78:16"
    },
    {
      "text": "اِنَّ يَوْمَ اَ۬لْفَصْلِ كَانَ مِيقَٰتاٗ ١٧",
      "numberInSurah": 17,
      "verse_key": "78:17"
    },
    {
      "text": "يَوْمَ يُنفَخُ فِے اِ۬لصُّورِ فَتَاتُونَ أَفْوَاجاٗ ١٨",
      "numberInSurah": 18,
      "verse_key": "78:18"
    },
    {
      "text": "وَفُتِّحَتِ اِ۬لسَّمَآءُ فَكَانَتَ اَبْوَٰباٗ ١٩",
      "numberInSurah": 19,
      "verse_key": "78:19"
    },
    {
      "text": "وَسُيِّرَتِ اِ۬لْجِبَالُ فَكَانَتْ سَرَاباًۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "78:20"
    },
    {
      "text": "اِنَّ جَهَنَّمَ كَانَتْ مِرْصَاداٗ ٢١",
      "numberInSurah": 21,
      "verse_key": "78:21"
    },
    {
      "text": "لِّلطَّٰغِينَ مَـَٔاباٗ ٢٢",
      "numberInSurah": 22,
      "verse_key": "78:22"
    },
    {
      "text": "لَّٰبِثِينَ فِيهَآ أَحْقَاباٗۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "78:23"
    },
    {
      "text": "لَّا يَذُوقُونَ فِيهَا بَرْداٗ وَلَا شَرَاباً ٢٤",
      "numberInSurah": 24,
      "verse_key": "78:24"
    },
    {
      "text": "اِلَّا حَمِيماٗ وَغَسَاقاٗ ٢٥",
      "numberInSurah": 25,
      "verse_key": "78:25"
    },
    {
      "text": "جَزَآءٗ وِفَاقاًۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "78:26"
    },
    {
      "text": "اِنَّهُمْ كَانُواْ لَا يَرْجُونَ حِسَاباٗ ٢٧",
      "numberInSurah": 27,
      "verse_key": "78:27"
    },
    {
      "text": "وَكَذَّبُواْ بِـَٔايَٰتِنَا كِذَّاباٗۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "78:28"
    },
    {
      "text": "وَكُلَّ شَےْءٍ اَحْصَيْنَٰهُ كِتَٰباٗۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "78:29"
    },
    {
      "text": "فَذُوقُواْ فَلَن نَّزِيدَكُمُۥٓ إِلَّا عَذَاباًۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "78:30"
    }
  ],
