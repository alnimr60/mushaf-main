{
  "pageNumber": 446,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالصَّٰٓفَّٰتِ صَفّاٗ ١",
      "numberInSurah": 1,
      "verse_key": "37:1"
    },
    {
      "text": "فَالزَّٰجِرَٰتِ زَجْراٗ ٢",
      "numberInSurah": 2,
      "verse_key": "37:2"
    },
    {
      "text": "فَالتَّٰلِيَٰتِ ذِكْراً ٣",
      "numberInSurah": 3,
      "verse_key": "37:3"
    },
    {
      "text": "اِنَّ إِلَٰهَكُمْ لَوَٰحِدٞۖ ٤",
      "numberInSurah": 4,
      "verse_key": "37:4"
    },
    {
      "text": "رَّبُّ اُ۬لسَّمَٰوَٰتِ وَالَارْضِ وَمَا بَيْنَهُمَا وَرَبُّ اُ۬لْمَشَٰرِقِۖ ٥",
      "numberInSurah": 5,
      "verse_key": "37:5"
    },
    {
      "text": "إِنَّا زَيَّنَّا اَ۬لسَّمَآءَ اَ۬لدُّنْي۪ا بِزِينَةِ اِ۬لْكَوَاكِبِۖ ٦",
      "numberInSurah": 6,
      "verse_key": "37:6"
    },
    {
      "text": "وَحِفْظاٗ مِّن كُلِّ شَيْطَٰنٖ مَّارِدٖۖ ٧",
      "numberInSurah": 7,
      "verse_key": "37:7"
    },
    {
      "text": "لَّا يَسْمَعُونَ إِلَي اَ۬لْمَلَإِ اِ۬لَاعْل۪يٰ وَيُقْذَفُونَ مِن كُلِّ جَانِبٖۖ ٨",
      "numberInSurah": 8,
      "verse_key": "37:8"
    },
    {
      "text": "دُحُوراٗۖ وَلَهُمْ عَذَابٞ وَاصِبٌ ٩",
      "numberInSurah": 9,
      "verse_key": "37:9"
    },
    {
      "text": "اِلَّا مَنْ خَطِفَ اَ۬لْخَطْفَةَ فَأَتْبَعَهُۥ شِهَابٞ ثَاقِبٞۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "37:10"
    },
    {
      "text": "فَاسْتَفْتِهِمُۥٓ أَهُمُۥٓ أَشَدُّ خَلْقاً اَم مَّنْ خَلَقْنَآۖ إِنَّا خَلَقْنَٰهُم مِّن طِينٖ لَّٰزِبِۢۖ ١١",
      "numberInSurah": 11,
      "verse_key": "37:11"
    },
    {
      "text": "بَلْ عَجِبْتَ وَيَسْخَرُونَۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "37:12"
    },
    {
      "text": "وَإِذَا ذُكِّرُواْ لَا يَذْكُرُونَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "37:13"
    },
    {
      "text": "وَإِذَا رَأَوَاْ اٰيَةٗ يَسْتَسْخِرُونَۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "37:14"
    },
    {
      "text": "وَقَالُوٓاْ إِنْ هَٰذَآ إِلَّا سِحْرٞ مُّبِينٌ ١٥",
      "numberInSurah": 15,
      "verse_key": "37:15"
    },
    {
      "text": "اَ۟ذَا مِتْنَا وَكُنَّا تُرَاباٗ وَعِظَٰماً اِنَّا لَمَبْعُوثُونَ ١٦",
      "numberInSurah": 16,
      "verse_key": "37:16"
    },
    {
      "text": "أَوَ ءَابَآؤُنَا اَ۬لَاوَّلُونَۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "37:17"
    },
    {
      "text": "قُلْ نَعَمْ وَأَنتُمْ دَٰخِرُونَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "37:18"
    },
    {
      "text": "فَإِنَّمَا هِيَ زَجْرَةٞ وَٰحِدَةٞ فَإِذَا هُمْ يَنظُرُونَۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "37:19"
    },
    {
      "text": "وَقَالُواْ يَٰوَيْلَنَا هَٰذَا يَوْمُ اُ۬لدِّينِۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "37:20"
    },
    {
      "text": "هَٰذَا يَوْمُ اُ۬لْفَصْلِ اِ۬لذِے كُنتُم بِهِۦ تُكَذِّبُونَۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "37:21"
    },
    {
      "text": "۞اَ۟حْشُرُواْ اُ۬لذِينَ ظَلَمُواْ وَأَزْوَٰجَهُمْ وَمَا كَانُواْ يَعْبُدُونَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "37:22"
    },
    {
      "text": "مِن دُونِ اِ۬للَّهِ فَاهْدُوهُمُۥٓ إِلَيٰ صِرَٰطِ اِ۬لْجَحِيمِۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "37:23"
    },
    {
      "text": "وَقِفُوهُمُۥٓ إِنَّهُم مَّسْـُٔولُونَۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "37:24"
    }
  ],
