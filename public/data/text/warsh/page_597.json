{
  "pageNumber": 597,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالتِّينِ وَالزَّيْتُونِ ١",
      "numberInSurah": 1,
      "verse_key": "95:1"
    },
    {
      "text": "وَطُورِ سِينِينَ ٢",
      "numberInSurah": 2,
      "verse_key": "95:2"
    },
    {
      "text": "وَهَٰذَا اَ۬لْبَلَدِ اِ۬لَامِينِ ٣",
      "numberInSurah": 3,
      "verse_key": "95:3"
    },
    {
      "text": "لَقَدْ خَلَقْنَا اَ۬لِانسَٰنَ فِےٓ أَحْسَنِ تَقْوِيمٖ ٤",
      "numberInSurah": 4,
      "verse_key": "95:4"
    },
    {
      "text": "ثُمَّ رَدَدْنَٰهُ أَسْفَلَ سَٰفِلِينَ ٥",
      "numberInSurah": 5,
      "verse_key": "95:5"
    },
    {
      "text": "إِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ فَلَهُمُۥٓ أَجْرٌ غَيْرُ مَمْنُونٖۖ ٦",
      "numberInSurah": 6,
      "verse_key": "95:6"
    },
    {
      "text": "فَمَا يُكَذِّبُكَ بَعْدُ بِالدِّينِۖ ٧",
      "numberInSurah": 7,
      "verse_key": "95:7"
    },
    {
      "text": "أَلَيْسَ اَ۬للَّهُ بِأَحْكَمِ اِ۬لْحَٰكِمِينَۖ ٨",
      "numberInSurah": 8,
      "verse_key": "95:8"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اَ۪قْرَأْ بِاسْمِ رَبِّكَ اَ۬لذِے خَلَقَۖ ١",
      "numberInSurah": 1,
      "verse_key": "96:1"
    },
    {
      "text": "خَلَقَ اَ۬لِانسَٰنَ مِنْ عَلَقٍۖ ٢",
      "numberInSurah": 2,
      "verse_key": "96:2"
    },
    {
      "text": "اِ۪قْرَأْ وَرَبُّكَ اَ۬لَاكْرَمُ ٣",
      "numberInSurah": 3,
      "verse_key": "96:3"
    },
    {
      "text": "اُ۬لذِے عَلَّمَ بِالْقَلَمِ ٤",
      "numberInSurah": 4,
      "verse_key": "96:4"
    },
    {
      "text": "عَلَّمَ اَ۬لِانسَٰنَ مَا لَمْ يَعْلَمْۖ ٥",
      "numberInSurah": 5,
      "verse_key": "96:5"
    },
    {
      "text": "كَلَّآ إِنَّ اَ۬لِانسَٰنَ لَيَطْغ۪يٰٓ ٦",
      "numberInSurah": 6,
      "verse_key": "96:6"
    },
    {
      "text": "أَن رّ۪ء۪اهُ اُ۪سْتَغْن۪يٰٓۖ ٧",
      "numberInSurah": 7,
      "verse_key": "96:7"
    },
    {
      "text": "إِنَّ إِلَيٰ رَبِّكَ اَ۬لرُّجْع۪يٰٓۖ ٨",
      "numberInSurah": 8,
      "verse_key": "96:8"
    },
    {
      "text": "أَرَٰٓيْتَ اَ۬لذِے يَنْه۪يٰ ٩",
      "numberInSurah": 9,
      "verse_key": "96:9"
    },
    {
      "text": "عَبْداً اِذَا صَلّ۪يٰٓۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "96:10"
    },
    {
      "text": "أَرَٰٓيْتَ إِن كَانَ عَلَي اَ۬لْهُد۪يٰٓ ١١",
      "numberInSurah": 11,
      "verse_key": "96:11"
    },
    {
      "text": "أَوَ اَمَرَ بِالتَّقْو۪يٰٓ ١٢",
      "numberInSurah": 12,
      "verse_key": "96:12"
    },
    {
      "text": "أَرَٰٓيْتَ إِن كَذَّبَ وَتَوَلّ۪يٰٓ ١٣",
      "numberInSurah": 13,
      "verse_key": "96:13"
    },
    {
      "text": "أَلَمْ يَعْلَم بِأَنَّ اَ۬للَّهَ يَر۪يٰۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "96:14"
    },
    {
      "text": "كَلَّا لَئِن لَّمْ يَنتَهِ ١٥",
      "numberInSurah": 15,
      "verse_key": "96:15"
    },
    {
      "text": "لَنَسْفَعاَۢ بِالنَّاصِيَةِ ١٦",
      "numberInSurah": 16,
      "verse_key": "96:16"
    },
    {
      "text": "نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "96:17"
    },
    {
      "text": "فَلْيَدْعُ نَادِيَهُۥ ١٨",
      "numberInSurah": 18,
      "verse_key": "96:18"
    },
    {
      "text": "سَنَدْعُ اُ۬لزَّبَانِيَةَۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "96:19"
    }
  ],
