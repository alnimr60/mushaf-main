{
  "pageNumber": 594,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَجَآءَ رَبُّكَ وَالْمَلَكُ صَفّاٗ صَفّاٗ ٢٤",
      "numberInSurah": 24,
      "verse_key": "89:24"
    },
    {
      "text": "وَجِےٓءَ يَوْمَئِذِۢ بِجَهَنَّمَ ٢٥",
      "numberInSurah": 25,
      "verse_key": "89:25"
    },
    {
      "text": "يَوْمَئِذٖ يَتَذَكَّرُ اُ۬لِانسَٰنُ وَأَنّ۪يٰ لَهُ اُ۬لذِّكْر۪يٰۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "89:26"
    },
    {
      "text": "يَقُولُ يَٰلَيْتَنِے قَدَّمْتُ لِحَيَاتِےۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "89:27"
    },
    {
      "text": "فَيَوْمَئِذٖ لَّا يُعَذِّبُ عَذَابَهُۥٓ أَحَدٞ ٢٨",
      "numberInSurah": 28,
      "verse_key": "89:28"
    },
    {
      "text": "وَلَا يُوثِقُ وَثَاقَهُۥٓ أَحَدٞۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "89:29"
    },
    {
      "text": "يَٰٓأَيَّتُهَا اَ۬لنَّفْسُ اُ۬لْمُطْمَئِنَّةُ ٣٠",
      "numberInSurah": 30,
      "verse_key": "89:30"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "لَآ أُقْسِمُ بِهَٰذَا اَ۬لْبَلَدِ ١",
      "numberInSurah": 1,
      "verse_key": "90:1"
    },
    {
      "text": "وَأَنتَ حِلُّۢ بِهَٰذَا اَ۬لْبَلَدِ ٢",
      "numberInSurah": 2,
      "verse_key": "90:2"
    },
    {
      "text": "وَوَالِدٖ وَمَا وَلَدَ ٣",
      "numberInSurah": 3,
      "verse_key": "90:3"
    },
    {
      "text": "لَقَدْ خَلَقْنَا اَ۬لِانسَٰنَ فِے كَبَدٍۖ ٤",
      "numberInSurah": 4,
      "verse_key": "90:4"
    },
    {
      "text": "اَيَحْسِبُ أَن لَّنْ يَّقْدِرَ عَلَيْهِ أَحَدٞ ٥",
      "numberInSurah": 5,
      "verse_key": "90:5"
    },
    {
      "text": "يَقُولُ أَهْلَكْتُ مَالاٗ لُّبَداًۖ ٦",
      "numberInSurah": 6,
      "verse_key": "90:6"
    },
    {
      "text": "اَيَحْسِبُ أَن لَّمْ يَرَهُۥٓ أَحَدٌۖ ٧",
      "numberInSurah": 7,
      "verse_key": "90:7"
    },
    {
      "text": "اَلَمْ نَجْعَل لَّهُۥ عَيْنَيْنِ ٨",
      "numberInSurah": 8,
      "verse_key": "90:8"
    },
    {
      "text": "وَلِسَاناٗ وَشَفَتَيْنِ ٩",
      "numberInSurah": 9,
      "verse_key": "90:9"
    },
    {
      "text": "وَهَدَيْنَٰهُ اُ۬لنَّجْدَيْنِۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "90:10"
    },
    {
      "text": "فَلَا اَ۪قْتَحَمَ اَ۬لْعَقَبَةَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "90:11"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا اَ۬لْعَقَبَةُۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "90:12"
    },
    {
      "text": "فَكُّ رَقَبَةٍ ١٣",
      "numberInSurah": 13,
      "verse_key": "90:13"
    },
    {
      "text": "اَوِ اِطْعَامٞ فِے يَوْمٖ ذِے مَسْغَبَةٖ ١٤",
      "numberInSurah": 14,
      "verse_key": "90:14"
    },
    {
      "text": "يَتِيماٗ ذَا مَقْرَبَةٍ ١٥",
      "numberInSurah": 15,
      "verse_key": "90:15"
    },
    {
      "text": "اَوْ مِسْكِيناٗ ذَا مَتْرَبَةٖۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "90:16"
    },
    {
      "text": "ثُمَّ كَانَ مِنَ اَ۬لذِينَ ءَامَنُواْ وَتَوَاصَوْاْ بِالصَّبْرِ وَتَوَاصَوْاْ بِالْمَرْحَمَةِۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "90:17"
    },
    {
      "text": "أُوْلَٰٓئِكَ أَصْحَٰبُ اُ۬لْمَيْمَنَةِۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "90:18"
    },
    {
      "text": "وَالذِينَ كَفَرُواْ بِـَٔايَٰتِنَا هُمُۥٓ أَصْحَٰبُ اُ۬لْمَشْـَٔمَةِۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "90:19"
    },
    {
      "text": "عَلَيْهِمْ نَارٞ مُّوصَدَةٞۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "90:20"
    }
  ],
