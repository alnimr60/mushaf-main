{
  "pageNumber": 567,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَعَصَوْاْ رَسُولَ رَبِّهِمْ فَأَخَذَهُمُۥٓ أَخْذَةٗ رَّابِيَةًۖ ٩",
      "numberInSurah": 9,
      "verse_key": "69:9"
    },
    {
      "text": "اِنَّا لَمَّا طَغَا اَ۬لْمَآءُ حَمَلْنَٰكُمْ فِے اِ۬لْجَارِيَةِ ١٠",
      "numberInSurah": 10,
      "verse_key": "69:10"
    },
    {
      "text": "لِنَجْعَلَهَا لَكُمْ تَذْكِرَةٗ وَتَعِيَهَآ أُذْنٞ وَٰعِيَةٞۖ ١١",
      "numberInSurah": 11,
      "verse_key": "69:11"
    },
    {
      "text": "فَإِذَا نُفِخَ فِے اِ۬لصُّورِ نَفْخَةٞ وَٰحِدَةٞ ١٢",
      "numberInSurah": 12,
      "verse_key": "69:12"
    },
    {
      "text": "وَحُمِلَتِ اِ۬لَارْضُ وَالْجِبَالُ فَدُكَّتَا دَكَّةٗ وَٰحِدَةٗ ١٣",
      "numberInSurah": 13,
      "verse_key": "69:13"
    },
    {
      "text": "فَيَوْمَئِذٖ وَقَعَتِ اِ۬لْوَاقِعَةُ ١٤",
      "numberInSurah": 14,
      "verse_key": "69:14"
    },
    {
      "text": "وَانشَقَّتِ اِ۬لسَّمَآءُ فَهِيَ يَوْمَئِذٖ وَاهِيَةٞ ١٥",
      "numberInSurah": 15,
      "verse_key": "69:15"
    },
    {
      "text": "وَالْمَلَكُ عَلَيٰٓ أَرْجَآئِهَاۖ وَيَحْمِلُ عَرْشَ رَبِّكَ فَوْقَهُمْ يَوْمَئِذٖ ثَمَٰنِيَةٞ ١٦",
      "numberInSurah": 16,
      "verse_key": "69:16"
    },
    {
      "text": "يَوْمَئِذٖ تُعْرَضُونَ لَا تَخْف۪يٰ مِنكُمْ خَافِيَةٞۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "69:17"
    },
    {
      "text": "۞فَأَمَّا مَنُ ا۟وتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ فَيَقُولُ هَآؤُمُ اُ۪قْرَءُواْ كِتَٰبِيَهْۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "69:18"
    },
    {
      "text": "إِنِّے ظَنَنتُ أَنِّے مُلَٰقٍ حِسَابِيَهْۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "69:19"
    },
    {
      "text": "فَهُوَ فِے عِيشَةٖ رَّاضِيَةٖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "69:20"
    },
    {
      "text": "فِے جَنَّةٍ عَالِيَةٖ ٢١",
      "numberInSurah": 21,
      "verse_key": "69:21"
    },
    {
      "text": "قُطُوفُهَا دَانِيَةٞۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "69:22"
    },
    {
      "text": "كُلُواْ وَاشْرَبُواْ هَنِيٓـٔاَۢ بِمَآ أَسْلَفْتُمْ فِے اِ۬لَايَّامِ اِ۬لْخَالِيَةِۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "69:23"
    },
    {
      "text": "وَأَمَّا مَنُ ا۟وتِيَ كِتَٰبَهُۥ بِشِمَالِهِۦ ٢٤",
      "numberInSurah": 24,
      "verse_key": "69:24"
    },
    {
      "text": "فَيَقُولُ يَٰلَيْتَنِے لَمُ ا۟وتَ كِتَٰبِيَهْۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "69:25"
    },
    {
      "text": "وَلَمَ اَدْرِ مَا حِسَابِيَهْۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "69:26"
    },
    {
      "text": "يَٰلَيْتَهَا كَانَتِ اِ۬لْقَاضِيَةَ ٢٧",
      "numberInSurah": 27,
      "verse_key": "69:27"
    },
    {
      "text": "مَآ أَغْن۪يٰ عَنِّے مَالِيَهۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "69:28"
    },
    {
      "text": "هَّلَكَ عَنِّے سُلْطَٰنِيَهْۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "69:29"
    },
    {
      "text": "خُذُوهُ فَغُلُّوهُ ٣٠",
      "numberInSurah": 30,
      "verse_key": "69:30"
    },
    {
      "text": "ثُمَّ اَ۬لْجَحِيمَ صَلُّوهُ ٣١",
      "numberInSurah": 31,
      "verse_key": "69:31"
    },
    {
      "text": "ثُمَّ فِے سِلْسِلَةٖ ذَرْعُهَا سَبْعُونَ ذِرَاعاٗ فَاسْلُكُوهُۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "69:32"
    },
    {
      "text": "إِنَّهُۥ كَانَ لَا يُومِنُ بِاللَّهِ اِ۬لْعَظِيمِ ٣٣",
      "numberInSurah": 33,
      "verse_key": "69:33"
    },
    {
      "text": "وَلَا يَحُضُّ عَلَيٰ طَعَامِ اِ۬لْمِسْكِينِۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "69:34"
    }
  ],
