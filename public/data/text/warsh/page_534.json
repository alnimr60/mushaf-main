    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٧٢",
      "numberInSurah": 72,
      "verse_key": "55:72"
    },
    {
      "text": "لَمْ يَطْمِثْهُنَّ إِنسٞ قَبْلَهُمْ وَلَا جَآنّٞۖ ٧٣",
      "numberInSurah": 73,
      "verse_key": "55:73"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٧٤",
      "numberInSurah": 74,
      "verse_key": "55:74"
    },
    {
      "text": "مُتَّكِـِٕينَ عَلَيٰ رَفْرَفٍ خُضْرٖ وَعَبْقَرِيٍّ حِسَانٖۖ ٧٥",
      "numberInSurah": 75,
      "verse_key": "55:75"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٧٦",
      "numberInSurah": 76,
      "verse_key": "55:76"
    },
    {
      "text": "تَبَٰرَكَ اَ۪سْمُ رَبِّكَ ذِے اِ۬لْجَلَٰلِ وَالِاكْرَامِۖ ٧٧",
      "numberInSurah": 77,
      "verse_key": "55:77"
    },
    {
      "text": "",
      "numberInSurah": 78,
      "verse_key": "55:78"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا وَقَعَتِ اِ۬لْوَاقِعَةُ ١",
      "numberInSurah": 1,
      "verse_key": "56:1"
    },
    {
      "text": "لَيْسَ لِوَقْعَتِهَا كَٰذِبَةٌۖ ٢",
      "numberInSurah": 2,
      "verse_key": "56:2"
    },
    {
      "text": "خَافِضَةٞ رَّافِعَةٌ ٣",
      "numberInSurah": 3,
      "verse_key": "56:3"
    },
    {
      "text": "اِذَا رُجَّتِ اِ۬لَارْضُ رَجّاٗ ٤",
      "numberInSurah": 4,
      "verse_key": "56:4"
    },
    {
      "text": "وَبُسَّتِ اِ۬لْجِبَالُ بَسّاٗ ٥",
      "numberInSurah": 5,
      "verse_key": "56:5"
    },
    {
      "text": "فَكَانَتْ هَبَآءٗ مُّنۢبَثّاٗ ٦",
      "numberInSurah": 6,
      "verse_key": "56:6"
    },
    {
      "text": "وَكُنتُمُۥٓ أَزْوَٰجاٗ ثَلَٰثَةٗۖ ٧",
      "numberInSurah": 7,
      "verse_key": "56:7"
    },
    {
      "text": "فَأَصْحَٰبُ اُ۬لْمَيْمَنَةِ ٨",
      "numberInSurah": 8,
      "verse_key": "56:8"
    },
    {
      "text": "مَآ أَصْحَٰبُ اُ۬لْمَيْمَنَةِۖ ٩",
      "numberInSurah": 9,
      "verse_key": "56:9"
    },
    {
      "text": "وَأَصْحَٰبُ اُ۬لْمَشْـَٔمَةِ ١٠",
      "numberInSurah": 10,
      "verse_key": "56:10"
    },
    {
      "text": "مَآ أَصْحَٰبُ اُ۬لْمَشْـَٔمَةِۖ ١١",
      "numberInSurah": 11,
      "verse_key": "56:11"
    },
    {
      "text": "وَالسَّٰبِقُونَ اَ۬لسَّٰبِقُونَۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "56:12"
    },
    {
      "text": "أُوْلَٰٓئِكَ اَ۬لْمُقَرَّبُونَ ١٣",
      "numberInSurah": 13,
      "verse_key": "56:13"
    },
    {
      "text": "فِے جَنَّٰتِ اِ۬لنَّعِيمِۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "56:14"
    },
    {
      "text": "ثُلَّةٞ مِّنَ اَ۬لَاوَّلِينَ ١٥",
      "numberInSurah": 15,
      "verse_key": "56:15"
    },
    {
