{
  "pageNumber": 456,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَخُذْ بِيَدِكَ ضِغْثاٗ فَاضْرِب بِّهِۦ وَلَا تَحْنَثِۖ اِنَّا وَجَدْنَٰهُ صَابِراٗۖ نِّعْمَ اَ۬لْعَبْدُۖ إِنَّهُۥٓ أَوَّابٞۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "38:43"
    },
    {
      "text": "وَاذْكُرْ عِبَٰدَنَآ إِبْرَٰهِيمَ وَإِسْحَٰقَ وَيَعْقُوبَ أُوْلِے اِ۬لَايْدِے وَالَابْصٰ۪رِۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "38:44"
    },
    {
      "text": "إِنَّآ أَخْلَصْنَٰهُم بِخَالِصَةِ ذِكْرَي اَ۬لدّ۪ارِۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "38:45"
    },
    {
      "text": "وَإِنَّهُمْ عِندَنَا لَمِنَ اَ۬لْمُصْطَفَيْنَ اَ۬لَاخْي۪ارِۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "38:46"
    },
    {
      "text": "وَاذْكُرِ اِسْمَٰعِيلَ وَالْيَسَعَ وَذَا اَ۬لْكِفْلِۖ وَكُلّٞ مِّنَ اَ۬لَاخْي۪ارِۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "38:47"
    },
    {
      "text": "هَٰذَا ذِكْرٞۖ وَإِنَّ لِلْمُتَّقِينَ لَحُسْنَ مَـَٔابٖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "38:48"
    },
    {
      "text": "جَنَّٰتِ عَدْنٖ مُّفَتَّحَةٗ لَّهُمُ اُ۬لَابْوَٰبُ ٤٩",
      "numberInSurah": 49,
      "verse_key": "38:49"
    },
    {
      "text": "مُتَّكِـِٕينَ فِيهَا يَدْعُونَ فِيهَا بِفَٰكِهَةٖ كَثِيرَةٖ وَشَرَابٖۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "38:50"
    },
    {
      "text": "۞وَعِندَهُمْ قَٰصِرَٰتُ اُ۬لطَّرْفِ أَتْرَابٌۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "38:51"
    },
    {
      "text": "هَٰذَا مَا تُوعَدُونَ لِيَوْمِ اِ۬لْحِسَابِۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "38:52"
    },
    {
      "text": "إِنَّ هَٰذَا لَرِزْقُنَا مَا لَهُۥ مِن نَّفَادٍۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "38:53"
    },
    {
      "text": "هَٰذَاۖ وَإِنَّ لِلطَّٰغِينَ لَشَرَّ مَـَٔابٖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "38:54"
    },
    {
      "text": "جَهَنَّمَ يَصْلَوْنَهَا فَبِيسَ اَ۬لْمِهَادُۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "38:55"
    },
    {
      "text": "هَٰذَا فَلْيَذُوقُوهُ حَمِيمٞ وَغَسَاقٞ ٥٦",
      "numberInSurah": 56,
      "verse_key": "38:56"
    },
    {
      "text": "وَءَاخَرُ مِن شَكْلِهِۦٓ أَزْوَٰجٌۖ ٥٧",
      "numberInSurah": 57,
      "verse_key": "38:57"
    },
    {
      "text": "هَٰذَا فَوْجٞ مُّقْتَحِمٞ مَّعَكُمْۖ لَا مَرْحَباَۢ بِهِمُۥٓۖ إِنَّهُمْ صَالُواْ اُ۬لنّ۪ارِۖ ٥٨",
      "numberInSurah": 58,
      "verse_key": "38:58"
    },
    {
      "text": "قَالُواْ بَلَ اَنتُمْ لَا مَرْحَباَۢ بِكُمُۥٓ أَنتُمْ قَدَّمْتُمُوهُ لَنَاۖ فَبِيسَ اَ۬لْقَرَارُۖ ٥٩",
      "numberInSurah": 59,
      "verse_key": "38:59"
    },
    {
      "text": "قَالُواْ رَبَّنَا مَن قَدَّمَ لَنَا هَٰذَا فَزِدْهُ عَذَاباٗ ضِعْفاٗ فِے اِ۬لنّ۪ارِۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "38:60"
    },
    {
      "text": "وَقَالُواْ مَا لَنَا لَا نَر۪يٰ رِجَالاٗ كُنَّا نَعُدُّهُم مِّنَ اَ۬لَاشْر۪ارِۖ ٦١",
      "numberInSurah": 61,
      "verse_key": "38:61"
    }
  ],
