{
  "pageNumber": 528,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "مِن نُّطْفَةٍ اِذَا تُمْن۪يٰۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "53:45"
    },
    {
      "text": "۞وَأَنَّ عَلَيْهِ اِ۬لنَّشْأَةَ اَ۬لُاخْر۪يٰۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "53:46"
    },
    {
      "text": "وَأَنَّهُۥ هُوَ أَغْن۪يٰ وَأَقْن۪يٰۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "53:47"
    },
    {
      "text": "وَأَنَّهُۥ هُوَ رَبُّ اُ۬لشِّعْر۪يٰۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "53:48"
    },
    {
      "text": "وَأَنَّهُۥٓ أَهْلَكَ عَاداٗ اَ۬لُّاول۪يٰ ٤٩",
      "numberInSurah": 49,
      "verse_key": "53:49"
    },
    {
      "text": "وَثَمُوداٗ فَمَآ أَبْق۪يٰ ٥٠",
      "numberInSurah": 50,
      "verse_key": "53:50"
    },
    {
      "text": "وَقَوْمَ نُوحٖ مِّن قَبْلُۖ إِنَّهُمْ كَانُواْ هُمُۥٓ أَظْلَمَ وَأَطْغ۪يٰۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "53:51"
    },
    {
      "text": "وَالْمُوتَفِكَةَ أَهْو۪يٰۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "53:52"
    },
    {
      "text": "فَغَشّ۪يٰهَا مَا غَشّ۪يٰۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "53:53"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَار۪يٰۖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "53:54"
    },
    {
      "text": "هَٰذَا نَذِيرٞ مِّنَ اَ۬لنُّذُرِ اِ۬لُاول۪يٰٓۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "53:55"
    },
    {
      "text": "أَزِفَتِ اِ۬لَازِفَةُۖ ٥٦",
      "numberInSurah": 56,
      "verse_key": "53:56"
    },
    {
      "text": "لَيْسَ لَهَا مِن دُونِ اِ۬للَّهِ كَاشِفَةٌۖ ٥٧",
      "numberInSurah": 57,
      "verse_key": "53:57"
    },
    {
      "text": "اَفَمِنْ هَٰذَا اَ۬لْحَدِيثِ تَعْجَبُونَ ٥٨",
      "numberInSurah": 58,
      "verse_key": "53:58"
    },
    {
      "text": "وَتَضْحَكُونَ وَلَا تَبْكُونَ ٥٩",
      "numberInSurah": 59,
      "verse_key": "53:59"
    },
    {
      "text": "وَأَنتُمْ سَٰمِدُونَۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "53:60"
    },
    {
      "text": "فَاسْجُدُواْ لِلهِ وَاعْبُدُواْ۩ۖ ٦١",
      "numberInSurah": 61,
      "verse_key": "53:61"
    },
    {
      "text": "",
      "numberInSurah": 62,
      "verse_key": "53:62"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اُ۪قْتَرَبَتِ اِ۬لسَّاعَةُ وَانشَقَّ اَ۬لْقَمَرُۖ ١",
      "numberInSurah": 1,
      "verse_key": "54:1"
    },
    {
      "text": "وَإِنْ يَّرَوَاْ اٰيَةٗ يُعْرِضُواْ وَيَقُولُواْ سِحْرٞ مُّسْتَمِرّٞۖ ٢",
      "numberInSurah": 2,
      "verse_key": "54:2"
    },
    {
      "text": "وَكَذَّبُواْ وَاتَّبَعُوٓاْ أَهْوَآءَهُمْۖ وَكُلُّ أَمْرٖ مُّسْتَقِرّٞۖ ٣",
      "numberInSurah": 3,
      "verse_key": "54:3"
    },
    {
      "text": "وَلَقَدْ جَآءَهُم مِّنَ اَ۬لَانۢبَآءِ مَا فِيهِ مُزْدَجَرٌۖ ٤",
      "numberInSurah": 4,
      "verse_key": "54:4"
    },
    {
      "text": "حِكْمَةُۢ بَٰلِغَةٞۖ فَمَا تُغْنِ اِ۬لنُّذُرُۖ ٥",
      "numberInSurah": 5,
      "verse_key": "54:5"
    },
    {
      "text": "فَتَوَلَّ عَنْهُمْۖ يَوْمَ يَدْعُ اُ۬لدَّاعِۦٓ إِلَيٰ شَےْءٖ نُّكُرٍ ٦",
      "numberInSurah": 6,
      "verse_key": "54:6"
    }
  ],
