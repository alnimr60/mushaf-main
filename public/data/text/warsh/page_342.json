{
  "pageNumber": 342,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قَدَ اَفْلَحَ اَ۬لْمُومِنُونَۖ ١",
      "numberInSurah": 1,
      "verse_key": "23:1"
    },
    {
      "text": "اَ۬لذِينَ هُمْ فِے صَلَاتِهِمْ خَٰشِعُونَۖ ٢",
      "numberInSurah": 2,
      "verse_key": "23:2"
    },
    {
      "text": "وَالذِينَ هُمْ عَنِ اِ۬للَّغْوِ مُعْرِضُونَۖ ٣",
      "numberInSurah": 3,
      "verse_key": "23:3"
    },
    {
      "text": "وَالذِينَ هُمْ لِلزَّكَوٰةِ فَٰعِلُونَۖ ٤",
      "numberInSurah": 4,
      "verse_key": "23:4"
    },
    {
      "text": "وَالذِينَ هُمْ لِفُرُوجِهِمْ حَٰفِظُونَ ٥",
      "numberInSurah": 5,
      "verse_key": "23:5"
    },
    {
      "text": "إِلَّا عَلَيٰٓ أَزْوَٰجِهِمُۥٓ أَوْ مَا مَلَكَتَ اَيْمَٰنُهُمْ فَإِنَّهُمْ غَيْرُ مَلُومِينَۖ ٦",
      "numberInSurah": 6,
      "verse_key": "23:6"
    },
    {
      "text": "فَمَنِ اِ۪بْتَغ۪يٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ اُ۬لْعَادُونَۖ ٧",
      "numberInSurah": 7,
      "verse_key": "23:7"
    },
    {
      "text": "وَالذِينَ هُمْ لِأَمَٰنَٰتِهِمْ وَعَهْدِهِمْ رَٰعُونَۖ ٨",
      "numberInSurah": 8,
      "verse_key": "23:8"
    },
    {
      "text": "وَالذِينَ هُمْ عَلَيٰ صَلَوَٰتِهِمْ يُحَافِظُونَ ٩",
      "numberInSurah": 9,
      "verse_key": "23:9"
    },
    {
      "text": "أُوْلَٰٓئِكَ هُمُ اُ۬لْوَٰرِثُونَ ١٠",
      "numberInSurah": 10,
      "verse_key": "23:10"
    },
    {
      "text": "اَ۬لذِينَ يَرِثُونَ اَ۬لْفِرْدَوْسَۖ هُمْ فِيهَا خَٰلِدُونَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "23:11"
    },
    {
      "text": "وَلَقَدْ خَلَقْنَا اَ۬لِانسَٰنَ مِن سُلَٰلَةٖ مِّن طِينٖۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "23:12"
    },
    {
      "text": "ثُمَّ جَعَلْنَٰهُ نُطْفَةٗ فِے قَر۪ارٖ مَّكِينٖۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "23:13"
    },
    {
      "text": "ثُمَّ خَلَقْنَا اَ۬لنُّطْفَةَ عَلَقَةٗ فَخَلَقْنَا اَ۬لْعَلَقَةَ مُضْغَةٗ فَخَلَقْنَا اَ۬لْمُضْغَةَ عِظَٰماٗ فَكَسَوْنَا اَ۬لْعِظَٰمَ لَحْماٗ ثُمَّ أَنشَأْنَٰهُ خَلْقاً اٰخَرَۖ فَتَبَٰرَكَ اَ۬للَّهُ أَحْسَنُ اُ۬لْخَٰلِقِينَۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "23:14"
    },
    {
      "text": "ثُمَّ إِنَّكُم بَعْدَ ذَٰلِكَ لَمَيِّتُونَۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "23:15"
    },
    {
      "text": "ثُمَّ إِنَّكُمْ يَوْمَ اَ۬لْقِيَٰمَةِ تُبْعَثُونَۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "23:16"
    },
    {
      "text": "وَلَقَدْ خَلَقْنَا فَوْقَكُمْ سَبْعَ طَرَآئِقَ وَمَا كُنَّا عَنِ اِ۬لْخَلْقِ غَٰفِلِينَۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "23:17"
    }
  ],
