{
  "pageNumber": 596,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "لَا يَصْلَيٰهَآ إِلَّا اَ۬لَاشْقَي ١٥",
      "numberInSurah": 15,
      "verse_key": "92:15"
    },
    {
      "text": "اَ۬لذِے كَذَّبَ وَتَوَلّ۪يٰۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "92:16"
    },
    {
      "text": "وَسَيُجَنَّبُهَا اَ۬لَاتْقَي ١٧",
      "numberInSurah": 17,
      "verse_key": "92:17"
    },
    {
      "text": "اَ۬لذِے يُوتِے مَالَهُۥ يَتَزَكّ۪يٰۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "92:18"
    },
    {
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٖ تُجْز۪يٰٓ ١٩",
      "numberInSurah": 19,
      "verse_key": "92:19"
    },
    {
      "text": "إِلَّا اَ۪بْتِغَآءَ وَجْهِ رَبِّهِ اِ۬لَاعْل۪يٰۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "92:20"
    },
    {
      "text": "وَلَسَوْفَ يَرْض۪يٰۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "92:21"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالضُّح۪يٰ ١",
      "numberInSurah": 1,
      "verse_key": "93:1"
    },
    {
      "text": "وَاليْلِ إِذَا سَج۪يٰ ٢",
      "numberInSurah": 2,
      "verse_key": "93:2"
    },
    {
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَل۪يٰۖ ٣",
      "numberInSurah": 3,
      "verse_key": "93:3"
    },
    {
      "text": "وَلَلَاخِرَةُ خَيْرٞ لَّكَ مِنَ اَ۬لُاول۪يٰۖ ٤",
      "numberInSurah": 4,
      "verse_key": "93:4"
    },
    {
      "text": "وَلَسَوْفَ يُعْطِيكَ رَبُّكَ فَتَرْض۪يٰٓۖ ٥",
      "numberInSurah": 5,
      "verse_key": "93:5"
    },
    {
      "text": "أَلَمْ يَجِدْكَ يَتِيماٗ فَـَٔاو۪يٰ ٦",
      "numberInSurah": 6,
      "verse_key": "93:6"
    },
    {
      "text": "وَوَجَدَكَ ضَآلّاٗ فَهَد۪يٰ ٧",
      "numberInSurah": 7,
      "verse_key": "93:7"
    },
    {
      "text": "وَوَجَدَكَ عَآئِلاٗ فَأَغْن۪يٰۖ ٨",
      "numberInSurah": 8,
      "verse_key": "93:8"
    },
    {
      "text": "فَأَمَّا اَ۬لْيَتِيمَ فَلَا تَقْهَرْۖ ٩",
      "numberInSurah": 9,
      "verse_key": "93:9"
    },
    {
      "text": "وَأَمَّا اَ۬لسَّآئِلَ فَلَا تَنْهَرْۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "93:10"
    },
    {
      "text": "وَأَمَّا بِنِعْمَةِ رَبِّكَ فَحَدِّثَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "93:11"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اَلَمْ نَشْرَحْ لَكَ صَدْرَكَ ١",
      "numberInSurah": 1,
      "verse_key": "94:1"
    },
    {
      "text": "وَوَضَعْنَا عَنكَ وِزْرَكَ ٢",
      "numberInSurah": 2,
      "verse_key": "94:2"
    },
    {
      "text": "اَ۬لذِےٓ أَنقَضَ ظَهْرَكَ ٣",
      "numberInSurah": 3,
      "verse_key": "94:3"
    },
    {
      "text": "وَرَفَعْنَا لَكَ ذِكْرَكَۖ ٤",
      "numberInSurah": 4,
      "verse_key": "94:4"
    },
    {
      "text": "فَإِنَّ مَعَ اَ۬لْعُسْرِ يُسْراً ٥",
      "numberInSurah": 5,
      "verse_key": "94:5"
    },
    {
      "text": "اِنَّ مَعَ اَ۬لْعُسْرِ يُسْراٗۖ ٦",
      "numberInSurah": 6,
      "verse_key": "94:6"
    },
    {
      "text": "فَإِذَا فَرَغْتَ فَانصَبْ ٧",
      "numberInSurah": 7,
      "verse_key": "94:7"
    },
    {
      "text": "وَإِلَيٰ رَبِّكَ فَارْغَبْۖ ٨",
      "numberInSurah": 8,
      "verse_key": "94:8"
    }
  ],
