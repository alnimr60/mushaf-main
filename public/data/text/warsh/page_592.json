{
  "pageNumber": 592,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بَلْ تُوثِرُونَ اَ۬لْحَيَوٰةَ اَ۬لدُّنْي۪ا ١٦",
      "numberInSurah": 16,
      "verse_key": "87:16"
    },
    {
      "text": "وَالَاخِرَةُ خَيْرٞ وَأَبْق۪يٰٓۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "87:17"
    },
    {
      "text": "إِنَّ هَٰذَا لَفِے اِ۬لصُّحُفِ اِ۬لُاول۪يٰ ١٨",
      "numberInSurah": 18,
      "verse_key": "87:18"
    },
    {
      "text": "صُحُفِ إِبْرَٰهِيمَ وَمُوس۪يٰۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "87:19"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "هَلَ اَت۪يٰكَ حَدِيثُ اُ۬لْغَٰشِيَةِۖ ١",
      "numberInSurah": 1,
      "verse_key": "88:1"
    },
    {
      "text": "وُجُوهٞ يَوْمَئِذٍ خَٰشِعَةٌ ٢",
      "numberInSurah": 2,
      "verse_key": "88:2"
    },
    {
      "text": "عَامِلَةٞ نَّاصِبَةٞ ٣",
      "numberInSurah": 3,
      "verse_key": "88:3"
    },
    {
      "text": "تَصْلَيٰ نَاراً حَامِيَةٗ ٤",
      "numberInSurah": 4,
      "verse_key": "88:4"
    },
    {
      "text": "تُسْق۪يٰ مِنْ عَيْنٍ اٰنِيَةٖۖ ٥",
      "numberInSurah": 5,
      "verse_key": "88:5"
    },
    {
      "text": "لَّيْسَ لَهُمْ طَعَامٌ اِلَّا مِن ضَرِيعٖ ٦",
      "numberInSurah": 6,
      "verse_key": "88:6"
    },
    {
      "text": "لَّا يُسْمِنُ وَلَا يُغْنِے مِن جُوعٖۖ ٧",
      "numberInSurah": 7,
      "verse_key": "88:7"
    },
    {
      "text": "وُجُوهٞ يَوْمَئِذٖ نَّاعِمَةٞ ٨",
      "numberInSurah": 8,
      "verse_key": "88:8"
    },
    {
      "text": "لِّسَعْيِهَا رَاضِيَةٞ ٩",
      "numberInSurah": 9,
      "verse_key": "88:9"
    },
    {
      "text": "فِے جَنَّةٍ عَالِيَةٖ ١٠",
      "numberInSurah": 10,
      "verse_key": "88:10"
    },
    {
      "text": "لَّا تُسْمَعُ فِيهَا لَٰغِيَةٞۖ ١١",
      "numberInSurah": 11,
      "verse_key": "88:11"
    },
    {
      "text": "فِيهَا عَيْنٞ جَارِيَةٞۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "88:12"
    },
    {
      "text": "فِيهَا سُرُرٞ مَّرْفُوعَةٞ ١٣",
      "numberInSurah": 13,
      "verse_key": "88:13"
    },
    {
      "text": "وَأَكْوَابٞ مَّوْضُوعَةٞ ١٤",
      "numberInSurah": 14,
      "verse_key": "88:14"
    },
    {
      "text": "وَنَمَارِقُ مَصْفُوفَةٞ ١٥",
      "numberInSurah": 15,
      "verse_key": "88:15"
    },
    {
      "text": "وَزَرَابِيُّ مَبْثُوثَةٌۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "88:16"
    },
    {
      "text": "۞اَفَلَا يَنظُرُونَ إِلَي اَ۬لِابِلِ كَيْفَ خُلِقَتْ ١٧",
      "numberInSurah": 17,
      "verse_key": "88:17"
    },
    {
      "text": "وَإِلَي اَ۬لسَّمَآءِ كَيْفَ رُفِعَتْ ١٨",
      "numberInSurah": 18,
      "verse_key": "88:18"
    },
    {
      "text": "وَإِلَي اَ۬لْجِبَالِ كَيْفَ نُصِبَتْ ١٩",
      "numberInSurah": 19,
      "verse_key": "88:19"
    },
    {
      "text": "وَإِلَي اَ۬لَارْضِ كَيْفَ سُطِحَتْۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "88:20"
    },
    {
      "text": "فَذَكِّرِ اِنَّمَآ أَنتَ مُذَكِّرٞۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "88:21"
    },
    {
      "text": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "88:22"
    },
    {
      "text": "اِلَّا مَن تَوَلّ۪يٰ وَكَفَرَ ٢٣",
      "numberInSurah": 23,
      "verse_key": "88:23"
    },
    {
      "text": "فَيُعَذِّبُهُ اُ۬للَّهُ اُ۬لْعَذَابَ اَ۬لَاكْبَرَۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "88:24"
    },
    {
      "text": "إِنَّ إِلَيْنَآ إِيَابَهُمْ ٢٥",
      "numberInSurah": 25,
      "verse_key": "88:25"
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُمْۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "88:26"
    }
  ],
