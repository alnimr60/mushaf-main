{
  "pageNumber": 375,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَاتَّقُواْ اُ۬لذِے خَلَقَكُمْ وَالْجِبِلَّةَ اَ۬لَاوَّلِينَۖ ١٨٤",
      "numberInSurah": 184,
      "verse_key": "26:184"
    },
    {
      "text": "قَالُوٓاْ إِنَّمَآ أَنتَ مِنَ اَ۬لْمُسَحَّرِينَ ١٨٥",
      "numberInSurah": 185,
      "verse_key": "26:185"
    },
    {
      "text": "وَمَآ أَنتَ إِلَّا بَشَرٞ مِّثْلُنَا وَإِن نَّظُنُّكَ لَمِنَ اَ۬لْكَٰذِبِينَ ١٨٦",
      "numberInSurah": 186,
      "verse_key": "26:186"
    },
    {
      "text": "فَأَسْقِطْ عَلَيْنَا كِسْفاٗ مِّنَ اَ۬لسَّمَآءِ ان كُنتَ مِنَ اَ۬لصَّٰدِقِينَۖ ١٨٧",
      "numberInSurah": 187,
      "verse_key": "26:187"
    },
    {
      "text": "قَالَ رَبِّيَ أَعْلَمُ بِمَا تَعْمَلُونَۖ ١٨٨",
      "numberInSurah": 188,
      "verse_key": "26:188"
    },
    {
      "text": "فَكَذَّبُوهُ فَأَخَذَهُمْ عَذَابُ يَوْمِ اِ۬لظُّلَّةِۖ إِنَّهُۥ كَانَ عَذَابَ يَوْمٍ عَظِيمٍۖ ١٨٩",
      "numberInSurah": 189,
      "verse_key": "26:189"
    },
    {
      "text": "اِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٩٠",
      "numberInSurah": 190,
      "verse_key": "26:190"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٩١",
      "numberInSurah": 191,
      "verse_key": "26:191"
    },
    {
      "text": "وَإِنَّهُۥ لَتَنزِيلُ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٩٢",
      "numberInSurah": 192,
      "verse_key": "26:192"
    },
    {
      "text": "نَزَلَ بِهِ اِ۬لرُّوحُ اُ۬لَامِينُ ١٩٣",
      "numberInSurah": 193,
      "verse_key": "26:193"
    },
    {
      "text": "عَلَيٰ قَلْبِكَ لِتَكُونَ مِنَ اَ۬لْمُنذِرِينَ ١٩٤",
      "numberInSurah": 194,
      "verse_key": "26:194"
    },
    {
      "text": "بِلِسَانٍ عَرَبِيّٖ مُّبِينٖۖ ١٩٥",
      "numberInSurah": 195,
      "verse_key": "26:195"
    },
    {
      "text": "وَإِنَّهُۥ لَفِے زُبُرِ اِ۬لَاوَّلِينَۖ ١٩٦",
      "numberInSurah": 196,
      "verse_key": "26:196"
    },
    {
      "text": "أَوَلَمْ يَكُن لَّهُمُۥٓ ءَايَةً اَنْ يَّعْلَمَهُۥ عُلَمَٰٓؤُاْ بَنِےٓ إِسْرَآءِيلَۖ ١٩٧",
      "numberInSurah": 197,
      "verse_key": "26:197"
    },
    {
      "text": "وَلَوْ نَزَّلْنَٰهُ عَلَيٰ بَعْضِ اِ۬لَاعْجَمِينَ ١٩٨",
      "numberInSurah": 198,
      "verse_key": "26:198"
    },
    {
      "text": "فَقَرَأَهُۥ عَلَيْهِم مَّا كَانُواْ بِهِۦ مُومِنِينَۖ ١٩٩",
      "numberInSurah": 199,
      "verse_key": "26:199"
    },
    {
      "text": "كَذَٰلِكَ سَلَكْنَٰهُ فِے قُلُوبِ اِ۬لْمُجْرِمِينَ ٢٠٠",
      "numberInSurah": 200,
      "verse_key": "26:200"
    },
    {
      "text": "لَا يُومِنُونَ بِهِۦ حَتَّيٰ يَرَوُاْ اُ۬لْعَذَابَ اَ۬لَالِيمَ ٢٠١",
      "numberInSurah": 201,
      "verse_key": "26:201"
    },
    {
      "text": "فَيَاتِيَهُم بَغْتَةٗ وَهُمْ لَا يَشْعُرُونَ ٢٠٢",
      "numberInSurah": 202,
      "verse_key": "26:202"
    },
    {
      "text": "فَيَقُولُواْ هَلْ نَحْنُ مُنظَرُونَۖ ٢٠٣",
      "numberInSurah": 203,
      "verse_key": "26:203"
    },
    {
      "text": "أَفَبِعَذَابِنَا يَسْتَعْجِلُونَۖ ٢٠٤",
      "numberInSurah": 204,
      "verse_key": "26:204"
    },
    {
      "text": "أَفَرَٰٓيْتَ إِن مَّتَّعْنَٰهُمْ سِنِينَ ٢٠٥",
      "numberInSurah": 205,
      "verse_key": "26:205"
    },
    {
      "text": "ثُمَّ جَآءَهُم مَّا كَانُواْ يُوعَدُونَ ٢٠٦",
      "numberInSurah": 206,
      "verse_key": "26:206"
    }
  ],
