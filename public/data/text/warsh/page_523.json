{
  "pageNumber": 523,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "كَذَٰلِكَۖ مَآ أَتَي اَ۬لذِينَ مِن قَبْلِهِم مِّن رَّسُولٍ اِلَّا قَالُواْ سَاحِرٌ اَوْ مَجْنُونٌۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "51:52"
    },
    {
      "text": "اَتَوَاصَوْاْ بِهِۦۖ بَلْ هُمْ قَوْمٞ طَاغُونَۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "51:53"
    },
    {
      "text": "فَتَوَلَّ عَنْهُمْ فَمَآ أَنتَ بِمَلُومٖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "51:54"
    },
    {
      "text": "وَذَكِّرْ فَإِنَّ اَ۬لذِّكْر۪يٰ تَنفَعُ اُ۬لْمُومِنِينَۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "51:55"
    },
    {
      "text": "۞وَمَا خَلَقْتُ اُ۬لْجِنَّ وَالِانسَ إِلَّا لِيَعْبُدُونِۖ ٥٦",
      "numberInSurah": 56,
      "verse_key": "51:56"
    },
    {
      "text": "مَآ أُرِيدُ مِنْهُم مِّن رِّزْقٖ وَمَآ أُرِيدُ أَنْ يُّطْعِمُونِۖ ٥٧",
      "numberInSurah": 57,
      "verse_key": "51:57"
    },
    {
      "text": "إِنَّ اَ۬للَّهَ هُوَ اَ۬لرَّزَّاقُ ذُو اُ۬لْقُوَّةِ اِ۬لْمَتِينُۖ ٥٨",
      "numberInSurah": 58,
      "verse_key": "51:58"
    },
    {
      "text": "فَإِنَّ لِلذِينَ ظَلَمُواْ ذَنُوباٗ مِّثْلَ ذَنُوبِ أَصْحَٰبِهِمْ فَلَا يَسْتَعْجِلُونِۖ ٥٩",
      "numberInSurah": 59,
      "verse_key": "51:59"
    },
    {
      "text": "فَوَيْلٞ لِّلذِينَ كَفَرُواْ مِنْ يَّوْمِهِمُ اُ۬لذِے يُوعَدُونَۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "51:60"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالطُّورِ وَكِتَٰبٖ مَّسْطُورٖ ١",
      "numberInSurah": 1,
      "verse_key": "52:1"
    },
    {
      "text": "فِے رَقّٖ مَّنشُورٖ ٢",
      "numberInSurah": 2,
      "verse_key": "52:2"
    },
    {
      "text": "وَالْبَيْتِ اِ۬لْمَعْمُورِ ٣",
      "numberInSurah": 3,
      "verse_key": "52:3"
    },
    {
      "text": "وَالسَّقْفِ اِ۬لْمَرْفُوعِ ٤",
      "numberInSurah": 4,
      "verse_key": "52:4"
    },
    {
      "text": "وَالْبَحْرِ اِ۬لْمَسْجُورِ ٥",
      "numberInSurah": 5,
      "verse_key": "52:5"
    },
    {
      "text": "إِنَّ عَذَابَ رَبِّكَ لَوَٰقِعٞۖ ٦",
      "numberInSurah": 6,
      "verse_key": "52:6"
    },
    {
      "text": "مَّا لَهُۥ مِن دَافِعٖۖ ٧",
      "numberInSurah": 7,
      "verse_key": "52:7"
    },
    {
      "text": "يَوْمَ تَمُورُ اُ۬لسَّمَآءُ مَوْراٗ ٨",
      "numberInSurah": 8,
      "verse_key": "52:8"
    },
    {
      "text": "وَتَسِيرُ اُ۬لْجِبَالُ سَيْراٗۖ ٩",
      "numberInSurah": 9,
      "verse_key": "52:9"
    },
    {
      "text": "فَوَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَ ١٠",
      "numberInSurah": 10,
      "verse_key": "52:10"
    },
    {
      "text": "اَ۬لذِينَ هُمْ فِے خَوْضٖ يَلْعَبُونَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "52:11"
    },
    {
      "text": "يَوْمَ يُدَعُّونَ إِلَيٰ ن۪ارِ جَهَنَّمَ دَعّاًۖ هَٰذِهِ اِ۬لنَّارُ اُ۬لتِے كُنتُم بِهَا تُكَذِّبُونَۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "52:12"
    },
    {
      "text": "أَفَسِحْرٌ هَٰذَآ أَمَ اَنتُمْ لَا تُبْصِرُونَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "52:13"
    },
    {
      "text": "اَ۪صْلَوْهَا فَاصْبِرُوٓاْ أَوْ لَا تَصْبِرُواْ سَوَآءٌ عَلَيْكُمُۥٓۖ إِنَّمَا تُجْزَوْنَ مَا كُنتُمْ تَعْمَلُونَۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "52:14"
    }
  ],
