{
  "pageNumber": 599,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "جَزَآؤُهُمْ عِندَ رَبِّهِمْ جَنَّٰتُ عَدْنٖ تَجْرِے مِن تَحْتِهَا اَ۬لَانْهَٰرُ خَٰلِدِينَ فِيهَآ أَبَداٗۖ رَّضِيَ اَ۬للَّهُ عَنْهُمْ وَرَضُواْ عَنْهُۖ ذَٰلِكَ لِمَنْ خَشِيَ رَبَّهُۥٓۖ ٨",
      "numberInSurah": 8,
      "verse_key": "98:8"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا زُلْزِلَتِ اِ۬لَارْضُ زِلْزَالَهَا ١",
      "numberInSurah": 1,
      "verse_key": "99:1"
    },
    {
      "text": "وَأَخْرَجَتِ اِ۬لَارْضُ أَثْقَالَهَا ٢",
      "numberInSurah": 2,
      "verse_key": "99:2"
    },
    {
      "text": "وَقَالَ اَ۬لِانسَٰنُ مَا لَهَا ٣",
      "numberInSurah": 3,
      "verse_key": "99:3"
    },
    {
      "text": "يَوْمَئِذٖ تُحَدِّثُ أَخْبَارَهَا ٤",
      "numberInSurah": 4,
      "verse_key": "99:4"
    },
    {
      "text": "بِأَنَّ رَبَّكَ أَوْح۪يٰ لَهَاۖ ٥",
      "numberInSurah": 5,
      "verse_key": "99:5"
    },
    {
      "text": "يَوْمَئِذٖ يَصْدُرُ اُ۬لنَّاسُ أَشْتَاتاٗ ٦",
      "numberInSurah": 6,
      "verse_key": "99:6"
    },
    {
      "text": "لِّيُرَوَاْ اَعْمَٰلَهُمْۖ ٧",
      "numberInSurah": 7,
      "verse_key": "99:7"
    },
    {
      "text": "فَمَنْ يَّعْمَلْ مِثْقَالَ ذَرَّةٍ خَيْراٗ يَرَهُۥۖ ٨",
      "numberInSurah": 8,
      "verse_key": "99:8"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالْعَٰدِيَٰتِ ضَبْحاٗ ١",
      "numberInSurah": 1,
      "verse_key": "100:1"
    },
    {
      "text": "فَالْمُورِيَٰتِ قَدْحاٗ ٢",
      "numberInSurah": 2,
      "verse_key": "100:2"
    },
    {
      "text": "فَالْمُغِيرَٰتِ صُبْحاٗ ٣",
      "numberInSurah": 3,
      "verse_key": "100:3"
    },
    {
      "text": "فَأَثَرْنَ بِهِۦ نَقْعاٗ ٤",
      "numberInSurah": 4,
      "verse_key": "100:4"
    },
    {
      "text": "فَوَسَطْنَ بِهِۦ جَمْعاً ٥",
      "numberInSurah": 5,
      "verse_key": "100:5"
    },
    {
      "text": "اِنَّ اَ۬لِانسَٰنَ لِرَبِّهِۦ لَكَنُودٞ ٦",
      "numberInSurah": 6,
      "verse_key": "100:6"
    },
    {
      "text": "وَإِنَّهُۥ عَلَيٰ ذَٰلِكَ لَشَهِيدٞ ٧",
      "numberInSurah": 7,
      "verse_key": "100:7"
    },
    {
      "text": "وَإِنَّهُۥ لِحُبِّ اِ۬لْخَيْرِ لَشَدِيدٌۖ ٨",
      "numberInSurah": 8,
      "verse_key": "100:8"
    },
    {
      "text": "۞اَفَلَا يَعْلَمُ إِذَا بُعْثِرَ مَا فِے اِ۬لْقُبُورِ ٩",
      "numberInSurah": 9,
      "verse_key": "100:9"
    }
  ],
