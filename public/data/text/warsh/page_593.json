{
  "pageNumber": 593,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالْفَجْرِ ١",
      "numberInSurah": 1,
      "verse_key": "89:1"
    },
    {
      "text": "وَلَيَالٍ عَشْرٖ ٢",
      "numberInSurah": 2,
      "verse_key": "89:2"
    },
    {
      "text": "وَالشَّفْعِ وَالْوَتْرِ ٣",
      "numberInSurah": 3,
      "verse_key": "89:3"
    },
    {
      "text": "وَاليْلِ إِذَا يَسْرِۦ ٤",
      "numberInSurah": 4,
      "verse_key": "89:4"
    },
    {
      "text": "هَلْ فِے ذَٰلِكَ قَسَمٞ لِّذِے حِجْرٍۖ ٥",
      "numberInSurah": 5,
      "verse_key": "89:5"
    },
    {
      "text": "اَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِعَادٍ ٦",
      "numberInSurah": 6,
      "verse_key": "89:6"
    },
    {
      "text": "اِرَمَ ذَاتِ اِ۬لْعِمَادِ ٧",
      "numberInSurah": 7,
      "verse_key": "89:7"
    },
    {
      "text": "اِ۬لتِے لَمْ يُخْلَقْ مِثْلُهَا فِے اِ۬لْبِلَٰدِ ٨",
      "numberInSurah": 8,
      "verse_key": "89:8"
    },
    {
      "text": "وَثَمُودَ اَ۬لذِينَ جَابُواْ اُ۬لصَّخْرَ بِالْوَادِۦ ٩",
      "numberInSurah": 9,
      "verse_key": "89:9"
    },
    {
      "text": "وَفِرْعَوْنَ ذِے اِ۬لَاوْتَادِ ١٠",
      "numberInSurah": 10,
      "verse_key": "89:10"
    },
    {
      "text": "اِ۬لذِينَ طَغَوْاْ فِے اِ۬لْبِلَٰدِ ١١",
      "numberInSurah": 11,
      "verse_key": "89:11"
    },
    {
      "text": "فَأَكْثَرُواْ فِيهَا اَ۬لْفَسَادَ ١٢",
      "numberInSurah": 12,
      "verse_key": "89:12"
    },
    {
      "text": "فَصَبَّ عَلَيْهِمْ رَبُّكَ سَوْطَ عَذَابٍۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "89:13"
    },
    {
      "text": "اِنَّ رَبَّكَ لَبِالْمِرْصَادِۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "89:14"
    },
    {
      "text": "فَأَمَّا اَ۬لِانسَٰنُ إِذَا مَا اَ۪بْتَل۪يٰهُ رَبُّهُۥ فَأَكْرَمَهُۥ وَنَعَّمَهُۥ ١٥",
      "numberInSurah": 15,
      "verse_key": "89:15"
    },
    {
      "text": "فَيَقُولُ رَبِّيَ أَكْرَمَنِۦۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "89:16"
    },
    {
      "text": "وَأَمَّآ إِذَا مَا اَ۪بْتَل۪يٰهُ فَقَدَرَ عَلَيْهِ رِزْقَهُۥ ١٧",
      "numberInSurah": 17,
      "verse_key": "89:17"
    },
    {
      "text": "فَيَقُولُ رَبِّيَ أَهَٰنَنِۦ ١٨",
      "numberInSurah": 18,
      "verse_key": "89:18"
    },
    {
      "text": "كَلَّاۖ بَل لَّا تُكْرِمُونَ اَ۬لْيَتِيمَ ١٩",
      "numberInSurah": 19,
      "verse_key": "89:19"
    },
    {
      "text": "وَلَا تَحُضُّونَ عَلَيٰ طَعَامِ اِ۬لْمِسْكِينِ ٢٠",
      "numberInSurah": 20,
      "verse_key": "89:20"
    },
    {
      "text": "وَتَاكُلُونَ اَ۬لتُّرَاثَ أَكْلاٗ لَّمّاٗ ٢١",
      "numberInSurah": 21,
      "verse_key": "89:21"
    },
    {
      "text": "وَتُحِبُّونَ اَ۬لْمَالَ حُبّاٗ جَمّاٗ ٢٢",
      "numberInSurah": 22,
      "verse_key": "89:22"
    },
    {
      "text": "كَلَّآ إِذَا دُكَّتِ اِ۬لَارْضُ دَكّاٗ دَكّاٗ ٢٣",
      "numberInSurah": 23,
      "verse_key": "89:23"
    }
  ],
