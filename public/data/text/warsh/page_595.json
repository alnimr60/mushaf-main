{
  "pageNumber": 595,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالشَّمْسِ وَضُحَيٰهَا ١",
      "numberInSurah": 1,
      "verse_key": "91:1"
    },
    {
      "text": "وَالْقَمَرِ إِذَا تَلَيٰهَا ٢",
      "numberInSurah": 2,
      "verse_key": "91:2"
    },
    {
      "text": "وَالنَّه۪ارِ إِذَا جَلَّيٰهَا ٣",
      "numberInSurah": 3,
      "verse_key": "91:3"
    },
    {
      "text": "وَاليْلِ إِذَا يَغْشَيٰهَا ٤",
      "numberInSurah": 4,
      "verse_key": "91:4"
    },
    {
      "text": "وَالسَّمَآءِ وَمَا بَنَيٰهَا ٥",
      "numberInSurah": 5,
      "verse_key": "91:5"
    },
    {
      "text": "وَالَارْضِ وَمَا طَحَيٰهَا ٦",
      "numberInSurah": 6,
      "verse_key": "91:6"
    },
    {
      "text": "وَنَفْسٖ وَمَا سَوَّيٰهَا ٧",
      "numberInSurah": 7,
      "verse_key": "91:7"
    },
    {
      "text": "فَأَلْهَمَهَا فُجُورَهَا وَتَقْوَيٰهَا ٨",
      "numberInSurah": 8,
      "verse_key": "91:8"
    },
    {
      "text": "قَدَ اَفْلَحَ مَن زَكَّيٰهَا ٩",
      "numberInSurah": 9,
      "verse_key": "91:9"
    },
    {
      "text": "وَقَدْ خَابَ مَن دَسَّيٰهَاۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "91:10"
    },
    {
      "text": "كَذَّبَتْ ثَمُودُ بِطَغْوَيٰهَآ ١١",
      "numberInSurah": 11,
      "verse_key": "91:11"
    },
    {
      "text": "إِذِ اِ۪نۢبَعَثَ أَشْقَيٰهَا ١٢",
      "numberInSurah": 12,
      "verse_key": "91:12"
    },
    {
      "text": "فَقَالَ لَهُمْ رَسُولُ اُ۬للَّهِ نَاقَةَ اَ۬للَّهِ وَسُقْيَاهَا ١٣",
      "numberInSurah": 13,
      "verse_key": "91:13"
    },
    {
      "text": "فَكَذَّبُوهُ فَعَقَرُوهَا فَدَمْدَمَ عَلَيْهِمْ رَبُّهُم بِذَنۢبِهِمْ فَسَوَّيٰهَاۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "91:14"
    },
    {
      "text": "فَلَا يَخَافُ عُقْبَٰهَاۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "91:15"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَاليْلِ إِذَا يَغْش۪يٰ ١",
      "numberInSurah": 1,
      "verse_key": "92:1"
    },
    {
      "text": "وَالنَّه۪ارِ إِذَا تَجَلّ۪يٰ ٢",
      "numberInSurah": 2,
      "verse_key": "92:2"
    },
    {
      "text": "وَمَا خَلَقَ اَ۬لذَّكَرَ وَالُانث۪يٰٓ ٣",
      "numberInSurah": 3,
      "verse_key": "92:3"
    },
    {
      "text": "إِنَّ سَعْيَكُمْ لَشَتّ۪يٰۖ ٤",
      "numberInSurah": 4,
      "verse_key": "92:4"
    },
    {
      "text": "فَأَمَّا مَنَ اَعْط۪يٰ وَاتَّق۪يٰ ٥",
      "numberInSurah": 5,
      "verse_key": "92:5"
    },
    {
      "text": "وَصَدَّقَ بِالْحُسْن۪يٰ ٦",
      "numberInSurah": 6,
      "verse_key": "92:6"
    },
    {
      "text": "فَسَنُيَسِّرُهُۥ لِلْيُسْر۪يٰۖ ٧",
      "numberInSurah": 7,
      "verse_key": "92:7"
    },
    {
      "text": "وَأَمَّا مَنۢ بَخِلَ وَاسْتَغْن۪يٰ ٨",
      "numberInSurah": 8,
      "verse_key": "92:8"
    },
    {
      "text": "وَكَذَّبَ بِالْحُسْن۪يٰ ٩",
      "numberInSurah": 9,
      "verse_key": "92:9"
    },
    {
      "text": "فَسَنُيَسِّرُهُۥ لِلْعُسْر۪يٰۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "92:10"
    },
    {
      "text": "وَمَا يُغْنِے عَنْهُ مَالُهُۥٓ إِذَا تَرَدّ۪يٰٓۖ ١١",
      "numberInSurah": 11,
      "verse_key": "92:11"
    },
    {
      "text": "إِنَّ عَلَيْنَا لَلْهُد۪يٰ ١٢",
      "numberInSurah": 12,
      "verse_key": "92:12"
    },
    {
      "text": "وَإِنَّ لَنَا لَلَاخِرَةَ وَالُاول۪يٰۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "92:13"
    },
    {
      "text": "فَأَنذَرْتُكُمْ نَاراٗ تَلَظّ۪يٰ ١٤",
      "numberInSurah": 14,
      "verse_key": "92:14"
    }
  ],
