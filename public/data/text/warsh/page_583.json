{
  "pageNumber": 583,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "اِنَّ لِلْمُتَّقِينَ مَفَازاً ٣١",
      "numberInSurah": 31,
      "verse_key": "78:31"
    },
    {
      "text": "حَدَآئِقَ وَأَعْنَٰباٗ ٣٢",
      "numberInSurah": 32,
      "verse_key": "78:32"
    },
    {
      "text": "وَكَوَاعِبَ أَتْرَاباٗ ٣٣",
      "numberInSurah": 33,
      "verse_key": "78:33"
    },
    {
      "text": "وَكَأْساٗ دِهَاقاٗ ٣٤",
      "numberInSurah": 34,
      "verse_key": "78:34"
    },
    {
      "text": "لَّا يَسْمَعُونَ فِيهَا لَغْواٗ وَلَا كِذَّاباٗۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "78:35"
    },
    {
      "text": "جَزَآءٗ مِّن رَّبِّكَ عَطَآءً حِسَاباٗۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "78:36"
    },
    {
      "text": "رَّبُّ اُ۬لسَّمَٰوَٰتِ وَالَارْضِ وَمَا بَيْنَهُمَاۖ اَ۬لرَّحْمَٰنُ لَا يَمْلِكُونَ مِنْهُ خِطَاباٗۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "78:37"
    },
    {
      "text": "يَوْمَ يَقُومُ اُ۬لرُّوحُ وَالْمَلَٰٓئِكَةُ صَفّاٗ لَّا يَتَكَلَّمُونَ إِلَّا مَنَ اَذِنَ لَهُ اُ۬لرَّحْمَٰنُ وَقَالَ صَوَاباٗۖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "78:38"
    },
    {
      "text": "ذَٰلِكَ اَ۬لْيَوْمُ اُ۬لْحَقُّۖ فَمَن شَآءَ اَ۪تَّخَذَ إِلَيٰ رَبِّهِۦ مَـَٔاباًۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "78:39"
    },
    {
      "text": "اِنَّآ أَنذَرْنَٰكُمْ عَذَاباٗ قَرِيباٗ يَوْمَ يَنظُرُ اُ۬لْمَرْءُ مَا قَدَّمَتْ يَدَٰهُ وَيَقُولُ اُ۬لْكَافِرُ يَٰلَيْتَنِے كُنتُ تُرَٰباٗۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "78:40"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالنَّٰزِعَٰتِ غَرْقاٗ ١",
      "numberInSurah": 1,
      "verse_key": "79:1"
    },
    {
      "text": "وَالنَّٰشِطَٰتِ نَشْطاٗ ٢",
      "numberInSurah": 2,
      "verse_key": "79:2"
    },
    {
      "text": "وَالسَّٰبِحَٰتِ سَبْحاٗ ٣",
      "numberInSurah": 3,
      "verse_key": "79:3"
    },
    {
      "text": "فَالسَّٰبِقَٰتِ سَبْقاٗ ٤",
      "numberInSurah": 4,
      "verse_key": "79:4"
    },
    {
      "text": "فَالْمُدَبِّرَٰتِ أَمْراٗ ٥",
      "numberInSurah": 5,
      "verse_key": "79:5"
    },
    {
      "text": "يَوْمَ تَرْجُفُ اُ۬لرَّاجِفَةُ ٦",
      "numberInSurah": 6,
      "verse_key": "79:6"
    },
    {
      "text": "تَتْبَعُهَا اَ۬لرَّادِفَةُۖ ٧",
      "numberInSurah": 7,
      "verse_key": "79:7"
    },
    {
      "text": "قُلُوبٞ يَوْمَئِذٖ وَاجِفَةٌ ٨",
      "numberInSurah": 8,
      "verse_key": "79:8"
    },
    {
      "text": "اَبْصَٰرُهَا خَٰشِعَةٞۖ ٩",
      "numberInSurah": 9,
      "verse_key": "79:9"
    },
    {
      "text": "يَقُولُونَ أَ۟نَّا لَمَرْدُودُونَ فِے اِ۬لْحَافِرَةِ ١٠",
      "numberInSurah": 10,
      "verse_key": "79:10"
    },
    {
      "text": "إِذَا كُنَّا عِظَٰماٗ نَّخِرَةٗۖ ١١",
      "numberInSurah": 11,
      "verse_key": "79:11"
    },
    {
      "text": "قَالُواْ تِلْكَ إِذاٗ كَرَّةٌ خَاسِرَةٞ ١٢",
      "numberInSurah": 12,
      "verse_key": "79:12"
    },
    {
      "text": "فَإِنَّمَا هِيَ زَجْرَةٞ وَٰحِدَةٞ ١٣",
      "numberInSurah": 13,
      "verse_key": "79:13"
    },
    {
      "text": "فَإِذَا هُم بِالسَّاهِرَةِۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "79:14"
    },
    {
      "text": "هَلَ اَت۪يٰكَ حَدِيثُ مُوس۪يٰٓ ١٥",
      "numberInSurah": 15,
      "verse_key": "79:15"
    }
  ],
