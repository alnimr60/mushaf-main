  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "اِنَّهُۥ فَكَّرَ وَقَدَّرَ ١٨",
      "numberInSurah": 18,
      "verse_key": "74:18"
    },
    {
      "text": "فَقُتِلَ كَيْفَ قَدَّرَ ١٩",
      "numberInSurah": 19,
      "verse_key": "74:19"
    },
    {
      "text": "ثُمَّ قُتِلَ كَيْفَ قَدَّرَ ٢٠",
      "numberInSurah": 20,
      "verse_key": "74:20"
    },
    {
      "text": "ثُمَّ نَظَرَ ٢١",
      "numberInSurah": 21,
      "verse_key": "74:21"
    },
    {
      "text": "ثُمَّ عَبَسَ وَبَسَرَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "74:22"
    },
    {
      "text": "ثُمَّ أَدْبَرَ وَاسْتَكْبَرَ ٢٣",
      "numberInSurah": 23,
      "verse_key": "74:23"
    },
    {
      "text": "فَقَالَ إِنْ هَٰذَآ إِلَّا سِحْرٞ يُوثَرُ ٢٤",
      "numberInSurah": 24,
      "verse_key": "74:24"
    },
    {
      "text": "إِنْ هَٰذَآ إِلَّا قَوْلُ اُ۬لْبَشَرِۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "74:25"
    },
    {
      "text": "سَأُصْلِيهِ سَقَرَۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "74:26"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا سَقَرُ ٢٧",
      "numberInSurah": 27,
      "verse_key": "74:27"
    },
    {
      "text": "لَا تُبْقِے وَلَا تَذَرُۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "74:28"
    },
    {
      "text": "لَوَّاحَةٞ لِّلْبَشَرِۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "74:29"
    },
    {
      "text": "عَلَيْهَا تِسْعَةَ عَشَرَۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "74:30"
    },
    {
      "text": "۞وَمَا جَعَلْنَآ أَصْحَٰبَ اَ۬لنّ۪ارِ إِلَّا مَلَٰٓئِكَةٗ وَمَا جَعَلْنَا عِدَّتَهُمُۥٓ إِلَّا فِتْنَةٗ لِّلذِينَ كَفَرُواْ لِيَسْتَيْقِنَ اَ۬لذِينَ أُوتُواْ اُ۬لْكِتَٰبَ وَيَزْدَادَ اَ۬لذِينَ ءَامَنُوٓاْ إِيمَٰناٗ وَلَا يَرْتَابَ اَ۬لذِينَ أُوتُواْ اُ۬لْكِتَٰبَ وَالْمُومِنُونَ وَلِيَقُولَ اَ۬لذِينَ فِے قُلُوبِهِم مَّرَضٞ وَالْكَٰفِرُونَ مَاذَآ أَرَادَ اَ۬للَّهُ بِهَٰذَا مَثَلاٗۖ كَذَٰلِكَ يُضِلُّ اُ۬للَّهُ مَنْ يَّشَآءُ وَيَهْدِے مَنْ يَّشَآءُۖ وَمَا يَعْلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۖ وَمَا هِيَ إِلَّا ذِكْر۪يٰ لِلْبَشَرِۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "74:31"
    },
    {
      "text": "كَلَّا وَالْقَمَرِ ٣٢",
      "numberInSurah": 32,
      "verse_key": "74:32"
    },
    {
      "text": "وَاليْلِ إِذَ اَدْبَرَ ٣٣",
      "numberInSurah": 33,
      "verse_key": "74:33"
    },
    {
      "text": "وَالصُّبْحِ إِذَآ أَسْفَرَ ٣٤",
      "numberInSurah": 34,
      "verse_key": "74:34"
    },
    {
      "text": "إِنَّهَا لَإِحْدَي اَ۬لْكُبَرِ ٣٥",
      "numberInSurah": 35,
      "verse_key": "74:35"
    },
    {
      "text": "نَذِيراٗ لِّلْبَشَرِ ٣٦",
      "numberInSurah": 36,
      "verse_key": "74:36"
    },
    {
      "text": "لِمَن شَآءَ مِنكُمُۥٓ أَنْ يَّتَقَدَّمَ أَوْ يَتَأَخَّرَۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "74:37"
    },
    {
      "text": "كُلُّ نَفْسِۢ بِمَا كَسَبَتْ رَهِينَةٌ ٣٨",
      "numberInSurah": 38,
      "verse_key": "74:38"
    },
    {
      "text": "اِلَّآ أَصْحَٰبَ اَ۬لْيَمِينِۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "74:39"
    },
    {
      "text": "فِے جَنَّٰتٖ يَتَسَآءَلُونَ عَنِ اِ۬لْمُجْرِمِينَ ٤٠",
      "numberInSurah": 40,
      "verse_key": "74:40"
    },
    {
      "text": "مَا سَلَكَكُمْ فِے سَقَرَۖ ٤١",
      "numberInSurah": 41,
      "verse_key": "74:41"
    },
    {
      "text": "قَالُواْ لَمْ نَكُ مِنَ اَ۬لْمُصَلِّينَ ٤٢",
      "numberInSurah": 42,
      "verse_key": "74:42"
    },
    {
      "text": "وَلَمْ نَكُ نُطْعِمُ اُ۬لْمِسْكِينَ ٤٣",
      "numberInSurah": 43,
      "verse_key": "74:43"
    },
    {
      "text": "وَكُنَّا نَخُوضُ مَعَ اَ۬لْخَآئِضِينَ ٤٤",
      "numberInSurah": 44,
      "verse_key": "74:44"
    },
    {
      "text": "وَكُنَّا نُكَذِّبُ بِيَوْمِ اِ۬لدِّينِ ٤٥",
      "numberInSurah": 45,
      "verse_key": "74:45"
    },
    {
      "text": "حَتَّيٰٓ أَت۪يٰنَا اَ۬لْيَقِينُۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "74:46"
    },
    {
      "text": "فَمَا تَنفَعُهُمْ شَفَٰعَةُ اُ۬لشَّٰفِعِينَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "74:47"
    }
  ],
