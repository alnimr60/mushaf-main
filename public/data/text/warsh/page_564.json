{
  "pageNumber": 564,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "قُلِ اِنَّمَا اَ۬لْعِلْمُ عِندَ اَ۬للَّهِ وَإِنَّمَآ أَنَا نَذِيرٞ مُّبِينٞۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "67:27"
    },
    {
      "text": "فَلَمَّا رَأَوْهُ زُلْفَةٗ س۬يَٓٔتْ وُجُوهُ اُ۬لذِينَ كَفَرُواْ وَقِيلَ هَٰذَا اَ۬لذِے كُنتُم بِهِۦ تَدَّعُونَۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "67:28"
    },
    {
      "text": "قُلَ اَرَٰٓيْتُمُۥٓ إِنَ اَهْلَكَنِيَ اَ۬للَّهُ وَمَن مَّعِيَ أَوْ رَحِمَنَا فَمَنْ يُّجِيرُ اُ۬لْكٰ۪فِرِينَ مِنْ عَذَابٍ اَلِيمٖۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "67:29"
    },
    {
      "text": "قُلْ هُوَ اَ۬لرَّحْمَٰنُ ءَامَنَّا بِهِۦ وَعَلَيْهِ تَوَكَّلْنَاۖ فَسَتَعْلَمُونَ مَنْ هُوَ فِے ضَلَٰلٖ مُّبِينٖۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "67:30"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "نُّٓۖ وَالْقَلَمِ وَمَا يَسْطُرُونَ ١",
      "numberInSurah": 1,
      "verse_key": "68:1"
    },
    {
      "text": "مَآ أَنتَ بِنِعْمَةِ رَبِّكَ بِمَجْنُونٖ ٢",
      "numberInSurah": 2,
      "verse_key": "68:2"
    },
    {
      "text": "وَإِنَّ لَكَ لَأَجْراً غَيْرَ مَمْنُونٖ ٣",
      "numberInSurah": 3,
      "verse_key": "68:3"
    },
    {
      "text": "وَإِنَّكَ لَعَلَيٰ خُلُقٍ عَظِيمٖۖ ٤",
      "numberInSurah": 4,
      "verse_key": "68:4"
    },
    {
      "text": "فَسَتُبْصِرُ وَيُبْصِرُونَ ٥",
      "numberInSurah": 5,
      "verse_key": "68:5"
    },
    {
      "text": "بِأَييِّكُمُ اُ۬لْمَفْتُونُۖ ٦",
      "numberInSurah": 6,
      "verse_key": "68:6"
    },
    {
      "text": "إِنَّ رَبَّكَ هُوَ أَعْلَمُ بِمَن ضَلَّ عَن سَبِيلِهِۦ وَهُوَ أَعْلَمُ بِالْمُهْتَدِينَۖ ٧",
      "numberInSurah": 7,
      "verse_key": "68:7"
    },
    {
      "text": "فَلَا تُطِعِ اِ۬لْمُكَذِّبِينَۖ ٨",
      "numberInSurah": 8,
      "verse_key": "68:8"
    },
    {
      "text": "وَدُّواْ لَوْ تُدْهِنُ فَيُدْهِنُونَۖ ٩",
      "numberInSurah": 9,
      "verse_key": "68:9"
    },
    {
      "text": "وَلَا تُطِعْ كُلَّ حَلَّٰفٖ مَّهِينٍ ١٠",
      "numberInSurah": 10,
      "verse_key": "68:10"
    },
    {
      "text": "هَمَّازٖ مَّشَّآءِۢ بِنَمِيمٖ ١١",
      "numberInSurah": 11,
      "verse_key": "68:11"
    },
    {
      "text": "مَّنَّاعٖ لِّلْخَيْرِ مُعْتَدٍ اَثِيمٍ ١٢",
      "numberInSurah": 12,
      "verse_key": "68:12"
    },
    {
      "text": "عُتُلِّۢ بَعْدَ ذَٰلِكَ زَنِيمٍ ١٣",
      "numberInSurah": 13,
      "verse_key": "68:13"
    },
    {
      "text": "اَن كَانَ ذَا مَالٖ وَبَنِينَ ١٤",
      "numberInSurah": 14,
      "verse_key": "68:14"
    },
    {
      "text": "إِذَا تُتْل۪يٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ اُ۬لَاوَّلِينَۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "68:15"
    }
  ],
