{
  "pageNumber": 374,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "كَذَّبَتْ قَوْمُ لُوطٍ اِ۬لْمُرْسَلِينَ ١٦٠",
      "numberInSurah": 160,
      "verse_key": "26:160"
    },
    {
      "text": "إِذْ قَالَ لَهُمُۥٓ أَخُوهُمْ لُوطٌ اَلَا تَتَّقُونَ ١٦١",
      "numberInSurah": 161,
      "verse_key": "26:161"
    },
    {
      "text": "إِنِّے لَكُمْ رَسُولٌ اَمِينٞۖ ١٦٢",
      "numberInSurah": 162,
      "verse_key": "26:162"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٦٣",
      "numberInSurah": 163,
      "verse_key": "26:163"
    },
    {
      "text": "وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنَ اَجْرٍۖ اِنَ اَجْرِيَ إِلَّا عَلَيٰ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٦٤",
      "numberInSurah": 164,
      "verse_key": "26:164"
    },
    {
      "text": "أَتَاتُونَ اَ۬لذُّكْرَانَ مِنَ اَ۬لْعَٰلَمِينَ ١٦٥",
      "numberInSurah": 165,
      "verse_key": "26:165"
    },
    {
      "text": "وَتَذَرُونَ مَا خَلَقَ لَكُمْ رَبُّكُم مِّنَ اَزْوَٰجِكُمۖ بَلَ اَنتُمْ قَوْمٌ عَادُونَۖ ١٦٦",
      "numberInSurah": 166,
      "verse_key": "26:166"
    },
    {
      "text": "قَالُواْ لَئِن لَّمْ تَنتَهِ يَٰلُوطُ لَتَكُونَنَّ مِنَ اَ۬لْمُخْرَجِينَۖ ١٦٧",
      "numberInSurah": 167,
      "verse_key": "26:167"
    },
    {
      "text": "قَالَ إِنِّے لِعَمَلِكُم مِّنَ اَ۬لْقَالِينَۖ ١٦٨",
      "numberInSurah": 168,
      "verse_key": "26:168"
    },
    {
      "text": "رَبِّ نَجِّنِے وَأَهْلِے مِمَّا يَعْمَلُونَۖ ١٦٩",
      "numberInSurah": 169,
      "verse_key": "26:169"
    },
    {
      "text": "فَنَجَّيْنَٰهُ وَأَهْلَهُۥٓ أَجْمَعِينَ ١٧٠",
      "numberInSurah": 170,
      "verse_key": "26:170"
    },
    {
      "text": "إِلَّا عَجُوزاٗ فِے اِ۬لْغَٰبِرِينَ ١٧١",
      "numberInSurah": 171,
      "verse_key": "26:171"
    },
    {
      "text": "ثُمَّ دَمَّرْنَا اَ۬لَاخَرِينَۖ ١٧٢",
      "numberInSurah": 172,
      "verse_key": "26:172"
    },
    {
      "text": "وَأَمْطَرْنَا عَلَيْهِم مَّطَراٗۖ فَسَآءَ مَطَرُ اُ۬لْمُنذَرِينَۖ ١٧٣",
      "numberInSurah": 173,
      "verse_key": "26:173"
    },
    {
      "text": "إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٧٤",
      "numberInSurah": 174,
      "verse_key": "26:174"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٧٥",
      "numberInSurah": 175,
      "verse_key": "26:175"
    },
    {
      "text": "كَذَّبَ أَصْحَٰبُ لَيْكَةَ اَ۬لْمُرْسَلِينَ ١٧٦",
      "numberInSurah": 176,
      "verse_key": "26:176"
    },
    {
      "text": "إِذْ قَالَ لَهُمْ شُعَيْبٌ اَلَا تَتَّقُونَ ١٧٧",
      "numberInSurah": 177,
      "verse_key": "26:177"
    },
    {
      "text": "إِنِّے لَكُمْ رَسُولٌ اَمِينٞۖ ١٧٨",
      "numberInSurah": 178,
      "verse_key": "26:178"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٧٩",
      "numberInSurah": 179,
      "verse_key": "26:179"
    },
    {
      "text": "وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنَ اَجْرٍۖ اِنَ اَجْرِيَ إِلَّا عَلَيٰ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٨٠",
      "numberInSurah": 180,
      "verse_key": "26:180"
    },
    {
      "text": "۞أَوْفُواْ اُ۬لْكَيْلَ وَلَا تَكُونُواْ مِنَ اَ۬لْمُخْسِرِينَۖ ١٨١",
      "numberInSurah": 181,
      "verse_key": "26:181"
    },
    {
      "text": "وَزِنُواْ بِالْقُسْطَاسِ اِ۬لْمُسْتَقِيمِۖ ١٨٢",
      "numberInSurah": 182,
      "verse_key": "26:182"
    },
    {
      "text": "وَلَا تَبْخَسُواْ اُ۬لنَّاسَ أَشْيَآءَهُمْ وَلَا تَعْثَوْاْ فِے اِ۬لَارْضِ مُفْسِدِينَۖ ١٨٣",
      "numberInSurah": 183,
      "verse_key": "26:183"
    }
  ],
