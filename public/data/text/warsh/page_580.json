{
  "pageNumber": 580,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَمِنَ اَ۬ليْلِ فَاسْجُدْ لَهُۥ وَسَبِّحْهُ لَيْلاٗ طَوِيلاًۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "76:26"
    },
    {
      "text": "اِنَّ هَٰٓؤُلَآءِ يُحِبُّونَ اَ۬لْعَاجِلَةَ وَيَذَرُونَ وَرَآءَهُمْ يَوْماٗ ثَقِيلاٗۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "76:27"
    },
    {
      "text": "نَّحْنُ خَلَقْنَٰهُمْ وَشَدَدْنَآ أَسْرَهُمْ وَإِذَا شِئْنَا بَدَّلْنَآ أَمْثَٰلَهُمْ تَبْدِيلاًۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "76:28"
    },
    {
      "text": "اِنَّ هَٰذِهِۦ تَذْكِرَةٞۖ فَمَن شَآءَ اَ۪تَّخَذَ إِلَيٰ رَبِّهِۦ سَبِيلاٗۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "76:29"
    },
    {
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَنْ يَّشَآءَ اَ۬للَّهُۖ إِنَّ اَ۬للَّهَ كَانَ عَلِيماً حَكِيماٗۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "76:30"
    },
    {
      "text": "يُدْخِلُ مَنْ يَّشَآءُ فِے رَحْمَتِهِۦۖ وَالظَّٰلِمِينَ أَعَدَّ لَهُمْ عَذَاباً اَلِيماٗۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "76:31"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالْمُرْسَلَٰتِ عُرْفاٗ ١",
      "numberInSurah": 1,
      "verse_key": "77:1"
    },
    {
      "text": "فَالْعَٰصِفَٰتِ عَصْفاٗ ٢",
      "numberInSurah": 2,
      "verse_key": "77:2"
    },
    {
      "text": "وَالنَّٰشِرَٰتِ نَشْراٗ ٣",
      "numberInSurah": 3,
      "verse_key": "77:3"
    },
    {
      "text": "فَالْفَٰرِقَٰتِ فَرْقاٗ ٤",
      "numberInSurah": 4,
      "verse_key": "77:4"
    },
    {
      "text": "فَالْمُلْقِيَٰتِ ذِكْراً ٥",
      "numberInSurah": 5,
      "verse_key": "77:5"
    },
    {
      "text": "عُذْراً اَوْ نُذُراً ٦",
      "numberInSurah": 6,
      "verse_key": "77:6"
    },
    {
      "text": "اِنَّمَا تُوعَدُونَ لَوَٰقِعٞۖ ٧",
      "numberInSurah": 7,
      "verse_key": "77:7"
    },
    {
      "text": "فَإِذَا اَ۬لنُّجُومُ طُمِسَتْ ٨",
      "numberInSurah": 8,
      "verse_key": "77:8"
    },
    {
      "text": "وَإِذَا اَ۬لسَّمَآءُ فُرِجَتْ ٩",
      "numberInSurah": 9,
      "verse_key": "77:9"
    },
    {
      "text": "وَإِذَا اَ۬لْجِبَالُ نُسِفَتْ ١٠",
      "numberInSurah": 10,
      "verse_key": "77:10"
    },
    {
      "text": "وَإِذَا اَ۬لرُّسُلُ أُقِّتَتْ ١١",
      "numberInSurah": 11,
      "verse_key": "77:11"
    },
    {
      "text": "لِأَيِّ يَوْمٍ ا۟جِّلَتْ ١٢",
      "numberInSurah": 12,
      "verse_key": "77:12"
    },
    {
      "text": "لِيَوْمِ اِ۬لْفَصْلِۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "77:13"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا يَوْمُ اُ۬لْفَصْلِۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "77:14"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "77:15"
    },
    {
      "text": "۞أَلَمْ نُهْلِكِ اِ۬لَاوَّلِينَۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "77:16"
    },
    {
      "text": "ثُمَّ نُتْبِعُهُمُ اُ۬لَاخِرِينَۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "77:17"
    },
    {
      "text": "كَذَٰلِكَ نَفْعَلُ بِالْمُجْرِمِينَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "77:18"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "77:19"
    }
