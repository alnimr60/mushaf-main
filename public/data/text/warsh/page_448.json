{
  "pageNumber": 448,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "يَقُولُ أَ۟نَّكَ لَمِنَ اَ۬لْمُصَدِّقِينَ ٥٢",
      "numberInSurah": 52,
      "verse_key": "37:52"
    },
    {
      "text": "أَ۟ذَا مِتْنَا وَكُنَّا تُرَاباٗ وَعِظَٰماً اِنَّا لَمَدِينُونَۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "37:53"
    },
    {
      "text": "قَالَ هَلَ اَنتُم مُّطَّلِعُونَ ٥٤",
      "numberInSurah": 54,
      "verse_key": "37:54"
    },
    {
      "text": "فَاطَّلَعَ فَر۪ء۪اهُ فِے سَوَآءِ اِ۬لْجَحِيمِۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "37:55"
    },
    {
      "text": "قَالَ تَاللَّهِ إِن كِدتَّ لَتُرْدِينِۦ ٥٦",
      "numberInSurah": 56,
      "verse_key": "37:56"
    },
    {
      "text": "وَلَوْلَا نِعْمَةُ رَبِّے لَكُنتُ مِنَ اَ۬لْمُحْضَرِينَۖ ٥٧",
      "numberInSurah": 57,
      "verse_key": "37:57"
    },
    {
      "text": "أَفَمَا نَحْنُ بِمَيِّتِينَ ٥٨",
      "numberInSurah": 58,
      "verse_key": "37:58"
    },
    {
      "text": "إِلَّا مَوْتَتَنَا اَ۬لُاول۪يٰ وَمَا نَحْنُ بِمُعَذَّبِينَۖ ٥٩",
      "numberInSurah": 59,
      "verse_key": "37:59"
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ اَ۬لْفَوْزُ اُ۬لْعَظِيمُۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "37:60"
    },
    {
      "text": "لِمِثْلِ هَٰذَا فَلْيَعْمَلِ اِ۬لْعَٰمِلُونَۖ ٦١",
      "numberInSurah": 61,
      "verse_key": "37:61"
    },
    {
      "text": "أَذَٰلِكَ خَيْرٞ نُّزُلاً اَمْ شَجَرَةُ اُ۬لزَّقُّومِۖ ٦٢",
      "numberInSurah": 62,
      "verse_key": "37:62"
    },
    {
      "text": "إِنَّا جَعَلْنَٰهَا فِتْنَةٗ لِّلظَّٰلِمِينَۖ ٦٣",
      "numberInSurah": 63,
      "verse_key": "37:63"
    },
    {
      "text": "إِنَّهَا شَجَرَةٞ تَخْرُجُ فِےٓ أَصْلِ اِ۬لْجَحِيمِ ٦٤",
      "numberInSurah": 64,
      "verse_key": "37:64"
    },
    {
      "text": "طَلْعُهَا كَأَنَّهُۥ رُءُوسُ اُ۬لشَّيَٰطِينِۖ ٦٥",
      "numberInSurah": 65,
      "verse_key": "37:65"
    },
    {
      "text": "فَإِنَّهُمْ لَأٓكِلُونَ مِنْهَا فَمَالِـُٔونَ مِنْهَا اَ۬لْبُطُونَ ٦٦",
      "numberInSurah": 66,
      "verse_key": "37:66"
    },
    {
      "text": "ثُمَّ إِنَّ لَهُمْ عَلَيْهَا لَشَوْباٗ مِّنْ حَمِيمٖۖ ٦٧",
      "numberInSurah": 67,
      "verse_key": "37:67"
    },
    {
      "text": "ثُمَّ إِنَّ مَرْجِعَهُمْ لَإِلَي اَ۬لْجَحِيمِۖ ٦٨",
      "numberInSurah": 68,
      "verse_key": "37:68"
    },
    {
      "text": "إِنَّهُمُۥٓ أَلْفَوَاْ اٰبَآءَهُمْ ضَآلِّينَ ٦٩",
      "numberInSurah": 69,
      "verse_key": "37:69"
    },
    {
      "text": "فَهُمْ عَلَيٰٓ ءَاثٰ۪رِهِمْ يُهْرَعُونَۖ ٧٠",
      "numberInSurah": 70,
      "verse_key": "37:70"
    },
    {
      "text": "وَلَقَد ضَّلَّ قَبْلَهُمُۥٓ أَكْثَرُ اُ۬لَاوَّلِينَۖ ٧١",
      "numberInSurah": 71,
      "verse_key": "37:71"
    },
    {
      "text": "وَلَقَدَ اَرْسَلْنَا فِيهِم مُّنذِرِينَۖ ٧٢",
      "numberInSurah": 72,
      "verse_key": "37:72"
    },
    {
      "text": "فَانظُرْ كَيْفَ كَانَ عَٰقِبَةُ اُ۬لْمُنذَرِينَ ٧٣",
      "numberInSurah": 73,
      "verse_key": "37:73"
    },
    {
      "text": "إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لْمُخْلَصِينَۖ ٧٤",
      "numberInSurah": 74,
      "verse_key": "37:74"
    },
    {
      "text": "وَلَقَدْ نَاد۪يٰنَا نُوحٞ فَلَنِعْمَ اَ۬لْمُجِيبُونَۖ ٧٥",
      "numberInSurah": 75,
      "verse_key": "37:75"
    },
    {
      "text": "وَنَجَّيْنَٰهُ وَأَهْلَهُۥ مِنَ اَ۬لْكَرْبِ اِ۬لْعَظِيمِۖ ٧٦",
      "numberInSurah": 76,
      "verse_key": "37:76"
    }
  ],
