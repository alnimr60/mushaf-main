{
  "pageNumber": 588,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "كَلَّآ إِنَّ كِتَٰبَ اَ۬لْفُجّ۪ارِ لَفِے سِجِّينٖۖ ٧",
      "numberInSurah": 7,
      "verse_key": "83:7"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا سِجِّينٞ ٨",
      "numberInSurah": 8,
      "verse_key": "83:8"
    },
    {
      "text": "كِتَٰبٞ مَّرْقُومٞۖ ٩",
      "numberInSurah": 9,
      "verse_key": "83:9"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَ ١٠",
      "numberInSurah": 10,
      "verse_key": "83:10"
    },
    {
      "text": "اَ۬لذِينَ يُكَذِّبُونَ بِيَوْمِ اِ۬لدِّينِۖ ١١",
      "numberInSurah": 11,
      "verse_key": "83:11"
    },
    {
      "text": "وَمَا يُكَذِّبُ بِهِۦٓ إِلَّا كُلُّ مُعْتَدٍ اَثِيمٍ ١٢",
      "numberInSurah": 12,
      "verse_key": "83:12"
    },
    {
      "text": "اِذَا تُتْل۪يٰ عَلَيْهِ ءَايَٰتُنَا قَالَ أَسَٰطِيرُ اُ۬لَاوَّلِينَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "83:13"
    },
    {
      "text": "۞كَلَّا بَل رَّانَ عَلَيٰ قُلُوبِهِم مَّا كَانُواْ يَكْسِبُونَۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "83:14"
    },
    {
      "text": "كَلَّآ إِنَّهُمْ عَن رَّبِّهِمْ يَوْمَئِذٖ لَّمَحْجُوبُونَۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "83:15"
    },
    {
      "text": "ثُمَّ إِنَّهُمْ لَصَالُواْ اُ۬لْجَحِيمِۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "83:16"
    },
    {
      "text": "ثُمَّ يُقَالُ هَٰذَا اَ۬لذِے كُنتُم بِهِۦ تُكَذِّبُونَۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "83:17"
    },
    {
      "text": "كَلَّآ إِنَّ كِتَٰبَ اَ۬لَابْر۪ارِ لَفِے عِلِّيِّينَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "83:18"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا عِلِّيُّونَ ١٩",
      "numberInSurah": 19,
      "verse_key": "83:19"
    },
    {
      "text": "كِتَٰبٞ مَّرْقُومٞ ٢٠",
      "numberInSurah": 20,
      "verse_key": "83:20"
    },
    {
      "text": "يَشْهَدُهُ اُ۬لْمُقَرَّبُونَۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "83:21"
    },
    {
      "text": "إِنَّ اَ۬لَابْرَارَ لَفِے نَعِيمٍ ٢٢",
      "numberInSurah": 22,
      "verse_key": "83:22"
    },
    {
      "text": "عَلَي اَ۬لَارَآئِكِ يَنظُرُونَ ٢٣",
      "numberInSurah": 23,
      "verse_key": "83:23"
    },
    {
      "text": "تَعْرِفُ فِے وُجُوهِهِمْ نَضْرَةَ اَ۬لنَّعِيمِ ٢٤",
      "numberInSurah": 24,
      "verse_key": "83:24"
    },
    {
      "text": "يُسْقَوْنَ مِن رَّحِيقٖ مَّخْتُومٍ ٢٥",
      "numberInSurah": 25,
      "verse_key": "83:25"
    },
    {
      "text": "خِتَٰمُهُۥ مِسْكٞۖ وَفِے ذَٰلِكَ فَلْيَتَنَافَسِ اِ۬لْمُتَنَٰفِسُونَۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "83:26"
    },
    {
      "text": "وَمِزَاجُهُۥ مِن تَسْنِيمٍ ٢٧",
      "numberInSurah": 27,
      "verse_key": "83:27"
    },
    {
      "text": "عَيْناٗ يَشْرَبُ بِهَا اَ۬لْمُقَرَّبُونَۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "83:28"
    },
    {
      "text": "إِنَّ اَ۬لذِينَ أَجْرَمُواْ كَانُواْ مِنَ اَ۬لذِينَ ءَامَنُواْ يَضْحَكُونَ ٢٩",
      "numberInSurah": 29,
      "verse_key": "83:29"
    },
    {
      "text": "وَإِذَا مَرُّواْ بِهِمْ يَتَغَامَزُونَ ٣٠",
      "numberInSurah": 30,
      "verse_key": "83:30"
    },
    {
      "text": "وَإِذَا اَ۪نقَلَبُوٓاْ إِلَيٰٓ أَهْلِهِمُ اُ۪نقَلَبُواْ فَٰكِهِينَ ٣١",
      "numberInSurah": 31,
      "verse_key": "83:31"
    },
    {
      "text": "وَإِذَا رَأَوْهُمْ قَالُوٓاْ إِنَّ هَٰٓؤُلَآءِ لَضَآلُّونَ ٣٢",
      "numberInSurah": 32,
      "verse_key": "83:32"
    },
    {
      "text": "وَمَآ أُرْسِلُواْ عَلَيْهِمْ حَٰفِظِينَۖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "83:33"
    },
    {
      "text": "فَالْيَوْمَ اَ۬لذِينَ ءَامَنُواْ مِنَ اَ۬لْكُفّ۪ارِ يَضْحَكُونَ ٣٤",
      "numberInSurah": 34,
      "verse_key": "83:34"
    }
  ],
