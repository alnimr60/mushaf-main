{
  "pageNumber": 521,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَالسَّمَآءِ ذَاتِ اِ۬لْحُبُكِ ٧",
      "numberInSurah": 7,
      "verse_key": "51:7"
    },
    {
      "text": "إِنَّكُمْ لَفِے قَوْلٖ مُّخْتَلِفٖ ٨",
      "numberInSurah": 8,
      "verse_key": "51:8"
    },
    {
      "text": "يُوفَكُ عَنْهُ مَنُ ا۟فِكَۖ ٩",
      "numberInSurah": 9,
      "verse_key": "51:9"
    },
    {
      "text": "قُتِلَ اَ۬لْخَرَّٰصُونَ ١٠",
      "numberInSurah": 10,
      "verse_key": "51:10"
    },
    {
      "text": "اَ۬لذِينَ هُمْ فِے غَمْرَةٖ سَاهُونَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "51:11"
    },
    {
      "text": "يَسْـَٔلُونَ أَيَّانَ يَوْمُ اُ۬لدِّينِ ١٢",
      "numberInSurah": 12,
      "verse_key": "51:12"
    },
    {
      "text": "يَوْمَ هُمْ عَلَي اَ۬لنّ۪ارِ يُفْتَنُونَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "51:13"
    },
    {
      "text": "ذُوقُواْ فِتْنَتَكُمْ هَٰذَا اَ۬لذِے كُنتُم بِهِۦ تَسْتَعْجِلُونَۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "51:14"
    },
    {
      "text": "إِنَّ اَ۬لْمُتَّقِينَ فِے جَنَّٰتٖ وَعُيُونٍ ١٥",
      "numberInSurah": 15,
      "verse_key": "51:15"
    },
    {
      "text": "اٰخِذِينَ مَآ ءَات۪يٰهُمْ رَبُّهُمُۥٓۖ إِنَّهُمْ كَانُواْ قَبْلَ ذَٰلِكَ مُحْسِنِينَۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "51:16"
    },
    {
      "text": "كَانُواْ قَلِيلاٗ مِّنَ اَ۬ليْلِ مَا يَهْجَعُونَۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "51:17"
    },
    {
      "text": "وَبِالَاسْح۪ارِ هُمْ يَسْتَغْفِرُونَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "51:18"
    },
    {
      "text": "وَفِےٓ أَمْوَٰلِهِمْ حَقّٞ لِّلسَّآئِلِ وَالْمَحْرُومِۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "51:19"
    },
    {
      "text": "وَفِے اِ۬لَارْضِ ءَايَٰتٞ لِّلْمُوقِنِينَۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "51:20"
    },
    {
      "text": "وَفِےٓ أَنفُسِكُمُۥٓۖ أَفَلَا تُبْصِرُونَۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "51:21"
    },
    {
      "text": "وَفِے اِ۬لسَّمَآءِ رِزْقُكُمْ وَمَا تُوعَدُونَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "51:22"
    },
    {
      "text": "فَوَرَبِّ اِ۬لسَّمَآءِ وَالَارْضِ إِنَّهُۥ لَحَقّٞ مِّثْلَ مَآ أَنَّكُمْ تَنطِقُونَۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "51:23"
    },
    {
      "text": "هَلَ اَت۪يٰكَ حَدِيثُ ضَيْفِ إِبْرَٰهِيمَ اَ۬لْمُكْرَمِينَ ٢٤",
      "numberInSurah": 24,
      "verse_key": "51:24"
    },
    {
      "text": "إِذْ دَخَلُواْ عَلَيْهِ فَقَالُواْ سَلَٰماٗۖ قَالَ سَلَٰمٞۖ قَوْمٞ مُّنكَرُونَۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "51:25"
    },
    {
      "text": "فَرَاغَ إِلَيٰٓ أَهْلِهِۦ فَجَآءَ بِعِجْلٖ سَمِينٖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "51:26"
    },
    {
      "text": "فَقَرَّبَهُۥٓ إِلَيْهِمْ قَالَ أَلَا تَاكُلُونَۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "51:27"
    },
    {
      "text": "فَأَوْجَسَ مِنْهُمْ خِيفَةٗۖ قَالُواْ لَا تَخَفْۖ وَبَشَّرُوهُ بِغُلَٰمٍ عَلِيمٖۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "51:28"
    },
    {
      "text": "فَأَقْبَلَتِ اِ۪مْرَأَتُهُۥ فِے صَرَّةٖ فَصَكَّتْ وَجْهَهَا وَقَالَتْ عَجُوزٌ عَقِيمٞۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "51:29"
    },
    {
      "text": "قَالُواْ كَذَٰلِكِ قَالَ رَبُّكِۖ إِنَّهُۥ هُوَ اَ۬لْحَكِيمُ اُ۬لْعَلِيمُۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "51:30"
    }
  ],
