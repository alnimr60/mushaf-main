{
  "pageNumber": 376,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "مَآ أَغْن۪يٰ عَنْهُم مَّا كَانُواْ يُمَتَّعُونَۖ ٢٠٧",
      "numberInSurah": 207,
      "verse_key": "26:207"
    },
    {
      "text": "وَمَآ أَهْلَكْنَا مِن قَرْيَةٍ اِلَّا لَهَا مُنذِرُونَ ٢٠٨",
      "numberInSurah": 208,
      "verse_key": "26:208"
    },
    {
      "text": "ذِكْر۪يٰۖ وَمَا كُنَّا ظَٰلِمِينَۖ ٢٠٩",
      "numberInSurah": 209,
      "verse_key": "26:209"
    },
    {
      "text": "۞وَمَا تَنَزَّلَتْ بِهِ اِ۬لشَّيَٰطِينُ وَمَا يَنۢبَغِے لَهُمْ وَمَا يَسْتَطِيعُونَۖ ٢١٠",
      "numberInSurah": 210,
      "verse_key": "26:210"
    },
    {
      "text": "إِنَّهُمْ عَنِ اِ۬لسَّمْعِ لَمَعْزُولُونَۖ ٢١١",
      "numberInSurah": 211,
      "verse_key": "26:211"
    },
    {
      "text": "فَلَا تَدْعُ مَعَ اَ۬للَّهِ إِلَٰهاً اٰخَرَ فَتَكُونَ مِنَ اَ۬لْمُعَذَّبِينَۖ ٢١٢",
      "numberInSurah": 212,
      "verse_key": "26:212"
    },
    {
      "text": "وَأَنذِرْ عَشِيرَتَكَ اَ۬لَاقْرَبِينَ ٢١٣",
      "numberInSurah": 213,
      "verse_key": "26:213"
    },
    {
      "text": "وَاخْفِضْ جَنَاحَكَ لِمَنِ اِ۪تَّبَعَكَ مِنَ اَ۬لْمُومِنِينَۖ ٢١٤",
      "numberInSurah": 214,
      "verse_key": "26:214"
    },
    {
      "text": "فَإِنْ عَصَوْكَ فَقُلِ اِنِّے بَرِےٓءٞ مِّمَّا تَعْمَلُونَۖ ٢١٥",
      "numberInSurah": 215,
      "verse_key": "26:215"
    },
    {
      "text": "فَتَوَكَّلْ عَلَي اَ۬لْعَزِيزِ اِ۬لرَّحِيمِ ٢١٦",
      "numberInSurah": 216,
      "verse_key": "26:216"
    },
    {
      "text": "اِ۬لذِے يَر۪يٰكَ حِينَ تَقُومُ ٢١٧",
      "numberInSurah": 217,
      "verse_key": "26:217"
    },
    {
      "text": "وَتَقَلُّبَكَ فِے اِ۬لسَّٰجِدِينَۖ ٢١٨",
      "numberInSurah": 218,
      "verse_key": "26:218"
    },
    {
      "text": "إِنَّهُۥ هُوَ اَ۬لسَّمِيعُ اُ۬لْعَلِيمُۖ ٢١٩",
      "numberInSurah": 219,
      "verse_key": "26:219"
    },
    {
      "text": "هَلُ ا۟نَبِّئُكُمْ عَلَيٰ مَن تَنَزَّلُ اُ۬لشَّيَٰطِينُ ٢٢٠",
      "numberInSurah": 220,
      "verse_key": "26:220"
    },
    {
      "text": "تَنَزَّلُ عَلَيٰ كُلِّ أَفَّاكٍ اَثِيمٖ ٢٢١",
      "numberInSurah": 221,
      "verse_key": "26:221"
    },
    {
      "text": "يُلْقُونَ اَ۬لسَّمْعَ وَأَكْثَرُهُمْ كَٰذِبُونَۖ ٢٢٢",
      "numberInSurah": 222,
      "verse_key": "26:222"
    },
    {
      "text": "وَالشُّعَرَآءُ يَتْبَعُهُمُ اُ۬لْغَاوُۥنَۖ ٢٢٣",
      "numberInSurah": 223,
      "verse_key": "26:223"
    },
    {
      "text": "أَلَمْ تَرَ أَنَّهُمْ فِے كُلِّ وَادٖ يَهِيمُونَ ٢٢٤",
      "numberInSurah": 224,
      "verse_key": "26:224"
    },
    {
      "text": "وَأَنَّهُمْ يَقُولُونَ مَا لَا يَفْعَلُونَۖ ٢٢٥",
      "numberInSurah": 225,
      "verse_key": "26:225"
    },
    {
      "text": "إِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ وَذَكَرُواْ اُ۬للَّهَ كَثِيراٗ وَانتَصَرُواْ مِنۢ بَعْدِ مَا ظُلِمُواْۖ وَسَيَعْلَمُ اُ۬لذِينَ ظَلَمُوٓاْ أَيَّ مُنقَلَبٖ يَنقَلِبُونَۖ ٢٢٦",
      "numberInSurah": 226,
      "verse_key": "26:226"
    },
    {
