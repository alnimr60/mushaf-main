{
  "pageNumber": 585,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "عَبَسَ وَتَوَلّ۪يٰٓ ١",
      "numberInSurah": 1,
      "verse_key": "80:1"
    },
    {
      "text": "أَن جَآءَهُ اُ۬لَاعْم۪يٰۖ ٢",
      "numberInSurah": 2,
      "verse_key": "80:2"
    },
    {
      "text": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكّ۪يٰٓ ٣",
      "numberInSurah": 3,
      "verse_key": "80:3"
    },
    {
      "text": "أَوْ يَذَّكَّرُ فَتَنفَعُهُ اُ۬لذِّكْر۪يٰٓۖ ٤",
      "numberInSurah": 4,
      "verse_key": "80:4"
    },
    {
      "text": "أَمَّا مَنِ اِ۪سْتَغْن۪يٰ ٥",
      "numberInSurah": 5,
      "verse_key": "80:5"
    },
    {
      "text": "فَأَنتَ لَهُۥ تَصَّدّ۪يٰ ٦",
      "numberInSurah": 6,
      "verse_key": "80:6"
    },
    {
      "text": "وَمَا عَلَيْكَ أَلَّا يَزَّكّ۪يٰۖ ٧",
      "numberInSurah": 7,
      "verse_key": "80:7"
    },
    {
      "text": "وَأَمَّا مَن جَآءَكَ يَسْع۪يٰ ٨",
      "numberInSurah": 8,
      "verse_key": "80:8"
    },
    {
      "text": "وَهُوَ يَخْش۪يٰ ٩",
      "numberInSurah": 9,
      "verse_key": "80:9"
    },
    {
      "text": "فَأَنتَ عَنْهُ تَلَهّ۪يٰ ١٠",
      "numberInSurah": 10,
      "verse_key": "80:10"
    },
    {
      "text": "كَلَّآ إِنَّهَا تَذْكِرَةٞۖ ١١",
      "numberInSurah": 11,
      "verse_key": "80:11"
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥ ١٢",
      "numberInSurah": 12,
      "verse_key": "80:12"
    },
    {
      "text": "فِے صُحُفٖ مُّكَرَّمَةٖ ١٣",
      "numberInSurah": 13,
      "verse_key": "80:13"
    },
    {
      "text": "مَّرْفُوعَةٖ مُّطَهَّرَةِۢ ١٤",
      "numberInSurah": 14,
      "verse_key": "80:14"
    },
    {
      "text": "بِأَيْدِے سَفَرَةٖ ١٥",
      "numberInSurah": 15,
      "verse_key": "80:15"
    },
    {
      "text": "كِرَامِۢ بَرَرَةٖۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "80:16"
    },
    {
      "text": "قُتِلَ اَ۬لِانسَٰنُ مَآ أَكْفَرَهُۥۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "80:17"
    },
    {
      "text": "مِنَ اَيِّ شَےْءٍ خَلَقَهُۥۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "80:18"
    },
    {
      "text": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ ١٩",
      "numberInSurah": 19,
      "verse_key": "80:19"
    },
    {
      "text": "ثُمَّ اَ۬لسَّبِيلَ يَسَّرَهُۥ ٢٠",
      "numberInSurah": 20,
      "verse_key": "80:20"
    },
    {
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "80:21"
    },
    {
      "text": "ثُمَّ إِذَا شَآءَ انشَرَهُۥۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "80:22"
    },
    {
      "text": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "80:23"
    },
    {
      "text": "فَلْيَنظُرِ اِ۬لِانسَٰنُ إِلَيٰ طَعَامِهِۦٓۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "80:24"
    },
    {
      "text": "إِنَّا صَبَبْنَا اَ۬لْمَآءَ صَبّاٗ ٢٥",
      "numberInSurah": 25,
      "verse_key": "80:25"
    },
    {
      "text": "ثُمَّ شَقَقْنَا اَ۬لَارْضَ شَقّاٗ ٢٦",
      "numberInSurah": 26,
      "verse_key": "80:26"
    },
    {
      "text": "فَأَنۢبَتْنَا فِيهَا حَبّاٗ ٢٧",
      "numberInSurah": 27,
      "verse_key": "80:27"
    },
    {
      "text": "وَعِنَباٗ وَقَضْباٗ ٢٨",
      "numberInSurah": 28,
      "verse_key": "80:28"
    },
    {
      "text": "وَزَيْتُوناٗ وَنَخْلاٗ ٢٩",
      "numberInSurah": 29,
      "verse_key": "80:29"
    },
    {
      "text": "وَحَدَآئِقَ غُلْباٗ ٣٠",
      "numberInSurah": 30,
      "verse_key": "80:30"
    },
    {
      "text": "وَفَٰكِهَةٗ وَأَبّاٗ ٣١",
      "numberInSurah": 31,
      "verse_key": "80:31"
    },
    {
      "text": "مَّتَٰعاٗ لَّكُمْ وَلِأَنْعَٰمِكُمْۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "80:32"
    },
    {
      "text": "فَإِذَا جَآءَتِ اِ۬لصَّآخَّةُ ٣٣",
      "numberInSurah": 33,
      "verse_key": "80:33"
    },
    {
      "text": "يَوْمَ يَفِرُّ اُ۬لْمَرْءُ مِنَ اَخِيهِ ٣٤",
      "numberInSurah": 34,
      "verse_key": "80:34"
    },
    {
      "text": "وَأُمِّهِۦ وَأَبِيهِ ٣٥",
      "numberInSurah": 35,
      "verse_key": "80:35"
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "80:36"
    },
    {
      "text": "لِكُلِّ اِ۪مْرِےٕٖ مِّنْهُمْ يَوْمَئِذٖ شَأْنٞ يُغْنِيهِۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "80:37"
    },
    {
      "text": "وُجُوهٞ يَوْمَئِذٖ مُّسْفِرَةٞ ٣٨",
      "numberInSurah": 38,
      "verse_key": "80:38"
    },
    {
      "text": "ضَاحِكَةٞ مُّسْتَبْشِرَةٞۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "80:39"
    },
    {
      "text": "وَوُجُوهٞ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٞ ٤٠",
      "numberInSurah": 40,
      "verse_key": "80:40"
    },
    {
      "text": "تَرْهَقُهَا قَتَرَةٌۖ ٤١",
      "numberInSurah": 41,
      "verse_key": "80:41"
    },
    {
      "text": "ا۟وْلَٰٓئِكَ هُمُ اُ۬لْكَفَرَةُ اُ۬لْفَجَرَةُۖ ٤٢",
      "numberInSurah": 42,
      "verse_key": "80:42"
    }
  ],
  "source": {
