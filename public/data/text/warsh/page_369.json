{
  "pageNumber": 369,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَلَمَّا جَآءَ اَ۬لسَّحَرَةُ قَالُواْ لِفِرْعَوْنَ أَئِنَّ لَنَا لَأَجْراً اِن كُنَّا نَحْنُ اُ۬لْغَٰلِبِينَۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "26:40"
    },
    {
      "text": "قَالَ نَعَمْ وَإِنَّكُمُۥٓ إِذاٗ لَّمِنَ اَ۬لْمُقَرَّبِينَۖ ٤١",
      "numberInSurah": 41,
      "verse_key": "26:41"
    },
    {
      "text": "قَالَ لَهُم مُّوس۪يٰٓ أَلْقُواْ مَآ أَنتُم مُّلْقُونَۖ ٤٢",
      "numberInSurah": 42,
      "verse_key": "26:42"
    },
    {
      "text": "فَأَلْقَوْاْ حِبَالَهُمْ وَعِصِيَّهُمْ وَقَالُواْ بِعِزَّةِ فِرْعَوْنَ إِنَّا لَنَحْنُ اُ۬لْغَٰلِبُونَۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "26:43"
    },
    {
      "text": "فَأَلْق۪يٰ مُوس۪يٰ عَصَاهُ فَإِذَا هِيَ تَلَقَّفُ مَا يَافِكُونَۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "26:44"
    },
    {
      "text": "فَأُلْقِيَ اَ۬لسَّحَرَةُ سَٰجِدِينَۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "26:45"
    },
    {
      "text": "قَالُوٓاْ ءَامَنَّا بِرَبِّ اِ۬لْعَٰلَمِينَ ٤٦",
      "numberInSurah": 46,
      "verse_key": "26:46"
    },
    {
      "text": "رَبِّ مُوس۪يٰ وَهَٰرُونَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "26:47"
    },
    {
      "text": "قَالَ ءَاٰ۬مَنتُمْ لَهُۥ قَبْلَ أَنَ اٰذَنَ لَكُمُۥٓ إِنَّهُۥ لَكَبِيرُكُمُ اُ۬لذِے عَلَّمَكُمُ اُ۬لسِّحْرَ فَلَسَوْفَ تَعْلَمُونَۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "26:48"
    },
    {
      "text": "لَأُقَطِّعَنَّ أَيْدِيَكُمْ وَأَرْجُلَكُم مِّنْ خِلَٰفٖ وَلَأُصَلِّبَنَّكُمُۥٓ أَجْمَعِينَۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "26:49"
    },
    {
      "text": "۞قَالُواْ لَا ضَيْرَۖ إِنَّآ إِلَيٰ رَبِّنَا مُنقَلِبُونَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "26:50"
    },
    {
      "text": "إِنَّا نَطْمَعُ أَنْ يَّغْفِرَ لَنَا رَبُّنَا خَطَٰيٰ۪نَآ أَن كُنَّآ أَوَّلَ اَ۬لْمُومِنِينَۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "26:51"
    },
    {
      "text": "وَأَوْحَيْنَآ إِلَيٰ مُوس۪يٰٓ أَنِ اِ۪سْرِ بِعِبَادِيَ إِنَّكُم مُّتَّبَعُونَۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "26:52"
    },
    {
      "text": "فَأَرْسَلَ فِرْعَوْنُ فِے اِ۬لْمَدَآئِنِ حَٰشِرِينَۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "26:53"
    },
    {
      "text": "إِنَّ هَٰٓؤُلَآءِ لَشِرْذِمَةٞ قَلِيلُونَ ٥٤",
      "numberInSurah": 54,
      "verse_key": "26:54"
    },
    {
      "text": "وَإِنَّهُمْ لَنَا لَغَآئِظُونَ ٥٥",
      "numberInSurah": 55,
      "verse_key": "26:55"
    },
    {
      "text": "وَإِنَّا لَجَمِيعٌ حَذِرُونَۖ ٥٦",
      "numberInSurah": 56,
      "verse_key": "26:56"
    },
    {
      "text": "فَأَخْرَجْنَٰهُم مِّن جَنَّٰتٖ وَعُيُونٖ ٥٧",
      "numberInSurah": 57,
      "verse_key": "26:57"
    },
    {
      "text": "وَكُنُوزٖ وَمَقَامٖ كَرِيمٖۖ ٥٨",
      "numberInSurah": 58,
      "verse_key": "26:58"
    },
    {
      "text": "كَذَٰلِكَۖ وَأَوْرَثْنَٰهَا بَنِےٓ إِسْرَآءِيلَ ٥٩",
      "numberInSurah": 59,
      "verse_key": "26:59"
    },
    {
      "text": "فَأَتْبَعُوهُم مُّشْرِقِينَۖ ٦٠",
      "numberInSurah": 60,
      "verse_key": "26:60"
    }
  ],
