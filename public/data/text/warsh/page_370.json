{
  "pageNumber": 370,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَلَمَّا تَرَٰٓءَا اَ۬لْجَمْعَٰنِ قَالَ أَصْحَٰبُ مُوس۪يٰٓ إِنَّا لَمُدْرَكُونَۖ ٦١",
      "numberInSurah": 61,
      "verse_key": "26:61"
    },
    {
      "text": "قَالَ كَلَّآۖ إِنَّ مَعِے رَبِّے سَيَهْدِينِۖ ٦٢",
      "numberInSurah": 62,
      "verse_key": "26:62"
    },
    {
      "text": "فَأَوْحَيْنَآ إِلَيٰ مُوس۪يٰٓ أَنِ اِ۪ضْرِب بِّعَصَاكَ اَ۬لْبَحْرَ فَانفَلَقَ فَكَانَ كُلُّ فِرْقٖ كَالطَّوْدِ اِ۬لْعَظِيمِۖ ٦٣",
      "numberInSurah": 63,
      "verse_key": "26:63"
    },
    {
      "text": "وَأَزْلَفْنَا ثَمَّ اَ۬لَاخَرِينَۖ ٦٤",
      "numberInSurah": 64,
      "verse_key": "26:64"
    },
    {
      "text": "وَأَنجَيْنَا مُوس۪يٰ وَمَن مَّعَهُۥٓ أَجْمَعِينَ ٦٥",
      "numberInSurah": 65,
      "verse_key": "26:65"
    },
    {
      "text": "ثُمَّ أَغْرَقْنَا اَ۬لَاخَرِينَۖ ٦٦",
      "numberInSurah": 66,
      "verse_key": "26:66"
    },
    {
      "text": "إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ٦٧",
      "numberInSurah": 67,
      "verse_key": "26:67"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ٦٨",
      "numberInSurah": 68,
      "verse_key": "26:68"
    },
    {
      "text": "وَاتْلُ عَلَيْهِمْ نَبَأَ ا۪بْرَٰهِيمَ ٦٩",
      "numberInSurah": 69,
      "verse_key": "26:69"
    },
    {
      "text": "إِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَا تَعْبُدُونَۖ ٧٠",
      "numberInSurah": 70,
      "verse_key": "26:70"
    },
    {
      "text": "قَالُواْ نَعْبُدُ أَصْنَاماٗ فَنَظَلُّ لَهَا عَٰكِفِينَۖ ٧١",
      "numberInSurah": 71,
      "verse_key": "26:71"
    },
    {
      "text": "قَالَ هَلْ يَسْمَعُونَكُمُۥٓ إِذْ تَدْعُونَ ٧٢",
      "numberInSurah": 72,
      "verse_key": "26:72"
    },
    {
      "text": "أَوْ يَنفَعُونَكُمُۥٓ أَوْ يَضُرُّونَۖ ٧٣",
      "numberInSurah": 73,
      "verse_key": "26:73"
    },
    {
      "text": "قَالُواْ بَلْ وَجَدْنَآ ءَابَآءَنَا كَذَٰلِكَ يَفْعَلُونَۖ ٧٤",
      "numberInSurah": 74,
      "verse_key": "26:74"
    },
    {
      "text": "قَالَ أَفَرَٰٓيْتُم مَّا كُنتُمْ تَعْبُدُونَ ٧٥",
      "numberInSurah": 75,
      "verse_key": "26:75"
    },
    {
      "text": "أَنتُمْ وَءَابَآؤُكُمُ اُ۬لَاقْدَمُونَ ٧٦",
      "numberInSurah": 76,
      "verse_key": "26:76"
    },
    {
      "text": "فَإِنَّهُمْ عَدُوّٞ لِّيَ إِلَّا رَبَّ اَ۬لْعَٰلَمِينَ ٧٧",
      "numberInSurah": 77,
      "verse_key": "26:77"
    },
    {
      "text": "اَ۬لذِے خَلَقَنِے فَهُوَ يَهْدِينِۖ ٧٨",
      "numberInSurah": 78,
      "verse_key": "26:78"
    },
    {
      "text": "وَالذِے هُوَ يُطْعِمُنِے وَيَسْقِينِ ٧٩",
      "numberInSurah": 79,
      "verse_key": "26:79"
    },
    {
      "text": "وَإِذَا مَرِضْتُ فَهُوَ يَشْفِينِۖ ٨٠",
      "numberInSurah": 80,
      "verse_key": "26:80"
    },
    {
      "text": "وَالذِے يُمِيتُنِے ثُمَّ يُحْيِينِۖ ٨١",
      "numberInSurah": 81,
      "verse_key": "26:81"
    },
    {
      "text": "۞وَالذِےٓ أَطْمَعُ أَنْ يَّغْفِرَ لِے خَطِيَٓٔتِے يَوْمَ اَ۬لدِّينِۖ ٨٢",
      "numberInSurah": 82,
      "verse_key": "26:82"
    },
    {
      "text": "رَبِّ هَبْ لِے حُكْماٗ وَأَلْحِقْنِے بِالصَّٰلِحِينَۖ ٨٣",
      "numberInSurah": 83,
      "verse_key": "26:83"
    }
  ],
