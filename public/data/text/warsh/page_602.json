      "numberInSurah": 2,
      "verse_key": "107:2"
    },
    {
      "text": "وَلَا يَحُضُّ عَلَيٰ طَعَامِ اِ۬لْمِسْكِينِۖ ٣",
      "numberInSurah": 3,
      "verse_key": "107:3"
    },
    {
