      "numberInSurah": 5,
      "verse_key": "107:5"
    },
    {
      "text": "اَ۬لذِينَ هُمْ يُرَآءُونَ وَيَمْنَعُونَ اَ۬لْمَاعُونَۖ ٦",
      "numberInSurah": 6,
