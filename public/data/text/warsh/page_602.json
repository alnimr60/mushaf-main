      "numberInSurah": 0
    },
    {
      "text": "اَرَٰٓيْتَ اَ۬لذِے يُكَذِّبُ بِالدِّينِ ١",
      "numberInSurah": 1,
      "verse_key": "107:1"
    },
    {
