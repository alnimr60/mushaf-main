{
  "pageNumber": 526,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالنَّجْمِ إِذَا هَو۪يٰ ١",
      "numberInSurah": 1,
      "verse_key": "53:1"
    },
    {
      "text": "مَا ضَلَّ صَٰحِبُكُمْ وَمَا غَو۪يٰ ٢",
      "numberInSurah": 2,
      "verse_key": "53:2"
    },
    {
      "text": "وَمَا يَنطِقُ عَنِ اِ۬لْهَو۪يٰٓ ٣",
      "numberInSurah": 3,
      "verse_key": "53:3"
    },
    {
      "text": "إِنْ هُوَ إِلَّا وَحْيٞ يُوح۪يٰۖ ٤",
      "numberInSurah": 4,
      "verse_key": "53:4"
    },
    {
      "text": "عَلَّمَهُۥ شَدِيدُ اُ۬لْقُو۪يٰ ٥",
      "numberInSurah": 5,
      "verse_key": "53:5"
    },
    {
      "text": "ذُو مِرَّةٖ فَاسْتَو۪يٰ ٦",
      "numberInSurah": 6,
      "verse_key": "53:6"
    },
    {
      "text": "وَهُوَ بِالُافُقِ اِ۬لَاعْل۪يٰۖ ٧",
      "numberInSurah": 7,
      "verse_key": "53:7"
    },
    {
      "text": "ثُمَّ دَنَا فَتَدَلّ۪يٰ ٨",
      "numberInSurah": 8,
      "verse_key": "53:8"
    },
    {
      "text": "فَكَانَ قَابَ قَوْسَيْنِ أَوَ اَدْن۪يٰۖ ٩",
      "numberInSurah": 9,
      "verse_key": "53:9"
    },
    {
      "text": "فَأَوْح۪يٰٓ إِلَيٰ عَبْدِهِۦ مَآ أَوْح۪يٰۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "53:10"
    },
    {
      "text": "مَا كَذَبَ اَ۬لْفُؤَادُ مَا ر۪أ۪يٰٓۖ ١١",
      "numberInSurah": 11,
      "verse_key": "53:11"
    },
    {
      "text": "أَفَتُمَٰرُونَهُۥ عَلَيٰ مَا يَر۪يٰۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "53:12"
    },
    {
      "text": "وَلَقَدْ ر۪ء۪اهُ نَزْلَةً ا۟خْر۪يٰ ١٣",
      "numberInSurah": 13,
      "verse_key": "53:13"
    },
    {
      "text": "عِندَ سِدْرَةِ اِ۬لْمُنتَه۪يٰ ١٤",
      "numberInSurah": 14,
      "verse_key": "53:14"
    },
    {
      "text": "عِندَهَا جَنَّةُ اُ۬لْمَأْو۪يٰٓ ١٥",
      "numberInSurah": 15,
      "verse_key": "53:15"
    },
    {
      "text": "إِذْ يَغْشَي اَ۬لسِّدْرَةَ مَا يَغْش۪يٰۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "53:16"
    },
    {
      "text": "مَا زَاغَ اَ۬لْبَصَرُ وَمَا طَغ۪يٰۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "53:17"
    },
    {
      "text": "لَقَدْ ر۪أ۪يٰ مِنَ اٰيَٰتِ رَبِّهِ اِ۬لْكُبْر۪يٰٓۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "53:18"
    },
    {
      "text": "أَفَرَٰٓيْتُمُ اُ۬للَّٰتَ وَالْعُزّ۪يٰ ١٩",
      "numberInSurah": 19,
      "verse_key": "53:19"
    },
    {
      "text": "وَمَنَوٰةَ اَ۬لثَّالِثَةَ اَ۬لُاخْر۪يٰٓ ٢٠",
      "numberInSurah": 20,
      "verse_key": "53:20"
    },
    {
      "text": "أَلَكُمُ اُ۬لذَّكَرُ وَلَهُ اُ۬لُانث۪يٰۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "53:21"
    },
    {
      "text": "تِلْكَ إِذاٗ قِسْمَةٞ ضِيز۪يٰٓۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "53:22"
    },
    {
      "text": "إِنْ هِيَ إِلَّآ أَسْمَآءٞ سَمَّيْتُمُوهَآ أَنتُمْ وَءَابَآؤُكُم مَّآ أَنزَلَ اَ۬للَّهُ بِهَا مِن سُلْطَٰنٍۖ اِنْ يَّتَّبِعُونَ إِلَّا اَ۬لظَّنَّ وَمَا تَهْوَي اَ۬لَانفُسُۖ وَلَقَدْ جَآءَهُم مِّن رَّبِّهِمُ اُ۬لْهُد۪يٰٓۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "53:23"
    },
    {
      "text": "أَمْ لِلِانسَٰنِ مَا تَمَنّ۪يٰۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "53:24"
    },
    {
      "text": "فَلِلهِ اِ۬لَاخِرَةُ وَالُاول۪يٰۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "53:25"
    },
    {
      "text": "۞وَكَم مِّن مَّلَكٖ فِے اِ۬لسَّمَٰوَٰتِ لَا تُغْنِے شَفَٰعَتُهُمْ شَئْاً اِلَّا مِنۢ بَعْدِ أَنْ يَّاذَنَ اَ۬للَّهُ لِمَنْ يَّشَآءُ وَيَرْض۪يٰٓۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "53:26"
    }
  ],
