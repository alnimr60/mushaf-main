{
  "pageNumber": 373,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "إِنْ هَٰذَآ إِلَّا خُلُقُ اُ۬لَاوَّلِينَ ١٣٧",
      "numberInSurah": 137,
      "verse_key": "26:137"
    },
    {
      "text": "وَمَا نَحْنُ بِمُعَذَّبِينَۖ ١٣٨",
      "numberInSurah": 138,
      "verse_key": "26:138"
    },
    {
      "text": "فَكَذَّبُوهُ فَأَهْلَكْنَٰهُمُۥٓۖ إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٣٩",
      "numberInSurah": 139,
      "verse_key": "26:139"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٤٠",
      "numberInSurah": 140,
      "verse_key": "26:140"
    },
    {
      "text": "كَذَّبَتْ ثَمُودُ اُ۬لْمُرْسَلِينَ ١٤١",
      "numberInSurah": 141,
      "verse_key": "26:141"
    },
    {
      "text": "إِذْ قَالَ لَهُمُۥٓ أَخُوهُمْ صَٰلِحٌ اَلَا تَتَّقُونَ ١٤٢",
      "numberInSurah": 142,
      "verse_key": "26:142"
    },
    {
      "text": "إِنِّے لَكُمْ رَسُولٌ اَمِينٞۖ ١٤٣",
      "numberInSurah": 143,
      "verse_key": "26:143"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٤٤",
      "numberInSurah": 144,
      "verse_key": "26:144"
    },
    {
      "text": "وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنَ اَجْرٍۖ اِنَ اَجْرِيَ إِلَّا عَلَيٰ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٤٥",
      "numberInSurah": 145,
      "verse_key": "26:145"
    },
    {
      "text": "۞أَتُتْرَكُونَ فِے مَا هَٰهُنَآ ءَامِنِينَ ١٤٦",
      "numberInSurah": 146,
      "verse_key": "26:146"
    },
    {
      "text": "فِے جَنَّٰتٖ وَعُيُونٖ ١٤٧",
      "numberInSurah": 147,
      "verse_key": "26:147"
    },
    {
      "text": "وَزُرُوعٖ وَنَخْلٖ طَلْعُهَا هَضِيمٞ ١٤٨",
      "numberInSurah": 148,
      "verse_key": "26:148"
    },
    {
      "text": "وَتَنْحِتُونَ مِنَ اَ۬لْجِبَالِ بُيُوتاٗ فَرِهِينَۖ ١٤٩",
      "numberInSurah": 149,
      "verse_key": "26:149"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٥٠",
      "numberInSurah": 150,
      "verse_key": "26:150"
    },
    {
      "text": "وَلَا تُطِيعُوٓاْ أَمْرَ اَ۬لْمُسْرِفِينَ ١٥١",
      "numberInSurah": 151,
      "verse_key": "26:151"
    },
    {
      "text": "اَ۬لذِينَ يُفْسِدُونَ فِے اِ۬لَارْضِ وَلَا يُصْلِحُونَۖ ١٥٢",
      "numberInSurah": 152,
      "verse_key": "26:152"
    },
    {
      "text": "قَالُوٓاْ إِنَّمَآ أَنتَ مِنَ اَ۬لْمُسَحَّرِينَ ١٥٣",
      "numberInSurah": 153,
      "verse_key": "26:153"
    },
    {
      "text": "مَآ أَنتَ إِلَّا بَشَرٞ مِّثْلُنَا فَاتِ بِـَٔايَةٍ اِن كُنتَ مِنَ اَ۬لصَّٰدِقِينَۖ ١٥٤",
      "numberInSurah": 154,
      "verse_key": "26:154"
    },
    {
      "text": "قَالَ هَٰذِهِۦ نَاقَةٞ لَّهَا شِرْبٞ وَلَكُمْ شِرْبُ يَوْمٖ مَّعْلُومٖۖ ١٥٥",
      "numberInSurah": 155,
      "verse_key": "26:155"
    },
    {
      "text": "وَلَا تَمَسُّوهَا بِسُوٓءٖ فَيَاخُذَكُمْ عَذَابُ يَوْمٍ عَظِيمٖۖ ١٥٦",
      "numberInSurah": 156,
      "verse_key": "26:156"
    },
    {
      "text": "فَعَقَرُوهَا فَأَصْبَحُواْ نَٰدِمِينَ ١٥٧",
      "numberInSurah": 157,
      "verse_key": "26:157"
    },
    {
      "text": "فَأَخَذَهُمُ اُ۬لْعَذَابُۖ إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٥٨",
      "numberInSurah": 158,
      "verse_key": "26:158"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٥٩",
      "numberInSurah": 159,
      "verse_key": "26:159"
    }
  ],
