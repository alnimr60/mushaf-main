{
  "pageNumber": 452,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "مَا لَكُمْ كَيْفَ تَحْكُمُونَۖ ١٥٤",
      "numberInSurah": 154,
      "verse_key": "37:154"
    },
    {
      "text": "أَفَلَا تَذَّكَّرُونَۖ ١٥٥",
      "numberInSurah": 155,
      "verse_key": "37:155"
    },
    {
      "text": "أَمْ لَكُمْ سُلْطَٰنٞ مُّبِينٞ ١٥٦",
      "numberInSurah": 156,
      "verse_key": "37:156"
    },
    {
      "text": "فَاتُواْ بِكِتَٰبِكُمُۥٓ إِن كُنتُمْ صَٰدِقِينَۖ ١٥٧",
      "numberInSurah": 157,
      "verse_key": "37:157"
    },
    {
      "text": "وَجَعَلُواْ بَيْنَهُۥ وَبَيْنَ اَ۬لْجِنَّةِ نَسَباٗۖ وَلَقَدْ عَلِمَتِ اِ۬لْجِنَّةُ إِنَّهُمْ لَمُحْضَرُونَۖ ١٥٨",
      "numberInSurah": 158,
      "verse_key": "37:158"
    },
    {
      "text": "سُبْحَٰنَ اَ۬للَّهِ عَمَّا يَصِفُونَۖ ١٥٩",
      "numberInSurah": 159,
      "verse_key": "37:159"
    },
    {
      "text": "إِلَّا عِبَادَ اَ۬للَّهِ اِ۬لْمُخْلَصِينَۖ ١٦٠",
      "numberInSurah": 160,
      "verse_key": "37:160"
    },
    {
      "text": "فَإِنَّكُمْ وَمَا تَعْبُدُونَ ١٦١",
      "numberInSurah": 161,
      "verse_key": "37:161"
    },
    {
      "text": "مَآ أَنتُمْ عَلَيْهِ بِفَٰتِنِينَ ١٦٢",
      "numberInSurah": 162,
      "verse_key": "37:162"
    },
    {
      "text": "إِلَّا مَنْ هُوَ صَالِ اِ۬لْجَحِيمِۖ ١٦٣",
      "numberInSurah": 163,
      "verse_key": "37:163"
    },
    {
      "text": "وَمَا مِنَّآ إِلَّا لَهُۥ مَقَامٞ مَّعْلُومٞۖ ١٦٤",
      "numberInSurah": 164,
      "verse_key": "37:164"
    },
    {
      "text": "وَإِنَّا لَنَحْنُ اُ۬لصَّآفُّونَ ١٦٥",
      "numberInSurah": 165,
      "verse_key": "37:165"
    },
    {
      "text": "وَإِنَّا لَنَحْنُ اُ۬لْمُسَبِّحُونَۖ ١٦٦",
      "numberInSurah": 166,
      "verse_key": "37:166"
    },
    {
      "text": "وَإِن كَانُواْ لَيَقُولُونَ ١٦٧",
      "numberInSurah": 167,
      "verse_key": "37:167"
    },
    {
      "text": "لَوَ اَنَّ عِندَنَا ذِكْراٗ مِّنَ اَ۬لَاوَّلِينَ ١٦٨",
      "numberInSurah": 168,
      "verse_key": "37:168"
    },
    {
      "text": "لَكُنَّا عِبَادَ اَ۬للَّهِ اِ۬لْمُخْلَصِينَۖ ١٦٩",
      "numberInSurah": 169,
      "verse_key": "37:169"
    },
    {
      "text": "فَكَفَرُواْ بِهِۦۖ فَسَوْفَ يَعْلَمُونَۖ ١٧٠",
      "numberInSurah": 170,
      "verse_key": "37:170"
    },
    {
      "text": "وَلَقَدْ سَبَقَتْ كَلِمَتُنَا لِعِبَادِنَا اَ۬لْمُرْسَلِينَ ١٧١",
      "numberInSurah": 171,
      "verse_key": "37:171"
    },
    {
      "text": "إِنَّهُمْ لَهُمُ اُ۬لْمَنصُورُونَ ١٧٢",
      "numberInSurah": 172,
      "verse_key": "37:172"
    },
    {
      "text": "وَإِنَّ جُندَنَا لَهُمُ اُ۬لْغَٰلِبُونَۖ ١٧٣",
      "numberInSurah": 173,
      "verse_key": "37:173"
    },
    {
      "text": "فَتَوَلَّ عَنْهُمْ حَتَّيٰ حِينٖۖ ١٧٤",
      "numberInSurah": 174,
      "verse_key": "37:174"
    },
    {
      "text": "وَأَبْصِرْهُمْ فَسَوْفَ يُبْصِرُونَۖ ١٧٥",
      "numberInSurah": 175,
      "verse_key": "37:175"
    },
    {
      "text": "أَفَبِعَذَابِنَا يَسْتَعْجِلُونَۖ ١٧٦",
      "numberInSurah": 176,
      "verse_key": "37:176"
    },
    {
      "text": "فَإِذَا نَزَلَ بِسَاحَتِهِمْ فَسَآءَ صَبَاحُ اُ۬لْمُنذَرِينَۖ ١٧٧",
      "numberInSurah": 177,
      "verse_key": "37:177"
    },
    {
      "text": "وَتَوَلَّ عَنْهُمْ حَتَّيٰ حِينٖۖ ١٧٨",
      "numberInSurah": 178,
      "verse_key": "37:178"
    },
    {
      "text": "وَأَبْصِرْ فَسَوْفَ يُبْصِرُونَۖ ١٧٩",
      "numberInSurah": 179,
      "verse_key": "37:179"
    },
    {
      "text": "سُبْحَٰنَ رَبِّكَ رَبِّ اِ۬لْعِزَّةِ عَمَّا يَصِفُونَۖ ١٨٠",
      "numberInSurah": 180,
      "verse_key": "37:180"
    },
    {
      "text": "وَسَلَٰمٌ عَلَي اَ۬لْمُرْسَلِينَۖ ١٨١",
      "numberInSurah": 181,
      "verse_key": "37:181"
    },
    {
      "text": "وَالْحَمْدُ لِلهِ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٨٢",
      "numberInSurah": 182,
      "verse_key": "37:182"
    }
  ],
