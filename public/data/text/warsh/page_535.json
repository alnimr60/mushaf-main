{
  "pageNumber": 535,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "عَلَيٰ سُرُرٖ مَّوْضُونَةٖ ١٧",
      "numberInSurah": 17,
      "verse_key": "56:17"
    },
    {
      "text": "مُّتَّكِـِٕينَ عَلَيْهَا مُتَقَٰبِلِينَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "56:18"
    },
    {
      "text": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٞ مُّخَلَّدُونَ ١٩",
      "numberInSurah": 19,
      "verse_key": "56:19"
    },
    {
      "text": "بِأَكْوَابٖ وَأَبَارِيقَ ٢٠",
      "numberInSurah": 20,
      "verse_key": "56:20"
    },
    {
      "text": "وَكَأْسٖ مِّن مَّعِينٖ ٢١",
      "numberInSurah": 21,
      "verse_key": "56:21"
    },
    {
      "text": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزَفُونَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "56:22"
    },
    {
      "text": "وَفَٰكِهَةٖ مِّمَّا يَتَخَيَّرُونَ ٢٣",
      "numberInSurah": 23,
      "verse_key": "56:23"
    },
    {
      "text": "وَلَحْمِ طَيْرٖ مِّمَّا يَشْتَهُونَۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "56:24"
    },
    {
      "text": "وَحُورٌ عِينٞ كَأَمْثَٰلِ اِ۬للُّؤْلُوِٕ اِ۬لْمَكْنُونِ ٢٥",
      "numberInSurah": 25,
      "verse_key": "56:25"
    },
    {
      "text": "جَزَآءَۢ بِمَا كَانُواْ يَعْمَلُونَۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "56:26"
    },
    {
      "text": "لَا يَسْمَعُونَ فِيهَا لَغْواٗ وَلَا تَاثِيماًۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "56:27"
    },
    {
      "text": "اِلَّا قِيلاٗ سَلَٰماٗ سَلَٰماٗۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "56:28"
    },
    {
      "text": "وَأَصْحَٰبُ اُ۬لْيَمِينِ مَآ أَصْحَٰبُ اُ۬لْيَمِينِۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "56:29"
    },
    {
      "text": "فِے سِدْرٖ مَّخْضُودٖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "56:30"
    },
    {
      "text": "وَطَلْحٖ مَّنضُودٖ ٣١",
      "numberInSurah": 31,
      "verse_key": "56:31"
    },
    {
      "text": "وَظِلّٖ مَّمْدُودٖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "56:32"
    },
    {
      "text": "وَمَآءٖ مَّسْكُوبٖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "56:33"
    },
    {
      "text": "وَفَٰكِهَةٖ كَثِيرَةٖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "56:34"
    },
    {
      "text": "لَّا مَقْطُوعَةٖ وَلَا مَمْنُوعَةٖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "56:35"
    },
    {
      "text": "وَفُرُشٖ مَّرْفُوعَةٍۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "56:36"
    },
    {
      "text": "اِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءٗ ٣٧",
      "numberInSurah": 37,
      "verse_key": "56:37"
    },
    {
      "text": "فَجَعَلْنَٰهُنَّ أَبْكَاراً ٣٨",
      "numberInSurah": 38,
      "verse_key": "56:38"
    },
    {
      "text": "عُرُباً اَتْرَاباٗ ٣٩",
      "numberInSurah": 39,
      "verse_key": "56:39"
    },
    {
      "text": "لِّأَصْحَٰبِ اِ۬لْيَمِينِۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "56:40"
    },
    {
      "text": "ثُلَّةٞ مِّنَ اَ۬لَاوَّلِينَ ٤١",
      "numberInSurah": 41,
      "verse_key": "56:41"
    },
    {
      "text": "وَثُلَّةٞ مِّنَ اَ۬لَاخِرِينَۖ ٤٢",
      "numberInSurah": 42,
      "verse_key": "56:42"
    },
    {
      "text": "وَأَصْحَٰبُ اُ۬لشِّمَالِ ٤٣",
      "numberInSurah": 43,
      "verse_key": "56:43"
    },
    {
      "text": "مَآ أَصْحَٰبُ اُ۬لشِّمَالِۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "56:44"
    },
    {
      "text": "فِے سَمُومٖ وَحَمِيمٖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "56:45"
    },
    {
      "text": "وَظِلّٖ مِّنْ يَّحْمُومٖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "56:46"
    },
    {
      "text": "لَّا بَارِدٖ وَلَا كَرِيمٍۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "56:47"
    },
    {
      "text": "اِنَّهُمْ كَانُواْ قَبْلَ ذَٰلِكَ مُتْرَفِينَۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "56:48"
    },
    {
      "text": "وَكَانُواْ يُصِرُّونَ عَلَي اَ۬لْحِنثِ اِ۬لْعَظِيمِۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "56:49"
    },
    {
      "text": "وَكَانُواْ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَاباٗ وَعِظَٰماً اِنَّا لَمَبْعُوثُونَ ٥٠",
      "numberInSurah": 50,
      "verse_key": "56:50"
    }
  ],
