{
  "pageNumber": 531,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَمَآ أَمْرُنَآ إِلَّا وَٰحِدَةٞ كَلَمْحِۢ بِالْبَصَرِۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "54:50"
    },
    {
      "text": "وَلَقَدَ اَهْلَكْنَآ أَشْيَاعَكُمْ فَهَلْ مِن مُّدَّكِرٖۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "54:51"
    },
    {
      "text": "وَكُلُّ شَےْءٖ فَعَلُوهُ فِے اِ۬لزُّبُرِۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "54:52"
    },
    {
      "text": "وَكُلُّ صَغِيرٖ وَكَبِيرٖ مُّسْتَطَرٌۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "54:53"
    },
    {
      "text": "اِنَّ اَ۬لْمُتَّقِينَ فِے جَنَّٰتٖ وَنَهَرٖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "54:54"
    },
    {
      "text": "فِے مَقْعَدِ صِدْقٍ عِندَ مَلِيكٖ مُّقْتَدِرٍۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "54:55"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اِ۬لرَّحْمَٰنُ عَلَّمَ اَ۬لْقُرْءَانَۖ ١",
      "numberInSurah": 1,
      "verse_key": "55:1"
    },
    {
      "text": "خَلَقَ اَ۬لِانسَٰنَ عَلَّمَهُ اُ۬لْبَيَانَۖ ٢",
      "numberInSurah": 2,
      "verse_key": "55:2"
    },
    {
      "text": "اَ۬لشَّمْسُ وَالْقَمَرُ بِحُسْبَانٖۖ ٣",
      "numberInSurah": 3,
      "verse_key": "55:3"
    },
    {
      "text": "وَالنَّجْمُ وَالشَّجَرُ يَسْجُدَٰنِۖ ٤",
      "numberInSurah": 4,
      "verse_key": "55:4"
    },
    {
      "text": "وَالسَّمَآءَ رَفَعَهَا وَوَضَعَ اَ۬لْمِيزَانَ ٥",
      "numberInSurah": 5,
      "verse_key": "55:5"
    },
    {
      "text": "أَلَّا تَطْغَوْاْ فِے اِ۬لْمِيزَانِ ٦",
      "numberInSurah": 6,
      "verse_key": "55:6"
    },
    {
      "text": "وَأَقِيمُواْ اُ۬لْوَزْنَ بِالْقِسْطِ وَلَا تُخْسِرُواْ اُ۬لْمِيزَانَۖ ٧",
      "numberInSurah": 7,
      "verse_key": "55:7"
    },
    {
      "text": "وَالَارْضَ وَضَعَهَا لِلَانَامِ ٨",
      "numberInSurah": 8,
      "verse_key": "55:8"
    },
    {
      "text": "فِيهَا فَٰكِهَةٞ وَالنَّخْلُ ذَاتُ اُ۬لَاكْمَامِ ٩",
      "numberInSurah": 9,
      "verse_key": "55:9"
    },
    {
      "text": "وَالْحَبُّ ذُو اُ۬لْعَصْفِ وَالرَّيْحَانُۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "55:10"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ١١",
      "numberInSurah": 11,
      "verse_key": "55:11"
    },
    {
      "text": "خَلَقَ اَ۬لِانسَٰنَ مِن صَلْصَٰلٖ كَالْفَخّ۪ارِ ١٢",
      "numberInSurah": 12,
      "verse_key": "55:12"
    },
    {
      "text": "وَخَلَقَ اَ۬لْجَآنَّ مِن مَّارِجٖ مِّن نّ۪ارٖۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "55:13"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ١٤",
      "numberInSurah": 14,
      "verse_key": "55:14"
    },
    {
      "text": "رَبُّ اُ۬لْمَشْرِقَيْنِ وَرَبُّ اُ۬لْمَغْرِبَيْنِۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "55:15"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "55:16"
    }
  ],
