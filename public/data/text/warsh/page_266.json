{
  "pageNumber": 266,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "قَالَ هَٰٓؤُلَآءِ بَنَاتِيَ إِن كُنتُمْ فَٰعِلِينَۖ ٧١",
      "numberInSurah": 71,
      "verse_key": "15:71"
    },
    {
      "text": "لَعَمْرُكَ إِنَّهُمْ لَفِے سَكْرَتِهِمْ يَعْمَهُونَۖ ٧٢",
      "numberInSurah": 72,
      "verse_key": "15:72"
    },
    {
      "text": "فَأَخَذَتْهُمُ اُ۬لصَّيْحَةُ مُشْرِقِينَ ٧٣",
      "numberInSurah": 73,
      "verse_key": "15:73"
    },
    {
      "text": "فَجَعَلْنَا عَٰلِيَهَا سَافِلَهَا وَأَمْطَرْنَا عَلَيْهِمْ حِجَارَةٗ مِّن سِجِّيلٍۖ ٧٤",
      "numberInSurah": 74,
      "verse_key": "15:74"
    },
    {
      "text": "اِنَّ فِے ذَٰلِكَ لَأٓيَٰتٖ لِّلْمُتَوَسِّمِينَۖ ٧٥",
      "numberInSurah": 75,
      "verse_key": "15:75"
    },
    {
      "text": "وَإِنَّهَا لَبِسَبِيلٖ مُّقِيمٍۖ ٧٦",
      "numberInSurah": 76,
      "verse_key": "15:76"
    },
    {
      "text": "اِنَّ فِے ذَٰلِكَ لَأٓيَةٗ لِّلْمُومِنِينَۖ ٧٧",
      "numberInSurah": 77,
      "verse_key": "15:77"
    },
    {
      "text": "وَإِن كَانَ أَصْحَٰبُ اُ۬لَايْكَةِ لَظَٰلِمِينَۖ ٧٨",
      "numberInSurah": 78,
      "verse_key": "15:78"
    },
    {
      "text": "فَانتَقَمْنَا مِنْهُمْ وَإِنَّهُمَا لَبِإِمَامٖ مُّبِينٖۖ ٧٩",
      "numberInSurah": 79,
      "verse_key": "15:79"
    },
    {
      "text": "وَلَقَدْ كَذَّبَ أَصْحَٰبُ اُ۬لْحِجْرِ اِ۬لْمُرْسَلِينَۖ ٨٠",
      "numberInSurah": 80,
      "verse_key": "15:80"
    },
    {
      "text": "وَءَاتَيْنَٰهُمُۥٓ ءَايَٰتِنَا فَكَانُواْ عَنْهَا مُعْرِضِينَۖ ٨١",
      "numberInSurah": 81,
      "verse_key": "15:81"
    },
    {
      "text": "وَكَانُواْ يَنْحِتُونَ مِنَ اَ۬لْجِبَالِ بُيُوتاً اٰمِنِينَۖ ٨٢",
      "numberInSurah": 82,
      "verse_key": "15:82"
    },
    {
      "text": "فَأَخَذَتْهُمُ اُ۬لصَّيْحَةُ مُصْبِحِينَۖ ٨٣",
      "numberInSurah": 83,
      "verse_key": "15:83"
    },
    {
      "text": "فَمَآ أَغْن۪يٰ عَنْهُم مَّا كَانُواْ يَكْسِبُونَۖ ٨٤",
      "numberInSurah": 84,
      "verse_key": "15:84"
    },
    {
      "text": "وَمَا خَلَقْنَا اَ۬لسَّمَٰوَٰتِ وَالَارْضَ وَمَا بَيْنَهُمَآ إِلَّا بِالْحَقِّۖ وَإِنَّ اَ۬لسَّاعَةَ لَأٓتِيَةٞۖ فَاصْفَحِ اِ۬لصَّفْحَ اَ۬لْجَمِيلَۖ ٨٥",
      "numberInSurah": 85,
      "verse_key": "15:85"
    },
    {
      "text": "إِنَّ رَبَّكَ هُوَ اَ۬لْخَلَّٰقُ اُ۬لْعَلِيمُۖ ٨٦",
      "numberInSurah": 86,
      "verse_key": "15:86"
    },
    {
      "text": "وَلَقَدَ اٰتَيْنَٰكَ سَبْعاٗ مِّنَ اَ۬لْمَثَانِے وَالْقُرْءَانَ اَ۬لْعَظِيمَۖ ٨٧",
      "numberInSurah": 87,
      "verse_key": "15:87"
    },
    {
      "text": "لَا تَمُدَّنَّ عَيْنَيْكَ إِلَيٰ مَا مَتَّعْنَا بِهِۦٓ أَزْوَٰجاٗ مِّنْهُمْ وَلَا تَحْزَنْ عَلَيْهِمْ وَاخْفِضْ جَنَاحَكَ لِلْمُومِنِينَۖ ٨٨",
      "numberInSurah": 88,
      "verse_key": "15:88"
    },
    {
      "text": "وَقُلِ اِنِّيَ أَنَا اَ۬لنَّذِيرُ اُ۬لْمُبِينُ ٨٩",
      "numberInSurah": 89,
      "verse_key": "15:89"
    },
    {
      "text": "كَمَآ أَنزَلْنَا عَلَي اَ۬لْمُقْتَسِمِينَ ٩٠",
      "numberInSurah": 90,
      "verse_key": "15:90"
    }
  ],
