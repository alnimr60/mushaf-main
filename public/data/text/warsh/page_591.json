{
  "pageNumber": 591,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالسَّمَآءِ وَالطَّارِقِ ١",
      "numberInSurah": 1,
      "verse_key": "86:1"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا اَ۬لطَّارِقُ ٢",
      "numberInSurah": 2,
      "verse_key": "86:2"
    },
    {
      "text": "اُ۬لنَّجْمُ اُ۬لثَّاقِبُ ٣",
      "numberInSurah": 3,
      "verse_key": "86:3"
    },
    {
      "text": "إِن كُلُّ نَفْسٖ لَّمَا عَلَيْهَا حَافِظٞۖ ٤",
      "numberInSurah": 4,
      "verse_key": "86:4"
    },
    {
      "text": "فَلْيَنظُرِ اِ۬لِانسَٰنُ مِمَّ خُلِقَۖ ٥",
      "numberInSurah": 5,
      "verse_key": "86:5"
    },
    {
      "text": "خُلِقَ مِن مَّآءٖ دَافِقٖ ٦",
      "numberInSurah": 6,
      "verse_key": "86:6"
    },
    {
      "text": "يَخْرُجُ مِنۢ بَيْنِ اِ۬لصُّلْبِ وَالتَّرَآئِبِۖ ٧",
      "numberInSurah": 7,
      "verse_key": "86:7"
    },
    {
      "text": "إِنَّهُۥ عَلَيٰ رَجْعِهِۦ لَقَادِرٞ ٨",
      "numberInSurah": 8,
      "verse_key": "86:8"
    },
    {
      "text": "يَوْمَ تُبْلَي اَ۬لسَّرَآئِرُ ٩",
      "numberInSurah": 9,
      "verse_key": "86:9"
    },
    {
      "text": "فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "86:10"
    },
    {
      "text": "وَالسَّمَآءِ ذَاتِ اِ۬لرَّجْعِ ١١",
      "numberInSurah": 11,
      "verse_key": "86:11"
    },
    {
      "text": "وَالَارْضِ ذَاتِ اِ۬لصَّدْعِ ١٢",
      "numberInSurah": 12,
      "verse_key": "86:12"
    },
    {
      "text": "إِنَّهُۥ لَقَوْلٞ فَصْلٞ ١٣",
      "numberInSurah": 13,
      "verse_key": "86:13"
    },
    {
      "text": "وَمَا هُوَ بِالْهَزْلِۖ ١٤",
      "numberInSurah": 14,
      "verse_key": "86:14"
    },
    {
      "text": "إِنَّهُمْ يَكِيدُونَ كَيْداٗ ١٥",
      "numberInSurah": 15,
      "verse_key": "86:15"
    },
    {
      "text": "وَأَكِيدُ كَيْداٗۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "86:16"
    },
    {
      "text": "فَمَهِّلِ اِ۬لْكٰ۪فِرِينَ أَمْهِلْهُمْ رُوَيْداٗۖ ١٧",
      "numberInSurah": 17,
      "verse_key": "86:17"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "سَبِّحِ اِ۪سْمَ رَبِّكَ اَ۬لَاعْلَي ١",
      "numberInSurah": 1,
      "verse_key": "87:1"
    },
    {
      "text": "اَ۬لذِے خَلَقَ فَسَوّ۪يٰ ٢",
      "numberInSurah": 2,
      "verse_key": "87:2"
    },
    {
      "text": "وَالذِے قَدَّرَ فَهَد۪يٰ ٣",
      "numberInSurah": 3,
      "verse_key": "87:3"
    },
    {
      "text": "وَالذِےٓ أَخْرَجَ اَ۬لْمَرْع۪يٰ ٤",
      "numberInSurah": 4,
      "verse_key": "87:4"
    },
    {
      "text": "فَجَعَلَهُۥ غُثَآءً اَحْو۪يٰۖ ٥",
      "numberInSurah": 5,
      "verse_key": "87:5"
    },
    {
      "text": "سَنُقْرِئُكَ فَلَا تَنس۪يٰٓ ٦",
      "numberInSurah": 6,
      "verse_key": "87:6"
    },
    {
      "text": "إِلَّا مَا شَآءَ اَ۬للَّهُۖ إِنَّهُۥ يَعْلَمُ اُ۬لْجَهْرَ وَمَا يَخْف۪يٰۖ ٧",
      "numberInSurah": 7,
      "verse_key": "87:7"
    },
    {
      "text": "وَنُيَسِّرُكَ لِلْيُسْر۪يٰۖ ٨",
      "numberInSurah": 8,
      "verse_key": "87:8"
    },
    {
      "text": "فَذَكِّرِ اِن نَّفَعَتِ اِ۬لذِّكْر۪يٰۖ ٩",
      "numberInSurah": 9,
      "verse_key": "87:9"
    },
    {
      "text": "سَيَذَّكَّرُ مَنْ يَّخْش۪يٰ ١٠",
      "numberInSurah": 10,
      "verse_key": "87:10"
    },
    {
      "text": "وَيَتَجَنَّبُهَا اَ۬لَاشْقَي ١١",
      "numberInSurah": 11,
      "verse_key": "87:11"
    },
    {
      "text": "اَ۬لذِے يَصْلَي اَ۬لنَّارَ اَ۬لْكُبْر۪يٰ ١٢",
      "numberInSurah": 12,
      "verse_key": "87:12"
    },
    {
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحْي۪يٰۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "87:13"
    },
    {
      "text": "قَدَ اَفْلَحَ مَن تَزَكّ۪يٰ ١٤",
      "numberInSurah": 14,
      "verse_key": "87:14"
    },
    {
      "text": "وَذَكَرَ اَ۪سْمَ رَبِّهِۦ فَصَلّ۪يٰۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "87:15"
    }
  ],
