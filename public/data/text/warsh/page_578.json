  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَتَذَرُونَ اَ۬لَاخِرَةَۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "75:20"
    },
    {
      "text": "وُجُوهٞ يَوْمَئِذٖ نَّاضِرَةٌ ٢١",
      "numberInSurah": 21,
      "verse_key": "75:21"
    },
    {
      "text": "اِلَيٰ رَبِّهَا نَاظِرَةٞۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "75:22"
    },
    {
      "text": "وَوُجُوهٞ يَوْمَئِذِۢ بَاسِرَةٞ ٢٣",
      "numberInSurah": 23,
      "verse_key": "75:23"
    },
    {
      "text": "تَظُنُّ أَنْ يُّفْعَلَ بِهَا فَاقِرَةٞۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "75:24"
    },
    {
      "text": "كَلَّآ إِذَا بَلَغَتِ اِ۬لتَّرَاقِيَ ٢٥",
      "numberInSurah": 25,
      "verse_key": "75:25"
    },
    {
      "text": "وَقِيلَ مَن رَّاقٖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "75:26"
    },
    {
      "text": "وَظَنَّ أَنَّهُ اُ۬لْفِرَاقُ ٢٧",
      "numberInSurah": 27,
      "verse_key": "75:27"
    },
    {
      "text": "وَالْتَفَّتِ اِ۬لسَّاقُ بِالسَّاقِ ٢٨",
      "numberInSurah": 28,
      "verse_key": "75:28"
    },
    {
      "text": "إِلَيٰ رَبِّكَ يَوْمَئِذٍ اِ۬لْمَسَاقُۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "75:29"
    },
    {
      "text": "فَلَا صَدَّقَ وَلَا صَلّ۪يٰۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "75:30"
    },
    {
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلّ۪يٰۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "75:31"
    },
    {
      "text": "ثُمَّ ذَهَبَ إِلَيٰٓ أَهْلِهِۦ يَتَمَطّ۪يٰٓۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "75:32"
    },
    {
      "text": "أَوْل۪يٰ لَكَ فَأَوْل۪يٰ ٣٣",
      "numberInSurah": 33,
      "verse_key": "75:33"
    },
    {
      "text": "ثُمَّ أَوْل۪يٰ لَكَ فَأَوْل۪يٰٓۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "75:34"
    },
    {
      "text": "أَيَحْسِبُ اُ۬لِانسَٰنُ أَنْ يُّتْرَكَ سُديًۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "75:35"
    },
    {
      "text": "اَلَمْ يَكُ نُطْفَةٗ مِّن مَّنِيّٖ تُمْن۪يٰ ٣٦",
      "numberInSurah": 36,
      "verse_key": "75:36"
    },
    {
      "text": "ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوّ۪يٰ ٣٧",
      "numberInSurah": 37,
      "verse_key": "75:37"
    },
    {
      "text": "فَجَعَلَ مِنْهُ اُ۬لزَّوْجَيْنِ اِ۬لذَّكَرَ وَالُانث۪يٰٓۖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "75:38"
    },
    {
      "text": "أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَيٰٓ أَنْ يُّحْـِۧيَ اَ۬لْمَوْت۪يٰۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "75:39"
    },
    {
      "text": "",
      "numberInSurah": 40,
      "verse_key": "75:40"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "هَلَ اَت۪يٰ عَلَي اَ۬لِانسَٰنِ حِينٞ مِّنَ اَ۬لدَّهْرِ لَمْ يَكُن شَئْاٗ مَّذْكُوراًۖ ١",
      "numberInSurah": 1,
      "verse_key": "76:1"
    },
    {
      "text": "اِنَّا خَلَقْنَا اَ۬لِانسَٰنَ مِن نُّطْفَةٍ اَمْشَاجٖ نَّبْتَلِيهِ فَجَعَلْنَٰهُ سَمِيعاَۢ بَصِيراًۖ ٢",
      "numberInSurah": 2,
      "verse_key": "76:2"
    },
    {
      "text": "اِنَّا هَدَيْنَٰهُ اُ۬لسَّبِيلَ إِمَّا شَاكِراٗ وَإِمَّا كَفُوراًۖ ٣",
      "numberInSurah": 3,
      "verse_key": "76:3"
    },
    {
      "text": "اِنَّآ أَعْتَدْنَا لِلْكٰ۪فِرِينَ سَلَٰسِلاٗ وَأَغْلَٰلاٗ وَسَعِيراًۖ ٤",
      "numberInSurah": 4,
      "verse_key": "76:4"
    },
    {
      "text": "اِنَّ اَ۬لَابْرَارَ يَشْرَبُونَ مِن كَأْسٖ كَانَ مِزَاجُهَا كَافُوراًۖ ٥",
      "numberInSurah": 5,
      "verse_key": "76:5"
    }
  ],
