{
  "pageNumber": 589,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "عَلَي اَ۬لَارَآئِكِ يَنظُرُونَۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "83:35"
    },
    {
      "text": "هَلْ ثُوِّبَ اَ۬لْكُفَّارُ مَا كَانُواْ يَفْعَلُونَۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "83:36"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "إِذَا اَ۬لسَّمَآءُ اُ۪نشَقَّتْ ١",
      "numberInSurah": 1,
      "verse_key": "84:1"
    },
    {
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْ ٢",
      "numberInSurah": 2,
      "verse_key": "84:2"
    },
    {
      "text": "وَإِذَا اَ۬لَارْضُ مُدَّتْ ٣",
      "numberInSurah": 3,
      "verse_key": "84:3"
    },
    {
      "text": "وَأَلْقَتْ مَا فِيهَا وَتَخَلَّتْ ٤",
      "numberInSurah": 4,
      "verse_key": "84:4"
    },
    {
      "text": "وَأَذِنَتْ لِرَبِّهَا وَحُقَّتْۖ ٥",
      "numberInSurah": 5,
      "verse_key": "84:5"
    },
    {
      "text": "يَٰٓأَيُّهَا اَ۬لِانسَٰنُ إِنَّكَ كَادِحٌ اِلَيٰ رَبِّكَ كَدْحاٗ فَمُلَٰقِيهِۖ ٦",
      "numberInSurah": 6,
      "verse_key": "84:6"
    },
    {
      "text": "فَأَمَّا مَنُ ا۟وتِيَ كِتَٰبَهُۥ بِيَمِينِهِۦ ٧",
      "numberInSurah": 7,
      "verse_key": "84:7"
    },
    {
      "text": "فَسَوْفَ يُحَاسَبُ حِسَاباٗ يَسِيراٗ ٨",
      "numberInSurah": 8,
      "verse_key": "84:8"
    },
    {
      "text": "وَيَنقَلِبُ إِلَيٰٓ أَهْلِهِۦ مَسْرُوراٗۖ ٩",
      "numberInSurah": 9,
      "verse_key": "84:9"
    },
    {
      "text": "وَأَمَّا مَنُ ا۟وتِيَ كِتَٰبَهُۥ وَرَآءَ ظَهْرِهِۦ ١٠",
      "numberInSurah": 10,
      "verse_key": "84:10"
    },
    {
      "text": "فَسَوْفَ يَدْعُواْ ثُبُوراٗ ١١",
      "numberInSurah": 11,
      "verse_key": "84:11"
    },
    {
      "text": "وَيُصَلَّيٰ سَعِيراًۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "84:12"
    },
    {
      "text": "اِنَّهُۥ كَانَ فِےٓ أَهْلِهِۦ مَسْرُوراًۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "84:13"
    },
    {
      "text": "اِنَّهُۥ ظَنَّ أَن لَّنْ يَّحُورَ ١٤",
      "numberInSurah": 14,
      "verse_key": "84:14"
    },
    {
      "text": "بَل۪يٰٓۖ إِنَّ رَبَّهُۥ كَانَ بِهِۦ بَصِيراٗۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "84:15"
    },
    {
      "text": "۞فَلَآ أُقْسِمُ بِالشَّفَقِ ١٦",
      "numberInSurah": 16,
      "verse_key": "84:16"
    },
    {
      "text": "وَاليْلِ وَمَا وَسَقَ ١٧",
      "numberInSurah": 17,
      "verse_key": "84:17"
    },
    {
      "text": "وَالْقَمَرِ إِذَا اَ۪تَّسَقَ ١٨",
      "numberInSurah": 18,
      "verse_key": "84:18"
    },
    {
      "text": "لَتَرْكَبُنَّ طَبَقاً عَن طَبَقٖۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "84:19"
    },
    {
      "text": "فَمَا لَهُمْ لَا يُومِنُونَ ٢٠",
      "numberInSurah": 20,
      "verse_key": "84:20"
    },
    {
      "text": "وَإِذَا قُرِۓَ عَلَيْهِمُ اُ۬لْقُرْءَانُ لَا يَسْجُدُونَ۩ۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "84:21"
    },
    {
      "text": "بَلِ اِ۬لذِينَ كَفَرُواْ يُكَذِّبُونَ ٢٢",
      "numberInSurah": 22,
      "verse_key": "84:22"
    },
    {
      "text": "وَاللَّهُ أَعْلَمُ بِمَا يُوعُونَۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "84:23"
    },
    {
      "text": "فَبَشِّرْهُم بِعَذَابٍ اَلِيمٍۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "84:24"
    },
    {
      "text": "اِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمُۥٓ أَجْرٌ غَيْرُ مَمْنُونٖۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "84:25"
    }
  ],
