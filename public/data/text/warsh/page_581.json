{
  "pageNumber": 581,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "أَلَمْ نَخْلُقكُّم مِّن مَّآءٖ مَّهِينٖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "77:20"
    },
    {
      "text": "فَجَعَلْنَٰهُ فِے قَر۪ارٖ مَّكِينٍ ٢١",
      "numberInSurah": 21,
      "verse_key": "77:21"
    },
    {
      "text": "اِلَيٰ قَدَرٖ مَّعْلُومٖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "77:22"
    },
    {
      "text": "فَقَدَّرْنَا فَنِعْمَ اَ۬لْقَٰدِرُونَۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "77:23"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "77:24"
    },
    {
      "text": "أَلَمْ نَجْعَلِ اِ۬لَارْضَ كِفَاتاً ٢٥",
      "numberInSurah": 25,
      "verse_key": "77:25"
    },
    {
      "text": "اَحْيَآءٗ وَأَمْوَٰتاٗ ٢٦",
      "numberInSurah": 26,
      "verse_key": "77:26"
    },
    {
      "text": "وَجَعَلْنَا فِيهَا رَوَٰسِيَ شَٰمِخَٰتٖ وَأَسْقَيْنَٰكُم مَّآءٗ فُرَاتاٗۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "77:27"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "77:28"
    },
    {
      "text": "اَ۪نطَلِقُوٓاْ إِلَيٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ ٢٩",
      "numberInSurah": 29,
      "verse_key": "77:29"
    },
    {
      "text": "اَ۪نطَلِقُوٓاْ إِلَيٰ ظِلّٖ ذِے ثَلَٰثِ شُعَبٖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "77:30"
    },
    {
      "text": "لَّا ظَلِيلٖ وَلَا يُغْنِے مِنَ اَ۬للَّهَبِۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "77:31"
    },
    {
      "text": "إِنَّهَا تَرْمِے بِشَرَرٖ كَالْقَصْرِ ٣٢",
      "numberInSurah": 32,
      "verse_key": "77:32"
    },
    {
      "text": "كَأَنَّهُۥ جِمَٰلَٰتٞ صُفْرٞۖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "77:33"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "77:34"
    },
    {
      "text": "هَٰذَا يَوْمُ لَا يَنطِقُونَ ٣٥",
      "numberInSurah": 35,
      "verse_key": "77:35"
    },
    {
      "text": "وَلَا يُوذَنُ لَهُمْ فَيَعْتَذِرُونَۖ ٣٦",
      "numberInSurah": 36,
      "verse_key": "77:36"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٣٧",
      "numberInSurah": 37,
      "verse_key": "77:37"
    },
    {
      "text": "هَٰذَا يَوْمُ اُ۬لْفَصْلِ جَمَعْنَٰكُمْ وَالَاوَّلِينَ ٣٨",
      "numberInSurah": 38,
      "verse_key": "77:38"
    },
    {
      "text": "فَإِن كَانَ لَكُمْ كَيْدٞ فَكِيدُونِۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "77:39"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٤٠",
      "numberInSurah": 40,
      "verse_key": "77:40"
    },
    {
      "text": "إِنَّ اَ۬لْمُتَّقِينَ فِے ظِلَٰلٖ وَعُيُونٖ ٤١",
      "numberInSurah": 41,
      "verse_key": "77:41"
    },
    {
      "text": "وَفَوَٰكِهَ مِمَّا يَشْتَهُونَۖ ٤٢",
      "numberInSurah": 42,
      "verse_key": "77:42"
    },
    {
      "text": "كُلُواْ وَاشْرَبُواْ هَنِيٓـٔاَۢ بِمَا كُنتُمْ تَعْمَلُونَۖ ٤٣",
      "numberInSurah": 43,
      "verse_key": "77:43"
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ٤٤",
      "numberInSurah": 44,
      "verse_key": "77:44"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٤٥",
      "numberInSurah": 45,
      "verse_key": "77:45"
    },
    {
      "text": "كُلُواْ وَتَمَتَّعُواْ قَلِيلاً اِنَّكُم مُّجْرِمُونَۖ ٤٦",
      "numberInSurah": 46,
      "verse_key": "77:46"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٤٧",
      "numberInSurah": 47,
      "verse_key": "77:47"
    },
    {
      "text": "وَإِذَا قِيلَ لَهُمُ اُ۪رْكَعُواْ لَا يَرْكَعُونَۖ ٤٨",
      "numberInSurah": 48,
      "verse_key": "77:48"
    },
    {
      "text": "وَيْلٞ يَوْمَئِذٖ لِّلْمُكَذِّبِينَۖ ٤٩",
      "numberInSurah": 49,
      "verse_key": "77:49"
    },
    {
      "text": "فَبِأَيِّ حَدِيثِۢ بَعْدَهُۥ يُومِنُونَۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "77:50"
    }
  ],
