{
  "pageNumber": 449,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَجَعَلْنَا ذُرِّيَّتَهُۥ هُمُ اُ۬لْبَاقِينَۖ ٧٧",
      "numberInSurah": 77,
      "verse_key": "37:77"
    },
    {
      "text": "وَتَرَكْنَا عَلَيْهِ فِے اِ۬لَاخِرِينَۖ ٧٨",
      "numberInSurah": 78,
      "verse_key": "37:78"
    },
    {
      "text": "سَلَٰمٌ عَلَيٰ نُوحٖ فِے اِ۬لْعَٰلَمِينَۖ ٧٩",
      "numberInSurah": 79,
      "verse_key": "37:79"
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ٨٠",
      "numberInSurah": 80,
      "verse_key": "37:80"
    },
    {
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا اَ۬لْمُومِنِينَۖ ٨١",
      "numberInSurah": 81,
      "verse_key": "37:81"
    },
    {
      "text": "ثُمَّ أَغْرَقْنَا اَ۬لَاخَرِينَۖ ٨٢",
      "numberInSurah": 82,
      "verse_key": "37:82"
    },
    {
      "text": "۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبْرَٰهِيمَ ٨٣",
      "numberInSurah": 83,
      "verse_key": "37:83"
    },
    {
      "text": "إِذْ جَآءَ رَبَّهُۥ بِقَلْبٖ سَلِيمٍ ٨٤",
      "numberInSurah": 84,
      "verse_key": "37:84"
    },
    {
      "text": "اِذْ قَالَ لِأَبِيهِ وَقَوْمِهِۦ مَاذَا تَعْبُدُونَۖ ٨٥",
      "numberInSurah": 85,
      "verse_key": "37:85"
    },
    {
      "text": "أَئِفْكاً اٰلِهَةٗ دُونَ اَ۬للَّهِ تُرِيدُونَۖ ٨٦",
      "numberInSurah": 86,
      "verse_key": "37:86"
    },
    {
      "text": "فَمَا ظَنُّكُم بِرَبِّ اِ۬لْعَٰلَمِينَۖ ٨٧",
      "numberInSurah": 87,
      "verse_key": "37:87"
    },
    {
      "text": "فَنَظَرَ نَظْرَةٗ فِے اِ۬لنُّجُومِ ٨٨",
      "numberInSurah": 88,
      "verse_key": "37:88"
    },
    {
      "text": "فَقَالَ إِنِّے سَقِيمٞ ٨٩",
      "numberInSurah": 89,
      "verse_key": "37:89"
    },
    {
      "text": "فَتَوَلَّوْاْ عَنْهُ مُدْبِرِينَۖ ٩٠",
      "numberInSurah": 90,
      "verse_key": "37:90"
    },
    {
      "text": "فَرَاغَ إِلَيٰٓ ءَالِهَتِهِمْ فَقَالَ أَلَا تَاكُلُونَ ٩١",
      "numberInSurah": 91,
      "verse_key": "37:91"
    },
    {
      "text": "مَا لَكُمْ لَا تَنطِقُونَۖ ٩٢",
      "numberInSurah": 92,
      "verse_key": "37:92"
    },
    {
      "text": "فَرَاغَ عَلَيْهِمْ ضَرْباَۢ بِالْيَمِينِ ٩٣",
      "numberInSurah": 93,
      "verse_key": "37:93"
    },
    {
      "text": "فَأَقْبَلُوٓاْ إِلَيْهِ يَزِفُّونَۖ ٩٤",
      "numberInSurah": 94,
      "verse_key": "37:94"
    },
    {
      "text": "قَالَ أَتَعْبُدُونَ مَا تَنْحِتُونَ ٩٥",
      "numberInSurah": 95,
      "verse_key": "37:95"
    },
    {
      "text": "وَاللَّهُ خَلَقَكُمْ وَمَا تَعْمَلُونَۖ ٩٦",
      "numberInSurah": 96,
      "verse_key": "37:96"
    },
    {
      "text": "قَالُواْ اُ۪بْنُواْ لَهُۥ بُنْيَٰناٗ فَأَلْقُوهُ فِے اِ۬لْجَحِيمِ ٩٧",
      "numberInSurah": 97,
      "verse_key": "37:97"
    },
    {
      "text": "فَأَرَادُواْ بِهِۦ كَيْداٗ فَجَعَلْنَٰهُمُ اُ۬لَاسْفَلِينَۖ ٩٨",
      "numberInSurah": 98,
      "verse_key": "37:98"
    },
    {
      "text": "وَقَالَ إِنِّے ذَاهِبٌ اِلَيٰ رَبِّے سَيَهْدِينِۖ ٩٩",
      "numberInSurah": 99,
      "verse_key": "37:99"
    },
    {
      "text": "رَبِّ هَبْ لِے مِنَ اَ۬لصَّٰلِحِينَۖ ١٠٠",
      "numberInSurah": 100,
      "verse_key": "37:100"
    },
    {
      "text": "فَبَشَّرْنَٰهُ بِغُلَٰمٍ حَلِيمٖۖ ١٠١",
      "numberInSurah": 101,
      "verse_key": "37:101"
    },
    {
      "text": "فَلَمَّا بَلَغَ مَعَهُ اُ۬لسَّعْيَ قَالَ يَٰبُنَيِّ إِنِّيَ أَر۪يٰ فِے اِ۬لْمَنَامِ أَنِّيَ أَذْبَحُكَ فَانظُرْ مَاذَا تَر۪يٰۖ قَالَ يَٰٓأَبَتِ اِ۪فْعَلْ مَا تُومَرُۖ سَتَجِدُنِيَ إِن شَآءَ اَ۬للَّهُ مِنَ اَ۬لصَّٰبِرِينَۖ ١٠٢",
      "numberInSurah": 102,
      "verse_key": "37:102"
    }
  ],
