{
  "pageNumber": 371,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "وَاجْعَل لِّے لِسَانَ صِدْقٖ فِے اِ۬لَاخِرِينَۖ ٨٤",
      "numberInSurah": 84,
      "verse_key": "26:84"
    },
    {
      "text": "وَاجْعَلْنِے مِنْ وَّرَثَةِ جَنَّةِ اِ۬لنَّعِيمِۖ ٨٥",
      "numberInSurah": 85,
      "verse_key": "26:85"
    },
    {
      "text": "وَاغْفِرْ لِأَبِيَ إِنَّهُۥ كَانَ مِنَ اَ۬لضَّآلِّينَۖ ٨٦",
      "numberInSurah": 86,
      "verse_key": "26:86"
    },
    {
      "text": "وَلَا تُخْزِنِے يَوْمَ يُبْعَثُونَ ٨٧",
      "numberInSurah": 87,
      "verse_key": "26:87"
    },
    {
      "text": "يَوْمَ لَا يَنفَعُ مَالٞ وَلَا بَنُونَ ٨٨",
      "numberInSurah": 88,
      "verse_key": "26:88"
    },
    {
      "text": "إِلَّا مَنَ اَتَي اَ۬للَّهَ بِقَلْبٖ سَلِيمٖۖ ٨٩",
      "numberInSurah": 89,
      "verse_key": "26:89"
    },
    {
      "text": "وَأُزْلِفَتِ اِ۬لْجَنَّةُ لِلْمُتَّقِينَۖ ٩٠",
      "numberInSurah": 90,
      "verse_key": "26:90"
    },
    {
      "text": "وَبُرِّزَتِ اِ۬لْجَحِيمُ لِلْغَاوِينَۖ ٩١",
      "numberInSurah": 91,
      "verse_key": "26:91"
    },
    {
      "text": "وَقِيلَ لَهُمُۥٓ أَيْنَ مَا كُنتُمْ تَعْبُدُونَ ٩٢",
      "numberInSurah": 92,
      "verse_key": "26:92"
    },
    {
      "text": "مِن دُونِ اِ۬للَّهِ هَلْ يَنصُرُونَكُمُۥٓ أَوْ يَنتَصِرُونَۖ ٩٣",
      "numberInSurah": 93,
      "verse_key": "26:93"
    },
    {
      "text": "فَكُبْكِبُواْ فِيهَا هُمْ وَالْغَاوُۥنَ ٩٤",
      "numberInSurah": 94,
      "verse_key": "26:94"
    },
    {
      "text": "وَجُنُودُ إِبْلِيسَ أَجْمَعُونَۖ ٩٥",
      "numberInSurah": 95,
      "verse_key": "26:95"
    },
    {
      "text": "قَالُواْ وَهُمْ فِيهَا يَخْتَصِمُونَ ٩٦",
      "numberInSurah": 96,
      "verse_key": "26:96"
    },
    {
      "text": "تَاللَّهِ إِن كُنَّا لَفِے ضَلَٰلٖ مُّبِينٍ ٩٧",
      "numberInSurah": 97,
      "verse_key": "26:97"
    },
    {
      "text": "اِذْ نُسَوِّيكُم بِرَبِّ اِ۬لْعَٰلَمِينَۖ ٩٨",
      "numberInSurah": 98,
      "verse_key": "26:98"
    },
    {
      "text": "وَمَآ أَضَلَّنَآ إِلَّا اَ۬لْمُجْرِمُونَۖ ٩٩",
      "numberInSurah": 99,
      "verse_key": "26:99"
    },
    {
      "text": "فَمَا لَنَا مِن شَٰفِعِينَ ١٠٠",
      "numberInSurah": 100,
      "verse_key": "26:100"
    },
    {
      "text": "وَلَا صَدِيقٍ حَمِيمٖۖ ١٠١",
      "numberInSurah": 101,
      "verse_key": "26:101"
    },
    {
      "text": "فَلَوَ اَنَّ لَنَا كَرَّةٗ فَنَكُونَ مِنَ اَ۬لْمُومِنِينَۖ ١٠٢",
      "numberInSurah": 102,
      "verse_key": "26:102"
    },
    {
      "text": "إِنَّ فِے ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكْثَرُهُم مُّومِنِينَۖ ١٠٣",
      "numberInSurah": 103,
      "verse_key": "26:103"
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ اَ۬لْعَزِيزُ اُ۬لرَّحِيمُۖ ١٠٤",
      "numberInSurah": 104,
      "verse_key": "26:104"
    },
    {
      "text": "كَذَّبَتْ قَوْمُ نُوحٍ اِ۬لْمُرْسَلِينَ ١٠٥",
      "numberInSurah": 105,
      "verse_key": "26:105"
    },
    {
      "text": "إِذْ قَالَ لَهُمُۥٓ أَخُوهُمْ نُوحٌ اَلَا تَتَّقُونَ ١٠٦",
      "numberInSurah": 106,
      "verse_key": "26:106"
    },
    {
      "text": "إِنِّے لَكُمْ رَسُولٌ اَمِينٞۖ ١٠٧",
      "numberInSurah": 107,
      "verse_key": "26:107"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١٠٨",
      "numberInSurah": 108,
      "verse_key": "26:108"
    },
    {
      "text": "وَمَآ أَسْـَٔلُكُمْ عَلَيْهِ مِنَ اَجْرٍۖ اِنَ اَجْرِيَ إِلَّا عَلَيٰ رَبِّ اِ۬لْعَٰلَمِينَۖ ١٠٩",
      "numberInSurah": 109,
      "verse_key": "26:109"
    },
    {
      "text": "فَاتَّقُواْ اُ۬للَّهَ وَأَطِيعُونِۖ ١١٠",
      "numberInSurah": 110,
      "verse_key": "26:110"
    },
    {
      "text": "۞قَالُوٓاْ أَنُومِنُ لَكَ وَاتَّبَعَكَ اَ۬لَارْذَلُونَۖ ١١١",
      "numberInSurah": 111,
      "verse_key": "26:111"
    }
  ],
