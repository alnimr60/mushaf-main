{
  "pageNumber": 577,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَمَا لَهُمْ عَنِ اِ۬لتَّذْكِرَةِ مُعْرِضِينَ ٤٨",
      "numberInSurah": 48,
      "verse_key": "74:48"
    },
    {
      "text": "كَأَنَّهُمْ حُمُرٞ مُّسْتَنفَرَةٞ ٤٩",
      "numberInSurah": 49,
      "verse_key": "74:49"
    },
    {
      "text": "فَرَّتْ مِن قَسْوَرَةِۢۖ ٥٠",
      "numberInSurah": 50,
      "verse_key": "74:50"
    },
    {
      "text": "بَلْ يُرِيدُ كُلُّ اُ۪مْرِےٕٖ مِّنْهُمُۥٓ أَنْ يُّوت۪يٰ صُحُفاٗ مُّنَشَّرَةٗۖ ٥١",
      "numberInSurah": 51,
      "verse_key": "74:51"
    },
    {
      "text": "كَلَّاۖ بَل لَّا يَخَافُونَ اَ۬لَاخِرَةَۖ ٥٢",
      "numberInSurah": 52,
      "verse_key": "74:52"
    },
    {
      "text": "كَلَّآ إِنَّهُۥ تَذْكِرَةٞۖ ٥٣",
      "numberInSurah": 53,
      "verse_key": "74:53"
    },
    {
      "text": "فَمَن شَآءَ ذَكَرَهُۥۖ ٥٤",
      "numberInSurah": 54,
      "verse_key": "74:54"
    },
    {
      "text": "وَمَا تَذْكُرُونَ إِلَّآ أَنْ يَّشَآءَ اَ۬للَّهُۖ هُوَ أَهْلُ اُ۬لتَّقْو۪يٰ وَأَهْلُ اُ۬لْمَغْفِرَةِۖ ٥٥",
      "numberInSurah": 55,
      "verse_key": "74:55"
    },
    {
      "text": "",
      "numberInSurah": 56,
      "verse_key": "74:56"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "لَآ أُقْسِمُ بِيَوْمِ اِ۬لْقِيَٰمَةِ ١",
      "numberInSurah": 1,
      "verse_key": "75:1"
    },
    {
      "text": "وَلَآ أُقْسِمُ بِالنَّفْسِ اِ۬للَّوَّامَةِۖ ٢",
      "numberInSurah": 2,
      "verse_key": "75:2"
    },
    {
      "text": "أَيَحْسِبُ اُ۬لِانسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ ٣",
      "numberInSurah": 3,
      "verse_key": "75:3"
    },
    {
      "text": "بَل۪يٰۖ قَٰدِرِينَ عَلَيٰٓ أَن نُّسَوِّيَ بَنَانَهُۥۖ ٤",
      "numberInSurah": 4,
      "verse_key": "75:4"
    },
    {
      "text": "بَلْ يُرِيدُ اُ۬لِانسَٰنُ لِيَفْجُرَ أَمَامَهُۥۖ ٥",
      "numberInSurah": 5,
      "verse_key": "75:5"
    },
    {
      "text": "يَسْـَٔلُ أَيَّانَ يَوْمُ اُ۬لْقِيَٰمَةِۖ ٦",
      "numberInSurah": 6,
      "verse_key": "75:6"
    },
    {
      "text": "فَإِذَا بَرَقَ اَ۬لْبَصَرُ ٧",
      "numberInSurah": 7,
      "verse_key": "75:7"
    },
    {
      "text": "وَخَسَفَ اَ۬لْقَمَرُ ٨",
      "numberInSurah": 8,
      "verse_key": "75:8"
    },
    {
      "text": "وَجُمِعَ اَ۬لشَّمْسُ وَالْقَمَرُ ٩",
      "numberInSurah": 9,
      "verse_key": "75:9"
    },
    {
      "text": "يَقُولُ اُ۬لِانسَٰنُ يَوْمَئِذٍ اَيْنَ اَ۬لْمَفَرُّۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "75:10"
    },
    {
      "text": "كَلَّا لَا وَزَرَۖ ١١",
      "numberInSurah": 11,
      "verse_key": "75:11"
    },
    {
      "text": "إِلَيٰ رَبِّكَ يَوْمَئِذٍ اِ۬لْمُسْتَقَرُّۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "75:12"
    },
    {
      "text": "يُنَبَّؤُاْ اُ۬لِانسَٰنُ يَوْمَئِذِۢ بِمَا قَدَّمَ وَأَخَّرَۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "75:13"
    },
    {
      "text": "بَلِ اِ۬لِانسَٰنُ عَلَيٰ نَفْسِهِۦ بَصِيرَةٞ ١٤",
      "numberInSurah": 14,
      "verse_key": "75:14"
    },
    {
      "text": "وَلَوَ اَلْق۪يٰ مَعَاذِيرَهُۥۖ ١٥",
      "numberInSurah": 15,
      "verse_key": "75:15"
    },
    {
      "text": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓۖ إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "75:16"
    },
    {
      "text": "فَإِذَا قَرَأْنَٰهُ فَاتَّبِعْ قُرْءَانَهُۥ ١٧",
      "numberInSurah": 17,
      "verse_key": "75:17"
    },
    {
      "text": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "75:18"
    },
    {
      "text": "كَلَّا بَلْ تُحِبُّونَ اَ۬لْعَاجِلَةَ ١٩",
      "numberInSurah": 19,
      "verse_key": "75:19"
    }
  ],
