{
  "pageNumber": 590,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالسَّمَآءِ ذَاتِ اِ۬لْبُرُوجِ ١",
      "numberInSurah": 1,
      "verse_key": "85:1"
    },
    {
      "text": "وَالْيَوْمِ اِ۬لْمَوْعُودِ ٢",
      "numberInSurah": 2,
      "verse_key": "85:2"
    },
    {
      "text": "وَشَاهِدٖ وَمَشْهُودٖ ٣",
      "numberInSurah": 3,
      "verse_key": "85:3"
    },
    {
      "text": "قُتِلَ أَصْحَٰبُ اُ۬لُاخْدُودِ ٤",
      "numberInSurah": 4,
      "verse_key": "85:4"
    },
    {
      "text": "اِ۬لنّ۪ارِ ذَاتِ اِ۬لْوَقُودِ ٥",
      "numberInSurah": 5,
      "verse_key": "85:5"
    },
    {
      "text": "إِذْ هُمْ عَلَيْهَا قُعُودٞ ٦",
      "numberInSurah": 6,
      "verse_key": "85:6"
    },
    {
      "text": "وَهُمْ عَلَيٰ مَا يَفْعَلُونَ بِالْمُومِنِينَ شُهُودٞۖ ٧",
      "numberInSurah": 7,
      "verse_key": "85:7"
    },
    {
      "text": "وَمَا نَقَمُواْ مِنْهُمُۥٓ إِلَّآ أَنْ يُّومِنُواْ بِاللَّهِ اِ۬لْعَزِيزِ اِ۬لْحَمِيدِ ٨",
      "numberInSurah": 8,
      "verse_key": "85:8"
    },
    {
      "text": "اِ۬لذِے لَهُۥ مُلْكُ اُ۬لسَّمَٰوَٰتِ وَالَارْضِۖ وَاللَّهُ عَلَيٰ كُلِّ شَےْءٖ شَهِيدٌۖ ٩",
      "numberInSurah": 9,
      "verse_key": "85:9"
    },
    {
      "text": "اِنَّ اَ۬لذِينَ فَتَنُواْ اُ۬لْمُومِنِينَ وَالْمُومِنَٰتِ ثُمَّ لَمْ يَتُوبُواْ فَلَهُمْ عَذَابُ جَهَنَّمَ وَلَهُمْ عَذَابُ اُ۬لْحَرِيقِۖ ١٠",
      "numberInSurah": 10,
      "verse_key": "85:10"
    },
    {
      "text": "إِنَّ اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ لَهُمْ جَنَّٰتٞ تَجْرِے مِن تَحْتِهَا اَ۬لَانْهَٰرُۖ ذَٰلِكَ اَ۬لْفَوْزُ اُ۬لْكَبِيرُۖ ١١",
      "numberInSurah": 11,
      "verse_key": "85:11"
    },
    {
      "text": "۞إِنَّ بَطْشَ رَبِّكَ لَشَدِيدٌۖ ١٢",
      "numberInSurah": 12,
      "verse_key": "85:12"
    },
    {
      "text": "اِنَّهُۥ هُوَ يُبْدِۓُ وَيُعِيدُۖ ١٣",
      "numberInSurah": 13,
      "verse_key": "85:13"
    },
    {
      "text": "وَهُوَ اَ۬لْغَفُورُ اُ۬لْوَدُودُ ١٤",
      "numberInSurah": 14,
      "verse_key": "85:14"
    },
    {
      "text": "ذُو اُ۬لْعَرْشِ اِ۬لْمَجِيدُ ١٥",
      "numberInSurah": 15,
      "verse_key": "85:15"
    },
    {
      "text": "فَعَّالٞ لِّمَا يُرِيدُۖ ١٦",
      "numberInSurah": 16,
      "verse_key": "85:16"
    },
    {
      "text": "هَلَ اَت۪يٰكَ حَدِيثُ اُ۬لْجُنُودِ ١٧",
      "numberInSurah": 17,
      "verse_key": "85:17"
    },
    {
      "text": "فِرْعَوْنَ وَثَمُودَۖ ١٨",
      "numberInSurah": 18,
      "verse_key": "85:18"
    },
    {
      "text": "بَلِ اِ۬لذِينَ كَفَرُواْ فِے تَكْذِيبٖ ١٩",
      "numberInSurah": 19,
      "verse_key": "85:19"
    },
    {
      "text": "وَاللَّهُ مِنْ وَّرَآئِهِم مُّحِيطُۢۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "85:20"
    },
    {
      "text": "بَلْ هُوَ قُرْءَانٞ مَّجِيدٞ ٢١",
      "numberInSurah": 21,
      "verse_key": "85:21"
    },
    {
      "text": "فِے لَوْحٖ مَّحْفُوظٞۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "85:22"
    }
  ],
