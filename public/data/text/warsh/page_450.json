{
  "pageNumber": 450,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "فَلَمَّآ أَسْلَمَا وَتَلَّهُۥ لِلْجَبِينِ ١٠٣",
      "numberInSurah": 103,
      "verse_key": "37:103"
    },
    {
      "text": "وَنَٰدَيْنَٰهُ أَنْ يَّٰٓإِبْرَٰهِيمُ ١٠٤",
      "numberInSurah": 104,
      "verse_key": "37:104"
    },
    {
      "text": "قَدْ صَدَّقْتَ اَ۬لرُّءْي۪آۖ إِنَّا كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ١٠٥",
      "numberInSurah": 105,
      "verse_key": "37:105"
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ اَ۬لْبَلَٰٓؤُاْ اُ۬لْمُبِينُۖ ١٠٦",
      "numberInSurah": 106,
      "verse_key": "37:106"
    },
    {
      "text": "وَفَدَيْنَٰهُ بِذِبْحٍ عَظِيمٖۖ ١٠٧",
      "numberInSurah": 107,
      "verse_key": "37:107"
    },
    {
      "text": "وَتَرَكْنَا عَلَيْهِ فِے اِ۬لَاخِرِينَۖ ١٠٨",
      "numberInSurah": 108,
      "verse_key": "37:108"
    },
    {
      "text": "سَلَٰمٌ عَلَيٰٓ إِبْرَٰهِيمَۖ ١٠٩",
      "numberInSurah": 109,
      "verse_key": "37:109"
    },
    {
      "text": "كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ١١٠",
      "numberInSurah": 110,
      "verse_key": "37:110"
    },
    {
      "text": "إِنَّهُۥ مِنْ عِبَادِنَا اَ۬لْمُومِنِينَۖ ١١١",
      "numberInSurah": 111,
      "verse_key": "37:111"
    },
    {
      "text": "وَبَشَّرْنَٰهُ بِإِسْحَٰقَ نَبِيٓـٔاٗ مِّنَ اَ۬لصَّٰلِحِينَ ١١٢",
      "numberInSurah": 112,
      "verse_key": "37:112"
    },
    {
      "text": "وَبَٰرَكْنَا عَلَيْهِ وَعَلَيٰٓ إِسْحَٰقَۖ وَمِن ذُرِّيَّتِهِمَا مُحْسِنٞ وَظَالِمٞ لِّنَفْسِهِۦ مُبِينٞۖ ١١٣",
      "numberInSurah": 113,
      "verse_key": "37:113"
    },
    {
      "text": "۞وَلَقَدْ مَنَنَّا عَلَيٰ مُوس۪يٰ وَهَٰرُونَ ١١٤",
      "numberInSurah": 114,
      "verse_key": "37:114"
    },
    {
      "text": "وَنَجَّيْنَٰهُمَا وَقَوْمَهُمَا مِنَ اَ۬لْكَرْبِ اِ۬لْعَظِيمِۖ ١١٥",
      "numberInSurah": 115,
      "verse_key": "37:115"
    },
    {
      "text": "وَنَصَرْنَٰهُمْ فَكَانُواْ هُمُ اُ۬لْغَٰلِبِينَۖ ١١٦",
      "numberInSurah": 116,
      "verse_key": "37:116"
    },
    {
      "text": "وَءَاتَيْنَٰهُمَا اَ۬لْكِتَٰبَ اَ۬لْمُسْتَبِينَۖ ١١٧",
      "numberInSurah": 117,
      "verse_key": "37:117"
    },
    {
      "text": "وَهَدَيْنَٰهُمَا اَ۬لصِّرَٰطَ اَ۬لْمُسْتَقِيمَۖ ١١٨",
      "numberInSurah": 118,
      "verse_key": "37:118"
    },
    {
      "text": "وَتَرَكْنَا عَلَيْهِمَا فِے اِ۬لَاخِرِينَۖ ١١٩",
      "numberInSurah": 119,
      "verse_key": "37:119"
    },
    {
      "text": "سَلَٰمٌ عَلَيٰ مُوس۪يٰ وَهَٰرُونَۖ ١٢٠",
      "numberInSurah": 120,
      "verse_key": "37:120"
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجْزِے اِ۬لْمُحْسِنِينَۖ ١٢١",
      "numberInSurah": 121,
      "verse_key": "37:121"
    },
    {
      "text": "إِنَّهُمَا مِنْ عِبَادِنَا اَ۬لْمُومِنِينَۖ ١٢٢",
      "numberInSurah": 122,
      "verse_key": "37:122"
    },
    {
      "text": "وَإِنَّ إِلْيَاسَ لَمِنَ اَ۬لْمُرْسَلِينَ ١٢٣",
      "numberInSurah": 123,
      "verse_key": "37:123"
    },
    {
      "text": "إِذْ قَالَ لِقَوْمِهِۦٓ أَلَا تَتَّقُونَ ١٢٤",
      "numberInSurah": 124,
      "verse_key": "37:124"
    },
    {
      "text": "أَتَدْعُونَ بَعْلاٗ وَتَذَرُونَ أَحْسَنَ اَ۬لْخَٰلِقِينَۖ ١٢٥",
      "numberInSurah": 125,
      "verse_key": "37:125"
    },
    {
      "text": "اَ۬للَّهُ رَبُّكُمْ وَرَبُّ ءَابَآئِكُمُ اُ۬لَاوَّلِينَۖ ١٢٦",
      "numberInSurah": 126,
      "verse_key": "37:126"
    }
  ],
