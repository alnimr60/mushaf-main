{
  "pageNumber": 601,
  "riwayaId": "warsh",
  "ayahs": [
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَالْعَصْرِ إِنَّ اَ۬لِانسَٰنَ لَفِے خُسْرٍ ١",
      "numberInSurah": 1,
      "verse_key": "103:1"
    },
    {
      "text": "اِلَّا اَ۬لذِينَ ءَامَنُواْ وَعَمِلُواْ اُ۬لصَّٰلِحَٰتِ وَتَوَاصَوْاْ بِالْحَقِّ ٢",
      "numberInSurah": 2,
      "verse_key": "103:2"
    },
    {
      "text": "وَتَوَاصَوْاْ بِالصَّبْرِۖ ٣",
      "numberInSurah": 3,
      "verse_key": "103:3"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "وَيْلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ ١",
      "numberInSurah": 1,
      "verse_key": "104:1"
    },
    {
      "text": "اِ۬لذِے جَمَعَ مَالاٗ وَعَدَّدَهُۥ ٢",
      "numberInSurah": 2,
      "verse_key": "104:2"
    },
    {
      "text": "يَحْسِبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ ٣",
      "numberInSurah": 3,
      "verse_key": "104:3"
    },
    {
      "text": "كَلَّاۖ لَيُنۢبَذَنَّ فِے اِ۬لْحُطَمَةِۖ ٤",
      "numberInSurah": 4,
      "verse_key": "104:4"
    },
    {
      "text": "وَمَآ أَدْر۪يٰكَ مَا اَ۬لْحُطَمَةُۖ ٥",
      "numberInSurah": 5,
      "verse_key": "104:5"
    },
    {
      "text": "نَارُ اُ۬للَّهِ اِ۬لْمُوقَدَةُ ٦",
      "numberInSurah": 6,
      "verse_key": "104:6"
    },
    {
      "text": "اُ۬لتِے تَطَّلِعُ عَلَي اَ۬لَافْـِٕدَةِۖ ٧",
      "numberInSurah": 7,
      "verse_key": "104:7"
    },
    {
      "text": "إِنَّهَا عَلَيْهِم مُّوصَدَةٞ ٨",
      "numberInSurah": 8,
      "verse_key": "104:8"
    },
    {
      "text": "فِے عَمَدٖ مُّمَدَّدَةٍۖ ٩",
      "numberInSurah": 9,
      "verse_key": "104:9"
    },
    {
      "text": "بِسْمِ اِ۬للَّهِ اِ۬لرَّحْمَٰنِ اِ۬لرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "اَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ اِ۬لْفِيلِۖ ١",
      "numberInSurah": 1,
      "verse_key": "105:1"
    },
    {
      "text": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِے تَضْلِيلٖ ٢",
      "numberInSurah": 2,
      "verse_key": "105:2"
    },
    {
      "text": "وَأَرْسَلَ عَلَيْهِمْ طَيْراً اَبَابِيلَ ٣",
      "numberInSurah": 3,
      "verse_key": "105:3"
    },
    {
      "text": "تَرْمِيهِم بِحِجَارَةٖ مِّن سِجِّيلٖ ٤",
      "numberInSurah": 4,
      "verse_key": "105:4"
    },
    {
      "text": "فَجَعَلَهُمْ كَعَصْفٖ مَّاكُولٖۖ ٥",
      "numberInSurah": 5,
      "verse_key": "105:5"
    }
  ],
