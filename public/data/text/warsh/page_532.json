      "verse_key": "55:18"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ١٩",
      "numberInSurah": 19,
      "verse_key": "55:19"
    },
    {
      "text": "يُخْرَجُ مِنْهُمَا اَ۬للُّؤْلُؤُاْ وَالْمَرْجَانُۖ ٢٠",
      "numberInSurah": 20,
      "verse_key": "55:20"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٢١",
      "numberInSurah": 21,
      "verse_key": "55:21"
    },
    {
      "text": "وَلَهُ اُ۬لْجَوَارِ اِ۬لْمُنشَأَٰتُ فِے اِ۬لْبَحْرِ كَالَاعْلَٰمِۖ ٢٢",
      "numberInSurah": 22,
      "verse_key": "55:22"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٢٣",
      "numberInSurah": 23,
      "verse_key": "55:23"
    },
    {
      "text": "كُلُّ مَنْ عَلَيْهَا فَانٖ ٢٤",
      "numberInSurah": 24,
      "verse_key": "55:24"
    },
    {
      "text": "وَيَبْق۪يٰ وَجْهُ رَبِّكَ ذُو اُ۬لْجَلَٰلِ وَالِاكْرَامِۖ ٢٥",
      "numberInSurah": 25,
      "verse_key": "55:25"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٢٦",
      "numberInSurah": 26,
      "verse_key": "55:26"
    },
    {
      "text": "يَسْـَٔلُهُۥ مَن فِے اِ۬لسَّمَٰوَٰتِ وَالَارْضِۖ كُلَّ يَوْمٍ هُوَ فِے شَأْنٖۖ ٢٧",
      "numberInSurah": 27,
      "verse_key": "55:27"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٢٨",
      "numberInSurah": 28,
      "verse_key": "55:28"
    },
    {
      "text": "سَنَفْرُغُ لَكُمُۥٓ أَيُّهَ اَ۬لثَّقَلَٰنِۖ ٢٩",
      "numberInSurah": 29,
      "verse_key": "55:29"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٣٠",
      "numberInSurah": 30,
      "verse_key": "55:30"
    },
    {
      "text": "يَٰمَعْشَرَ اَ۬لْجِنِّ وَالِانسِ إِنِ اِ۪سْتَطَعْتُمُۥٓ أَن تَنفُذُواْ مِنَ اَقْط۪ارِ اِ۬لسَّمَٰوَٰتِ وَالَارْضِ فَانفُذُواْۖ لَا تَنفُذُونَ إِلَّا بِسُلْطَٰنٖۖ ٣١",
      "numberInSurah": 31,
      "verse_key": "55:31"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٣٢",
      "numberInSurah": 32,
      "verse_key": "55:32"
    },
    {
      "text": "يُرْسَلُ عَلَيْكُمَا شُوَاظٞ مِّن نّ۪ارٖ ٣٣",
      "numberInSurah": 33,
      "verse_key": "55:33"
    },
    {
      "text": "وَنُحَاسٞ فَلَا تَنتَصِرَٰنِۖ ٣٤",
      "numberInSurah": 34,
      "verse_key": "55:34"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٣٥",
      "numberInSurah": 35,
      "verse_key": "55:35"
    },
    {
      "text": "فَإِذَا اَ۪نشَقَّتِ اِ۬لسَّمَآءُ فَكَانَتْ وَرْدَةٗ كَالدِّهَانِ ٣٦",
      "numberInSurah": 36,
      "verse_key": "55:36"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِ ٣٧",
      "numberInSurah": 37,
      "verse_key": "55:37"
    },
    {
      "text": "فَيَوْمَئِذٖ لَّا يُسْـَٔلُ عَن ذَنۢبِهِۦٓ إِنسٞ وَلَا جَآنّٞۖ ٣٨",
      "numberInSurah": 38,
      "verse_key": "55:38"
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكُمَا تُكَذِّبَانِۖ ٣٩",
      "numberInSurah": 39,
      "verse_key": "55:39"
    },
    {
