  "pageNumber": 590,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ لَهُمُۥ أَجۡرٌ غَيۡرُ مَمۡنُونِۭ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "سُورَةُ البُرُوجِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلسَّمَآءِ ذَاتِ ٱلۡبُرُوجِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَٱلۡيَوۡمِ ٱلۡمَوۡعُودِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَشَاهِدٖ وَمَشۡهُودٖ ٣",
      "numberInSurah": 3
    },
    {
      "text": "قُتِلَ أَصۡحَٰبُ ٱلۡأُخۡدُودِ ٤",
      "numberInSurah": 4
    },
    {
      "text": "ٱلنَّارِ ذَاتِ ٱلۡوَقُودِ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِذۡ هُمُۥ عَلَيۡهَا قُعُودٞ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَهُمُۥ عَلَىٰ مَا يَفۡعَلُونَ بِٱلۡمُؤۡمِنِينَ شُهُودٞ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَمَا نَقَمُواْ مِنۡهُمُۥ إِلَّا أَن يُؤۡمِنُواْ بِٱللَّهِ ٱلۡعَزِيزِ ٱلۡحَمِيدِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "ٱلَّذِي لَهُۥ مُلۡكُ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِۚ وَٱللَّهُ عَلَىٰ كُلِّ شَيۡءٖ شَهِيدٌ ٩",
      "numberInSurah": 9
    },
    {
      "text": "إِنَّ ٱلَّذِينَ فَتَنُواْ ٱلۡمُؤۡمِنِينَ وَٱلۡمُؤۡمِنَٰتِ ثُمَّ لَمۡ يَتُوبُواْ فَلَهُمُۥ عَذَابُ جَهَنَّمَ وَلَهُمُۥ عَذَابُ ٱلۡحَرِيقِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "إِنَّ ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّٰلِحَٰتِ لَهُمُۥ جَنَّٰتٞ تَجۡرِي مِن تَحۡتِهَا ٱلۡأَنۡهَٰرُۚ ذَٰلِكَ ٱلۡفَوۡزُ ٱلۡكَبِيرُ ١١",
      "numberInSurah": 11
    },
    {
      "text": "إِنَّ بَطۡشَ رَبِّكَ لَشَدِيدٌ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّهُۥ هُوَ يُبۡدِئُ وَيُعِيدُ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَهُوَ ٱلۡغَفُورُ ٱلۡوَدُودُ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "ذُو ٱلۡعَرۡشِ ٱلۡمَجِيدُ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "فَعَّالٞ لِّمَا يُرِيدُ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ ٱلۡجُنُودِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "فِرۡعَوۡنَ وَثَمُودَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "بَلِ ٱلَّذِينَ كَفَرُواْ فِي تَكۡذِيبٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "وَٱللَّهُ مِن وَرَآئِهِمُۥ مُحِيطُۢ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "بَلۡ هُوَ قُرَانٞ مَّجِيدٞ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "فِي لَوۡحٖ مَّحۡفُوظِۭ ٢٢",
      "numberInSurah": 22
    }
  ]
