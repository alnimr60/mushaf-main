{
  "pageNumber": 594,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَجِاْيٓءَ يَوۡمَئِذِۭ بِجَهَنَّمَ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "يَوۡمَئِذٖ يَتَذَكَّرُ ٱلۡإِنسَٰنُ وَأَنَّىٰ لَهُ ٱلذِّكۡرَىٰ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَقُولُ يَٰلَيۡتَنِي قَدَّمۡتُ لِحَيَاتِي ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "فَيَوۡمَئِذٖ لَّا يُعَذِّبُ عَذَابَهُۥ أَحَدٞ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَلَا يُوثِقُ وَثَاقَهُۥ أَحَدٞ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "يَٰأَيَّتُهَا ٱلنَّفۡسُ ٱلۡمُطۡمَئِنَّةُ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "ٱرۡجِعِي إِلَىٰ رَبِّكِ رَاضِيَةٗ مَّرۡضِيَّةٗ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "فَٱدۡخُلِي فِي عِبَٰدِي وَٱدۡخُلِي جَنَّتِي ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "سُورَةُ البَلَدِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ لَا أُقۡسِمُ بِهَٰذَا ٱلۡبَلَدِ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَأَنتَ حِلُّۢ بِهَٰذَا ٱلۡبَلَدِ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَوَالِدٖ وَمَا وَلَدَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "لَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ فِي كَبَدٍ ٤",
      "numberInSurah": 4
    },
    {
      "text": "أَيَحۡسِبُ أَن لَّن يَقۡدِرَ عَلَيۡهِۦ أَحَدٞ ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَقُولُ أَهۡلَكۡتُ مَالٗا لُّبَدًا ٦",
      "numberInSurah": 6
    },
    {
      "text": "أَيَحۡسِبُ أَن لَّمۡ يَرَهُۥ أَحَدٌ ٧",
      "numberInSurah": 7
    },
    {
      "text": "أَلَمۡ نَجۡعَل لَّهُۥ عَيۡنَيۡنِ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَلِسَانٗا وَشَفَتَيۡنِ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَهَدَيۡنَٰهُ ٱلنَّجۡدَيۡنِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "فَلَا ٱقۡتَحَمَ ٱلۡعَقَبَةَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَمَا أَدۡرَىٰكَ مَا ٱلۡعَقَبَةُ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَكَّ رَقَبَةً ١٣",
      "numberInSurah": 13
    },
    {
      "text": "أَوۡ أَطۡعَمَ فِي يَوۡمٖ ذِي مَسۡغَبَةٖ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "يَتِيمٗا ذَا مَقۡرَبَةٍ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "أَوۡ مِسۡكِينٗا ذَا مَتۡرَبَةٖ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "ثُمَّ كَانَ مِنَ ٱلَّذِينَ ءَامَنُواْ وَتَوَاصَوۡاْ بِٱلصَّبۡرِ وَتَوَاصَوۡاْ بِٱلۡمَرۡحَمَةِ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "أُوْلَٰٓئِكَ أَصۡحَٰبُ ٱلۡمَيۡمَنَةِ ١٨",
      "numberInSurah": 18
    }
  ]
}
