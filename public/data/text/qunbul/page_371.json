{
  "pageNumber": 371,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَٱجۡعَل لِّي لِسَانَ صِدۡقٖ فِي ٱلۡأٓخِرِينَ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "وَٱجۡعَلۡنِي مِن وَرَثَةِ جَنَّةِ ٱلنَّعِيمِ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "وَٱغۡفِرۡ لِأَبِي إِنَّهُۥ كَانَ مِنَ ٱلضَّآلِّينَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "وَلَا تُخۡزِنِي يَوۡمَ يُبۡعَثُونَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "يَوۡمَ لَا يَنفَعُ مَالٞ وَلَا بَنُونَ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "إِلَّا مَنۡ أَتَى ٱللَّهَ بِقَلۡبٖ سَلِيمٖ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "وَأُزۡلِفَتِ ٱلۡجَنَّةُ لِلۡمُتَّقِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "وَبُرِّزَتِ ٱلۡجَحِيمُ لِلۡغَاوِينَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "وَقِيلَ لَهُمُۥ أَيۡنَ مَا كُنتُمُۥ تَعۡبُدُونَ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "مِن دُونِ ٱللَّهِ هَلۡ يَنصُرُونَكُمُۥ أَوۡ يَنتَصِرُونَ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَكُبۡكِبُواْ فِيهَا هُمُۥ وَٱلۡغَاوُۥنَ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "وَجُنُودُ إِبۡلِيسَ أَجۡمَعُونَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "قَالُواْ وَهُمُۥ فِيهَا يَخۡتَصِمُونَ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "تَٱللَّهِ إِن كُنَّا لَفِي ضَلَٰلٖ مُّبِينٍ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "إِذۡ نُسَوِّيكُمُۥ بِرَبِّ ٱلۡعَٰلَمِينَ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "وَمَا أَضَلَّنَا إِلَّا ٱلۡمُجۡرِمُونَ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "فَمَا لَنَا مِن شَٰفِعِينَ ١٠٠",
      "numberInSurah": 100
    },
    {
      "text": "وَلَا صَدِيقٍ حَمِيمٖ ١٠١",
      "numberInSurah": 101
    },
    {
      "text": "فَلَوۡ أَنَّ لَنَا كَرَّةٗ فَنَكُونَ مِنَ ٱلۡمُؤۡمِنِينَ ١٠٢",
      "numberInSurah": 102
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُمُۥ مُؤۡمِنِينَ ١٠٣",
      "numberInSurah": 103
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ١٠٤",
      "numberInSurah": 104
    },
    {
      "text": "كَذَّبَتۡ قَوۡمُ نُوحٍ ٱلۡمُرۡسَلِينَ ١٠٥",
      "numberInSurah": 105
    },
    {
      "text": "إِذۡ قَالَ لَهُمُۥ أَخُوهُمُۥ نُوحٌ أَلَا تَتَّقُونَ ١٠٦",
      "numberInSurah": 106
    },
    {
      "text": "إِنِّي لَكُمُۥ رَسُولٌ أَمِينٞ ١٠٧",
      "numberInSurah": 107
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١٠٨",
      "numberInSurah": 108
    },
    {
      "text": "وَمَا أَسۡـَٔلُكُمُۥ عَلَيۡهِۦ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِي إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ ١٠٩",
      "numberInSurah": 109
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١١٠",
      "numberInSurah": 110
    },
    {
      "text": "۞قَالُواْ أَنُؤۡمِنُ لَكَ وَٱتَّبَعَكَ ٱلۡأَرۡذَلُونَ ١١١",
      "numberInSurah": 111
    }
  ]
}
