{
  "pageNumber": 528,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَأَنَّهُۥ خَلَقَ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "مِن نُّطۡفَةٍ إِذَا تُمۡنَىٰ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "وَأَنَّ عَلَيۡهِ ٱلنَّشَآءَةَ ٱلۡأُخۡرَىٰ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "وَأَنَّهُۥ هُوَ أَغۡنَىٰ وَأَقۡنَىٰ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَأَنَّهُۥ هُوَ رَبُّ ٱلشِّعۡرَىٰ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَأَنَّهُۥ أَهۡلَكَ عَادًا ٱلۡأُولَىٰ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "وَثَمُودٗا فَمَا أَبۡقَىٰ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "وَقَوۡمَ نُوحٖ مِّن قَبۡلُۖ إِنَّهُمُۥ كَانُواْ هُمُۥ أَظۡلَمَ وَأَطۡغَىٰ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "وَٱلۡمُؤۡتَفِكَةَ أَهۡوَىٰ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "فَغَشَّىٰهَا مَا غَشَّىٰ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "فَبِأَيِّ ءَالَآءِ رَبِّكَ تَتَمَارَىٰ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "هَٰذَا نَذِيرٞ مِّنَ ٱلنُّذُرِ ٱلۡأُولَىٰ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "أَزِفَتِ ٱلۡأٓزِفَةُ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "لَيۡسَ لَهَا مِن دُونِ ٱللَّهِ كَاشِفَةٌ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "أَفَمِنۡ هَٰذَا ٱلۡحَدِيثِ تَعۡجَبُونَ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "وَتَضۡحَكُونَ وَلَا تَبۡكُونَ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "وَأَنتُمُۥ سَٰمِدُونَ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "فَٱسۡجُدُواْۤ لِلَّهِۤ وَٱعۡبُدُواْ۩ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "سُورَةُ القَمَرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ ٱقۡتَرَبَتِ ٱلسَّاعَةُ وَٱنشَقَّ ٱلۡقَمَرُ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِن يَرَوۡاْ ءَايَةٗ يُعۡرِضُواْ وَيَقُولُواْ سِحۡرٞ مُّسۡتَمِرّٞ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَكَذَّبُواْ وَٱتَّبَعُواْ أَهۡوَآءَهُمُۥۚ وَكُلُّ أَمۡرٖ مُّسۡتَقِرّٞ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَلَقَدۡ جَآءَهُمُۥ مِنَ ٱلۡأَنۢبَآءِ مَا فِيهِۦ مُزۡدَجَرٌ ٤",
      "numberInSurah": 4
    },
    {
      "text": "حِكۡمَةُۢ بَٰلِغَةٞۖ فَمَا تُغۡنِ ٱلنُّذُرُ ٥",
      "numberInSurah": 5
    },
    {
      "text": "فَتَوَلَّ عَنۡهُمُۥۘ يَوۡمَ يَدۡعُ ٱلدَّاعِ إِلَىٰ شَيۡءٖ نُّكۡرٍ ٦",
      "numberInSurah": 6
    }
  ]
}
