{
  "pageNumber": 342,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ",
      "numberInSurah": 0
    },
    {
      "text": "قَدۡ أَفۡلَحَ ٱلۡمُؤۡمِنُونَ ١",
      "numberInSurah": 1
    },
    {
      "text": "ٱلَّذِينَ هُمُۥ فِي صَلَاتِهِمُۥ خَٰشِعُونَ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ عَنِ ٱللَّغۡوِ مُعۡرِضُونَ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ لِلزَّكَوٰةِ فَٰعِلُونَ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ لِفُرُوجِهِمُۥ حَٰفِظُونَ ٥",
      "numberInSurah": 5
    },
    {
      "text": "إِلَّا عَلَىٰ أَزۡوَٰجِهِمُۥ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمُۥ فَإِنَّهُمُۥ غَيۡرُ مَلُومِينَ ٦",
      "numberInSurah": 6
    },
    {
      "text": "فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ ٱلۡعَادُونَ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ لِأَمَٰنَتِهِمُۥ وَعَهۡدِهِمُۥ رَٰعُونَ ٨",
      "numberInSurah": 8
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ عَلَىٰ صَلَوَٰتِهِمُۥ يُحَافِظُونَ ٩",
      "numberInSurah": 9
    },
    {
      "text": "أُوْلَٰٓئِكَ هُمُ ٱلۡوَٰرِثُونَ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "ٱلَّذِينَ يَرِثُونَ ٱلۡفِرۡدَوۡسَ هُمُۥ فِيهَا خَٰلِدُونَ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَلَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ مِن سُلَٰلَةٖ مِّن طِينٖ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "ثُمَّ جَعَلۡنَٰهُۥ نُطۡفَةٗ فِي قَرَارٖ مَّكِينٖ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "ثُمَّ خَلَقۡنَا ٱلنُّطۡفَةَ عَلَقَةٗ فَخَلَقۡنَا ٱلۡعَلَقَةَ مُضۡغَةٗ فَخَلَقۡنَا ٱلۡمُضۡغَةَ عِظَٰمٗا فَكَسَوۡنَا ٱلۡعِظَٰمَ لَحۡمٗا ثُمَّ أَنشَأۡنَٰهُۥ خَلۡقًا ءَاخَرَۚ فَتَبَارَكَ ٱللَّهُ أَحۡسَنُ ٱلۡخَٰلِقِينَ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "ثُمَّ إِنَّكُمُۥ بَعۡدَ ذَٰلِكَ لَمَيِّتُونَ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ثُمَّ إِنَّكُمُۥ يَوۡمَ ٱلۡقِيَٰمَةِ تُبۡعَثُونَ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَلَقَدۡ خَلَقۡنَا فَوۡقَكُمُۥ سَبۡعَ طَرَآئِقَ وَمَا كُنَّا عَنِ ٱلۡخَلۡقِ غَٰفِلِينَ ١٧",
      "numberInSurah": 17
    }
  ]
}
