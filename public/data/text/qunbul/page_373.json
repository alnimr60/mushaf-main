{
  "pageNumber": 373,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "إِنۡ هَٰذَا إِلَّا خَلۡقُ ٱلۡأَوَّلِينَ ١٣٧",
      "numberInSurah": 137
    },
    {
      "text": "وَمَا نَحۡنُ بِمُعَذَّبِينَ ١٣٨",
      "numberInSurah": 138
    },
    {
      "text": "فَكَذَّبُوهُۥ فَأَهۡلَكۡنَٰهُمُۥۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُمُۥ مُؤۡمِنِينَ ١٣٩",
      "numberInSurah": 139
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ١٤٠",
      "numberInSurah": 140
    },
    {
      "text": "كَذَّبَتۡ ثَمُودُ ٱلۡمُرۡسَلِينَ ١٤١",
      "numberInSurah": 141
    },
    {
      "text": "إِذۡ قَالَ لَهُمُۥ أَخُوهُمُۥ صَٰلِحٌ أَلَا تَتَّقُونَ ١٤٢",
      "numberInSurah": 142
    },
    {
      "text": "إِنِّي لَكُمُۥ رَسُولٌ أَمِينٞ ١٤٣",
      "numberInSurah": 143
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١٤٤",
      "numberInSurah": 144
    },
    {
      "text": "وَمَا أَسۡـَٔلُكُمُۥ عَلَيۡهِۦ مِنۡ أَجۡرٍۖ إِنۡ أَجۡرِي إِلَّا عَلَىٰ رَبِّ ٱلۡعَٰلَمِينَ ١٤٥",
      "numberInSurah": 145
    },
    {
      "text": "أَتُتۡرَكُونَ فِي مَا هَٰهُنَا ءَامِنِينَ ١٤٦",
      "numberInSurah": 146
    },
    {
      "text": "فِي جَنَّٰتٖ وَعِيُونٖ ١٤٧",
      "numberInSurah": 147
    },
    {
      "text": "وَزُرُوعٖ وَنَخۡلٖ طَلۡعُهَا هَضِيمٞ ١٤٨",
      "numberInSurah": 148
    },
    {
      "text": "وَتَنۡحِتُونَ مِنَ ٱلۡجِبَالِ بِيُوتٗا فَرِهِينَ ١٤٩",
      "numberInSurah": 149
    },
    {
      "text": "فَٱتَّقُواْ ٱللَّهَ وَأَطِيعُونِ ١٥٠",
      "numberInSurah": 150
    },
    {
      "text": "وَلَا تُطِيعُواْ أَمۡرَ ٱلۡمُسۡرِفِينَ ١٥١",
      "numberInSurah": 151
    },
    {
      "text": "ٱلَّذِينَ يُفۡسِدُونَ فِي ٱلۡأَرۡضِ وَلَا يُصۡلِحُونَ ١٥٢",
      "numberInSurah": 152
    },
    {
      "text": "قَالُواْ إِنَّمَا أَنتَ مِنَ ٱلۡمُسَحَّرِينَ ١٥٣",
      "numberInSurah": 153
    },
    {
      "text": "مَا أَنتَ إِلَّا بَشَرٞ مِّثۡلُنَا فَأۡتِ بِـَٔايَةٍ إِن كُنتَ مِنَ ٱلصَّٰدِقِينَ ١٥٤",
      "numberInSurah": 154
    },
    {
      "text": "قَالَ هَٰذِهِۦ نَاقَةٞ لَّهَا شِرۡبٞ وَلَكُمُۥ شِرۡبُ يَوۡمٖ مَّعۡلُومٖ ١٥٥",
      "numberInSurah": 155
    },
    {
      "text": "وَلَا تَمَسُّوهَا بِسُوٓءٖ فَيَأۡخُذَكُمُۥ عَذَابُ يَوۡمٍ عَظِيمٖ ١٥٦",
      "numberInSurah": 156
    },
    {
      "text": "فَعَقَرُوهَا فَأَصۡبَحُواْ نَٰدِمِينَ ١٥٧",
      "numberInSurah": 157
    },
    {
      "text": "فَأَخَذَهُمُ ٱلۡعَذَابُۚ إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُمُۥ مُؤۡمِنِينَ ١٥٨",
      "numberInSurah": 158
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ١٥٩",
      "numberInSurah": 159
    }
  ]
}
