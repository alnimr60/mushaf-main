      "text": "ثُمَّ قُتِلَ كَيۡفَ قَدَّرَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "ثُمَّ نَظَرَ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "ثُمَّ عَبَسَ وَبَسَرَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "ثُمَّ أَدۡبَرَ وَٱسۡتَكۡبَرَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "فَقَالَ إِنۡ هَٰذَا إِلَّا سِحۡرٞ يُؤۡثَرُ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "إِنۡ هَٰذَا إِلَّا قَوۡلُ ٱلۡبَشَرِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "سَأُصۡلِيهِۦ سَقَرَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَمَا أَدۡرَىٰكَ مَا سَقَرُ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "لَا تُبۡقِي وَلَا تَذَرُ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "لَوَّاحَةٞ لِّلۡبَشَرِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "عَلَيۡهَا تِسۡعَةَ عَشَرَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَمَا جَعَلۡنَا أَصۡحَٰبَ ٱلنَّارِ إِلَّا مَلَٰٓئِكَةٗۖ وَمَا جَعَلۡنَا عِدَّتَهُمُۥ إِلَّا فِتۡنَةٗ لِّلَّذِينَ كَفَرُواْ لِيَسۡتَيۡقِنَ ٱلَّذِينَ أُوتُواْ ٱلۡكِتَٰبَ وَيَزۡدَادَ ٱلَّذِينَ ءَامَنُواْ إِيمَٰنٗا وَلَا يَرۡتَابَ ٱلَّذِينَ أُوتُواْ ٱلۡكِتَٰبَ وَٱلۡمُؤۡمِنُونَ وَلِيَقُولَ ٱلَّذِينَ فِي قُلُوبِهِمُۥ مَرَضٞ وَٱلۡكَٰفِرُونَ مَاذَا أَرَادَ ٱللَّهُ بِهَٰذَا مَثَلٗاۚ كَذَٰلِكَ يُضِلُّ ٱللَّهُ مَن يَشَآءُ وَيَهۡدِي مَن يَشَآءُۚ وَمَا يَعۡلَمُ جُنُودَ رَبِّكَ إِلَّا هُوَۚ وَمَا هِيَ إِلَّا ذِكۡرَىٰ لِلۡبَشَرِ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "كَلَّا وَٱلۡقَمَرِ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَٱلَّيۡلِ إِذَا دَبَرَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَٱلصُّبۡحِ إِذَا أَسۡفَرَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "إِنَّهَا لَإِحۡدَى ٱلۡكُبَرِ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "نَذِيرٗا لِّلۡبَشَرِ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "لِمَن شَآءَ مِنكُمُۥ أَن يَتَقَدَّمَ أَوۡ يَتَأَخَّرَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "كُلُّ نَفۡسِۭ بِمَا كَسَبَتۡ رَهِينَةٌ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "إِلَّا أَصۡحَٰبَ ٱلۡيَمِينِ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فِي جَنَّٰتٖ يَتَسَآءَلُونَ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "عَنِ ٱلۡمُجۡرِمِينَ مَا سَلَكَكُمُۥ فِي سَقَرَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "قَالُواْ لَمۡ نَكُ مِنَ ٱلۡمُصَلِّينَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "وَلَمۡ نَكُ نُطۡعِمُ ٱلۡمِسۡكِينَ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "وَكُنَّا نَخُوضُ مَعَ ٱلۡخَآئِضِينَ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "وَكُنَّا نُكَذِّبُ بِيَوۡمِ ٱلدِّينِ ٤٥",
      "numberInSurah": 45
    },
    {
