{
  "pageNumber": 569,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "يُبَصَّرُونَهُمُۥۚ يَوَدُّ ٱلۡمُجۡرِمُ لَوۡ يَفۡتَدِي مِنۡ عَذَابِ يَوۡمِئِذِۭ بِبَنِيهِۦ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَصَٰحِبَتِهِۦ وَأَخِيهِۦ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَفَصِيلَتِهِ ٱلَّتِي تُـٔۡوِيهِۦ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "وَمَن فِي ٱلۡأَرۡضِ جَمِيعٗا ثُمَّ يُنجِيهِۦ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "كَلَّاۖ إِنَّهَا لَظَىٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "نَزَّاعَةٞ لِّلشَّوَىٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "تَدۡعُواْ مَنۡ أَدۡبَرَ وَتَوَلَّىٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَجَمَعَ فَأَوۡعَىٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "۞إِنَّ ٱلۡإِنسَٰنَ خُلِقَ هَلُوعًا ١٩",
      "numberInSurah": 19
    },
    {
      "text": "إِذَا مَسَّهُ ٱلشَّرُّ جَزُوعٗا ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَإِذَا مَسَّهُ ٱلۡخَيۡرُ مَنُوعًا ٢١",
      "numberInSurah": 21
    },
    {
      "text": "إِلَّا ٱلۡمُصَلِّينَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "ٱلَّذِينَ هُمُۥ عَلَىٰ صَلَاتِهِمُۥ دَآئِمُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَٱلَّذِينَ فِي أَمۡوَٰلِهِمُۥ حَقّٞ مَّعۡلُومٞ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "لِّلسَّآئِلِ وَٱلۡمَحۡرُومِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَٱلَّذِينَ يُصَدِّقُونَ بِيَوۡمِ ٱلدِّينِ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ مِنۡ عَذَابِ رَبِّهِمُۥ مُشۡفِقُونَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "إِنَّ عَذَابَ رَبِّهِمُۥ غَيۡرُ مَأۡمُونٖ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ لِفُرُوجِهِمُۥ حَٰفِظُونَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "إِلَّا عَلَىٰ أَزۡوَٰجِهِمُۥ أَوۡ مَا مَلَكَتۡ أَيۡمَٰنُهُمُۥ فَإِنَّهُمُۥ غَيۡرُ مَلُومِينَ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "فَمَنِ ٱبۡتَغَىٰ وَرَآءَ ذَٰلِكَ فَأُوْلَٰٓئِكَ هُمُ ٱلۡعَادُونَ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ لِأَمَٰنَتِهِمُۥ وَعَهۡدِهِمُۥ رَٰعُونَ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ بِشَهَٰدَتِهِمُۥ قَآئِمُونَ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَٱلَّذِينَ هُمُۥ عَلَىٰ صَلَاتِهِمُۥ يُحَافِظُونَ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "أُوْلَٰٓئِكَ فِي جَنَّٰتٖ مُّكۡرَمُونَ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "فَمَالِ ٱلَّذِينَ كَفَرُواْ قِبَلَكَ مُهۡطِعِينَ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "عَنِ ٱلۡيَمِينِ وَعَنِ ٱلشِّمَالِ عِزِينَ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "أَيَطۡمَعُ كُلُّ ٱمۡرِيٕٖ مِّنۡهُمُۥ أَن يُدۡخَلَ جَنَّةَ نَعِيمٖ ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "كَلَّاۖ إِنَّا خَلَقۡنَٰهُمُۥ مِمَّا يَعۡلَمُونَ ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "فَلَا أُقۡسِمُ بِرَبِّ ٱلۡمَشَٰرِقِ وَٱلۡمَغَٰرِبِ إِنَّا لَقَٰدِرُونَ ٤٠",
      "numberInSurah": 40
    }
  ]
}
