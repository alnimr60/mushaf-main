{
  "pageNumber": 586,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "تَرۡهَقُهَا قَتَرَةٌ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "أُوْلَٰٓئِكَ هُمُ ٱلۡكَفَرَةُ ٱلۡفَجَرَةُ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "سُورَةُ التَّكۡوِيرِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ إِذَا ٱلشَّمۡسُ كُوِّرَتۡ ١",
      "numberInSurah": 1
    },
    {
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَإِذَا ٱلۡجِبَالُ سُيِّرَتۡ ٣",
      "numberInSurah": 3
    },
    {
      "text": "وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ ٤",
      "numberInSurah": 4
    },
    {
      "text": "وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ ٥",
      "numberInSurah": 5
    },
    {
      "text": "وَإِذَا ٱلۡبِحَارُ سُجِرَتۡ ٦",
      "numberInSurah": 6
    },
    {
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتۡ ٧",
      "numberInSurah": 7
    },
    {
      "text": "وَإِذَا ٱلۡمَوۡءُۥدَةُ سُئِلَتۡ ٨",
      "numberInSurah": 8
    },
    {
      "text": "بِأَيِّ ذَنۢبٖ قُتِلَتۡ ٩",
      "numberInSurah": 9
    },
    {
      "text": "وَإِذَا ٱلصُّحُفُ نُشِّرَتۡ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتۡ ١١",
      "numberInSurah": 11
    },
    {
      "text": "وَإِذَا ٱلۡجَحِيمُ سُعِرَتۡ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "وَإِذَا ٱلۡجَنَّةُ أُزۡلِفَتۡ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "عَلِمَتۡ نَفۡسٞ مَّا أَحۡضَرَتۡ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَلَا أُقۡسِمُ بِٱلۡخُنَّسِ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "ٱلۡجَوَارِ ٱلۡكُنَّسِ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "وَٱلَّيۡلِ إِذَا عَسۡعَسَ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "وَٱلصُّبۡحِ إِذَا تَنَفَّسَ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "ذِي قُوَّةٍ عِندَ ذِي ٱلۡعَرۡشِ مَكِينٖ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "مُّطَاعٖ ثَمَّ أَمِينٖ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "وَمَا صَاحِبُكُمُۥ بِمَجۡنُونٖ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَلَقَدۡ رَءَاهُۥ بِٱلۡأُفُقِ ٱلۡمُبِينِ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَمَا هُوَ عَلَى ٱلۡغَيۡبِ بِضظَنِينٖ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَمَا هُوَ بِقَوۡلِ شَيۡطَٰنٖ رَّجِيمٖ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "فَأَيۡنَ تَذۡهَبُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "إِنۡ هُوَ إِلَّا ذِكۡرٞ لِّلۡعَٰلَمِينَ ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "لِمَن شَآءَ مِنكُمُۥ أَن يَسۡتَقِيمَ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "وَمَا تَشَآءُونَ إِلَّا أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلۡعَٰلَمِينَ ٢٩",
      "numberInSurah": 29
    }
  ]
}
