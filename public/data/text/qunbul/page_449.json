{
  "pageNumber": 449,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَجَعَلۡنَا ذُرِّيَّتَهُۥ هُمُ ٱلۡبَاقِينَ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "وَتَرَكۡنَا عَلَيۡهِۦ فِي ٱلۡأٓخِرِينَ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "سَلَٰمٌ عَلَىٰ نُوحٖ فِي ٱلۡعَٰلَمِينَ ٧٩",
      "numberInSurah": 79
    },
    {
      "text": "إِنَّا كَذَٰلِكَ نَجۡزِي ٱلۡمُحۡسِنِينَ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "إِنَّهُۥ مِنۡ عِبَادِنَا ٱلۡمُؤۡمِنِينَ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "ثُمَّ أَغۡرَقۡنَا ٱلۡأٓخَرِينَ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "۞وَإِنَّ مِن شِيعَتِهِۦ لَإِبۡرَٰهِيمَ ٨٣",
      "numberInSurah": 83
    },
    {
      "text": "إِذۡ جَآءَ رَبَّهُۥ بِقَلۡبٖ سَلِيمٍ ٨٤",
      "numberInSurah": 84
    },
    {
      "text": "إِذۡ قَالَ لِأَبِيهِۦ وَقَوۡمِهِۦ مَاذَا تَعۡبُدُونَ ٨٥",
      "numberInSurah": 85
    },
    {
      "text": "أَى۪فۡكًا ءَالِهَةٗ دُونَ ٱللَّهِ تُرِيدُونَ ٨٦",
      "numberInSurah": 86
    },
    {
      "text": "فَمَا ظَنُّكُمُۥ بِرَبِّ ٱلۡعَٰلَمِينَ ٨٧",
      "numberInSurah": 87
    },
    {
      "text": "فَنَظَرَ نَظۡرَةٗ فِي ٱلنُّجُومِ ٨٨",
      "numberInSurah": 88
    },
    {
      "text": "فَقَالَ إِنِّي سَقِيمٞ ٨٩",
      "numberInSurah": 89
    },
    {
      "text": "فَتَوَلَّوۡاْ عَنۡهُۥ مُدۡبِرِينَ ٩٠",
      "numberInSurah": 90
    },
    {
      "text": "فَرَاغَ إِلَىٰ ءَالِهَتِهِمُۥ فَقَالَ أَلَا تَأۡكُلُونَ ٩١",
      "numberInSurah": 91
    },
    {
      "text": "مَا لَكُمُۥ لَا تَنطِقُونَ ٩٢",
      "numberInSurah": 92
    },
    {
      "text": "فَرَاغَ عَلَيۡهِمُۥ ضَرۡبَۢا بِٱلۡيَمِينِ ٩٣",
      "numberInSurah": 93
    },
    {
      "text": "فَأَقۡبَلُواْ إِلَيۡهِۦ يَزِفُّونَ ٩٤",
      "numberInSurah": 94
    },
    {
      "text": "قَالَ أَتَعۡبُدُونَ مَا تَنۡحِتُونَ ٩٥",
      "numberInSurah": 95
    },
    {
      "text": "وَٱللَّهُ خَلَقَكُمُۥ وَمَا تَعۡمَلُونَ ٩٦",
      "numberInSurah": 96
    },
    {
      "text": "قَالُواْ ٱبۡنُواْ لَهُۥ بُنۡيَٰنٗا فَأَلۡقُوهُۥ فِي ٱلۡجَحِيمِ ٩٧",
      "numberInSurah": 97
    },
    {
      "text": "فَأَرَادُواْ بِهِۦ كَيۡدٗا فَجَعَلۡنَٰهُمُ ٱلۡأَسۡفَلِينَ ٩٨",
      "numberInSurah": 98
    },
    {
      "text": "وَقَالَ إِنِّي ذَاهِبٌ إِلَىٰ رَبِّي سَيَهۡدِينِ ٩٩",
      "numberInSurah": 99
    },
    {
      "text": "رَبِّ هَبۡ لِي مِنَ ٱلصَّٰلِحِينَ ١٠٠",
      "numberInSurah": 100
    },
    {
      "text": "فَبَشَّرۡنَٰهُۥ بِغُلَٰمٍ حَلِيمٖ ١٠١",
      "numberInSurah": 101
    },
    {
      "text": "فَلَمَّا بَلَغَ مَعَهُ ٱلسَّعۡيَ قَالَ يَٰبُنَيِّ إِنِّيَ أَرَىٰ فِي ٱلۡمَنَامِ أَنِّيَ أَذۡبَحُكَ فَٱنظُرۡ مَاذَا تَرَىٰۚ قَالَ يَٰأَبَتِ ٱفۡعَلۡ مَا تُؤۡمَرُۖ سَتَجِدُنِي إِن شَآءَ ٱللَّهُ مِنَ ٱلصَّٰبِرِينَ ١٠٢",
      "numberInSurah": 102
    }
  ]
}
