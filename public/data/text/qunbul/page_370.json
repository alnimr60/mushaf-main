{
  "pageNumber": 370,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "فَلَمَّا تَرَٰٓءَا ٱلۡجَمۡعَانِ قَالَ أَصۡحَٰبُ مُوسَىٰ إِنَّا لَمُدۡرَكُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "قَالَ كَلَّاۖ إِنَّ مَعِي رَبِّي سَيَهۡدِينِ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "فَأَوۡحَيۡنَا إِلَىٰ مُوسَىٰ أَنِ ٱضۡرِب بِّعَصَاكَ ٱلۡبَحۡرَۖ فَٱنفَلَقَ فَكَانَ كُلُّ فِرۡقٖ كَٱلطَّوۡدِ ٱلۡعَظِيمِ ٦٣",
      "numberInSurah": 63
    },
    {
      "text": "وَأَزۡلَفۡنَا ثَمَّ ٱلۡأٓخَرِينَ ٦٤",
      "numberInSurah": 64
    },
    {
      "text": "وَأَنجَيۡنَا مُوسَىٰ وَمَن مَّعَهُۥ أَجۡمَعِينَ ٦٥",
      "numberInSurah": 65
    },
    {
      "text": "ثُمَّ أَغۡرَقۡنَا ٱلۡأٓخَرِينَ ٦٦",
      "numberInSurah": 66
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُمُۥ مُؤۡمِنِينَ ٦٧",
      "numberInSurah": 67
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ٦٨",
      "numberInSurah": 68
    },
    {
      "text": "وَٱتۡلُ عَلَيۡهِمُۥ نَبَأَ ا۪بۡرَٰهِيمَ ٦٩",
      "numberInSurah": 69
    },
    {
      "text": "إِذۡ قَالَ لِأَبِيهِۦ وَقَوۡمِهِۦ مَا تَعۡبُدُونَ ٧٠",
      "numberInSurah": 70
    },
    {
      "text": "قَالُواْ نَعۡبُدُ أَصۡنَامٗا فَنَظَلُّ لَهَا عَٰكِفِينَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "قَالَ هَلۡ يَسۡمَعُونَكُمُۥ إِذۡ تَدۡعُونَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "أَوۡ يَنفَعُونَكُمُۥ أَوۡ يَضُرُّونَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "قَالُواْ بَلۡ وَجَدۡنَا ءَابَآءَنَا كَذَٰلِكَ يَفۡعَلُونَ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "قَالَ أَفَرَءَيۡتُمُۥ مَا كُنتُمُۥ تَعۡبُدُونَ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "أَنتُمُۥ وَءَابَآؤُكُمُ ٱلۡأَقۡدَمُونَ ٧٦",
      "numberInSurah": 76
    },
    {
      "text": "فَإِنَّهُمُۥ عَدُوّٞ لِّي إِلَّا رَبَّ ٱلۡعَٰلَمِينَ ٧٧",
      "numberInSurah": 77
    },
    {
      "text": "ٱلَّذِي خَلَقَنِي فَهُوَ يَهۡدِينِ ٧٨",
      "numberInSurah": 78
    },
    {
      "text": "وَٱلَّذِي هُوَ يُطۡعِمُنِي وَيَسۡقِينِ ٧٩",
      "numberInSurah": 79
    },
    {
      "text": "وَإِذَا مَرِضۡتُ فَهُوَ يَشۡفِينِ ٨٠",
      "numberInSurah": 80
    },
    {
      "text": "وَٱلَّذِي يُمِيتُنِي ثُمَّ يُحۡيِينِ ٨١",
      "numberInSurah": 81
    },
    {
      "text": "وَٱلَّذِي أَطۡمَعُ أَن يَغۡفِرَ لِي خَطِيٓـَٔتِي يَوۡمَ ٱلدِّينِ ٨٢",
      "numberInSurah": 82
    },
    {
      "text": "رَبِّ هَبۡ لِي حُكۡمٗا وَأَلۡحِقۡنِي بِٱلصَّٰلِحِينَ ٨٣",
      "numberInSurah": 83
    }
  ]
}
