{
  "pageNumber": 448,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "يَقُولُ أَ۟نَّكَ لَمِنَ ٱلۡمُصَدِّقِينَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "أَ۟ذَا مُتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَ۟نَّا لَمَدِينُونَ ٥٣",
      "numberInSurah": 53
    },
    {
      "text": "قَالَ هَلۡ أَنتُمُۥ مُطَّلِعُونَ ٥٤",
      "numberInSurah": 54
    },
    {
      "text": "فَٱطَّلَعَ فَرَءَاهُۥ فِي سَوَآءِ ٱلۡجَحِيمِ ٥٥",
      "numberInSurah": 55
    },
    {
      "text": "قَالَ تَٱللَّهِ إِن كِدتَّ لَتُرۡدِينِ ٥٦",
      "numberInSurah": 56
    },
    {
      "text": "وَلَوۡلَا نِعۡمَةُ رَبِّي لَكُنتُ مِنَ ٱلۡمُحۡضَرِينَ ٥٧",
      "numberInSurah": 57
    },
    {
      "text": "أَفَمَا نَحۡنُ بِمَيِّتِينَ ٥٨",
      "numberInSurah": 58
    },
    {
      "text": "إِلَّا مَوۡتَتَنَا ٱلۡأُولَىٰ وَمَا نَحۡنُ بِمُعَذَّبِينَ ٥٩",
      "numberInSurah": 59
    },
    {
      "text": "إِنَّ هَٰذَا لَهُوَ ٱلۡفَوۡزُ ٱلۡعَظِيمُ ٦٠",
      "numberInSurah": 60
    },
    {
      "text": "لِمِثۡلِ هَٰذَا فَلۡيَعۡمَلِ ٱلۡعَٰمِلُونَ ٦١",
      "numberInSurah": 61
    },
    {
      "text": "أَذَٰلِكَ خَيۡرٞ نُّزُلًا أَمۡ شَجَرَةُ ٱلزَّقُّومِ ٦٢",
      "numberInSurah": 62
    },
    {
      "text": "إِنَّا جَعَلۡنَٰهَا فِتۡنَةٗ لِّلظَّٰلِمِينَ ٦٣",
      "numberInSurah": 63
    },
    {
      "text": "إِنَّهَا شَجَرَةٞ تَخۡرُجُ فِي أَصۡلِ ٱلۡجَحِيمِ ٦٤",
      "numberInSurah": 64
    },
    {
      "text": "طَلۡعُهَا كَأَنَّهُۥ رُءُوسُ ٱلشَّيَٰطِينِ ٦٥",
      "numberInSurah": 65
    },
    {
      "text": "فَإِنَّهُمُۥ لَأٓكِلُونَ مِنۡهَا فَمَالِـُٔونَ مِنۡهَا ٱلۡبُطُونَ ٦٦",
      "numberInSurah": 66
    },
    {
      "text": "ثُمَّ إِنَّ لَهُمُۥ عَلَيۡهَا لَشَوۡبٗا مِّنۡ حَمِيمٖ ٦٧",
      "numberInSurah": 67
    },
    {
      "text": "ثُمَّ إِنَّ مَرۡجِعَهُمُۥ لَإِلَى ٱلۡجَحِيمِ ٦٨",
      "numberInSurah": 68
    },
    {
      "text": "إِنَّهُمُۥ أَلۡفَوۡاْ ءَابَآءَهُمُۥ ضَآلِّينَ ٦٩",
      "numberInSurah": 69
    },
    {
      "text": "فَهُمُۥ عَلَىٰ ءَاثَٰرِهِمُۥ يُهۡرَعُونَ ٧٠",
      "numberInSurah": 70
    },
    {
      "text": "وَلَقَدۡ ضَلَّ قَبۡلَهُمُۥ أَكۡثَرُ ٱلۡأَوَّلِينَ ٧١",
      "numberInSurah": 71
    },
    {
      "text": "وَلَقَدۡ أَرۡسَلۡنَا فِيهِمُۥ مُنذِرِينَ ٧٢",
      "numberInSurah": 72
    },
    {
      "text": "فَٱنظُرۡ كَيۡفَ كَانَ عَٰقِبَةُ ٱلۡمُنذَرِينَ ٧٣",
      "numberInSurah": 73
    },
    {
      "text": "إِلَّا عِبَادَ ٱللَّهِ ٱلۡمُخۡلِصِينَ ٧٤",
      "numberInSurah": 74
    },
    {
      "text": "وَلَقَدۡ نَادَىٰنَا نُوحٞ فَلَنِعۡمَ ٱلۡمُجِيبُونَ ٧٥",
      "numberInSurah": 75
    },
    {
      "text": "وَنَجَّيۡنَٰهُۥ وَأَهۡلَهُۥ مِنَ ٱلۡكَرۡبِ ٱلۡعَظِيمِ ٧٦",
      "numberInSurah": 76
    }
  ]
}
