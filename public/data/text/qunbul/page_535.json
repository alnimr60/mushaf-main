{
  "pageNumber": 535,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "يَطُوفُ عَلَيۡهِمُۥ وِلۡدَٰنٞ مُّخَلَّدُونَ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "بِأَكۡوَابٖ وَأَبَارِيقَ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَكَأۡسٖ مِّن مَّعِينٖ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "لَّا يُصَدَّعُونَ عَنۡهَا وَلَا يُنزَفُونَ ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "وَفَٰكِهَةٖ مِّمَّا يَتَخَيَّرُونَ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "وَلَحۡمِ طَيۡرٖ مِّمَّا يَشۡتَهُونَ ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَحُورٌ عِينٞ كَأَمۡثَٰلِ ٱللُّؤۡلُوِٕ ٱلۡمَكۡنُونِ ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "جَزَآءَۢ بِمَا كَانُواْ يَعۡمَلُونَ ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "لَا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا تَأۡثِيمًا إِلَّا قِيلٗا سَلَٰمٗا سَلَٰمٗا ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَأَصۡحَٰبُ ٱلۡيَمِينِ ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "مَا أَصۡحَٰبُ ٱلۡيَمِينِ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "فِي سِدۡرٖ مَّخۡضُودٖ ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَطَلۡحٖ مَّنضُودٖ ٣١",
      "numberInSurah": 31
    },
    {
      "text": "وَظِلّٖ مَّمۡدُودٖ ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَمَآءٖ مَّسۡكُوبٖ ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَفَٰكِهَةٖ كَثِيرَةٖ ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "لَّا مَقۡطُوعَةٖ وَلَا مَمۡنُوعَةٖ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَفُرُشٖ مَّرۡفُوعَةٍ ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "إِنَّا أَنشَأۡنَٰهُنَّ إِنشَآءٗ ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "فَجَعَلۡنَٰهُنَّ أَبۡكَارًا ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "عُرُبًا أَتۡرَابٗا ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "لِّأَصۡحَٰبِ ٱلۡيَمِينِ ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "ثُلَّةٞ مِّنَ ٱلۡأَوَّلِينَ ٤١",
      "numberInSurah": 41
    },
    {
      "text": "وَثُلَّةٞ مِّنَ ٱلۡأٓخِرِينَ ٤٢",
      "numberInSurah": 42
    },
    {
      "text": "وَأَصۡحَٰبُ ٱلشِّمَالِ ٤٣",
      "numberInSurah": 43
    },
    {
      "text": "مَا أَصۡحَٰبُ ٱلشِّمَالِ ٤٤",
      "numberInSurah": 44
    },
    {
      "text": "فِي سَمُومٖ وَحَمِيمٖ وَظِلّٖ مِّن يَحۡمُومٖ ٤٥",
      "numberInSurah": 45
    },
    {
      "text": "لَّا بَارِدٖ وَلَا كَرِيمٍ ٤٦",
      "numberInSurah": 46
    },
    {
      "text": "إِنَّهُمُۥ كَانُواْ قَبۡلَ ذَٰلِكَ مُتۡرَفِينَ ٤٧",
      "numberInSurah": 47
    },
    {
      "text": "وَكَانُواْ يُصِرُّونَ عَلَى ٱلۡحِنثِ ٱلۡعَظِيمِ ٤٨",
      "numberInSurah": 48
    },
    {
      "text": "وَكَانُواْ يَقُولُونَ ٤٩",
      "numberInSurah": 49
    },
    {
      "text": "أَى۪ذَا مُتۡنَا وَكُنَّا تُرَابٗا وَعِظَٰمًا أَ۟نَّا لَمَبۡعُوثُونَ ٥٠",
      "numberInSurah": 50
    },
    {
      "text": "أَوَءَابَآؤُنَا ٱلۡأَوَّلُونَ ٥١",
      "numberInSurah": 51
    },
    {
      "text": "قُلۡ إِنَّ ٱلۡأَوَّلِينَ وَٱلۡأٓخِرِينَ ٥٢",
      "numberInSurah": 52
    },
    {
      "text": "لَمَجۡمُوعُونَ إِلَىٰ مِيقَٰتِ يَوۡمٖ مَّعۡلُومٖ ٥٣",
      "numberInSurah": 53
    }
  ]
}
