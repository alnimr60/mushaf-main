{
  "pageNumber": 375,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَٱتَّقُواْ ٱلَّذِي خَلَقَكُمُۥ وَٱلۡجِبِلَّةَ ٱلۡأَوَّلِينَ ١٨٤",
      "numberInSurah": 184
    },
    {
      "text": "قَالُواْ إِنَّمَا أَنتَ مِنَ ٱلۡمُسَحَّرِينَ ١٨٥",
      "numberInSurah": 185
    },
    {
      "text": "وَمَا أَنتَ إِلَّا بَشَرٞ مِّثۡلُنَا وَإِن نَّظُنُّكَ لَمِنَ ٱلۡكَٰذِبِينَ ١٨٦",
      "numberInSurah": 186
    },
    {
      "text": "فَأَسۡقِطۡ عَلَيۡنَا كِسۡفٗا مِّنَ ٱلسَّمَآءِ ا۪ن كُنتَ مِنَ ٱلصَّٰدِقِينَ ١٨٧",
      "numberInSurah": 187
    },
    {
      "text": "قَالَ رَبِّيَ أَعۡلَمُ بِمَا تَعۡمَلُونَ ١٨٨",
      "numberInSurah": 188
    },
    {
      "text": "فَكَذَّبُوهُۥ فَأَخَذَهُمُۥ عَذَابُ يَوۡمِ ٱلظُّلَّةِۚ إِنَّهُۥ كَانَ عَذَابَ يَوۡمٍ عَظِيمٍ ١٨٩",
      "numberInSurah": 189
    },
    {
      "text": "إِنَّ فِي ذَٰلِكَ لَأٓيَةٗۖ وَمَا كَانَ أَكۡثَرُهُمُۥ مُؤۡمِنِينَ ١٩٠",
      "numberInSurah": 190
    },
    {
      "text": "وَإِنَّ رَبَّكَ لَهُوَ ٱلۡعَزِيزُ ٱلرَّحِيمُ ١٩١",
      "numberInSurah": 191
    },
    {
      "text": "وَإِنَّهُۥ لَتَنزِيلُ رَبِّ ٱلۡعَٰلَمِينَ ١٩٢",
      "numberInSurah": 192
    },
    {
      "text": "نَزَلَ بِهِ ٱلرُّوحُ ٱلۡأَمِينُ ١٩٣",
      "numberInSurah": 193
    },
    {
      "text": "عَلَىٰ قَلۡبِكَ لِتَكُونَ مِنَ ٱلۡمُنذِرِينَ ١٩٤",
      "numberInSurah": 194
    },
    {
      "text": "بِلِسَانٍ عَرَبِيّٖ مُّبِينٖ ١٩٥",
      "numberInSurah": 195
    },
    {
      "text": "وَإِنَّهُۥ لَفِي زُبُرِ ٱلۡأَوَّلِينَ ١٩٦",
      "numberInSurah": 196
    },
    {
      "text": "أَوَلَمۡ يَكُن لَّهُمُۥ ءَايَةً أَن يَعۡلَمَهُۥ عُلَمَٰٓؤُاْ بَنِي إِسۡرَٰٓءِيلَ ١٩٧",
      "numberInSurah": 197
    },
    {
      "text": "وَلَوۡ نَزَّلۡنَٰهُۥ عَلَىٰ بَعۡضِ ٱلۡأَعۡجَمِينَ ١٩٨",
      "numberInSurah": 198
    },
    {
      "text": "فَقَرَأَهُۥ عَلَيۡهِمُۥ مَا كَانُواْ بِهِۦ مُؤۡمِنِينَ ١٩٩",
      "numberInSurah": 199
    },
    {
      "text": "كَذَٰلِكَ سَلَكۡنَٰهُۥ فِي قُلُوبِ ٱلۡمُجۡرِمِينَ ٢٠٠",
      "numberInSurah": 200
    },
    {
      "text": "لَا يُؤۡمِنُونَ بِهِۦ حَتَّىٰ يَرَوُاْ ٱلۡعَذَابَ ٱلۡأَلِيمَ ٢٠١",
      "numberInSurah": 201
    },
    {
      "text": "فَيَأۡتِيَهُمُۥ بَغۡتَةٗ وَهُمُۥ لَا يَشۡعُرُونَ ٢٠٢",
      "numberInSurah": 202
    },
    {
      "text": "فَيَقُولُواْ هَلۡ نَحۡنُ مُنظَرُونَ ٢٠٣",
      "numberInSurah": 203
    },
    {
      "text": "أَفَبِعَذَابِنَا يَسۡتَعۡجِلُونَ ٢٠٤",
      "numberInSurah": 204
    },
    {
      "text": "أَفَرَءَيۡتَ إِن مَّتَّعۡنَٰهُمُۥ سِنِينَ ٢٠٥",
      "numberInSurah": 205
    },
    {
      "text": "ثُمَّ جَآءَهُمُۥ مَا كَانُواْ يُوعَدُونَ ٢٠٦",
      "numberInSurah": 206
    }
  ]
}
