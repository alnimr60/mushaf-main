{
  "pageNumber": 583,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "إِنَّ لِلۡمُتَّقِينَ مَفَازًا ٣١",
      "numberInSurah": 31
    },
    {
      "text": "حَدَآئِقَ وَأَعۡنَٰبٗا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَكَوَاعِبَ أَتۡرَابٗا ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "وَكَأۡسٗا دِهَاقٗا ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "لَّا يَسۡمَعُونَ فِيهَا لَغۡوٗا وَلَا كِذَّٰبٗا ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "جَزَآءٗ مِّن رَّبِّكَ عَطَآءً حِسَابٗا ٣٦",
      "numberInSurah": 36
    },
    {
      "text": "رَّبُّ ٱلسَّمَٰوَٰتِ وَٱلۡأَرۡضِ وَمَا بَيۡنَهُمَا ٱلرَّحۡمَٰنُۖ لَا يَمۡلِكُونَ مِنۡهُۥ خِطَابٗا ٣٧",
      "numberInSurah": 37
    },
    {
      "text": "يَوۡمَ يَقُومُ ٱلرُّوحُ وَٱلۡمَلَٰٓئِكَةُ صَفّٗاۖ لَّا يَتَكَلَّمُونَ إِلَّا مَنۡ أَذِنَ لَهُ ٱلرَّحۡمَٰنُ وَقَالَ صَوَابٗا ٣٨",
      "numberInSurah": 38
    },
    {
      "text": "ذَٰلِكَ ٱلۡيَوۡمُ ٱلۡحَقُّۖ فَمَن شَآءَ ٱتَّخَذَ إِلَىٰ رَبِّهِۦ مَـَٔابًا ٣٩",
      "numberInSurah": 39
    },
    {
      "text": "إِنَّا أَنذَرۡنَٰكُمُۥ عَذَابٗا قَرِيبٗا ٤٠",
      "numberInSurah": 40
    },
    {
      "text": "يَوۡمَ يَنظُرُ ٱلۡمَرۡءُ مَا قَدَّمَتۡ يَدَاهُۥ وَيَقُولُ ٱلۡكَافِرُ يَٰلَيۡتَنِي كُنتُ تُرَٰبَۢا ٤١",
      "numberInSurah": 41
    },
    {
      "text": "سُورَةُ النَّازِعَاتِ بِسۡمِ ٱللَّهِ ٱلرَّحۡمَٰنِ ٱلرَّحِيمِ وَٱلنَّٰزِعَٰتِ غَرۡقٗا ١",
      "numberInSurah": 1
    },
    {
      "text": "وَٱلنَّٰشِطَٰتِ نَشۡطٗا ٢",
      "numberInSurah": 2
    },
    {
      "text": "وَٱلسَّٰبِحَٰتِ سَبۡحٗا ٣",
      "numberInSurah": 3
    },
    {
      "text": "فَٱلسَّٰبِقَٰتِ سَبۡقٗا ٤",
      "numberInSurah": 4
    },
    {
      "text": "فَٱلۡمُدَبِّرَٰتِ أَمۡرٗا ٥",
      "numberInSurah": 5
    },
    {
      "text": "يَوۡمَ تَرۡجُفُ ٱلرَّاجِفَةُ ٦",
      "numberInSurah": 6
    },
    {
      "text": "تَتۡبَعُهَا ٱلرَّادِفَةُ ٧",
      "numberInSurah": 7
    },
    {
      "text": "قُلُوبٞ يَوۡمَئِذٖ وَاجِفَةٌ ٨",
      "numberInSurah": 8
    },
    {
      "text": "أَبۡصَٰرُهَا خَٰشِعَةٞ ٩",
      "numberInSurah": 9
    },
    {
      "text": "يَقُولُونَ أَ۟نَّا لَمَرۡدُودُونَ فِي ٱلۡحَافِرَةِ ١٠",
      "numberInSurah": 10
    },
    {
      "text": "أَ۟ذَا كُنَّا عِظَٰمٗا نَّخِرَةٗ ١١",
      "numberInSurah": 11
    },
    {
      "text": "قَالُواْ تِلۡكَ إِذٗا كَرَّةٌ خَاسِرَةٞ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "فَإِنَّمَا هِيَ زَجۡرَةٞ وَٰحِدَةٞ ١٣",
      "numberInSurah": 13
    },
    {
      "text": "فَإِذَا هُمُۥ بِٱلسَّاهِرَةِ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "هَلۡ أَتَىٰكَ حَدِيثُ مُوسَىٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "إِذۡ نَادَىٰهُۥ رَبُّهُۥ بِٱلۡوَادِ ٱلۡمُقَدَّسِ طُوَى ١٦",
      "numberInSurah": 16
    }
  ]
}
