{
  "pageNumber": 313,
  "riwayaId": "qunbul",
  "ayahs": [
    {
      "text": "وَأَنَا ٱخۡتَرۡتُكَ فَٱسۡتَمِعۡ لِمَا يُوحَىٰ ١٢",
      "numberInSurah": 12
    },
    {
      "text": "إِنَّنِيَ أَنَا ٱللَّهُ لَا إِلَٰهَ إِلَّا أَنَا۠ فَٱعۡبُدۡنِي وَأَقِمِ ٱلصَّلَوٰةَ لِذِكۡرِي ١٣",
      "numberInSurah": 13
    },
    {
      "text": "إِنَّ ٱلسَّاعَةَ ءَاتِيَةٌ أَكَادُ أُخۡفِيهَا لِتُجۡزَىٰ كُلُّ نَفۡسِۭ بِمَا تَسۡعَىٰ ١٤",
      "numberInSurah": 14
    },
    {
      "text": "فَلَا يَصُدَّنَّكَ عَنۡهَا مَن لَّا يُؤۡمِنُ بِهَا وَٱتَّبَعَ هَوَىٰهُۥ فَتَرۡدَىٰ ١٥",
      "numberInSurah": 15
    },
    {
      "text": "وَمَا تِلۡكَ بِيَمِينِكَ يَٰمُوسَىٰ ١٦",
      "numberInSurah": 16
    },
    {
      "text": "قَالَ هِيَ عَصَايَ أَتَوَكَّؤُاْ عَلَيۡهَا وَأَهُشُّ بِهَا عَلَىٰ غَنَمِي وَلِي فِيهَا مَـَٔارِبُ أُخۡرَىٰ ١٧",
      "numberInSurah": 17
    },
    {
      "text": "قَالَ أَلۡقِهَا يَٰمُوسَىٰ ١٨",
      "numberInSurah": 18
    },
    {
      "text": "فَأَلۡقَىٰهَا فَإِذَا هِيَ حَيَّةٞ تَسۡعَىٰ ١٩",
      "numberInSurah": 19
    },
    {
      "text": "قَالَ خُذۡهَا وَلَا تَخَفۡۖ سَنُعِيدُهَا سِيرَتَهَا ٱلۡأُولَىٰ ٢٠",
      "numberInSurah": 20
    },
    {
      "text": "وَٱضۡمُمۡ يَدَكَ إِلَىٰ جَنَاحِكَ تَخۡرُجۡ بَيۡضَآءَ مِنۡ غَيۡرِ سُوٓءٍ ءَايَةً أُخۡرَىٰ ٢١",
      "numberInSurah": 21
    },
    {
      "text": "لِنُرِيَكَ مِنۡ ءَايَٰتِنَا ٱلۡكُبۡرَى ٢٢",
      "numberInSurah": 22
    },
    {
      "text": "ٱذۡهَبۡ إِلَىٰ فِرۡعَوۡنَ إِنَّهُۥ طَغَىٰ ٢٣",
      "numberInSurah": 23
    },
    {
      "text": "قَالَ رَبِّ ٱشۡرَحۡ لِي صَدۡرِي ٢٤",
      "numberInSurah": 24
    },
    {
      "text": "وَيَسِّرۡ لِي أَمۡرِي ٢٥",
      "numberInSurah": 25
    },
    {
      "text": "وَٱحۡلُلۡ عُقۡدَةٗ مِّن لِّسَانِي ٢٦",
      "numberInSurah": 26
    },
    {
      "text": "يَفۡقَهُواْ قَوۡلِي ٢٧",
      "numberInSurah": 27
    },
    {
      "text": "وَٱجۡعَل لِّي وَزِيرٗا مِّنۡ أَهۡلِي ٢٨",
      "numberInSurah": 28
    },
    {
      "text": "هَٰرُونَ أَخِيَ ٢٩",
      "numberInSurah": 29
    },
    {
      "text": "ٱشۡدُدۡ بِهِۦ أَزۡرِي ٣٠",
      "numberInSurah": 30
    },
    {
      "text": "وَأَشۡرِكۡهُۥ فِي أَمۡرِي ٣١",
      "numberInSurah": 31
    },
    {
      "text": "كَيۡ نُسَبِّحَكَ كَثِيرٗا ٣٢",
      "numberInSurah": 32
    },
    {
      "text": "وَنَذۡكُرَكَ كَثِيرًا ٣٣",
      "numberInSurah": 33
    },
    {
      "text": "إِنَّكَ كُنتَ بِنَا بَصِيرٗا ٣٤",
      "numberInSurah": 34
    },
    {
      "text": "قَالَ قَدۡ أُوتِيتَ سُؤۡلَكَ يَٰمُوسَىٰ ٣٥",
      "numberInSurah": 35
    },
    {
      "text": "وَلَقَدۡ مَنَنَّا عَلَيۡكَ مَرَّةً أُخۡرَىٰ ٣٦",
      "numberInSurah": 36
    }
  ]
}
